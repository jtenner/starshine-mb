          Some(values) =>
            match values[p] {
              Some(value) if dae_batchable_uniform_literal(value) ||
                (
                  allow_written_uniform_const &&
                  dae_instr_is_materializable_const_with_immutable_global(
                    mod_, value,
                  )
                ) => {
                remove[p] = true
                const_params[p] = Some(value)
                any = true
              }
              _ => ()
            }
          None => ()
        }
      }
      p += 1
    }
    let preserve_current_result = original_result_preservation_for_def
    if any && !skip_param_removal {
      let scalar_unused_only = const_params.all(fn(value) { value is None })
      if scalar_unused_only {
        let callee_source = if rewrite_mod == mod_ {
          None
        } else {
          match rewrite_mod.code_sec {
            Some(@lib.CodeSec(rewrite_funcs)) if def_idx >= 0 &&
              def_idx < rewrite_funcs.length() => Some(rewrite_funcs[def_idx])
            _ => None
          }
        }
        let planned = dae_try_rewrite_scalar_unused_param_candidate(
          mod_,
          original,
          current_graph,
          callee_abs,
          remove,
          local_use,
          direct_calls[callee_abs],
          direct_callers[callee_abs],
          callee_source~,
        )
        if planned.applied {
          return planned.result
        }
        if planned.reason != DaeActualValueSliceUnavailable {
          def_idx += 1
          continue
        }
      }
      let result = dae_try_rewrite_candidate(
        rewrite_mod,
        callee_abs,
        remove,
        const_params,
        local_use,
        direct_calls[callee_abs],
        direct_callers[callee_abs],
      )
      if result.changed {
        return result
      }
    } else if !skip_original_large_result_cleanup &&
      !dae_original_result_preservation_blocks_argument_side_result_repair(
        preserve_current_result, true,
      ) {
      let dropped_result = dae_try_remove_dropped_results(
        mod_,
        callee_abs,
        direct_calls[callee_abs],
        dropped_calls[callee_abs],
      )
      if dropped_result.changed {
        return dropped_result
      }
    }
    def_idx += 1
  }
  { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
}

///|
fn dae_try_rewrite_reverse_exact_literal_once(
  mod_ : @lib.Module,
  original_param_counts : Array[Int],
  original_call_counts : Array[Int],
  original_active_nonself_call_counts : Array[Int],
  original_active_parameterized_nonself_call_counts : Array[Int],
  original_nonself_undropped_call_counts : Array[Int],
  original_self_call_counts : Array[Int],
  original_private_result_dead_suffix_calls_from_escaped_operand_callees : Array[
    Int,
  ],
  original_escaped_dead_suffix_call_counts : Array[Int],
  original_dead_suffix_undropped_self_calls : Array[Bool],
  original_dead_suffix_dropped_self_calls : Array[Bool],
  original_dead_suffix_block_undropped_self_calls : Array[Bool],
  original_dead_suffix_result_calls_from_undropped_self_callers : Array[Int],
  original_dead_suffix_result_calls_from_no_param_undropped_self_callers : Array[
    Int,
  ],
  original_dead_suffix_same_self_result_operand_calls : Array[Bool],
  original_dead_suffix_undropped_self_call_param_operands : Array[Bool],
  original_dead_suffix_result_other_calls : Array[Bool],
  original_dead_suffix_escaped_result_call_facts : DaeOriginalDeadSuffixEscapedResultCallFacts,
  original_dead_suffix_mutual_calls : Array[Bool],
  original_dead_suffix_calls_from_param_operand_self_result_callers : Array[Int],
  original_dead_suffix_escaped_result_operand_call_counts : Array[Int],
  original_dead_suffix_dropped_calls_from_parameterized_self_callers : Array[
    Int,
  ],
  reverse? : Bool = true,
  max_def_exclusive? : Int = -1,
) -> DaePassResult {
  let original_dead_suffix_undropped_escaped_result_calls = original_dead_suffix_escaped_result_call_facts.undropped_calls
  let original_dead_suffix_dropped_escaped_result_calls = original_dead_suffix_escaped_result_call_facts.dropped_calls
  let boundary_snapshot = dae_collect_module_boundary_snapshot(mod_)
  let imported = boundary_snapshot.imported
  let defined = boundary_snapshot.defined
  let boundary_facts = boundary_snapshot.boundary_facts
  let type_indices = boundary_snapshot.type_indices
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let original_result_preservation_context = dae_original_result_preservation_context(
    original_param_counts, original_call_counts, original_active_nonself_call_counts,
    original_active_parameterized_nonself_call_counts, original_nonself_undropped_call_counts,
    original_self_call_counts, original_private_result_dead_suffix_calls_from_escaped_operand_callees,
    original_escaped_dead_suffix_call_counts, original_dead_suffix_undropped_self_calls,
    original_dead_suffix_dropped_self_calls, original_dead_suffix_block_undropped_self_calls,
    original_dead_suffix_result_calls_from_undropped_self_callers, original_dead_suffix_result_calls_from_no_param_undropped_self_callers,
    original_dead_suffix_same_self_result_operand_calls, original_dead_suffix_undropped_self_call_param_operands,
    original_dead_suffix_result_other_calls, original_dead_suffix_dropped_escaped_result_calls,
    original_dead_suffix_mutual_calls, original_dead_suffix_calls_from_param_operand_self_result_callers,
    original_dead_suffix_escaped_result_operand_call_counts, original_dead_suffix_dropped_calls_from_parameterized_self_callers,
  )
  let scan_limit = if max_def_exclusive >= 0 && max_def_exclusive < defined {
    max_def_exclusive
  } else {
    defined
  }
  let mut def_idx = if reverse { scan_limit - 1 } else { 0 }
  while (if reverse { def_idx >= 0 } else { def_idx < scan_limit }) {
    let callee_abs = imported + def_idx
    let boundary_candidate = match
      dae_call_boundary_candidate(boundary_facts, callee_abs) {
      Some(candidate) => candidate
      None => {
        if reverse {
          def_idx -= 1
        } else {
          def_idx += 1
        }
        continue
      }
    }
    if !boundary_candidate.owned {
      if reverse {
        def_idx -= 1
      } else {
        def_idx += 1
      }
      continue
    }
    let self_calls_anywhere = dae_count_self_calls_anywhere(
      funcs[def_idx],
      callee_abs,
    )
    if self_calls_anywhere > 0 {
      if reverse {
        def_idx -= 1
      } else {
        def_idx += 1
      }
      continue
    }
    let func_type = match
      dae_resolve_func_type(mod_, type_indices, callee_abs) {
      Some(ft) => ft
      None => {
        if reverse {
          def_idx -= 1
        } else {
          def_idx += 1
        }
        continue
      }
    }
    let @lib.FuncType(params, _) = func_type
    if params.length() == 0 || boundary_candidate.direct_call_count == 0 {
      if reverse {
        def_idx -= 1
      } else {
        def_idx += 1
      }
      continue
    }
    let @lib.Func(locals, _) = funcs[def_idx]
    let local_use = dae_local_use_for_callee(
      funcs[def_idx],
      params.length() + locals.length(),
      callee_abs,
      params.length(),
    )
    let uniform_const_params = dae_collect_uniform_const_actuals_from_current_call_facts(
      mod_,
      callee_abs,
      params.length(),
      type_indices,
      boundary_facts,
      boundary_snapshot.function_infos,
    )
    let remove = Array::make(params.length(), false)
    let const_params : Array[@lib.Instruction?] = Array::make(
      params.length(),
      None,
    )
    let mut any_const = false
    let mut has_dead_param = false
    let mut p = 0
    while p < params.length() {
      if !local_use.gets[p] {
        has_dead_param = true
      } else if !local_use.writes[p] {
        match uniform_const_params {
          Some(values) =>
            match values[p] {
              Some(value) => {
                remove[p] = true
                const_params[p] = Some(value)
                any_const = true
              }
              None => ()
            }
          None => ()
        }
      }
      p += 1
    }
    let preserve_current_result = dae_original_result_preservation_evidence_from_context(
      def_idx, original_result_preservation_context,
    )
    if any_const &&
      !has_dead_param &&
      !dae_original_result_preservation_blocks_argument_side_result_repair(
        preserve_current_result, false,
      ) &&
      def_idx <
      original_dead_suffix_calls_from_param_operand_self_result_callers.length() &&
      original_dead_suffix_calls_from_param_operand_self_result_callers[def_idx] ==
      0 &&
      def_idx < original_dead_suffix_undropped_escaped_result_calls.length() &&
      !original_dead_suffix_undropped_escaped_result_calls[def_idx] {
      let result = dae_try_rewrite_candidate(
        mod_,
        callee_abs,
        remove,
        const_params,
        local_use,
        boundary_candidate.direct_call_count,
        boundary_candidate.direct_callers,
      )
      if result.changed {
        return result
      }
    }
    if reverse {
      def_idx -= 1
    } else {
      def_idx += 1
    }
  }
  { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
}

///|
fn dae_merge_touched(dst : Array[Bool], src : Array[Bool]) -> Array[Bool] {
  if dst.length() == 0 {
    // `src` is the one-shot touched bitmap returned by a just-finished rewrite
    // lane. Adopt it as the scheduler-local accumulator instead of allocating a
    // full defined-function copy before the next merge mutates it in place.
    return src
  }
  // `touched` is a scheduler-local accumulation bitmap. Mutate it in place so
  // large artifact lanes do not allocate and copy a full defined-function bitmap
  // after every selected rewrite.
  let mut idx = 0
  while idx < src.length() && idx < dst.length() {
    dst[idx] = dst[idx] || src[idx]
    idx += 1
  }
  dst
}

///|
fn dae_apply_core_result(
  current : @lib.Module,
  touched : Array[Bool],
  changed : Bool,
  result : DaePassResult,
) -> DaeCoreResultApplication {
  if !result.changed {
    return {
      mod_out: current,
      touched,
      changed,
      applied: false,
      primary_def: -1,
    }
  }
  {
    mod_out: result.mod_out,
    touched: dae_merge_touched(touched, result.touched),
    changed: true,
    applied: true,
    primary_def: result.primary_def,
  }
}

///|
fn dae_apply_cleanup_result_preserving_touched(
  current : @lib.Module,
  touched : Array[Bool],
  changed : Bool,
  result : DaePassResult,
) -> DaeCoreResultApplication {
  let application_result : DaePassResult = {
    mod_out: result.mod_out,
    touched: [],
    changed: result.changed,
    primary_def: result.primary_def,
  }
  dae_apply_core_result(current, touched, changed, application_result)
}

///|
fn dae_apply_selected_core_result(
  current : @lib.Module,
  touched : Array[Bool],
  changed : Bool,
  selected_defs : Array[Bool],
  selected_def : Int,
  result : DaePassResult,
) -> DaeCoreResultApplication {
  if selected_def >= 0 && selected_def < selected_defs.length() {
    selected_defs[selected_def] = false
  }
  dae_apply_core_result(current, touched, changed, result)
}

///|
fn dae_run_singleton_selected_core_rewrite(
  current : @lib.Module,
  touched : Array[Bool],
  changed : Bool,
  selected_defs : Array[Bool],
  selected_def : Int,
  rewrite_func : (@lib.Module, Array[Bool]) -> DaePassResult,
) -> DaeCoreResultApplication {
  if selected_def >= 0 && selected_def < selected_defs.length() {
    selected_defs[selected_def] = true
  }
  let result = rewrite_func(current, selected_defs)
  dae_apply_selected_core_result(
    current, touched, changed, selected_defs, selected_def, result,
  )
}

///|
fn dae_run_bounded_singleton_selected_core_rewrite(
  current : @lib.Module,
  touched : Array[Bool],
  changed : Bool,
  selected_defs : Array[Bool],
  selected_def : Int,
  max_iterations : Int,
  rewrite_func : (@lib.Module, Array[Bool]) -> DaePassResult,
  on_applied : (Int, DaeCoreResultApplication) -> Unit,
) -> DaeCoreResultApplication {
  let mut application : DaeCoreResultApplication = {
    mod_out: current,
    touched,
    changed,
    applied: false,
    primary_def: -1,
  }
  let mut iteration = 0
  while iteration < max_iterations {
    application = dae_run_singleton_selected_core_rewrite(
      application.mod_out,
      application.touched,
      application.changed,
      selected_defs,
      selected_def,
      rewrite_func,
    )
    if !application.applied {
      break
    }
    on_applied(iteration, application)
    iteration += 1
  }
  application
}

///|
fn dae_apply_primary_selected_core_result(
  current : @lib.Module,
  touched : Array[Bool],
  changed : Bool,
  selected_defs : Array[Bool],
  result : DaePassResult,
) -> DaeCoreResultApplication {
  let application = dae_apply_core_result(current, touched, changed, result)
  if application.applied &&
    application.primary_def >= 0 &&
    application.primary_def < selected_defs.length() {
    selected_defs[application.primary_def] = false
  }
  application
}

///|
fn dae_try_apply_selected_def_func_rewrite_once(
  mod_ : @lib.Module,
  selected_defs : Array[Bool],
  def_idx : Int,
  rewrite_func : (@lib.Func, @lib.TypeSec?) -> @lib.Func?,
) -> DaePassResult {
  if def_idx < 0 || def_idx >= selected_defs.length() || !selected_defs[def_idx] {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  if def_idx >= funcs.length() {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let current_func = funcs[def_idx]
  let rewritten = match rewrite_func(current_func, mod_.type_sec) {
    Some(func) => func
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  if rewritten == current_func {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let rewritten_funcs = funcs.copy()
  rewritten_funcs[def_idx] = rewritten
  let touched = Array::make(funcs.length(), false)
  touched[def_idx] = true
  {
    mod_out: mod_
    .with_code_sec(@lib.CodeSec::new(rewritten_funcs))
    .without_name_sec(),
    touched,
    changed: true,
    primary_def: def_idx,
  }
}

///|
fn dae_try_apply_selected_def_typed_func_rewrite_once(
  mod_ : @lib.Module,
  selected_defs : Array[Bool],
  def_idx : Int,
  rewrite_func : (@lib.Func, @lib.FuncType, @lib.TypeSec?) -> @lib.Func?,
) -> DaePassResult {
  let rewrite_selected = fn(
    func : @lib.Func,
    type_sec : @lib.TypeSec?,
  ) -> @lib.Func? {
    let func_type = match
      dae_resolve_func_type(
        mod_,
        dae_collect_func_type_indices(mod_),
        dae_imported_func_count(mod_) + def_idx,
      ) {
      Some(func_type) => func_type
      None => return None
    }
    rewrite_func(func, func_type, type_sec)
  }
  dae_try_apply_selected_def_func_rewrite_once(
    mod_, selected_defs, def_idx, rewrite_selected,
  )
}

///|
fn dae_try_apply_selected_def_funcsec_func_rewrite_once(
  mod_ : @lib.Module,
  selected_defs : Array[Bool],
  def_idx : Int,
  rewrite_func : (@lib.Func, @lib.FuncType, @lib.TypeSec) -> @lib.Func?,
) -> DaePassResult {
  if def_idx < 0 || def_idx >= selected_defs.length() || !selected_defs[def_idx] {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let (type_idxs, funcs, type_sec) = match
    (mod_.func_sec, mod_.code_sec, mod_.type_sec) {
    (Some(@lib.FuncSec(type_idxs)), Some(@lib.CodeSec(funcs)), Some(type_sec)) =>
      (type_idxs, funcs, type_sec)
    _ => return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  if def_idx >= funcs.length() || def_idx >= type_idxs.length() {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let func_type = match dae_type_sec_func_type(type_sec, type_idxs[def_idx]) {
    Some(func_type) => func_type
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let current_func = funcs[def_idx]
  let rewritten = match rewrite_func(current_func, func_type, type_sec) {
    Some(func) => func
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  if rewritten == current_func {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let @lib.FuncType(params, results) = func_type
  let canonical_type_idx = match
    dae_find_first_matching_func_type_idx(type_sec, params, results) {
    Some(type_idx) => type_idx
    None => type_idxs[def_idx]
  }
  let rewritten_type_idxs = type_idxs.copy()
  rewritten_type_idxs[def_idx] = canonical_type_idx
  let rewritten_funcs = funcs.copy()
  rewritten_funcs[def_idx] = rewritten
  let touched = Array::make(funcs.length(), false)
  touched[def_idx] = true
  {
    mod_out: mod_
    .with_func_sec(@lib.FuncSec::new(rewritten_type_idxs))
    .with_code_sec(@lib.CodeSec::new(rewritten_funcs))
    .without_name_sec(),
    touched,
    changed: true,
    primary_def: def_idx,
  }
}

///|
fn dae_try_apply_first_selected_func_rewrite_once(
  mod_ : @lib.Module,
  selected_defs : Array[Bool],
  rewrite_func : (@lib.Func, Int, @lib.TypeSec?) -> @lib.Func?,
) -> DaePassResult {
  let defined = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs.length()
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let mut def_idx = 0
  while def_idx < defined && def_idx < selected_defs.length() {
    if selected_defs[def_idx] {
      let selected_def = def_idx
      let rewrite_selected = fn(
        func : @lib.Func,
        type_sec : @lib.TypeSec?,
      ) -> @lib.Func? {
        rewrite_func(func, selected_def, type_sec)
      }
      let result = dae_try_apply_selected_def_func_rewrite_once(
        mod_, selected_defs, selected_def, rewrite_selected,
      )
      if result.changed {
        return result
      }
    }
    def_idx += 1
  }
  { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
}

///|
fn dae_try_apply_selected_def_body_rewrite_once(
  mod_ : @lib.Module,
  selected_defs : Array[Bool],
  def_idx : Int,
  rewrite_body : (Array[@lib.Instruction], @lib.TypeSec?) -> Array[
    @lib.Instruction,
  ]?,
) -> DaePassResult {
  let rewrite_func = fn(
    func : @lib.Func,
    type_sec : @lib.TypeSec?,
  ) -> @lib.Func? {
    let @lib.Func(locals, @lib.Expr(body)) = func
    match rewrite_body(body, type_sec) {
      Some(rewritten) => Some(@lib.Func::new(locals, @lib.Expr::new(rewritten)))
      None => None
    }
  }
  dae_try_apply_selected_def_func_rewrite_once(
    mod_, selected_defs, def_idx, rewrite_func,
  )
}

///|
fn dae_collect_direct_callee_defs_from_caller_prefix(
  mod_ : @lib.Module,
  max_caller_def_exclusive : Int,
) -> Array[Bool] {
  let imported = dae_imported_func_count(mod_)
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None => return []
  }
  let defined = funcs.length()
  let caller_limit = if max_caller_def_exclusive >= 0 &&
    max_caller_def_exclusive < defined {
    max_caller_def_exclusive
  } else {
    defined
  }
  let selected = Array::make(defined, false)
  let mut caller_def = 0
  while caller_def < caller_limit {
    let @lib.Func(_, @lib.Expr(body)) = funcs[caller_def]
    let callees : Array[Int] = []
    dae_collect_direct_call_targets_anywhere(body, imported, defined, callees)
    for callee_def in callees {
      if callee_def >= caller_limit && callee_def < defined {
        selected[callee_def] = true
      }
    }
    caller_def += 1
  }
  selected
}

///|
fn dae_collect_shifted_forward_wrapper_callee_order(
  mod_ : @lib.Module,
  min_caller_def_inclusive : Int,
  max_caller_def_exclusive : Int,
) -> Array[Int] {
  let defined = dae_defined_func_count(mod_)
  let caller_start = if min_caller_def_inclusive > 0 &&
    min_caller_def_inclusive < defined {
    min_caller_def_inclusive
  } else if min_caller_def_inclusive >= defined {
    defined
  } else {
    0
  }
  let caller_limit = if max_caller_def_exclusive >= caller_start &&
    max_caller_def_exclusive < defined {
    max_caller_def_exclusive
  } else {
    defined
  }
  let type_indices = dae_collect_func_type_indices(mod_)
  let ordered : Array[Int] = []
  let mut caller_def = caller_start
  while caller_def < caller_limit {
    let callee_def = dae_find_shifted_forward_wrapper_callee_def(
      mod_, type_indices, caller_def,
    )
    if callee_def >= 0 && !ordered.contains(callee_def) {
      ordered.push(callee_def)
    }
    caller_def += 1
  }
  ordered
}

///|
fn dae_collect_shifted_forward_wrapper_callee_defs(
  mod_ : @lib.Module,
  min_caller_def_inclusive : Int,
  max_caller_def_exclusive : Int,
) -> Array[Bool] {
  let imported = dae_imported_func_count(mod_)
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None => return []
  }
  let defined = funcs.length()
  let caller_start = if min_caller_def_inclusive > 0 &&
    min_caller_def_inclusive < defined {
    min_caller_def_inclusive
  } else if min_caller_def_inclusive >= defined {
    defined
  } else {
    0
  }
  let caller_limit = if max_caller_def_exclusive >= caller_start &&
    max_caller_def_exclusive < defined {
    max_caller_def_exclusive
  } else {
    defined
  }
  let type_indices = dae_collect_func_type_indices(mod_)
  let selected = Array::make(defined, false)
  let mut caller_def = caller_start
  while caller_def < caller_limit {
    let wrapper_abs = imported + caller_def
    let wrapper_type = match
      dae_resolve_func_type(mod_, type_indices, wrapper_abs) {
      Some(ft) => ft
      None => {
        caller_def += 1
        continue
      }
    }
    let @lib.FuncType(wrapper_params, wrapper_results) = wrapper_type
    let wrapper_param_count = wrapper_params.length()
    if wrapper_param_count <= 1 {
      caller_def += 1
      continue
    }
    let @lib.Func(_, @lib.Expr(body)) = funcs[caller_def]
    if body.length() != wrapper_param_count {
      caller_def += 1
      continue
    }
    let mut forwards = true
    let mut param_idx = 0
    while param_idx + 1 < wrapper_param_count {
      match body[param_idx] {
        @lib.LocalGet(local_idx) if dae_local_idx_slot(local_idx) ==
          param_idx + 1 => ()
        _ => forwards = false
      }
      param_idx += 1
    }
    if !forwards {
      caller_def += 1
      continue
    }
    match body[wrapper_param_count - 1] {
      @lib.Call(func_idx) => {
        let callee_abs = dae_func_idx_slot(func_idx)
        let callee_def = callee_abs - imported
        if callee_def >= caller_limit && callee_def < defined {
          match dae_resolve_func_type(mod_, type_indices, callee_abs) {
            Some(@lib.FuncType(callee_params, callee_results)) if callee_params.length() +
              1 ==
              wrapper_param_count &&
              callee_results == wrapper_results => selected[callee_def] = true
            _ => ()
          }
        }
      }
      _ => ()
    }
    caller_def += 1
  }
  selected
}

///|
fn dae_find_shifted_forward_wrapper_callee_def(
  mod_ : @lib.Module,
  type_indices : Array[@lib.TypeIdx],
  wrapper_def : Int,
) -> Int {
  let imported = dae_imported_func_count(mod_)
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None => return -1
  }
  let defined = funcs.length()
  if wrapper_def < 0 || wrapper_def >= defined {
    return -1
  }
  let caller_limit = wrapper_def + 1
  let wrapper_abs = imported + wrapper_def
  let wrapper_type = match
    dae_resolve_func_type(mod_, type_indices, wrapper_abs) {
    Some(ft) => ft
    None => return -1
  }
  let @lib.FuncType(wrapper_params, wrapper_results) = wrapper_type
  let wrapper_param_count = wrapper_params.length()
  if wrapper_param_count <= 1 {
    return -1
  }
  let @lib.Func(_, @lib.Expr(body)) = funcs[wrapper_def]
  if body.length() != wrapper_param_count {
    return -1
  }
  let mut param_idx = 0
  while param_idx + 1 < wrapper_param_count {
    match body[param_idx] {
      @lib.LocalGet(local_idx) if dae_local_idx_slot(local_idx) == param_idx + 1 =>
        ()
      _ => return -1
    }
    param_idx += 1
  }
  match body[wrapper_param_count - 1] {
    @lib.Call(func_idx) => {
      let callee_abs = dae_func_idx_slot(func_idx)
      let callee_def = callee_abs - imported
      if callee_def < caller_limit || callee_def >= defined {
        return -1
      }
      match dae_resolve_func_type(mod_, type_indices, callee_abs) {
        Some(@lib.FuncType(callee_params, callee_results)) if callee_params.length() +
          1 ==
          wrapper_param_count &&
          callee_results == wrapper_results => callee_def
        _ => -1
      }
    }
    _ => -1
  }
}

///|
fn dae_try_rewrite_selected_defs_unread_params_with_facts_once(
  mod_ : @lib.Module,
  selected_defs : Array[Bool],
  call_facts : DaeCurrentCallFacts,
  allow_stack_carried_void_effects? : Bool = false,
  require_localization_retry? : Bool = false,
  only_def? : Int = -1,
  type_indices_override? : Array[@lib.TypeIdx]? = None,
) -> DaePassResult {
  let imported = dae_imported_func_count(mod_)
  let boundary_facts = dae_call_boundary_facts_from_current(call_facts)
  let type_indices = match type_indices_override {
    Some(indices) => indices
    None => dae_collect_func_type_indices(mod_)
  }
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let scan_limit = if only_def >= 0 && only_def < funcs.length() {
    only_def + 1
  } else if only_def >= funcs.length() {
    funcs.length()
  } else if selected_defs.length() < funcs.length() {
    selected_defs.length()
  } else {
    funcs.length()
  }
  let mut def_idx = if only_def >= 0 { only_def } else { 0 }
  while def_idx < scan_limit {
    if only_def < 0 && !selected_defs[def_idx] {
      def_idx += 1
      continue
    }
    let callee_abs = imported + def_idx
    let boundary_candidate = match
      dae_call_boundary_candidate(boundary_facts, callee_abs, def_idx~) {
      Some(candidate) => candidate
      None => {
        def_idx += 1
        continue
      }
    }
    if !boundary_candidate.owned ||
      boundary_candidate.has_self_direct_caller ||
      !boundary_candidate.allows_nonself_direct_rewrite {
      def_idx += 1
      continue
    }
    let func_type = match
      dae_resolve_func_type(mod_, type_indices, callee_abs) {
      Some(ft) => ft
      None => {
        def_idx += 1
        continue
      }
    }
    let @lib.FuncType(params, _) = func_type
    if params.length() == 0 {
      def_idx += 1
      continue
    }
    let @lib.Func(locals, _) = funcs[def_idx]
    let local_use = dae_local_use_for_callee(
      funcs[def_idx],
      params.length() + locals.length(),
      callee_abs,
      params.length(),
    )
    let remove = Array::make(params.length(), false)
    let const_params : Array[@lib.Instruction?] = Array::make(
      params.length(),
      None,
    )
    let mut any = false
    let mut p = 0
    while p < params.length() {
      if !local_use.gets[p] {
        remove[p] = true
        any = true
      }
      p += 1
    }
    if any {
      let result = dae_try_rewrite_candidate(
        mod_,
        callee_abs,
        remove,
        const_params,
        local_use,
        boundary_candidate.direct_call_count,
        boundary_candidate.direct_callers,
      )
      if result.changed && !require_localization_retry {
        return result
      }
      let direct_rewrite_succeeded = result.changed
      let mut kept_count = 0
      let mut removed_param_written = false
      p = 0
      while p < params.length() {
        if remove[p] {
          removed_param_written = removed_param_written || local_use.writes[p]
        } else {
          kept_count += 1
        }
        p += 1
      }
      // After an exact control literal folds, a selected callee can retain one
      // argument while older removed arguments remain stack-carried across void
      // effects in its callers. Retry only that bounded shape. The alternate
      // value slicing includes those void effects in the preceding operand;
      // the existing localization, exact call-count, signature, callee-local,
      // and module-validation transaction remains authoritative.
      if allow_stack_carried_void_effects &&
        !direct_rewrite_succeeded &&
        kept_count == 1 &&
        !removed_param_written {
        let stack_carried = dae_try_rewrite_candidate(
          mod_,
          callee_abs,
          remove,
          const_params,
          local_use,
          boundary_candidate.direct_call_count,
          boundary_candidate.direct_callers,
          allow_stack_carried_void_effects=true,
        )
        if stack_carried.changed {
          return stack_carried
        }
      }
    }
    def_idx += 1
  }
  { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
}

///|
fn dae_try_rewrite_unread_params_for_def_with_facts(
  mod_ : @lib.Module,
  def_idx : Int,
  call_facts : DaeCurrentCallFacts,
  allow_stack_carried_void_effects? : Bool = false,
  require_localization_retry? : Bool = false,
  type_indices_override? : Array[@lib.TypeIdx]? = None,
) -> DaePassResult {
  dae_try_rewrite_selected_defs_unread_params_with_facts_once(
    mod_,
    [],
    call_facts,
    allow_stack_carried_void_effects~,
    require_localization_retry~,
    only_def=def_idx,
    type_indices_override~,
  )
}

///|
fn dae_fold_const_i32_eq_if_instrs_once(
  instrs : Array[@lib.Instruction],
) -> (Array[@lib.Instruction], Bool) {
  let out : Array[@lib.Instruction] = []
  let mut changed = false
  let mut idx = 0
  while idx < instrs.length() {
    if idx + 3 < instrs.length() {
      match (instrs[idx], instrs[idx + 1], instrs[idx + 2], instrs[idx + 3]) {
        (
          @lib.I32Const(@lib.I32(lhs)),
          @lib.I32Const(@lib.I32(rhs)),
          @lib.I32Eq,
          @lib.If(_, then_body, else_body),
        ) => {
          if lhs == rhs {
            out.append(then_body)
          } else {
            match else_body {
              Some(body) => out.append(body)
              None => ()
            }
          }
          changed = true
          idx += 4
          continue
        }
        (
          @lib.I64Const(@lib.I64(lhs)),
          @lib.I64Const(@lib.I64(rhs)),
          @lib.I64Eq,
          @lib.If(_, then_body, else_body),
        ) => {
          if lhs == rhs {
            out.append(then_body)
          } else {
            match else_body {
              Some(body) => out.append(body)
              None => ()
            }
          }
          changed = true
          idx += 4
          continue
        }
        _ => ()
      }
    }
    out.push(instrs[idx])
    idx += 1
  }
  (out, changed)
}

///|
fn dae_instr_is_droppable_pure_leaf(instr : @lib.Instruction) -> Bool {
  match instr {
    @lib.I32Const(_)
    | @lib.I64Const(_)
    | @lib.F32Const(_)
    | @lib.F64Const(_)
    | @lib.V128Const(_, _, _, _, _, _, _, _, _, _, _, _, _, _, _, _)
    | @lib.RefNull(_)
    | @lib.LocalGet(_)
    | @lib.GlobalGet(_)
    | @lib.MemorySize(_)
    | @lib.TableSize(_) => true
    _ => false
  }
}

