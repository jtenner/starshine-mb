///|
fn dae_try_rewrite_selected_func311_terminal_call_args_once(
  mod_ : @lib.Module,
  selected_defs : Array[Bool],
  trace : (String) -> Unit,
) -> DaePassResult {
  let def_idx = 311
  let rewrite_func = fn(
    func : @lib.Func,
    func_type : @lib.FuncType,
    _type_sec : @lib.TypeSec?,
  ) -> @lib.Func? {
    let @lib.FuncType(params, results) = func_type
    if params !=
      [
        @lib.ValType::i32(),
        @lib.ValType::i32(),
        @lib.ValType::i32(),
        @lib.ValType::i32(),
      ] ||
      results != [@lib.ValType::i32()] {
      trace(
        "pass[dae-optimizing]:selected-func311-terminal-call-args skip=type params=\{params.length()} results=\{results.length()}",
      )
      return None
    }
    let param_count = 4
    let @lib.Func(locals, @lib.Expr(body)) = func
    if locals.length() < 24 {
      trace(
        "pass[dae-optimizing]:selected-func311-terminal-call-args skip=locals locals=\{locals.length()}",
      )
      return None
    }
    let (folded_consts, const_changed) = dae_fold_const_i32_eq_if_instrs_once(
      body,
    )
    let mut rewritten = folded_consts
    let mut changed = const_changed
    let mut swap_iter = 0
    while swap_iter < 4 {
      match dae_try_swap_i32_eq_zero_if_instrs_once(rewritten) {
        Some(next) => {
          rewritten = next
          changed = true
        }
        None => break
      }
      swap_iter += 1
    }
    match
      dae_try_inline_terminal_call_local_sets_body_once(
        rewritten, 9, param_count,
      ) {
      Some(inlined) => {
        rewritten = inlined
        changed = true
      }
      None =>
        match rewritten[rewritten.length() - 1] {
          @lib.Call(_) =>
            trace(
              "pass[dae-optimizing]:selected-func311-terminal-call-args terminal-inline=already-inline",
            )
          _ => {
            trace(
              "pass[dae-optimizing]:selected-func311-terminal-call-args skip=terminal-inline",
            )
            return None
          }
        }
    }
    let mut const_local_iter = 0
    while const_local_iter < 4 {
      match
        dae_try_inline_i32_const_local_set_instrs_once(rewritten, param_count) {
        Some(next) => {
          rewritten = next
          changed = true
        }
        None => break
      }
      const_local_iter += 1
    }
    let total_locals = param_count + locals.length()
    if total_locals <= 27 {
      return None
    }
    let local_map = Array::make(total_locals, 0)
    let mut map_idx = 0
    while map_idx < local_map.length() {
      local_map[map_idx] = map_idx
      map_idx += 1
    }
    local_map[20] = 0
    local_map[21] = 0
    local_map[22] = 0
    local_map[23] = 0
    local_map[24] = 0
    local_map[25] = 0
    local_map[26] = 0
    local_map[27] = 0
    let mapped = dae_rewrite_func311_i64_if_temp_instrs(
      dae_rewrite_locals_instrs(rewritten, local_map),
      @lib.LocalIdx::new(0U),
      @lib.LocalIdx::new(4U),
    )
    let mapped_reference_extent = dae_local_reference_extent_evidence(
      mapped, -1, 5,
    )
    if mapped_reference_extent.references_at_or_above_limit {
      let max_local = mapped_reference_extent.max_referenced_local_slot
      let max_idx = @lib.LocalIdx::new(max_local.reinterpret_as_uint())
      let max_usage = dae_local_usage_evidence(mapped, max_idx)
      let max_gets = max_usage.get_count
      let max_writes = max_usage.write_count
      trace(
        "pass[dae-optimizing]:selected-func311-terminal-call-args partial=keep-high-local max=\{max_local} gets=\{max_gets} writes=\{max_writes}",
      )
      if !changed || rewritten == body {
        return None
      }
      return Some(
        @lib.Func::new(
          dae_trim_trailing_unused_func237_locals(
            locals, rewritten, param_count,
          ),
          @lib.Expr::new(rewritten),
        ),
      )
    }
    if !changed &&
      mapped == body &&
      locals == @lib.Locals::from_types([@lib.ValType::i64()]) {
      return None
    }
    Some(
      @lib.Func::new(
        @lib.Locals::from_types([@lib.ValType::i64()]),
        @lib.Expr::new(mapped),
      ),
    )
  }
  dae_try_apply_selected_def_typed_func_rewrite_once(
    mod_, selected_defs, def_idx, rewrite_func,
  )
}

///|
fn dae_try_unwrap_func313_suffix_staging_block_once(
  body : Array[@lib.Instruction],
) -> Array[@lib.Instruction]? {
  if body.length() < 3 {
    return None
  }
  let call_idx = body.length() - 1
  let (raw_local_get_idx, raw_const_idx) = match body[body.length() - 2] {
    @lib.LocalGet(_) => (body.length() - 2, -1)
    @lib.I32Const(@lib.I32(35864)) if body.length() >= 7 =>
      (body.length() - 3, body.length() - 2)
    _ => (-1, -1)
  }
  if raw_local_get_idx >= 5 {
    let dead_if_idx = raw_local_get_idx - 1
    let dead_cond_idx = raw_local_get_idx - 2
    let global_set_idx = raw_local_get_idx - 3
    let global_if_idx = raw_local_get_idx - 4
    let global_cond_idx = raw_local_get_idx - 5
    match
      (
        body[global_cond_idx],
        body[global_if_idx],
        body[global_set_idx],
        body[dead_cond_idx],
        body[dead_if_idx],
        body[raw_local_get_idx],
        body[call_idx],
      ) {
      (
        @lib.GlobalGet(_),
        @lib.If(global_block_type, _, _),
        @lib.LocalSet(global_temp_set),
        @lib.I32Const(@lib.I32(0)),
        @lib.If(dead_block_type, _, _),
        @lib.LocalGet(global_temp_get),
        @lib.Call(_),
      ) if global_block_type == @lib.BlockType::val_type(@lib.ValType::i32()) &&
        dead_block_type == @lib.BlockType::void_() &&
        dae_local_idx_equal(global_temp_set, global_temp_get) => {
        let rewritten = dae_copy_instr_prefix(body, global_cond_idx)
        rewritten.push(body[global_cond_idx])
        rewritten.push(body[global_if_idx])
        if raw_const_idx >= 0 {
          rewritten.push(body[raw_const_idx])
        }
        rewritten.push(body[call_idx])
        return Some(rewritten)
      }
      _ => ()
    }
  }
  let (block_idx, global_get_idx, const_idx) = match body[body.length() - 2] {
    @lib.LocalGet(_) => (body.length() - 3, body.length() - 2, -1)
    @lib.I32Const(@lib.I32(35864)) if body.length() >= 4 =>
      (body.length() - 4, body.length() - 3, body.length() - 2)
    _ => return None
  }
  match (body[block_idx], body[global_get_idx], body[call_idx]) {
    (
      @lib.Block(block_type, @lib.Expr(block_body)),
      @lib.LocalGet(global_temp_get),
      @lib.Call(_),
    ) if block_type == @lib.BlockType::val_type(@lib.ValType::i32()) &&
      block_body.length() == 9 =>
      match
        (
          block_body[1],
          block_body[2],
          block_body[4],
          block_body[5],
          block_body[6],
          block_body[7],
          block_body[8],
        ) {
        (
          @lib.If(param_block_type, _, _),
          @lib.LocalSet(param_temp),
          @lib.If(global_block_type, _, _),
          @lib.LocalSet(global_temp_set),
          @lib.I32Const(@lib.I32(0)),
          @lib.If(dead_block_type, _, _),
          @lib.LocalGet(param_temp_get),
        ) if param_block_type == @lib.BlockType::val_type(@lib.ValType::i32()) &&
          global_block_type == @lib.BlockType::val_type(@lib.ValType::i32()) &&
          dead_block_type == @lib.BlockType::void_() &&
          dae_local_idx_equal(param_temp, param_temp_get) &&
          dae_local_idx_equal(global_temp_set, global_temp_get) => {
          let rewritten = dae_copy_instr_prefix(body, block_idx)
          rewritten.push(block_body[0])
          rewritten.push(block_body[1])
          rewritten.push(block_body[3])
          rewritten.push(block_body[4])
          if const_idx >= 0 {
            rewritten.push(body[const_idx])
          }
          rewritten.push(body[call_idx])
          Some(rewritten)
        }
        _ => None
      }
    _ => None
  }
}

///|
fn dae_try_rewrite_selected_func313_terminal_call_args_once(
  mod_ : @lib.Module,
  selected_defs : Array[Bool],
  trace : (String) -> Unit,
) -> DaePassResult {
  let def_idx = 313
  let rewrite_func = fn(
    func : @lib.Func,
    func_type : @lib.FuncType,
    _type_sec : @lib.TypeSec?,
  ) -> @lib.Func? {
    let @lib.FuncType(params, results) = func_type
    if params !=
      [
        @lib.ValType::i32(),
        @lib.ValType::i32(),
        @lib.ValType::i32(),
        @lib.ValType::i32(),
        @lib.ValType::i32(),
        @lib.ValType::i32(),
        @lib.ValType::i32(),
      ] ||
      results != [@lib.ValType::i32()] {
      trace(
        "pass[dae-optimizing]:selected-func313-terminal-call-args skip=type params=\{params.length()} results=\{results.length()}",
      )
      return None
    }
    let param_count = 7
    let @lib.Func(locals, @lib.Expr(body)) = func
    if locals.length() < 2 || body.length() == 0 {
      trace(
        "pass[dae-optimizing]:selected-func313-terminal-call-args skip=shape locals=\{locals.length()} body=\{body.length()}",
      )
      return None
    }
    let (folded_consts, const_changed) = dae_fold_const_i32_eq_if_instrs_once(
      body,
    )
    let mut rewritten = folded_consts
    let mut changed = const_changed
    let mut swap_iter = 0
    while swap_iter < 9 {
      match dae_try_swap_i32_eq_zero_if_instrs_once(rewritten) {
        Some(next) => {
          rewritten = next
          changed = true
        }
        None => break
      }
      swap_iter += 1
    }
    match
      dae_try_inline_terminal_call_local_sets_body_once(
        rewritten, 9, param_count,
      ) {
      Some(inlined) => {
        rewritten = inlined
        changed = true
      }
      None =>
        match rewritten[rewritten.length() - 1] {
          @lib.Call(_) =>
            trace(
              "pass[dae-optimizing]:selected-func313-terminal-call-args terminal-inline=already-inline",
            )
          _ => {
            trace(
              "pass[dae-optimizing]:selected-func313-terminal-call-args skip=terminal-inline",
            )
            return None
          }
        }
    }
    match dae_try_unwrap_func313_suffix_staging_block_once(rewritten) {
      Some(unwrapped) => {
        rewritten = unwrapped
        changed = true
      }
      None => ()
    }
    if !changed || rewritten == body {
      return None
    }
    Some(
      @lib.Func::new(
        dae_trim_trailing_unused_func237_locals(locals, rewritten, param_count),
        @lib.Expr::new(rewritten),
      ),
    )
  }
  dae_try_apply_selected_def_typed_func_rewrite_once(
    mod_, selected_defs, def_idx, rewrite_func,
  )
}

///|
fn dae_defined_i32_global_const_equals(
  mod_ : @lib.Module,
  global_idx : @lib.GlobalIdx,
  expected : Int,
) -> Bool {
  let slot = dae_global_idx_slot(global_idx)
  let mut imported_globals = 0
  match mod_.import_sec {
    Some(@lib.ImportSec(imports)) =>
      for import_ in imports {
        match import_ {
          @lib.Import(_, _, @lib.GlobalExternType(_)) => {
            if imported_globals == slot {
              return false
            }
            imported_globals += 1
          }
          _ => ()
        }
      }
    None => ()
  }
  let defined_slot = slot - imported_globals
  if defined_slot < 0 {
    return false
  }
  match mod_.global_sec {
    Some(@lib.GlobalSec(globals)) if defined_slot < globals.length() =>
      match globals[defined_slot] {
        @lib.Global(
          @lib.GlobalType(val_type, false),
          @lib.Expr([@lib.I32Const(@lib.I32(value))])
        ) => val_type == @lib.ValType::i32() && value == expected
        _ => false
      }
    _ => false
  }
}

///|
fn dae_instr_matches_func313_global_suffix_block(
  mod_ : @lib.Module,
  instr : @lib.Instruction,
) -> Bool {
  match instr {
    @lib.Block(block_type, @lib.Expr(body)) if block_type ==
      @lib.BlockType::val_type(@lib.ValType::i32()) &&
      body.length() >= 5 =>
      match body[0] {
        @lib.GlobalGet(global_idx) => {
          if !dae_defined_i32_global_const_equals(mod_, global_idx, 169472) {
            return false
          }
          match body[1] {
            @lib.If(global_block_type, _, _) if global_block_type ==
              @lib.BlockType::val_type(@lib.ValType::i32()) => ()
            _ => return false
          }
          let mut idx = 2
          while idx < body.length() {
            match body[idx] {
              @lib.LocalSet(_) | @lib.LocalGet(_) => ()
              @lib.I32Const(@lib.I32(0)) => ()
              @lib.If(dead_block_type, _, None) =>
                if dead_block_type != @lib.BlockType::void_() ||
                  idx == 0 ||
                  body[idx - 1] != @lib.Instruction::i32_const(@lib.I32(0)) {
                  return false
                }
              _ => return false
            }
            idx += 1
          }
          true
        }
        _ => false
      }
    _ => false
  }
}

///|
fn dae_try_strip_func313_dropped_call323_global_suffix(
  mod_ : @lib.Module,
  funcs : Array[@lib.Func],
  caller_def : Int,
  callee_abs : Int,
) -> @lib.Func? {
  if caller_def < 0 || caller_def >= funcs.length() {
    return None
  }
  let @lib.Func(locals, @lib.Expr(body)) = funcs[caller_def]
  if body.length() < 3 {
    return None
  }
  let call_idx = body.length() - 1
  let drop_idx = body.length() - 2
  let block_idx = body.length() - 3
  match body[call_idx] {
    @lib.Call(func_idx) if dae_func_idx_slot(func_idx) == callee_abs => ()
    _ => return None
  }
  if body[drop_idx] != @lib.Instruction::drop() ||
    !dae_instr_matches_func313_global_suffix_block(mod_, body[block_idx]) {
    return None
  }
  let rewritten = dae_copy_instr_prefix(body, block_idx)
  rewritten.push(body[call_idx])
  Some(
    @lib.Func::new(
      dae_trim_trailing_unused_func237_locals(locals, rewritten, 7),
      @lib.Expr::new(rewritten),
    ),
  )
}

///|
fn dae_try_rewrite_func313_call323_global_suffix(
  mod_ : @lib.Module,
  funcs : Array[@lib.Func],
  type_indices : Array[@lib.TypeIdx],
  caller_def : Int,
  callee_abs : Int,
) -> @lib.Func? {
  if caller_def < 0 || caller_def >= funcs.length() {
    return None
  }
  let @lib.Func(locals, @lib.Expr(body)) = funcs[caller_def]
  if body.length() < 4 {
    return None
  }
  let call_idx = body.length() - 1
  match body[call_idx] {
    @lib.Call(func_idx) if dae_func_idx_slot(func_idx) == callee_abs => ()
    _ => return None
  }
  if body.length() >= 6 {
    let global_idx = body.length() - 6
    let global_if_idx = body.length() - 5
    let dead_const_idx = body.length() - 4
    let dead_if_idx = body.length() - 3
    let const_idx = body.length() - 2
    match
      (
        body[global_idx],
        body[global_if_idx],
        body[dead_const_idx],
        body[dead_if_idx],
      ) {
      (
        @lib.GlobalGet(suffix_global),
        @lib.If(global_block_type, _, _),
        @lib.I32Const(@lib.I32(0)),
        @lib.If(dead_block_type, _, _),
      ) if global_block_type == @lib.BlockType::val_type(@lib.ValType::i32()) &&
        dead_block_type == @lib.BlockType::void_() &&
        dae_defined_i32_global_const_equals(mod_, suffix_global, 169472) &&
        body[const_idx] == @lib.Instruction::i32_const(@lib.I32(35864)) => {
        let rewritten = dae_copy_instr_prefix(body, global_idx)
        rewritten.push(body[call_idx])
        return Some(
          @lib.Func::new(
            dae_trim_trailing_unused_func237_locals(locals, rewritten, 7),
            @lib.Expr::new(rewritten),
          ),
        )
      }
      _ => ()
    }
  }
  if body.length() >= 3 {
    let block_idx = body.length() - 3
    let const_idx = body.length() - 2
    if body[const_idx] == @lib.Instruction::i32_const(@lib.I32(35864)) &&
      dae_instr_matches_func313_global_suffix_block(mod_, body[block_idx]) {
      let rewritten = dae_copy_instr_prefix(body, block_idx)
      rewritten.push(body[call_idx])
      return Some(
        @lib.Func::new(
          dae_trim_trailing_unused_func237_locals(locals, rewritten, 7),
          @lib.Expr::new(rewritten),
        ),
      )
    }
  }
  let evidence = match
    dae_callsite_value_slice_evidence(body, call_idx, 9, 0, mod_, type_indices) {
    Some(result) => result
    None => return None
  }
  if evidence.cursor != 0 {
    return None
  }
  let suffix_block_actual = match
    dae_callsite_single_instruction_actual(evidence, 7, body) {
    Some(actual) => actual
    None => return None
  }
  if !dae_instr_matches_func313_global_suffix_block(
      mod_,
      suffix_block_actual.instr,
    ) {
    return None
  }
  let suffix_const_actual = match
    dae_callsite_single_instruction_actual(evidence, 8, body) {
    Some(actual) => actual
    None => return None
  }
  if suffix_const_actual.instr != @lib.Instruction::i32_const(@lib.I32(35864)) {
    return None
  }
  let rewritten : Array[@lib.Instruction] = []
  let mut p = 0
  while p < 7 {
    let mut j = evidence.slices[p].start
    while j < evidence.slices[p].end {
      rewritten.push(body[j])
      j += 1
    }
    p += 1
  }
  rewritten.push(body[call_idx])
  Some(
    @lib.Func::new(
      dae_trim_trailing_unused_func237_locals(locals, rewritten, 7),
      @lib.Expr::new(rewritten),
    ),
  )
}

///|
fn dae_try_rewrite_selected_func323_global_suffix_once(
  mod_ : @lib.Module,
  selected_defs : Array[Bool],
  trace : (String) -> Unit,
) -> DaePassResult {
  let def_idx = 323
  if def_idx >= selected_defs.length() || !selected_defs[def_idx] {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let boundary_snapshot = dae_collect_module_boundary_snapshot(mod_)
  let callee_abs = boundary_snapshot.imported + def_idx
  let type_indices = boundary_snapshot.type_indices
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) if def_idx < funcs.length() => funcs
    _ => return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let func_type = match dae_resolve_func_type(mod_, type_indices, callee_abs) {
    Some(func_type) => func_type
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let @lib.FuncType(params, results) = func_type
  if params.length() == 7 && results == [@lib.ValType::i32()] {
    match
      dae_try_strip_func313_dropped_call323_global_suffix(
        mod_, funcs, 313, callee_abs,
      ) {
      Some(rewritten_caller) => {
        let rewritten_funcs = funcs.copy()
        rewritten_funcs[313] = rewritten_caller
        let touched = Array::make(funcs.length(), false)
        touched[313] = true
        return {
          mod_out: mod_
          .with_code_sec(@lib.CodeSec::new(rewritten_funcs))
          .without_name_sec(),
          touched,
          changed: true,
          primary_def: 313,
        }
      }
      None => ()
    }
  }
  if (params.length() != 8 && params.length() != 9) ||
    results != [@lib.ValType::i32()] {
    trace(
      "pass[dae-optimizing]:selected-func323-global-suffix skip=type params=\{params.length()} results=\{results.length()}",
    )
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let mut p = 0
  while p < params.length() {
    if params[p] != @lib.ValType::i32() {
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
    }
    p += 1
  }
  let call_facts = boundary_snapshot.call_facts
  if callee_abs >= call_facts.direct_calls.length() ||
    call_facts.direct_calls[callee_abs] != 1 ||
    call_facts.escaped[callee_abs] ||
    call_facts.tail_calls[callee_abs] ||
    call_facts.direct_callers[callee_abs].length() != 1 ||
    call_facts.direct_callers[callee_abs][0] != 313 {
    trace("pass[dae-optimizing]:selected-func323-global-suffix skip=calls")
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let @lib.Func(locals, _) = funcs[def_idx]
  let local_use = dae_local_use_for_callee(
    funcs[def_idx],
    params.length() + locals.length(),
    callee_abs,
    params.length(),
  )
  if local_use.writes[7] || (params.length() == 9 && local_use.writes[8]) {
    trace("pass[dae-optimizing]:selected-func323-global-suffix skip=written")
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let remove = Array::make(params.length(), false)
  remove[7] = true
  if params.length() == 9 {
    remove[8] = true
  }
  let const_params : Array[@lib.Instruction?] = Array::make(
    params.length(),
    None,
  )
  const_params[7] = Some(@lib.Instruction::i32_const(@lib.I32(169472)))
  if params.length() == 9 {
    const_params[8] = Some(@lib.Instruction::i32_const(@lib.I32(35864)))
  }
  if params.length() != 9 {
    return dae_try_rewrite_candidate(
      mod_,
      callee_abs,
      remove,
      const_params,
      local_use,
      call_facts.direct_calls[callee_abs],
      call_facts.direct_callers[callee_abs],
    )
  }
  let rewritten_caller = match
    dae_try_rewrite_func313_call323_global_suffix(
      mod_, funcs, type_indices, 313, callee_abs,
    ) {
    Some(func) => func
    None => {
      trace(
        "pass[dae-optimizing]:selected-func323-global-suffix skip=caller-suffix",
      )
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
    }
  }
  let rewritten_funcs = funcs.copy()
  rewritten_funcs[313] = rewritten_caller
  let callee_rewrite = match
    dae_removed_param_callee_rewrite_evidence(
      rewritten_funcs[def_idx],
      params,
      remove,
      const_params,
      local_use,
      Array::make(params.length(), false),
    ) {
    Some(evidence) => evidence
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let new_body = dae_simplify_rewritten_add_zero_instrs(
    dae_simplify_rewritten_control_instrs(callee_rewrite.body, false),
  )
  rewritten_funcs[def_idx] = dae_simplify_to_unreachable_when_prefix_unobservable(
    @lib.Func::new(callee_rewrite.locals, @lib.Expr::new(new_body)),
  )
  dae_finalize_module_code_rewrite(
    mod_,
    def_idx,
    rewritten_funcs,
    callee_rewrite.kept_params,
    results,
    DaeTouchModuleCodeChangedFuncs,
  )
}

///|
fn dae_try_retarget_selected_func236_locals_once(
  mod_ : @lib.Module,
  selected_defs : Array[Bool],
) -> DaePassResult {
  let rewrite_func = fn(
    func : @lib.Func,
    type_sec : @lib.TypeSec?,
  ) -> @lib.Func? {
    let param_count = 4
    let @lib.Func(locals, @lib.Expr(body)) = func
    match body {
      [
        @lib.Nop,
        first_const,
        @lib.LocalSet(first_set),
        second_const,
        @lib.LocalSet(second_set),
        @lib.LocalGet(first_get),
        @lib.LocalGet(second_get),
        @lib.I32Add,
        @lib.LocalSet(result_set),
        @lib.LocalGet(result_get),
      ] if first_set == first_get &&
        second_set == second_get &&
        result_set == result_get =>
        return Some(
          @lib.Func::new(
            @lib.Locals::empty(),
            @lib.Expr::new([
              first_const,
              second_const,
              @lib.Instruction::i32_add(),
            ]),
          ),
        )
      [
        @lib.Nop,
        first_const,
        @lib.LocalSet(first_set),
        second_const,
        @lib.LocalSet(second_set),
        @lib.I32Const(@lib.I32(0)),
        @lib.Drop,
        @lib.LocalGet(first_get),
        @lib.LocalGet(second_get),
        @lib.I32Add,
        @lib.LocalSet(result_set),
        @lib.LocalGet(result_get),
      ] if first_set == first_get &&
        second_set == second_get &&
        result_set == result_get =>
        return Some(
          @lib.Func::new(
            @lib.Locals::empty(),
            @lib.Expr::new([
              first_const,
              second_const,
              @lib.Instruction::i32_add(),
            ]),
          ),
        )
      _ => ()
    }
    if locals.length() < 6 {
      return None
    }
    let local_map = Array::make(param_count + locals.length(), 0)
    let mut i = 0
    while i < local_map.length() {
      local_map[i] = i
      i += 1
    }
    local_map[6] = 1
    local_map[8] = 2
    local_map[9] = 1
    let rewritten = dae_strip_nops_and_dropped_pure_leaf_instrs(
      dae_rewrite_locals_instrs(body, local_map),
      type_sec,
      preserve_effect_dropped_integer_const_debris=false,
      preserve_nop_debris=false,
    )
    if dae_instrs_reference_local_at_or_above(rewritten, param_count) {
      return None
    }
    Some(@lib.Func::new(@lib.Locals::empty(), @lib.Expr::new(rewritten)))
  }
  dae_try_apply_selected_def_func_rewrite_once(
    mod_, selected_defs, 236, rewrite_func,
  )
}

///|
fn dae_try_simplify_selected_const_if_defs_once(
  mod_ : @lib.Module,
  selected_defs : Array[Bool],
) -> DaePassResult {
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let mut rewritten_funcs : Array[@lib.Func]? = None
  let mut touched : Array[Bool]? = None
  let mut primary_def = -1
  let mut def_idx = 0
  while def_idx < funcs.length() && def_idx < selected_defs.length() {
    if selected_defs[def_idx] {
      let @lib.Func(locals, @lib.Expr(body)) = funcs[def_idx]
      let (rewritten_body, body_changed) = dae_fold_const_i32_eq_if_instrs_once(
        body,
      )
      if body_changed {
        let next_func = @lib.Func::new(locals, @lib.Expr::new(rewritten_body))
        match rewritten_funcs {
          Some(copy) => copy[def_idx] = next_func
          None => {
            let copy = funcs.copy()
            copy[def_idx] = next_func
            rewritten_funcs = Some(copy)
          }
        }
        match touched {
          Some(flags) => flags[def_idx] = true
          None => {
            let flags = Array::make(funcs.length(), false)
            flags[def_idx] = true
            touched = Some(flags)
          }
        }
        if primary_def < 0 {
          primary_def = def_idx
        }
      }
    }
    def_idx += 1
  }
  match (rewritten_funcs, touched) {
    (Some(copy), Some(flags)) =>
      {
        mod_out: mod_.with_code_sec(@lib.CodeSec::new(copy)).without_name_sec(),
        touched: flags,
        changed: true,
        primary_def,
      }
    _ => { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
}

///|
fn dae_collect_fact_dropped_result_candidate_defs(
  mod_ : @lib.Module,
  call_facts : DaeCurrentCallFacts,
) -> Array[Bool] {
  let imported = dae_imported_func_count(mod_)
  let defined = dae_defined_func_count(mod_)
  let selected = Array::make(defined, false)
  let boundary_facts = dae_call_boundary_facts_from_current(call_facts)
  let mut def_idx = 0
  while def_idx < defined {
    let callee_abs = imported + def_idx
    match
      dae_dropped_result_candidate_from_boundary_facts(
        boundary_facts, callee_abs,
      ) {
      Some(candidate) =>
        if candidate.owned &&
          candidate.all_direct_calls_dropped &&
          candidate.owned_dropped_result_candidate {
          selected[def_idx] = true
        }
      None => ()
    }
    def_idx += 1
  }
  selected
}

///|
fn dae_try_remove_dropped_result_def_with_facts(
  mod_ : @lib.Module,
  def_idx : Int,
  call_facts : DaeCurrentCallFacts,
  perf? : HotPerfSession? = None,
) -> DaePassResult {
  let imported = dae_imported_func_count(mod_)
  let defined = dae_defined_func_count(mod_)
  let callee_abs = imported + def_idx
  if def_idx < 0 ||
    def_idx >= defined ||
    callee_abs >= call_facts.direct_calls.length() {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let candidate = match
    dae_dropped_result_candidate_from_current_call_facts(call_facts, callee_abs) {
    Some(candidate) => candidate
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let result = dae_try_remove_dropped_results(
    mod_,
    candidate.callee_abs,
    candidate.direct_call_count,
    candidate.dropped_call_count,
    perf~,
    caller_defs=Some(candidate.direct_callers),
  )
  if result.changed {
    let touched = if result.touched.length() == defined {
      result.touched
    } else {
      let fallback = Array::make(defined, false)
      if def_idx < fallback.length() {
        fallback[def_idx] = true
      }
      fallback
    }
    return {
      mod_out: result.mod_out,
      touched,
      changed: true,
      primary_def: result.primary_def,
    }
  }
  { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
}

///|
fn dae_try_remove_selected_defs_dropped_results_with_facts_once(
  mod_ : @lib.Module,
  selected_defs : Array[Bool],
  call_facts : DaeCurrentCallFacts,
  perf? : HotPerfSession? = None,
) -> DaePassResult {
  let helper_start_us = perf_start_timer_opt(
    perf, "detail:dae:core:selected-lanes:dropped-results:selected-defs:helper",
  )
  let defined = dae_defined_func_count(mod_)
  let mut def_idx = 0
  while def_idx < defined && def_idx < selected_defs.length() {
    if selected_defs[def_idx] {
      let result = dae_try_remove_dropped_result_def_with_facts(
        mod_,
        def_idx,
        call_facts,
        perf~,
      )
      if result.changed {
        perf_stop_timer_opt(
          perf, "detail:dae:core:selected-lanes:dropped-results:selected-defs:helper",
          helper_start_us,
        )
        return result
      }
    }
    def_idx += 1
  }
  perf_stop_timer_opt(
    perf, "detail:dae:core:selected-lanes:dropped-results:selected-defs:helper",
    helper_start_us,
  )
  { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
}

///|
fn dae_collect_descending_selected_def_candidates(
  selected_defs : Array[Bool],
  defined : Int,
) -> Array[Int] {
  dae_collect_descending_selected_def_attempts(selected_defs, defined, -1)
}

///|
fn dae_collect_descending_selected_def_attempts(
  selected_defs : Array[Bool],
  defined : Int,
  attempt_limit : Int,
) -> Array[Int] {
  let candidates : Array[Int] = []
  let limit = if defined < selected_defs.length() {
    defined
  } else {
    selected_defs.length()
  }
  let mut def_idx = limit - 1
  while def_idx >= 0 &&
        (attempt_limit < 0 || candidates.length() < attempt_limit) {
    if selected_defs[def_idx] {
      candidates.push(def_idx)
    }
    def_idx -= 1
  }
  candidates
}

///|
fn dae_selected_dropped_result_fallback_neighborhood_defs() -> Array[Int] {
  []
}

///|
fn dae_push_unique_candidate(candidates : Array[Int], def_idx : Int) -> Unit {
  if !candidates.contains(def_idx) {
    candidates.push(def_idx)
  }
}

///|
fn dae_collect_bucketed_large_dropped_result_attempts(
  selected_defs : Array[Bool],
  defined : Int,
  attempt_limit : Int,
) -> Array[Int] {
  let candidates : Array[Int] = []
  let high_quota = 4
  let fallback_quota = 4
  let low_quota = 2
  let mut high_seen = 0
  for
    def_idx in dae_collect_descending_selected_def_candidates(
      selected_defs, defined,
    ) {
    if high_seen < high_quota && candidates.length() < attempt_limit {
      dae_push_unique_candidate(candidates, def_idx)
      high_seen += 1
    }
  }
  let mut fallback_seen = 0
  for def_idx in dae_selected_dropped_result_fallback_neighborhood_defs() {
    if fallback_seen < fallback_quota &&
      candidates.length() < attempt_limit &&
      def_idx >= 0 &&
      def_idx < defined &&
      def_idx < selected_defs.length() &&
      selected_defs[def_idx] {
      dae_push_unique_candidate(candidates, def_idx)
      fallback_seen += 1
    }
  }
  let limit = if defined < selected_defs.length() {
    defined
  } else {
    selected_defs.length()
  }
  let mut low_seen = 0
  let mut def_idx = 0
  while def_idx < limit &&
        low_seen < low_quota &&
        candidates.length() < attempt_limit {
    if selected_defs[def_idx] {
      let before = candidates.length()
      dae_push_unique_candidate(candidates, def_idx)
      if candidates.length() > before {
        low_seen += 1
      }
    }
    def_idx += 1
  }
  candidates
}

///|
fn dae_run_dropped_result_candidate_worklist_with_facts(
  current : @lib.Module,
  touched : Array[Bool],
  changed : Bool,
  candidate_defs : Array[Int],
) -> DaeExactLiteralWorklistApplication {
  let original = dae_collect_original_boundary_snapshot(current)
  let graph = dae_current_boundary_graph_new(current)
  let mut dependencies = dae_boundary_dependency_graph_new(graph)
  let diagnostics = dae_diagnostics_new()
  let productive_defs : Array[Int] = []
  let mut mod_out = current
  let mut touched_out = touched
  let mut changed_out = changed
  for candidate_def in candidate_defs {
    let item = dae_work_item_new(
      graph,
      dependencies,
      candidate_def,
      DaeDroppedResultWork,
    )
    match
      dae_process_work_item(
        original, mod_out, touched_out, changed_out, graph, dependencies, item, diagnostics,
      ) {
      DaeWorkCommitted(application) => {
        mod_out = application.mod_out
        touched_out = application.touched
        changed_out = application.changed
        productive_defs.push(application.primary_def)
        dae_current_boundary_graph_refresh(graph, mod_out)
        dependencies = dae_boundary_dependency_graph_new(graph)
      }
      _ => ()
    }
  }
  { mod_out, touched: touched_out, changed: changed_out, productive_defs }
}

///|
fn dae_run_post_cleanup_boundary_revisit_worklist(
  current : @lib.Module,
  touched : Array[Bool],
) -> DaePassResult {
  let defined = dae_defined_func_count(current)
  if touched.length() != defined {
    return { mod_out: current, touched, changed: false, primary_def: -1 }
  }
  let original = dae_collect_original_boundary_snapshot(current)
  let graph = dae_current_boundary_graph_new(current)
  let mut dependencies = dae_boundary_dependency_graph_new(graph)
  let diagnostics = dae_diagnostics_new()
  let mut mod_out = current
  let mut touched_out = touched
  let mut changed = false
  let mut primary_def = -1
  let mut def_idx = 0
  while def_idx < defined {
    if touched[def_idx] {
      let item = dae_work_item_new(
        graph,
        dependencies,
        def_idx,
        DaePostCleanupBoundaryRevisitWork,
      )
      match
        dae_process_work_item(
          original, mod_out, touched_out, changed, graph, dependencies, item, diagnostics,
        ) {
        DaeWorkCommitted(application) => {
          mod_out = application.mod_out
          touched_out = application.touched
          changed = application.changed
          if primary_def < 0 {
            primary_def = application.primary_def
          }
          dae_current_boundary_graph_refresh(graph, mod_out)
          dependencies = dae_boundary_dependency_graph_new(graph)
        }
        _ => ()
      }
    }
    def_idx += 1
  }
  if !changed {
    return { mod_out: current, touched: [], changed: false, primary_def: -1 }
  }
  { mod_out, touched: touched_out, changed, primary_def }
}

///|
fn dae_dropped_result_payoff_instrs(instrs : Array[@lib.Instruction]) -> Int {
  let mut payoff = 0
  for instr in instrs {
    match instr {
      @lib.LocalSet(_) | @lib.LocalTee(_) => payoff += 4
      @lib.LocalGet(_) => payoff += 1
      @lib.Block(_, @lib.Expr(body))
      | @lib.Loop(_, @lib.Expr(body))
      | @lib.TryTable(_, _, @lib.Expr(body)) =>
        payoff += dae_dropped_result_payoff_instrs(body)
      @lib.If(_, then_body, else_body) => {
        payoff += dae_dropped_result_payoff_instrs(then_body)
        match else_body {
          Some(body) => payoff += dae_dropped_result_payoff_instrs(body)
          None => ()
        }
      }
      _ => ()
    }
  }
  payoff
}

///|
fn dae_terminal_direct_callee_def(
  func : @lib.Func,
  imported : Int,
  defined : Int,
) -> Int? {
  let @lib.Func(_, @lib.Expr(body)) = func
  if body.length() == 0 {
    return None
  }
  match body[body.length() - 1] {
    @lib.Call(func_idx) => {
      let callee_def = dae_func_idx_slot(func_idx) - imported
      if callee_def >= 0 && callee_def < defined {
        Some(callee_def)
      } else {
        None
      }
    }
    _ => None
  }
}

///|
fn dae_func_result_count(
  mod_ : @lib.Module,
  type_indices : Array[@lib.TypeIdx],
  func_abs : Int,
) -> Int {
  match dae_resolve_func_type(mod_, type_indices, func_abs) {
    Some(@lib.FuncType(_, results)) => results.length()
    None => 0
  }
}

///|
fn dae_collect_dropped_result_payoff_chain_candidates(
  mod_ : @lib.Module,
  call_facts : DaeCurrentCallFacts,
) -> Array[DaeDroppedResultPayoffChainCandidate] {
  let candidates : Array[DaeDroppedResultPayoffChainCandidate] = []
  let imported = dae_imported_func_count(mod_)
  let defined = dae_defined_func_count(mod_)
  if defined <= 8192 {
    return candidates
  }
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None => return candidates
  }
  let type_indices = dae_collect_func_type_indices(mod_)
  let boundary_facts = dae_call_boundary_facts_from_current(call_facts)
  for wrapper_def = 0
      wrapper_def < funcs.length()
      wrapper_def = wrapper_def + 1 {
    let wrapper_abs = imported + wrapper_def
    let wrapper_candidate = match
      dae_dropped_result_candidate_from_boundary_facts(
        boundary_facts, wrapper_abs,
      ) {
      Some(candidate) => candidate
      None => continue
    }
    if !wrapper_candidate.owned_dropped_result_candidate ||
      dae_func_result_count(mod_, type_indices, wrapper_abs) != 1 {
      continue
    }
    let callee_def = match
      dae_terminal_direct_callee_def(funcs[wrapper_def], imported, defined) {
      Some(def_idx) if def_idx != wrapper_def => def_idx
      _ => continue
    }
    let callee_abs = imported + callee_def
    if dae_func_result_count(mod_, type_indices, callee_abs) != 1 {
      continue
    }
    let @lib.Func(locals, @lib.Expr(callee_body)) = funcs[callee_def]
    let payoff = dae_dropped_result_payoff_instrs(callee_body)
    if locals.length() >= 128 && payoff >= 128 {
      candidates.push({ wrapper_def, callee_def, payoff })
    }
  }
  candidates
}

///|
fn dae_run_broad_dropped_result_payoff_chain(
  current : @lib.Module,
  touched : Array[Bool],
  changed : Bool,
  perf? : HotPerfSession? = None,
) -> DaeExactLiteralWorklistApplication {
  let imported = dae_imported_func_count(current)
  let defined = dae_defined_func_count(current)
  if defined <= 8192 {
    return { mod_out: current, touched, changed, productive_defs: [] }
  }
  let total = imported + defined
  let mut current_mod = current
  let mut current_touched = touched
  let productive_defs : Array[Int] = []
  let mut iteration = 0
  while iteration < 2 {
    let call_facts = dae_collect_current_call_facts(current_mod, total)
    let candidates = dae_collect_dropped_result_payoff_chain_candidates(
      current_mod, call_facts,
    )
    let mut applied = false
    while candidates.length() > 0 && !applied {
      let mut best_idx = 0
      for idx = 1; idx < candidates.length(); idx = idx + 1 {
        if candidates[idx].payoff > candidates[best_idx].payoff {
          best_idx = idx
        }
      }
      let candidate = candidates[best_idx]
      ignore(candidates.remove(best_idx))
      let wrapper_result = dae_try_remove_dropped_result_def_with_facts(
        current_mod,
        candidate.wrapper_def,
        call_facts,
        perf~,
      )
      if !wrapper_result.changed {
        continue
      }
      let next_facts = dae_collect_current_call_facts(
        wrapper_result.mod_out,
        total,
      )
      let callee_result = dae_try_remove_dropped_result_def_with_facts(
        wrapper_result.mod_out,
        candidate.callee_def,
        next_facts,
        perf~,
      )
      if !callee_result.changed {
        continue
      }
      current_mod = callee_result.mod_out
      current_touched = dae_merge_touched(
        dae_merge_touched(current_touched, wrapper_result.touched),
        callee_result.touched,
      )
      productive_defs.push(candidate.wrapper_def)
      productive_defs.push(candidate.callee_def)
      applied = true
    }
    if !applied {
      break
    }
    iteration += 1
  }
  {
    mod_out: current_mod,
    touched: current_touched,
    changed: changed || productive_defs.length() > 0,
    productive_defs,
  }
}

///|
fn dae_collect_dropped_result_payoff_cleanup_candidates(
  original : @lib.Module,
  current : @lib.Module,
) -> Array[DaeDroppedResultPayoffChainCandidate] {
  let candidates : Array[DaeDroppedResultPayoffChainCandidate] = []
  let imported = dae_imported_func_count(original)
  let defined = dae_defined_func_count(original)
  if defined <= 8192 || dae_defined_func_count(current) != defined {
    return candidates
  }
  let original_funcs = match original.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None => return candidates
  }
  let original_types = dae_collect_func_type_indices(original)
  let current_types = dae_collect_func_type_indices(current)
  let original_call_facts = dae_collect_current_call_facts(
    original,
    imported + defined,
  )
  let original_boundary_facts = dae_call_boundary_facts_from_current(
    original_call_facts,
  )
  for wrapper_def = 0
      wrapper_def < original_funcs.length()
      wrapper_def = wrapper_def + 1 {
    let callee_def = match
      dae_terminal_direct_callee_def(
        original_funcs[wrapper_def],
        imported,
        defined,
      ) {
      Some(def_idx) if def_idx != wrapper_def => def_idx
      _ => continue
    }
    let wrapper_abs = imported + wrapper_def
    let wrapper_candidate = match
      dae_dropped_result_candidate_from_boundary_facts(
        original_boundary_facts, wrapper_abs,
      ) {
      Some(candidate) if candidate.owned_dropped_result_candidate => candidate
      _ => continue
    }
    if wrapper_candidate.direct_call_count == 0 ||
      dae_func_result_count(original, original_types, wrapper_abs) != 1 ||
      dae_func_result_count(original, original_types, imported + callee_def) !=
      1 ||
      dae_func_result_count(current, current_types, imported + wrapper_def) != 0 ||
      dae_func_result_count(current, current_types, imported + callee_def) != 0 {
      continue
    }
    let @lib.Func(locals, @lib.Expr(body)) = original_funcs[callee_def]
    let candidate = {
      wrapper_def,
      callee_def,
      payoff: dae_dropped_result_payoff_instrs(body),
    }
    if locals.length() >= 128 && candidate.payoff >= 128 {
      candidates.push(candidate)
    }
  }
  let selected : Array[DaeDroppedResultPayoffChainCandidate] = []
  while candidates.length() > 0 && selected.length() < 2 {
    let mut best_idx = 0
    for idx = 1; idx < candidates.length(); idx = idx + 1 {
      if candidates[idx].payoff > candidates[best_idx].payoff {
        best_idx = idx
      }
    }
    selected.push(candidates[best_idx])
    ignore(candidates.remove(best_idx))
  }
  selected
}

///|
fn dae_collect_uniform_immediate_i32_suffix_instrs(
  instrs : Array[@lib.Instruction],
  callee_abs : Int,
  expected : Array[@lib.I32?],
  call_count : Array[Int],
) -> Bool {
  let mut idx = 0
  while idx < instrs.length() {
    match instrs[idx] {
      @lib.Call(func_idx) if dae_func_idx_slot(func_idx) == callee_abs => {
        if idx == 0 {
          return false
        }
        let value = match instrs[idx - 1] {
          @lib.I32Const(value) => value
          _ => return false
        }
        match expected[0] {
          Some(current) if current != value => return false
          Some(_) => ()
          None => expected[0] = Some(value)
        }
        call_count[0] += 1
      }
      @lib.Block(_, @lib.Expr(body))
      | @lib.Loop(_, @lib.Expr(body))
      | @lib.TryTable(_, _, @lib.Expr(body)) =>
        if !dae_collect_uniform_immediate_i32_suffix_instrs(
            body, callee_abs, expected, call_count,
          ) {
          return false
        }
      @lib.If(_, then_body, else_body) => {
        if !dae_collect_uniform_immediate_i32_suffix_instrs(
            then_body, callee_abs, expected, call_count,
          ) {
          return false
        }
        match else_body {
          Some(body) =>
            if !dae_collect_uniform_immediate_i32_suffix_instrs(
                body, callee_abs, expected, call_count,
              ) {
              return false
            }
          None => ()
        }
      }
      _ => ()
    }
    idx += 1
  }
  true
}

///|
fn dae_collect_uniform_immediate_i32_suffix_from_callers(
  funcs : Array[@lib.Func],
  caller_defs : Array[Int],
  callee_abs : Int,
  expected_call_count : Int,
) -> @lib.Instruction? {
  let expected : Array[@lib.I32?] = [None]
  let call_count = [0]
  for caller_def in caller_defs {
    if caller_def < 0 || caller_def >= funcs.length() {
      return None
    }
    let @lib.Func(_, @lib.Expr(body)) = funcs[caller_def]
    if !dae_collect_uniform_immediate_i32_suffix_instrs(
        body, callee_abs, expected, call_count,
      ) {
      return None
    }
  }
  if call_count[0] != expected_call_count {
    return None
  }
  match expected[0] {
    Some(value) => Some(@lib.Instruction::i32_const(value))
    None => None
  }
}

///|
fn dae_direct_calls_need_stack_carried_void_effects_instrs(
  instrs : Array[@lib.Instruction],
  callee_abs : Int,
  param_count : Int,
  entry_stack_values : Int,
  mod_ : @lib.Module,
  type_indices : Array[@lib.TypeIdx],
  failed : Array[Bool],
) -> Bool {
  let mut idx = 0
  while idx < instrs.length() {
    match
      dae_target_callsite_evidence(
        instrs[idx],
        callee_abs,
        DaeTargetDirectCallOnly,
      ) {
      Some(_) =>
        if dae_callsite_value_slice_evidence(
            instrs, idx, param_count, entry_stack_values, mod_, type_indices,
          )
          is None {
          failed[0] = true
        }
      None =>
        match instrs[idx] {
          @lib.Block(_, _)
          | @lib.Loop(_, _)
          | @lib.TryTable(_, _, _)
          | @lib.If(_, _, _) => {
            let children = match
              dae_nested_control_children_evidence(instrs[idx], mod_) {
              Some(children) => children
              None => return false
            }
            if !dae_direct_calls_need_stack_carried_void_effects_instrs(
                children.primary_body,
                callee_abs,
                param_count,
                children.entry_stack_values,
                mod_,
                type_indices,
                failed,
              ) {
              return false
            }
            match children.secondary_body {
              Some(body) =>
                if !dae_direct_calls_need_stack_carried_void_effects_instrs(
                    body,
                    callee_abs,
                    param_count,
                    children.entry_stack_values,
                    mod_,
                    type_indices,
                    failed,
                  ) {
                  return false
                }
              None => ()
            }
          }
          _ => ()
        }
    }
    idx += 1
  }
  true
}

///|
fn dae_direct_calls_need_stack_carried_void_effects(
  funcs : Array[@lib.Func],
  caller_defs : Array[Int],
  callee_abs : Int,
  param_count : Int,
  mod_ : @lib.Module,
  type_indices : Array[@lib.TypeIdx],
) -> Bool {
  let failed = [false]
  for caller_def in caller_defs {
    if caller_def < 0 || caller_def >= funcs.length() {
      return false
    }
    let @lib.Func(_, @lib.Expr(body)) = funcs[caller_def]
    if !dae_direct_calls_need_stack_carried_void_effects_instrs(
        body, callee_abs, param_count, 0, mod_, type_indices, failed,
      ) {
      return false
    }
  }
  failed[0]
}

///|
fn dae_exact_literal_def_has_immediate_i32_suffix_priority(
  mod_ : @lib.Module,
  def_idx : Int,
  call_facts : DaeCurrentCallFacts,
) -> Bool {
  let imported = dae_imported_func_count(mod_)
  let boundary_facts = dae_call_boundary_facts_from_current(call_facts)
  let type_indices = dae_collect_func_type_indices(mod_)
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None => return false
  }
  if def_idx < 0 || def_idx >= funcs.length() {
    return false
  }
  let callee_abs = imported + def_idx
  let boundary_candidate = match
    dae_call_boundary_candidate(boundary_facts, callee_abs, def_idx~) {
    Some(candidate) => candidate
    None => return false
  }
  if !boundary_candidate.owned ||
    boundary_candidate.has_self_direct_caller ||
    !boundary_candidate.allows_nonself_direct_rewrite {
    return false
  }
  let @lib.FuncType(params, _) = match
    dae_resolve_func_type(mod_, type_indices, callee_abs) {
    Some(func_type) => func_type
    None => return false
  }
  if params.length() == 0 || params[params.length() - 1] != @lib.ValType::i32() {
    return false
  }
  let @lib.Func(locals, _) = funcs[def_idx]
  let local_use = dae_local_use_for_callee(
    funcs[def_idx],
    params.length() + locals.length(),
    callee_abs,
    params.length(),
  )
  let mut has_dead_param = false
  let mut p = 0
  while p < params.length() {
    if !local_use.gets[p] {
      has_dead_param = true
    }
    p += 1
  }
  let final_param = params.length() - 1
  if has_dead_param ||
    !local_use.gets[final_param] ||
    local_use.writes[final_param] {
    return false
  }
  dae_collect_uniform_immediate_i32_suffix_from_callers(
    funcs,
    boundary_candidate.direct_callers,
    callee_abs,
    boundary_candidate.direct_call_count,
  ).is_some() &&
  dae_direct_calls_need_stack_carried_void_effects(
    funcs,
    boundary_candidate.direct_callers,
    callee_abs,
    params.length(),
    mod_,
    type_indices,
  )
}

///|
fn dae_try_rewrite_exact_literal_def_with_facts_once(
  mod_ : @lib.Module,
  def_idx : Int,
  call_facts : DaeCurrentCallFacts,
  allow_immutable_global_get? : Bool = false,
  allow_immediate_i32_suffix_fallback? : Bool = false,
) -> DaePassResult {
  let imported = dae_imported_func_count(mod_)
  let boundary_facts = dae_call_boundary_facts_from_current(call_facts)
  let type_indices = dae_collect_func_type_indices(mod_)
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  if def_idx < 0 || def_idx >= funcs.length() {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let callee_abs = imported + def_idx
  let boundary_candidate = match
    dae_call_boundary_candidate(boundary_facts, callee_abs, def_idx~) {
    Some(candidate) => candidate
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  if !boundary_candidate.owned ||
    boundary_candidate.has_self_direct_caller ||
    !boundary_candidate.allows_nonself_direct_rewrite {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let func_type = match dae_resolve_func_type(mod_, type_indices, callee_abs) {
    Some(ft) => ft
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let @lib.FuncType(params, _) = func_type
  if params.length() == 0 {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let @lib.Func(locals, _) = funcs[def_idx]
  let local_use = dae_local_use_for_callee(
    funcs[def_idx],
    params.length() + locals.length(),
    callee_abs,
    params.length(),
  )
  let uniform_const_params = dae_collect_uniform_const_actuals_from_boundary_facts(
    mod_,
    callee_abs,
    params.length(),
    type_indices,
    boundary_facts,
    allow_immutable_global_get~,
  )
  let remove = Array::make(params.length(), false)
  let const_params : Array[@lib.Instruction?] = Array::make(
    params.length(),
    None,
  )
  let mut any_const = false
  let mut has_dead_param = false
  let mut p = 0
  while p < params.length() {
    if !local_use.gets[p] {
      has_dead_param = true
    } else if !local_use.writes[p] {
      match uniform_const_params {
        Some(values) =>
          match values[p] {
            Some(value) => {
              remove[p] = true
              const_params[p] = Some(value)
              any_const = true
            }
            None => ()
          }
        None => ()
      }
    }
    p += 1
  }
  if has_dead_param {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  if any_const {
    return dae_try_rewrite_candidate(
      mod_,
      callee_abs,
      remove,
      const_params,
      local_use,
      boundary_candidate.direct_call_count,
      boundary_candidate.direct_callers,
    )
  }
  if !allow_immediate_i32_suffix_fallback {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  // A void effect can sit between older stack-carried arguments and a direct
  // call, making complete value-slice reconstruction intentionally fail even
  // when the final literal is the immediate call suffix. Prove only that i32
  // suffix across the already-owned caller set, then use the existing suffix
  // transaction to reverify every call, preserve all preceding effects, update
  // the signature and callee body, and reject any count or validation drift.
  let final_param = params.length() - 1
  if params[final_param] != @lib.ValType::i32() ||
    !local_use.gets[final_param] ||
    local_use.writes[final_param] {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let expected = match
    dae_collect_uniform_immediate_i32_suffix_from_callers(
      funcs,
      boundary_candidate.direct_callers,
      callee_abs,
      boundary_candidate.direct_call_count,
    ) {
    Some(expected) => expected
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  dae_try_rewrite_verified_materialized_const_suffix_candidate(
    mod_,
    callee_abs,
    params,
    [expected],
    local_use,
    boundary_candidate.direct_call_count,
    boundary_candidate.direct_callers,
  )
}

///|
fn dae_try_rewrite_uniform_values_def_with_facts_once(
  mod_ : @lib.Module,
  def_idx : Int,
  call_facts : DaeCurrentCallFacts,
  uniform_values : Array[@lib.Instruction?],
) -> DaePassResult {
  let imported = dae_imported_func_count(mod_)
  let type_indices = dae_collect_func_type_indices(mod_)
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  if def_idx < 0 || def_idx >= funcs.length() {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let callee_abs = imported + def_idx
  let boundary_facts = dae_call_boundary_facts_from_current(call_facts)
  let boundary_candidate = match
    dae_call_boundary_candidate(boundary_facts, callee_abs, def_idx~) {
    Some(candidate) => candidate
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  if !boundary_candidate.owned ||
    boundary_candidate.has_self_direct_caller ||
    !boundary_candidate.allows_nonself_direct_rewrite {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let params = match dae_resolve_func_type(mod_, type_indices, callee_abs) {
    Some(@lib.FuncType(params, _)) => params
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  if uniform_values.length() != params.length() {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let @lib.Func(locals, _) = funcs[def_idx]
  let local_use = dae_local_use_for_callee(
    funcs[def_idx],
    params.length() + locals.length(),
    callee_abs,
    params.length(),
  )
  let remove = Array::make(params.length(), false)
  let const_params : Array[@lib.Instruction?] = Array::make(
    params.length(),
    None,
  )
  let mut any = false
  let mut param_idx = 0
  while param_idx < params.length() {
    match uniform_values[param_idx] {
      Some(value) if local_use.gets[param_idx] &&
        !local_use.writes[param_idx] &&
        dae_instr_is_materializable_const(value) => {
        remove[param_idx] = true
        const_params[param_idx] = Some(value)
        any = true
      }
      _ => ()
    }
    param_idx += 1
  }
  if !any {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  dae_try_rewrite_candidate(
    mod_,
    callee_abs,
    remove,
    const_params,
    local_use,
    boundary_candidate.direct_call_count,
    boundary_candidate.direct_callers,
  )
}

///|
fn dae_collect_exact_literal_candidate_defs_with_facts(
  mod_ : @lib.Module,
  call_facts : DaeCurrentCallFacts,
  max_def_exclusive : Int,
  allow_immutable_global_get? : Bool = false,
  min_param_count? : Int = 1,
  require_all_nullable_refs? : Bool = false,
) -> Array[Int] {
  let candidates : Array[Int] = []
  let imported = dae_imported_func_count(mod_)
  let boundary_facts = dae_call_boundary_facts_from_current(call_facts)
  let type_indices = dae_collect_func_type_indices(mod_)
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None => return candidates
  }
  let limit = if max_def_exclusive >= 0 && max_def_exclusive < funcs.length() {
    max_def_exclusive
  } else {
    funcs.length()
  }
  let mut def_idx = 0
  while def_idx < limit {
    let callee_abs = imported + def_idx
    let boundary_candidate = match
      dae_call_boundary_candidate(boundary_facts, callee_abs, def_idx~) {
      Some(candidate) => candidate
      None => {
        def_idx += 1
        continue
      }
    }
    if !boundary_candidate.owned ||
      boundary_candidate.has_self_direct_caller ||
      !boundary_candidate.allows_nonself_direct_rewrite {
      def_idx += 1
      continue
    }
    let func_type = match
      dae_resolve_func_type(mod_, type_indices, callee_abs) {
      Some(ft) => ft
      None => {
        def_idx += 1
        continue
      }
    }
    let @lib.FuncType(params, _) = func_type
    if params.length() < min_param_count {
      def_idx += 1
      continue
    }
    if require_all_nullable_refs {
      let mut all_nullable_refs = true
      for param in params {
        match param {
          @lib.RefTypeValType(@lib.HeapTypeRefType(true, _, _)) => ()
          _ => all_nullable_refs = false
        }
      }
      if !all_nullable_refs {
        def_idx += 1
        continue
      }
    }
    let @lib.Func(locals, _) = funcs[def_idx]
    let local_use = dae_local_use_for_callee(
      funcs[def_idx],
      params.length() + locals.length(),
      callee_abs,
      params.length(),
    )
    let uniform_const_params = dae_collect_uniform_const_actuals_from_boundary_facts(
      mod_,
      callee_abs,
      params.length(),
      type_indices,
      boundary_facts,
      allow_immutable_global_get~,
    )
    let mut any_const = false
    let mut has_dead_param = false
    let mut p = 0
    while p < params.length() {
      if !local_use.gets[p] {
        has_dead_param = true
      } else if !local_use.writes[p] {
        match uniform_const_params {
          Some(values) =>
            match values[p] {
              Some(_) => any_const = true
              None => ()
            }
          None => ()
        }
      }
      p += 1
    }
    if any_const && !has_dead_param {
      candidates.push(def_idx)
    }
    def_idx += 1
  }
  candidates
}

///|
fn dae_exact_literal_candidate_is_single_param_identity(
  mod_ : @lib.Module,
  def_idx : Int,
) -> Bool {
  let imported = dae_imported_func_count(mod_)
  let type_indices = dae_collect_func_type_indices(mod_)
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None => return false
  }
  if def_idx < 0 || def_idx >= funcs.length() {
    return false
  }
  match dae_resolve_func_type(mod_, type_indices, imported + def_idx) {
    Some(@lib.FuncType([param], [result])) if param == result => {
      let @lib.Func(locals, @lib.Expr(body)) = funcs[def_idx]
      locals.length() == 0 &&
      body == [@lib.Instruction::local_get(@lib.LocalIdx::new(0U))]
    }
    _ => false
  }
}

///|
fn dae_exact_literal_candidate_has_scalar_constructor_shape(
  mod_ : @lib.Module,
  def_idx : Int,
) -> Bool {
  let imported = dae_imported_func_count(mod_)
  let type_indices = dae_collect_func_type_indices(mod_)
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None => return false
  }
  if def_idx < 0 || def_idx >= funcs.length() {
    return false
  }
  let callee_abs = imported + def_idx
  let params = match dae_resolve_func_type(mod_, type_indices, callee_abs) {
    Some(@lib.FuncType(params, _)) => params
    None => return false
  }
  if params.length() < 2 ||
    !params.all(fn(param) {
      param == @lib.ValType::i32() ||
      param == @lib.ValType::i64() ||
      param == @lib.ValType::f32() ||
      param == @lib.ValType::f64() ||
      param == @lib.ValType::v128()
    }) {
    return false
  }
  let @lib.Func(locals, @lib.Expr(body)) = funcs[def_idx]
  if locals.length() != 1 || body.length() < 6 {
    return false
  }
  let constructor_local = @lib.LocalIdx::new(
    params.length().reinterpret_as_uint(),
  )
  match (body[0], body[1], body[2], body[body.length() - 1]) {
    (
      @lib.I32Const(_),
      @lib.Call(_),
      @lib.LocalTee(allocated_local),
      @lib.LocalGet(returned_local),
    ) if dae_local_idx_equal(allocated_local, constructor_local) &&
      dae_local_idx_equal(returned_local, constructor_local) => ()
    _ => return false
  }
  let mut store_count = 0
  for instr in body {
    match instr {
      @lib.I32Store(_)
      | @lib.I64Store(_)
      | @lib.F32Store(_)
      | @lib.F64Store(_)
      | @lib.I32Store8(_)
      | @lib.I32Store16(_)
      | @lib.I64Store8(_)
      | @lib.I64Store16(_)
      | @lib.I64Store32(_) => store_count += 1
      _ => ()
    }
  }
  if store_count < params.length() {
    return false
  }
  let local_use = dae_local_use_for_callee(
    funcs[def_idx],
    params.length() + locals.length(),
    callee_abs,
    params.length(),
  )
  let mut param_idx = 0
  while param_idx < params.length() {
    let usage = dae_local_usage_evidence(
      body,
      @lib.LocalIdx::new(param_idx.reinterpret_as_uint()),
    )
    if !local_use.gets[param_idx] ||
      local_use.writes[param_idx] ||
      usage.get_count != 1 ||
      usage.write_count != 0 {
      return false
    }
    param_idx += 1
  }
  true
}

///|
fn dae_run_exact_literal_candidate_worklist_with_facts(
  current : @lib.Module,
  touched : Array[Bool],
  changed : Bool,
  candidate_defs : Array[Int],
  call_facts : DaeCurrentCallFacts,
  productive_limit : Int,
  allow_immutable_global_get? : Bool = false,
) -> DaeExactLiteralWorklistApplication {
  let mut mod_out = current
  let mut touched_out = touched
  let mut changed_out = changed
  let productive_defs : Array[Int] = []
  ignore(call_facts.direct_calls.length())
  let original = dae_collect_original_boundary_snapshot(current)
  let graph = dae_current_boundary_graph_new(current)
  let mut dependencies = dae_boundary_dependency_graph_new(graph)
  let mut flow = if allow_immutable_global_get {
    { facts: [] }
  } else {
    dae_solve_parameter_flow(graph, dependencies, seed_defs=candidate_defs)
  }
  let diagnostics = dae_diagnostics_new()
  for candidate_def in candidate_defs {
    if productive_limit >= 0 && productive_defs.length() >= productive_limit {
      break
    }
    let item = {
      ..dae_work_item_new(
        graph,
        dependencies,
        candidate_def,
        DaeUniformActualWork,
      ),
      uniform_values: dae_parameter_flow_uniform_values_for_def(
        graph, flow, candidate_def,
      ),
      allow_immutable_global_get,
    }
    match
      dae_process_work_item(
        original, mod_out, touched_out, changed_out, graph, dependencies, item, diagnostics,
      ) {
      DaeWorkCommitted(application) => {
        mod_out = application.mod_out
        touched_out = application.touched
        changed_out = application.changed
        productive_defs.push(application.primary_def)
        dae_current_boundary_graph_refresh(graph, mod_out)
        dependencies = dae_boundary_dependency_graph_new(graph)
        if !allow_immutable_global_get {
          flow = dae_solve_parameter_flow(
            graph,
            dependencies,
            seed_defs=candidate_defs,
          )
        }
      }
      _ => ()
    }
  }
  { mod_out, touched: touched_out, changed: changed_out, productive_defs }
}

///|
fn dae_exact_param_aggregate_constructor_count_instrs(
  instrs : Array[@lib.Instruction],
) -> Int {
  let mut count = 0
  for instr in instrs {
    match instr {
      @lib.StructNew(_)
      | @lib.StructNewDefault(_)
      | @lib.ArrayNew(_)
      | @lib.ArrayNewDefault(_)
      | @lib.ArrayNewFixed(_, _)
      | @lib.ArrayNewData(_, _)
      | @lib.ArrayNewElem(_, _) => count += 1
      @lib.Block(_, @lib.Expr(body))
      | @lib.Loop(_, @lib.Expr(body))
      | @lib.TryTable(_, _, @lib.Expr(body)) =>
        count += dae_exact_param_aggregate_constructor_count_instrs(body)
      @lib.If(_, then_body, else_body) => {
        count += dae_exact_param_aggregate_constructor_count_instrs(then_body)
        match else_body {
          Some(body) =>
            count += dae_exact_param_aggregate_constructor_count_instrs(body)
          None => ()
        }
      }
      _ => ()
    }
  }
  count
}

///|
fn dae_exact_param_aggregate_constructor_count(
  mod_ : @lib.Module,
  def_idx : Int,
) -> Int {
  match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) if def_idx >= 0 && def_idx < funcs.length() => {
      let @lib.Func(_, @lib.Expr(body)) = funcs[def_idx]
      dae_exact_param_aggregate_constructor_count_instrs(body)
    }
    _ => 0
  }
}

///|
fn dae_func_directly_calls_def(
  func : @lib.Func,
  callee_def : Int,
  imported : Int,
  defined : Int,
) -> Bool {
  let @lib.Func(_, @lib.Expr(body)) = func
  let callees : Array[Int] = []
  dae_collect_direct_call_targets_anywhere(body, imported, defined, callees)
  callees.contains(callee_def)
}

///|
fn dae_collect_broad_exact_param_adjacent_cleanup_candidates(
  mod_ : @lib.Module,
) -> Array[DaeBroadExactParamAdjacentCleanupCandidate] {
  let candidates : Array[DaeBroadExactParamAdjacentCleanupCandidate] = []
  let imported = dae_imported_func_count(mod_)
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None => return candidates
  }
  let defined = funcs.length()
  let type_indices = dae_collect_func_type_indices(mod_)
  let first_limit = if defined < 8200 { defined - 1 } else { 8199 }
  let mut first_def = 4097
  while first_def < first_limit {
    let second_def = first_def + 1
    let @lib.Func(first_locals, @lib.Expr(first_body)) = funcs[first_def]
    let @lib.Func(second_locals, @lib.Expr(second_body)) = funcs[second_def]
    if first_locals.length() >= 128 &&
      second_locals.length() >= 128 &&
      dae_resolve_func_type(mod_, type_indices, imported + first_def) ==
      dae_resolve_func_type(mod_, type_indices, imported + second_def) &&
      dae_func_directly_calls_def(
        funcs[second_def],
        first_def,
        imported,
        defined,
      ) {
      let payoff = dae_dropped_result_payoff_instrs(first_body) +
        dae_dropped_result_payoff_instrs(second_body)
      let root_start = if first_def - 8 > 4096 { first_def - 8 } else { 4096 }
      let mut root_def = root_start
      while root_def < first_def && root_def < 8192 {
        candidates.push({ root_def, first_def, second_def, payoff })
        root_def += 1
      }
    }
    first_def += 1
  }
  candidates
}

///|
fn dae_forwarded_param_node_index(
  nodes : Array[DaeForwardedParamNode],
  callee_abs : Int,
  param_idx : Int,
) -> Int {
  let mut idx = 0
  while idx < nodes.length() {
    if nodes[idx].callee_abs == callee_abs && nodes[idx].param_idx == param_idx {
      return idx
    }
    idx += 1
  }
  -1
}

///|
fn dae_record_forwarded_param_scc_const(
  candidate : @lib.Instruction,
  constant : Array[@lib.Instruction?],
  flags : Array[Bool],
) -> Bool {
  if !dae_instr_is_materializable_const(candidate) {
    return false
  }
  match constant[0] {
    Some(existing) => dae_materialized_const_equal(existing, candidate)
    None => {
      constant[0] = Some(candidate)
      flags[2] = true
      true
    }
  }
}

///|
fn dae_forwarded_param_suffix_single_instruction_actual(
  instrs : Array[@lib.Instruction],
  call_idx : Int,
  param_count : Int,
  param_idx : Int,
  mod_ : @lib.Module,
  type_indices : Array[@lib.TypeIdx],
) -> @lib.Instruction? {
  let suffix_count = param_count - param_idx
  let start = call_idx - suffix_count
  if suffix_count <= 0 || start < 0 {
    return None
  }
  let mut idx = start
  while idx < call_idx {
    match dae_instr_stack_effect(instrs[idx], mod_, type_indices) {
      Some((0, 1)) => ()
      _ => return None
    }
    idx += 1
  }
  Some(instrs[start])
}

///|
fn dae_collect_forwarded_param_scc_actuals_instrs(
  instrs : Array[@lib.Instruction],
  entry_stack_values : Int,
  mod_ : @lib.Module,
  callee_abs : Int,
  param_count : Int,
  param_idx : Int,
  caller_abs : Int,
  caller_param_count : Int,
  type_indices : Array[@lib.TypeIdx],
  boundary_facts : DaeCallBoundaryFacts,
  nodes : Array[DaeForwardedParamNode],
  states : Array[Int],
  cycle_nodes : Array[DaeForwardedParamNode],
  constant : Array[@lib.Instruction?],
  flags : Array[Bool],
  seen_calls : Array[Int],
) -> Bool {
  let mut idx = 0
  while idx < instrs.length() {
    match
      dae_target_callsite_evidence(
        instrs[idx],
        callee_abs,
        DaeTargetDirectCallOnly,
      ) {
      Some(_) => {
        let actual = match
          dae_callsite_value_slice_evidence(
            instrs, idx, param_count, entry_stack_values, mod_, type_indices,
          ) {
          Some(evidence) =>
            match
              dae_callsite_single_instruction_actual(
                evidence, param_idx, instrs,
              ) {
              Some(actual) => Some(actual.instr)
              None => None
            }
          None => None
        }
        let actual = match actual {
          Some(actual) => actual
          None =>
            match
              dae_forwarded_param_suffix_single_instruction_actual(
                instrs, idx, param_count, param_idx, mod_, type_indices,
              ) {
              Some(actual) => actual
              None => return false
            }
        }
        seen_calls[0] += 1
        if dae_instr_is_materializable_const(actual) {
          if !dae_record_forwarded_param_scc_const(actual, constant, flags) {
            return false
          }
        } else {
          match actual {
            @lib.LocalGet(local_idx) => {
              let local_slot = dae_local_idx_slot(local_idx)
              if local_slot < 0 ||
                local_slot >= caller_param_count ||
                !dae_collect_forwarded_param_scc_node(
                  mod_, caller_abs, local_slot, type_indices, boundary_facts, nodes,
                  states, cycle_nodes, constant, flags,
                ) {
                return false
              }
            }
            _ => return false
          }
        }
      }
      None =>
        match instrs[idx] {
          @lib.Block(_, @lib.Expr(_))
          | @lib.Loop(_, @lib.Expr(_))
          | @lib.TryTable(_, _, @lib.Expr(_))
          | @lib.If(_, _, _) => {
            let children = match
              dae_nested_control_children_evidence(instrs[idx], mod_) {
              Some(children) => children
              None => return false
            }
            if !dae_collect_forwarded_param_scc_actuals_instrs(
                children.primary_body,
                children.entry_stack_values,
                mod_,
                callee_abs,
                param_count,
                param_idx,
                caller_abs,
                caller_param_count,
                type_indices,
                boundary_facts,
                nodes,
                states,
                cycle_nodes,
                constant,
                flags,
                seen_calls,
              ) {
              return false
            }
            match children.secondary_body {
              Some(body) =>
                if !dae_collect_forwarded_param_scc_actuals_instrs(
                    body,
                    children.entry_stack_values,
                    mod_,
                    callee_abs,
                    param_count,
                    param_idx,
                    caller_abs,
                    caller_param_count,
                    type_indices,
                    boundary_facts,
                    nodes,
                    states,
                    cycle_nodes,
                    constant,
                    flags,
                    seen_calls,
                  ) {
                  return false
                }
              None => ()
            }
          }
          _ => ()
        }
    }
    idx += 1
  }
  true
}

///|
fn dae_collect_forwarded_param_scc_node(
  mod_ : @lib.Module,
  callee_abs : Int,
  param_idx : Int,
  type_indices : Array[@lib.TypeIdx],
  boundary_facts : DaeCallBoundaryFacts,
  nodes : Array[DaeForwardedParamNode],
  states : Array[Int],
  cycle_nodes : Array[DaeForwardedParamNode],
  constant : Array[@lib.Instruction?],
  flags : Array[Bool],
) -> Bool {
  let existing_idx = dae_forwarded_param_node_index(
    nodes, callee_abs, param_idx,
  )
  if existing_idx >= 0 {
    if states[existing_idx] == 1 {
      flags[1] = true
      if cycle_nodes.length() == 0 {
        let mut cycle_idx = existing_idx
        while cycle_idx < nodes.length() {
          cycle_nodes.push(nodes[cycle_idx])
          cycle_idx += 1
        }
      }
    }
    return states[existing_idx] != 0
  }
  let imported = dae_imported_func_count(mod_)
  let def_idx = callee_abs - imported
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None => return false
  }
  if def_idx < 0 ||
    def_idx >= funcs.length() ||
    !dae_call_boundary_allows_forwarding(boundary_facts, callee_abs) ||
    callee_abs >= boundary_facts.direct_calls.length() ||
    boundary_facts.direct_calls[callee_abs] <= 0 {
    return false
  }
  let params = match dae_resolve_func_type(mod_, type_indices, callee_abs) {
    Some(@lib.FuncType(params, _)) => params
    None => return false
  }
  if param_idx < 0 || param_idx >= params.length() {
    return false
  }
  let @lib.Func(locals, _) = funcs[def_idx]
  let local_use = dae_local_use_for_callee(
    funcs[def_idx],
    params.length() + locals.length(),
    callee_abs,
    params.length(),
  )
  if local_use.writes[param_idx] {
    return false
  }
  let node_idx = nodes.length()
  nodes.push({ callee_abs, param_idx })
  states.push(1)
  let caller_defs = dae_call_boundary_direct_callers(boundary_facts, callee_abs)
  let seen_calls = [0]
  for caller_def in caller_defs {
    if caller_def < 0 || caller_def >= funcs.length() {
      return false
    }
    let caller_abs = imported + caller_def
    let caller_params = match
      dae_resolve_func_type(mod_, type_indices, caller_abs) {
      Some(@lib.FuncType(params, _)) => params
      None => return false
    }
    let @lib.Func(_, @lib.Expr(body)) = funcs[caller_def]
    if !dae_collect_forwarded_param_scc_actuals_instrs(
        body,
        0,
        mod_,
        callee_abs,
        params.length(),
        param_idx,
        caller_abs,
        caller_params.length(),
        type_indices,
        boundary_facts,
        nodes,
        states,
        cycle_nodes,
        constant,
        flags,
        seen_calls,
      ) {
      return false
    }
  }
  if seen_calls[0] != boundary_facts.direct_calls[callee_abs] {
    return false
  }
  states[node_idx] = 2
  true
}

///|
fn dae_parameter_flow_edge_epochs_are_current(
  graph : DaeCurrentBoundaryGraph,
  edge : DaeParameterForwardingEdge,
) -> Bool {
  if edge.caller_def < 0 ||
    edge.caller_def >= graph.function_epochs.length() ||
    edge.callee_def < 0 ||
    edge.callee_def >= graph.function_epochs.length() {
    return false
  }
  let caller = graph.function_epochs[edge.caller_def]
  let callee = graph.function_epochs[edge.callee_def]
  caller.signature_epoch == edge.caller_signature_epoch &&
  caller.body_epoch == edge.caller_body_epoch &&
  callee.signature_epoch == edge.callee_signature_epoch &&
  callee.body_epoch == edge.callee_body_epoch
}

///|
fn dae_parameter_flow_fact_index(
  facts : Array[DaeParameterFlowFact],
  def_idx : Int,
  param_idx : Int,
) -> Int {
  let mut fact_idx = 0
  while fact_idx < facts.length() {
    if facts[fact_idx].def_idx == def_idx &&
      facts[fact_idx].param_idx == param_idx {
      return fact_idx
    }
    fact_idx += 1
  }
  -1
}

///|
fn dae_parameter_flow_record(
  facts : Array[DaeParameterFlowFact],
  def_idx : Int,
  param_idx : Int,
  state : DaeParameterFlowState,
) -> Unit {
  let fact_idx = dae_parameter_flow_fact_index(facts, def_idx, param_idx)
  if fact_idx < 0 {
    facts.push({ def_idx, param_idx, state })
    return
  }
  let existing = facts[fact_idx].state
  facts[fact_idx].state = match (existing, state) {
    (DaeParameterConflict, _) | (_, DaeParameterConflict) =>
      DaeParameterConflict
    (DaeParameterBlocked, _) | (_, DaeParameterBlocked) => DaeParameterBlocked
    (DaeParameterUniform(left), DaeParameterUniform(right)) =>
      if dae_materialized_const_equal(left, right) {
        DaeParameterUniform(left)
      } else {
        DaeParameterConflict
      }
    (DaeParameterUniform(value), DaeParameterForwardedOnly)
    | (DaeParameterForwardedOnly, DaeParameterUniform(value)) =>
      DaeParameterUniform(value)
    (DaeParameterForwardedOnly, DaeParameterForwardedOnly) =>
      DaeParameterForwardedOnly
  }
}

///|
fn dae_solve_parameter_flow(
  graph : DaeCurrentBoundaryGraph,
  dependencies : DaeBoundaryDependencyGraph,
  seed_defs? : Array[Int] = [],
) -> DaeParameterFlowSolution {
  for edge in dependencies.parameter_forwarding_edges {
    if !dae_parameter_flow_edge_epochs_are_current(graph, edge) {
      return { facts: [] }
    }
  }
  let facts : Array[DaeParameterFlowFact] = []
  let boundary_facts = graph.snapshot.boundary_facts
  let imported = graph.snapshot.imported
  let defs : Array[Int] = []
  if seed_defs.length() == 0 {
    let mut def_idx = 0
    while def_idx < graph.snapshot.defined {
      defs.push(def_idx)
      def_idx += 1
    }
  } else {
    for def_idx in seed_defs {
      if def_idx >= 0 &&
        def_idx < graph.snapshot.defined &&
        !defs.contains(def_idx) {
        defs.push(def_idx)
      }
    }
  }
  for def_idx in defs {
    let callee_abs = imported + def_idx
    let params = match
      dae_resolve_func_type(graph.mod_, graph.snapshot.type_indices, callee_abs) {
      Some(@lib.FuncType(params, _)) => params
      None => continue
    }
    let mut param_idx = 0
    while param_idx < params.length() {
      let nodes : Array[DaeForwardedParamNode] = []
      let states : Array[Int] = []
      let cycle_nodes : Array[DaeForwardedParamNode] = []
      let constant : Array[@lib.Instruction?] = [None]
      let flags = [true, false, false]
      let collected = dae_collect_forwarded_param_scc_node(
        graph.mod_,
        callee_abs,
        param_idx,
        graph.snapshot.type_indices,
        boundary_facts,
        nodes,
        states,
        cycle_nodes,
        constant,
        flags,
      )
      if collected {
        let state = match constant[0] {
          Some(value) => DaeParameterUniform(value)
          None => DaeParameterForwardedOnly
        }
        for node in nodes {
          let node_def = node.callee_abs - imported
          if node_def >= 0 && node_def < graph.snapshot.defined {
            dae_parameter_flow_record(facts, node_def, node.param_idx, state)
          }
        }
      }
      param_idx += 1
    }
  }
  { facts, }
}

///|
fn dae_parameter_flow_state_at(
  solution : DaeParameterFlowSolution,
  def_idx : Int,
  param_idx : Int,
) -> DaeParameterFlowState {
  let fact_idx = dae_parameter_flow_fact_index(
    solution.facts,
    def_idx,
    param_idx,
  )
  if fact_idx < 0 {
    DaeParameterBlocked
  } else {
    solution.facts[fact_idx].state
  }
}

///|
fn dae_parameter_flow_uniform_values_for_def(
  graph : DaeCurrentBoundaryGraph,
  solution : DaeParameterFlowSolution,
  def_idx : Int,
) -> Array[@lib.Instruction?] {
  if def_idx < 0 || def_idx >= graph.snapshot.defined {
    return []
  }
  let callee_abs = graph.snapshot.imported + def_idx
  let params = match
    dae_resolve_func_type(graph.mod_, graph.snapshot.type_indices, callee_abs) {
    Some(@lib.FuncType(params, _)) => params
    None => return []
  }
  let values : Array[@lib.Instruction?] = Array::make(params.length(), None)
  let mut any = false
  let mut param_idx = 0
  while param_idx < params.length() {
    match dae_parameter_flow_state_at(solution, def_idx, param_idx) {
      DaeParameterUniform(value) => {
        values[param_idx] = Some(value)
        any = true
      }
      _ => ()
    }
    param_idx += 1
  }
  if any {
    values
  } else {
    []
  }
}

///|
fn dae_apply_forwarded_param_scc_transaction(
  mod_ : @lib.Module,
  touched : Array[Bool],
  nodes : Array[DaeForwardedParamNode],
  constant : @lib.Instruction,
  boundary_facts : DaeCallBoundaryFacts,
) -> DaeForwardedParamSccApplication? {
  let imported = dae_imported_func_count(mod_)
  let (original_type_idxs, funcs, original_type_sec) = match
    (mod_.func_sec, mod_.code_sec, mod_.type_sec) {
    (Some(@lib.FuncSec(type_idxs)), Some(@lib.CodeSec(funcs)), Some(type_sec)) =>
      (type_idxs, funcs, type_sec)
    _ => return None
  }
  let type_indices = dae_collect_func_type_indices(mod_)
  let defs : Array[Int] = []
  let removes : Array[Array[Bool]] = []
  let const_params_by_def : Array[Array[@lib.Instruction?]] = []
  let localized_by_def : Array[Array[Bool]] = []
  for node in nodes {
    let def_idx = node.callee_abs - imported
    if def_idx < 0 || def_idx >= funcs.length() {
      return None
    }
    let mut def_slot = -1
    let mut existing_def_slot = 0
    while existing_def_slot < defs.length() {
      if defs[existing_def_slot] == def_idx {
        def_slot = existing_def_slot
        break
      }
      existing_def_slot += 1
    }
    if def_slot < 0 {
      let params = match
        dae_resolve_func_type(mod_, type_indices, node.callee_abs) {
        Some(@lib.FuncType(params, _)) => params
        None => return None
      }
      def_slot = defs.length()
      defs.push(def_idx)
      removes.push(Array::make(params.length(), false))
      const_params_by_def.push(Array::make(params.length(), None))
      localized_by_def.push(Array::make(params.length(), false))
    }
    if node.param_idx < 0 || node.param_idx >= removes[def_slot].length() {
      return None
    }
    removes[def_slot][node.param_idx] = true
    const_params_by_def[def_slot][node.param_idx] = Some(constant)
  }
  let rewritten_funcs = funcs.copy()
  let touched_out = if touched.length() == funcs.length() {
    touched.copy()
  } else {
    Array::make(funcs.length(), false)
  }
  let mut def_slot = 0
  while def_slot < defs.length() {
    let def_idx = defs[def_slot]
    let callee_abs = imported + def_idx
    let remove = removes[def_slot]
    let params = match dae_resolve_func_type(mod_, type_indices, callee_abs) {
      Some(@lib.FuncType(params, _)) => params
      None => return None
    }
    let mut rewritten_calls = 0
    for
      caller_def in dae_call_boundary_direct_callers(boundary_facts, callee_abs) {
      if caller_def < 0 || caller_def >= rewritten_funcs.length() {
        return None
      }
      let caller_abs = imported + caller_def
      let caller_params = match
        dae_resolve_func_type(mod_, type_indices, caller_abs) {
        Some(@lib.FuncType(caller_params, _)) => caller_params
        None => return None
      }
      let @lib.Func(caller_locals, @lib.Expr(caller_body)) = rewritten_funcs[caller_def]
      let localization = {
        first_scratch_local: dae_next_free_local_idx(
          caller_body,
          caller_params.length() + caller_locals.length(),
        ),
        param_types: params,
        scratch_local_types: [],
        localized_params: localized_by_def[def_slot],
      }
      let rewrite = dae_rewrite_calls_instrs(
        caller_body,
        callee_abs,
        remove,
        0,
        mod_,
        type_indices,
        localization=Some(localization),
      )
      if !rewrite.ok {
        return None
      }
      rewritten_calls += rewrite.calls_rewritten
      if rewrite.calls_rewritten > 0 {
        let next_locals = caller_locals.copy()
        next_locals.append_types(localization.scratch_local_types)
        rewritten_funcs[caller_def] = @lib.Func::new(
          next_locals,
          @lib.Expr::new(rewrite.instrs),
        )
        touched_out[caller_def] = true
      }
    }
    if callee_abs >= boundary_facts.direct_calls.length() ||
      rewritten_calls != boundary_facts.direct_calls[callee_abs] ||
      localized_by_def[def_slot].any(fn(localized) { localized }) {
      return None
    }
    def_slot += 1
  }
  let type_idxs = original_type_idxs.copy()
  let mut type_sec = original_type_sec
  def_slot = 0
  while def_slot < defs.length() {
    let def_idx = defs[def_slot]
    let callee_abs = imported + def_idx
    let (params, results) = match
      dae_resolve_func_type(mod_, type_indices, callee_abs) {
      Some(@lib.FuncType(params, results)) => (params, results)
      None => return None
    }
    let local_use = {
      gets: Array::make(params.length(), false),
      writes: Array::make(params.length(), false),
    }
    let rewrite = match
      dae_removed_param_callee_rewrite_evidence(
        rewritten_funcs[def_idx],
        params,
        removes[def_slot],
        const_params_by_def[def_slot],
        local_use,
        localized_by_def[def_slot],
      ) {
      Some(rewrite) => rewrite
      None => return None
    }
    rewritten_funcs[def_idx] = @lib.Func::new(
      rewrite.locals,
      @lib.Expr::new(rewrite.body),
    )
    let (next_type_sec, next_type_idx) = dae_update_defined_func_type(
      mod_,
      type_sec,
      type_idxs,
      def_idx,
      rewrite.kept_params,
      results,
    )
    type_sec = next_type_sec
    type_idxs[def_idx] = next_type_idx
    touched_out[def_idx] = true
    def_slot += 1
  }
  Some({
    mod_out: mod_
    .with_type_sec(type_sec)
    .with_func_sec(@lib.FuncSec::new(type_idxs))
    .with_code_sec(@lib.CodeSec::new(rewritten_funcs))
    .without_name_sec(),
    touched: touched_out,
    defs,
    param_count: nodes.length(),
  })
}

///|
fn dae_collect_forwarded_param_cycle_defs_with_facts(
  current : @lib.Module,
  touched : Array[Bool],
  preferred_defs : Array[Int],
  excluded_defs : Array[Int],
  imported : Int,
  defined : Int,
  type_indices : Array[@lib.TypeIdx],
  boundary_facts : DaeCallBoundaryFacts,
) -> Array[Int] {
  let seed_defs : Array[Int] = []
  for preferred_def in preferred_defs {
    if preferred_def >= 0 &&
      preferred_def < defined &&
      touched[preferred_def] &&
      !excluded_defs.contains(preferred_def) &&
      !seed_defs.contains(preferred_def) {
      seed_defs.push(preferred_def)
    }
  }
  for seed_def = 0; seed_def < defined; seed_def = seed_def + 1 {
    if touched[seed_def] &&
      !excluded_defs.contains(seed_def) &&
      !seed_defs.contains(seed_def) {
      seed_defs.push(seed_def)
    }
  }
  for seed_def in seed_defs {
    let callee_abs = imported + seed_def
    let params = match
      dae_resolve_func_type(current, type_indices, callee_abs) {
      Some(@lib.FuncType(params, _)) => params
      None => continue
    }
    let mut seed_param = 0
    while seed_param < params.length() {
      let nodes : Array[DaeForwardedParamNode] = []
      let states : Array[Int] = []
      let cycle_nodes : Array[DaeForwardedParamNode] = []
      let constant : Array[@lib.Instruction?] = [None]
      let flags = [true, false, false]
      ignore(
        dae_collect_forwarded_param_scc_node(
          current, callee_abs, seed_param, type_indices, boundary_facts, nodes, states,
          cycle_nodes, constant, flags,
        ),
      )
      if flags[1] && cycle_nodes.length() > 1 {
        let defs : Array[Int] = []
        for node in cycle_nodes {
          let def_idx = node.callee_abs - imported
          if def_idx >= 0 && def_idx < defined && !defs.contains(def_idx) {
            defs.push(def_idx)
          }
        }
        if defs.length() > 1 &&
          !defs.any(fn(def_idx) { excluded_defs.contains(def_idx) }) {
          return defs
        }
      }
      seed_param += 1
    }
  }
  []
}

///|
fn dae_collect_forwarded_param_cycle_batches(
  current : @lib.Module,
  touched : Array[Bool],
  preferred_defs? : Array[Int] = [],
  excluded_defs? : Array[Int] = [],
  limit? : Int = -1,
) -> Array[Array[Int]] {
  let imported = dae_imported_func_count(current)
  let defined = dae_defined_func_count(current)
  if defined == 0 || touched.length() != defined || limit == 0 {
    return []
  }
  let total = imported + defined
  let call_facts = dae_collect_current_call_facts(current, total)
  let boundary_facts = dae_call_boundary_facts_from_current(call_facts)
  let type_indices = dae_collect_func_type_indices(current)
  let batches : Array[Array[Int]] = []
  let processed_defs = excluded_defs.copy()
  let ordered_preferred_defs = preferred_defs.copy()
  while limit < 0 || batches.length() < limit {
    let defs = dae_collect_forwarded_param_cycle_defs_with_facts(
      current, touched, ordered_preferred_defs, processed_defs, imported, defined,
      type_indices, boundary_facts,
    )
    ordered_preferred_defs.clear()
    if defs.length() < 2 {
      break
    }
    batches.push(defs)
    for def_idx in defs {
      if !processed_defs.contains(def_idx) {
        processed_defs.push(def_idx)
      }
    }
  }
  batches
}

///|
fn dae_forwarded_param_direct_call_target_after_get(
  instrs : Array[@lib.Instruction],
  get_idx : Int,
  current : @lib.Module,
  type_indices : Array[@lib.TypeIdx],
) -> DaeForwardedParamNode? {
  if get_idx < 0 || get_idx >= instrs.length() {
    return None
  }
  let mut values_above = 0
  let mut idx = get_idx + 1
  while idx < instrs.length() {
    match instrs[idx] {
      @lib.Call(func_idx) => {
        let callee_abs = dae_func_idx_slot(func_idx)
        let params = match
          dae_resolve_func_type(current, type_indices, callee_abs) {
          Some(@lib.FuncType(params, _)) => params
          None => return None
        }
        if values_above < params.length() {
          return Some({
            callee_abs,
            param_idx: params.length() - 1 - values_above,
          })
        }
      }
      @lib.ReturnCall(_) => return None
      _ => ()
    }
    match dae_instr_stack_effect(instrs[idx], current, type_indices) {
      Some((pop_count, push_count)) => {
        if pop_count > values_above {
          return None
        }
        values_above = values_above - pop_count + push_count
      }
      None => return None
    }
    idx += 1
  }
  None
}

///|
fn dae_collect_forwarded_param_component_uses_instrs(
  instrs : Array[@lib.Instruction],
  entry_stack_values : Int,
  current : @lib.Module,
  caller_param_count : Int,
  source_param_idx : Int,
  type_indices : Array[@lib.TypeIdx],
  targets : Array[DaeForwardedParamNode],
  covered_gets : Array[Int],
) -> Bool {
  let source_local = @lib.LocalIdx::new(source_param_idx.reinterpret_as_uint())
  let mut idx = 0
  while idx < instrs.length() {
    match instrs[idx] {
      @lib.LocalGet(local_idx) if dae_local_idx_equal(local_idx, source_local) =>
        match
          dae_forwarded_param_direct_call_target_after_get(
            instrs, idx, current, type_indices,
          ) {
          Some(target) => {
            covered_gets[0] += 1
            targets.push(target)
          }
          None => ()
        }
      @lib.Block(_, @lib.Expr(_))
      | @lib.Loop(_, @lib.Expr(_))
      | @lib.TryTable(_, _, @lib.Expr(_))
      | @lib.If(_, _, _) => {
        let children = match
          dae_nested_control_children_evidence(instrs[idx], current) {
          Some(children) => children
          None => return false
        }
        if !dae_collect_forwarded_param_component_uses_instrs(
            children.primary_body,
            children.entry_stack_values,
            current,
            caller_param_count,
            source_param_idx,
            type_indices,
            targets,
            covered_gets,
          ) {
          return false
        }
        match children.secondary_body {
          Some(body) =>
            if !dae_collect_forwarded_param_component_uses_instrs(
                body,
                children.entry_stack_values,
                current,
                caller_param_count,
                source_param_idx,
                type_indices,
                targets,
                covered_gets,
              ) {
              return false
            }
          None => ()
        }
      }
      _ => ()
    }
    idx += 1
  }
  entry_stack_values >= 0 && caller_param_count >= 0
}

///|
fn dae_collect_forwarded_param_component_node(
  current : @lib.Module,
  callee_abs : Int,
  param_idx : Int,
  type_indices : Array[@lib.TypeIdx],
  boundary_facts : DaeCallBoundaryFacts,
  nodes : Array[DaeForwardedParamNode],
  states : Array[Int],
  flags : Array[Bool],
) -> Bool {
  let existing_idx = dae_forwarded_param_node_index(
    nodes, callee_abs, param_idx,
  )
  if existing_idx >= 0 {
    if states[existing_idx] == 1 {
      flags[0] = true
    }
    return states[existing_idx] != 0
  }
  let imported = dae_imported_func_count(current)
  let def_idx = callee_abs - imported
  let funcs = match current.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None => return false
  }
  if def_idx < 0 ||
    def_idx >= funcs.length() ||
    !dae_call_boundary_allows_forwarding(boundary_facts, callee_abs) ||
    callee_abs >= boundary_facts.direct_calls.length() ||
    boundary_facts.direct_calls[callee_abs] <= 0 {
    return false
  }
  let params = match dae_resolve_func_type(current, type_indices, callee_abs) {
    Some(@lib.FuncType(params, _)) => params
    None => return false
  }
  if param_idx < 0 || param_idx >= params.length() {
    return false
  }
  let @lib.Func(locals, @lib.Expr(body)) = funcs[def_idx]
  if !dae_local_indices_fit_instrs(body, params.length() + locals.length()) {
    return false
  }
  let target_local = @lib.LocalIdx::new(param_idx.reinterpret_as_uint())
  let usage = dae_local_usage_evidence(body, target_local)
  if usage.write_count != 0 {
    return false
  }
  let node_idx = nodes.length()
  nodes.push({ callee_abs, param_idx })
  states.push(1)
  if usage.get_count == 0 {
    if flags.length() > 1 {
      flags[1] = true
    }
    states[node_idx] = 2
    return true
  }
  let targets : Array[DaeForwardedParamNode] = []
  let covered_gets = [0]
  let scanned = dae_collect_forwarded_param_component_uses_instrs(
    body,
    0,
    current,
    params.length(),
    param_idx,
    type_indices,
    targets,
    covered_gets,
  )
  if !scanned || covered_gets[0] != usage.get_count || targets.length() == 0 {
    states[node_idx] = 0
    return false
  }
  for target in targets {
    if !dae_collect_forwarded_param_component_node(
        current,
        target.callee_abs,
        target.param_idx,
        type_indices,
        boundary_facts,
        nodes,
        states,
        flags,
      ) {
      states[node_idx] = 0
      return false
    }
  }
  states[node_idx] = 2
  true
}

///|
fn dae_collect_forwarded_param_component_sources_instrs(
  instrs : Array[@lib.Instruction],
  entry_stack_values : Int,
  current : @lib.Module,
  callee_abs : Int,
  param_count : Int,
  param_idx : Int,
  caller_abs : Int,
  caller_param_count : Int,
  type_indices : Array[@lib.TypeIdx],
  sources : Array[DaeForwardedParamNode],
  seen_calls : Array[Int],
) -> Bool {
  let mut idx = 0
  while idx < instrs.length() {
    match
      dae_target_callsite_evidence(
        instrs[idx],
        callee_abs,
        DaeTargetDirectCallOnly,
      ) {
      Some(_) => {
        let actual = match
          dae_callsite_value_slice_evidence(
            instrs, idx, param_count, entry_stack_values, current, type_indices,
          ) {
          Some(evidence) =>
            match
              dae_callsite_single_instruction_actual(
                evidence, param_idx, instrs,
              ) {
              Some(actual) => Some(actual.instr)
              None => None
            }
          None => None
        }
        let actual = match actual {
          Some(actual) => actual
          None =>
            match
              dae_forwarded_param_suffix_single_instruction_actual(
                instrs, idx, param_count, param_idx, current, type_indices,
              ) {
              Some(actual) => actual
              None => return false
            }
        }
        seen_calls[0] += 1
        match actual {
          @lib.LocalGet(local_idx) => {
            let local_slot = dae_local_idx_slot(local_idx)
            if local_slot >= 0 && local_slot < caller_param_count {
              sources.push({ callee_abs: caller_abs, param_idx: local_slot })
            }
          }
          _ => ()
        }
      }
      None =>
        match instrs[idx] {
          @lib.Block(_, @lib.Expr(_))
          | @lib.Loop(_, @lib.Expr(_))
          | @lib.TryTable(_, _, @lib.Expr(_))
          | @lib.If(_, _, _) => {
            let children = match
              dae_nested_control_children_evidence(instrs[idx], current) {
              Some(children) => children
              None => return false
            }
            if !dae_collect_forwarded_param_component_sources_instrs(
                children.primary_body,
                children.entry_stack_values,
                current,
                callee_abs,
                param_count,
                param_idx,
                caller_abs,
                caller_param_count,
                type_indices,
                sources,
                seen_calls,
              ) {
              return false
            }
            match children.secondary_body {
              Some(body) =>
                if !dae_collect_forwarded_param_component_sources_instrs(
                    body,
                    children.entry_stack_values,
                    current,
                    callee_abs,
                    param_count,
                    param_idx,
                    caller_abs,
                    caller_param_count,
                    type_indices,
                    sources,
                    seen_calls,
                  ) {
                  return false
                }
              None => ()
            }
          }
          _ => ()
        }
    }
    idx += 1
  }
  true
}

///|
fn dae_collect_forwarded_param_component_sources(
  current : @lib.Module,
  node : DaeForwardedParamNode,
  type_indices : Array[@lib.TypeIdx],
  boundary_facts : DaeCallBoundaryFacts,
) -> Array[DaeForwardedParamNode] {
  let sources : Array[DaeForwardedParamNode] = []
  let imported = dae_imported_func_count(current)
  let funcs = match current.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None => return sources
  }
  let params = match
    dae_resolve_func_type(current, type_indices, node.callee_abs) {
    Some(@lib.FuncType(params, _)) => params
    None => return sources
  }
  let seen_calls = [0]
  for
    caller_def in dae_call_boundary_direct_callers(
      boundary_facts,
      node.callee_abs,
    ) {
    if caller_def < 0 || caller_def >= funcs.length() {
      return []
    }
    let caller_abs = imported + caller_def
    let caller_params = match
      dae_resolve_func_type(current, type_indices, caller_abs) {
      Some(@lib.FuncType(caller_params, _)) => caller_params
      None => return []
    }
    let @lib.Func(_, @lib.Expr(body)) = funcs[caller_def]
    if !dae_collect_forwarded_param_component_sources_instrs(
        body,
        0,
        current,
        node.callee_abs,
        params.length(),
        node.param_idx,
        caller_abs,
        caller_params.length(),
        type_indices,
        sources,
        seen_calls,
      ) {
      return []
    }
  }
  if node.callee_abs >= boundary_facts.direct_calls.length() ||
    seen_calls[0] != boundary_facts.direct_calls[node.callee_abs] {
    return []
  }
  sources
}

///|
fn dae_forwarded_param_node_calls_rewritable(
  current : @lib.Module,
  node : DaeForwardedParamNode,
  type_indices : Array[@lib.TypeIdx],
  boundary_facts : DaeCallBoundaryFacts,
) -> Bool {
  let imported = dae_imported_func_count(current)
  let funcs = match current.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None => return false
  }
  let def_idx = node.callee_abs - imported
  if def_idx < 0 || def_idx >= funcs.length() {
    return false
  }
  let params = match
    dae_resolve_func_type(current, type_indices, node.callee_abs) {
    Some(@lib.FuncType(params, _)) => params
    None => return false
  }
  if node.param_idx < 0 || node.param_idx >= params.length() {
    return false
  }
  let remove = Array::make(params.length(), false)
  remove[node.param_idx] = true
  let localized = Array::make(params.length(), false)
  let mut rewritten_calls = 0
  for
    caller_def in dae_call_boundary_direct_callers(
      boundary_facts,
      node.callee_abs,
    ) {
    if caller_def < 0 || caller_def >= funcs.length() {
      return false
    }
    let caller_abs = imported + caller_def
    let caller_params = match
      dae_resolve_func_type(current, type_indices, caller_abs) {
      Some(@lib.FuncType(caller_params, _)) => caller_params
      None => return false
    }
    let @lib.Func(caller_locals, @lib.Expr(caller_body)) = funcs[caller_def]
    let localization = {
      first_scratch_local: dae_next_free_local_idx(
        caller_body,
        caller_params.length() + caller_locals.length(),
      ),
      param_types: params,
      scratch_local_types: [],
      localized_params: localized,
    }
    let rewrite = dae_rewrite_calls_instrs(
      caller_body,
      node.callee_abs,
      remove,
      0,
      current,
      type_indices,
      localization=Some(localization),
    )
    if !rewrite.ok {
      return false
    }
    rewritten_calls += rewrite.calls_rewritten
  }
  node.callee_abs < boundary_facts.direct_calls.length() &&
  rewritten_calls == boundary_facts.direct_calls[node.callee_abs]
}

///|
fn dae_collect_forwarded_param_component(
  current : @lib.Module,
  cycle_defs : Array[Int],
  type_indices : Array[@lib.TypeIdx],
  boundary_facts : DaeCallBoundaryFacts,
) -> Array[DaeForwardedParamNode] {
  let imported = dae_imported_func_count(current)
  let defined = dae_defined_func_count(current)
  let mut seed_slot = 0
  while seed_slot < cycle_defs.length() {
    let seed_def = cycle_defs[seed_slot]
    if seed_def < 0 || seed_def >= defined {
      seed_slot += 1
      continue
    }
    let seed_abs = imported + seed_def
    let params = match dae_resolve_func_type(current, type_indices, seed_abs) {
      Some(@lib.FuncType(params, _)) => params
      None => {
        seed_slot += 1
        continue
      }
    }
    let mut seed_param = 0
    while seed_param < params.length() {
      let nodes : Array[DaeForwardedParamNode] = []
      let states : Array[Int] = []
      let flags = [false, false]
      let collected = dae_collect_forwarded_param_component_node(
        current, seed_abs, seed_param, type_indices, boundary_facts, nodes, states,
        flags,
      )
      let component_defs : Array[Int] = []
      if collected && (flags[0] || flags[1]) {
        for node in nodes {
          let def_idx = node.callee_abs - imported
          if def_idx >= 0 &&
            def_idx < defined &&
            !component_defs.contains(def_idx) {
            component_defs.push(def_idx)
          }
        }
      }
      let mut cycle_member_defs = 0
      for def_idx in cycle_defs {
        if component_defs.contains(def_idx) {
          cycle_member_defs += 1
        }
      }
      if collected && (flags[0] || flags[1]) && cycle_member_defs >= 2 {
        let mut changed = true
        while changed {
          changed = false
          let frontier = nodes.copy()
          for target in frontier {
            let sources = dae_collect_forwarded_param_component_sources(
              current, target, type_indices, boundary_facts,
            )
            for source in sources {
              if dae_forwarded_param_node_index(
                  nodes,
                  source.callee_abs,
                  source.param_idx,
                ) >=
                0 ||
                !dae_forwarded_param_node_calls_rewritable(
                  current, source, type_indices, boundary_facts,
                ) {
                continue
              }
              let trial_nodes = nodes.copy()
              let trial_states = Array::make(trial_nodes.length(), 2)
              let trial_flags = [true, true]
              if dae_collect_forwarded_param_component_node(
                  current,
                  source.callee_abs,
                  source.param_idx,
                  type_indices,
                  boundary_facts,
                  trial_nodes,
                  trial_states,
                  trial_flags,
                ) {
                nodes.clear()
                nodes.append(trial_nodes)
                states.clear()
                states.append(trial_states)
                changed = true
              }
            }
          }
        }
        return nodes
      }
      seed_param += 1
    }
    seed_slot += 1
  }
  []
}

///|
fn dae_build_forwarded_param_component_candidate(
  current : @lib.Module,
  touched : Array[Bool],
  nodes : Array[DaeForwardedParamNode],
  boundary_facts : DaeCallBoundaryFacts,
) -> DaeForwardedParamSccApplication? {
  if nodes.length() < 2 {
    return None
  }
  let imported = dae_imported_func_count(current)
  let (original_type_idxs, funcs, original_type_sec) = match
    (current.func_sec, current.code_sec, current.type_sec) {
    (Some(@lib.FuncSec(type_idxs)), Some(@lib.CodeSec(funcs)), Some(type_sec)) =>
      (type_idxs, funcs, type_sec)
    _ => return None
  }
  let type_indices = dae_collect_func_type_indices(current)
  let defs : Array[Int] = []
  let removes : Array[Array[Bool]] = []
  let localized_by_def : Array[Array[Bool]] = []
  for node in nodes {
    let def_idx = node.callee_abs - imported
    if def_idx < 0 || def_idx >= funcs.length() {
      return None
    }
    let mut def_slot = -1
    let mut existing_slot = 0
    while existing_slot < defs.length() {
      if defs[existing_slot] == def_idx {
        def_slot = existing_slot
        break
      }
      existing_slot += 1
    }
    if def_slot < 0 {
      let params = match
        dae_resolve_func_type(current, type_indices, node.callee_abs) {
        Some(@lib.FuncType(params, _)) => params
        None => return None
      }
      def_slot = defs.length()
      defs.push(def_idx)
      removes.push(Array::make(params.length(), false))
      localized_by_def.push(Array::make(params.length(), false))
    }
    if node.param_idx < 0 || node.param_idx >= removes[def_slot].length() {
      return None
    }
    removes[def_slot][node.param_idx] = true
  }
  let rewritten_funcs = funcs.copy()
  let touched_out = if touched.length() == funcs.length() {
    touched.copy()
  } else {
    Array::make(funcs.length(), false)
  }
  let mut def_slot = 0
  while def_slot < defs.length() {
    let def_idx = defs[def_slot]
    let callee_abs = imported + def_idx
    let remove = removes[def_slot]
    let params = match
      dae_resolve_func_type(current, type_indices, callee_abs) {
      Some(@lib.FuncType(params, _)) => params
      None => return None
    }
    let mut rewritten_calls = 0
    for
      caller_def in dae_call_boundary_direct_callers(boundary_facts, callee_abs) {
      if caller_def < 0 || caller_def >= rewritten_funcs.length() {
        return None
      }
      let caller_abs = imported + caller_def
      let caller_params = match
        dae_resolve_func_type(current, type_indices, caller_abs) {
        Some(@lib.FuncType(caller_params, _)) => caller_params
        None => return None
      }
      let @lib.Func(caller_locals, @lib.Expr(caller_body)) = rewritten_funcs[caller_def]
      let localization = {
        first_scratch_local: dae_next_free_local_idx(
          caller_body,
          caller_params.length() + caller_locals.length(),
        ),
        param_types: params,
        scratch_local_types: [],
        localized_params: localized_by_def[def_slot],
      }
      let rewrite = dae_rewrite_calls_instrs(
        caller_body,
        callee_abs,
        remove,
        0,
        current,
        type_indices,
        localization=Some(localization),
      )
      if !rewrite.ok {
        return None
      }
      rewritten_calls += rewrite.calls_rewritten
      if rewrite.calls_rewritten > 0 {
        let next_locals = caller_locals.copy()
        next_locals.append_types(localization.scratch_local_types)
        rewritten_funcs[caller_def] = @lib.Func::new(
          next_locals,
          @lib.Expr::new(rewrite.instrs),
        )
        touched_out[caller_def] = true
      }
    }
    if callee_abs >= boundary_facts.direct_calls.length() ||
      rewritten_calls != boundary_facts.direct_calls[callee_abs] {
      return None
    }
    def_slot += 1
  }
  let type_idxs = original_type_idxs.copy()
  let mut type_sec = original_type_sec
  def_slot = 0
  while def_slot < defs.length() {
    let def_idx = defs[def_slot]
    let callee_abs = imported + def_idx
    let (params, results) = match
      dae_resolve_func_type(current, type_indices, callee_abs) {
      Some(@lib.FuncType(params, results)) => (params, results)
      None => return None
    }
    let @lib.Func(locals, @lib.Expr(body)) = rewritten_funcs[def_idx]
    let remove = removes[def_slot]
    let mut param_idx = 0
    while param_idx < remove.length() {
      if remove[param_idx] {
        let usage = dae_local_usage_evidence(
          body,
          @lib.LocalIdx::new(param_idx.reinterpret_as_uint()),
        )
        if usage.get_count != 0 || usage.write_count != 0 {
          return None
        }
      }
      param_idx += 1
    }
    let local_use = dae_local_use_for_callee(
      rewritten_funcs[def_idx],
      params.length() + locals.length(),
      callee_abs,
      params.length(),
    )
    let rewrite = match
      dae_removed_param_callee_rewrite_evidence(
        rewritten_funcs[def_idx],
        params,
        remove,
        Array::make(params.length(), None),
        local_use,
        Array::make(params.length(), false),
      ) {
      Some(rewrite) => rewrite
      None => return None
    }
    rewritten_funcs[def_idx] = @lib.Func::new(
      rewrite.locals,
      @lib.Expr::new(rewrite.body),
    )
    let (next_type_sec, next_type_idx) = dae_update_defined_func_type(
      current,
      type_sec,
      type_idxs,
      def_idx,
      rewrite.kept_params,
      results,
    )
    type_sec = next_type_sec
    type_idxs[def_idx] = next_type_idx
    touched_out[def_idx] = true
    def_slot += 1
  }
  Some({
    mod_out: current
    .with_type_sec(type_sec)
    .with_func_sec(@lib.FuncSec::new(type_idxs))
    .with_code_sec(@lib.CodeSec::new(rewritten_funcs))
    .without_name_sec(),
    touched: touched_out,
    defs,
    param_count: nodes.length(),
  })
}

///|
fn dae_count_component_target_call_kinds(
  funcs : Array[@lib.Func],
  target_abs : Int,
) -> (Int, Int) {
  let mut direct_calls = 0
  let mut return_calls = 0
  for func in funcs {
    let @lib.Func(_, @lib.Expr(body)) = func
    let (body_direct, body_return) = dae_count_target_call_kinds_instrs(
      body, target_abs,
    )
    direct_calls += body_direct
    return_calls += body_return
  }
  (direct_calls, return_calls)
}

///|
fn dae_build_forwarded_param_component_rewrite_plan(
  current : @lib.Module,
  graph : DaeCurrentBoundaryGraph,
  dependencies : DaeBoundaryDependencyGraph,
  touched : Array[Bool],
  nodes : Array[DaeForwardedParamNode],
  boundary_facts : DaeCallBoundaryFacts,
) -> DaeComponentRewritePlan? {
  let candidate = match
    dae_build_forwarded_param_component_candidate(
      current, touched, nodes, boundary_facts,
    ) {
    Some(value) => value
    None => return None
  }
  let (expected_type_sec, expected_type_idxs, expected_funcs) = match
    (current.type_sec, current.func_sec, current.code_sec) {
    (Some(type_sec), Some(@lib.FuncSec(type_idxs)), Some(@lib.CodeSec(funcs))) =>
      (type_sec, type_idxs, funcs)
    _ => return None
  }
  if candidate.defs.length() < 2 {
    return None
  }
  let component_id = if candidate.defs[0] >= 0 &&
    candidate.defs[0] < dependencies.component_by_def.length() {
    dependencies.component_by_def[candidate.defs[0]]
  } else {
    return None
  }
  let expected_members : Array[DaeComponentMemberExpectation] = []
  let expected_callers : Array[DaeComponentCallerExpectation] = []
  for def_idx in candidate.defs {
    if def_idx < 0 ||
      def_idx >= graph.function_epochs.length() ||
      def_idx >= dependencies.component_by_def.length() {
      return None
    }
    let epochs = graph.function_epochs[def_idx]
    let target_abs = graph.snapshot.imported + def_idx
    let (direct_calls, return_calls) = dae_count_component_target_call_kinds(
      graph.snapshot.funcs,
      target_abs,
    )
    expected_members.push({
      def_idx,
      signature_epoch: epochs.signature_epoch,
      body_epoch: epochs.body_epoch,
      direct_calls,
      return_calls,
    })
    if target_abs >= 0 &&
      target_abs < graph.snapshot.call_facts.direct_callers.length() {
      for caller_def in graph.snapshot.call_facts.direct_callers[target_abs] {
        if caller_def < 0 || caller_def >= graph.function_epochs.length() {
          return None
        }
        if !expected_callers.any(fn(expected) { expected.def_idx == caller_def }) {
          let caller_epochs = graph.function_epochs[caller_def]
          expected_callers.push({
            def_idx: caller_def,
            signature_epoch: caller_epochs.signature_epoch,
            body_epoch: caller_epochs.body_epoch,
          })
        }
      }
    }
  }
  Some({
    component_id,
    member_defs: candidate.defs.copy(),
    expected_module_epoch: graph.module_epoch,
    expected_call_epoch: graph.call_epoch,
    expected_members,
    expected_callers,
    expected_type_sec,
    expected_type_idxs: expected_type_idxs.copy(),
    expected_funcs: expected_funcs.copy(),
    candidate,
  })
}

///|
fn dae_apply_component_rewrite_plan(
  current : @lib.Module,
  graph : DaeCurrentBoundaryGraph,
  plan : DaeComponentRewritePlan,
) -> DaeComponentRewritePlanApplication {
  if plan.expected_module_epoch != graph.module_epoch ||
    plan.expected_call_epoch != graph.call_epoch {
    return DaeComponentPlanRejected(current, DaeStaleCandidateFacts)
  }
  match (current.type_sec, current.func_sec, current.code_sec) {
    (Some(type_sec), Some(@lib.FuncSec(type_idxs)), Some(@lib.CodeSec(funcs))) =>
      if type_sec != plan.expected_type_sec ||
        type_idxs != plan.expected_type_idxs ||
        funcs != plan.expected_funcs {
        return DaeComponentPlanRejected(current, DaeStaleCandidateFacts)
      }
    _ =>
      return DaeComponentPlanRejected(current, DaeTypeReconstructionUnavailable)
  }
  for expected in plan.expected_members {
    if expected.def_idx < 0 ||
      expected.def_idx >= graph.function_epochs.length() ||
      expected.def_idx >= graph.snapshot.defined {
      return DaeComponentPlanRejected(current, DaeStaleCandidateFacts)
    }
    let epochs = graph.function_epochs[expected.def_idx]
    if epochs.signature_epoch != expected.signature_epoch ||
      epochs.body_epoch != expected.body_epoch {
      return DaeComponentPlanRejected(current, DaeStaleCandidateFacts)
    }
    let target_abs = graph.snapshot.imported + expected.def_idx
    let (direct_calls, return_calls) = dae_count_component_target_call_kinds(
      graph.snapshot.funcs,
      target_abs,
    )
    if direct_calls != expected.direct_calls ||
      return_calls != expected.return_calls {
      return DaeComponentPlanRejected(current, DaeCallCountChanged)
    }
    if expected.def_idx >= plan.candidate.touched.length() ||
      !plan.candidate.touched[expected.def_idx] {
      return DaeComponentPlanRejected(current, DaeTypeReconstructionUnavailable)
    }
  }
  for expected in plan.expected_callers {
    if expected.def_idx < 0 ||
      expected.def_idx >= graph.function_epochs.length() {
      return DaeComponentPlanRejected(current, DaeStaleCandidateFacts)
    }
    let epochs = graph.function_epochs[expected.def_idx]
    if epochs.signature_epoch != expected.signature_epoch ||
      epochs.body_epoch != expected.body_epoch {
      return DaeComponentPlanRejected(current, DaeStaleCandidateFacts)
    }
  }
  match @validate.validate_module(plan.candidate.mod_out) {
    Ok(_) => DaeComponentPlanCommitted(plan.candidate)
    Err(_) => DaeComponentPlanRejected(current, DaeValidationRollback)
  }
}

///|
fn dae_run_forwarded_param_component_transaction_with_graph(
  current : @lib.Module,
  touched : Array[Bool],
  cycle_defs : Array[Int],
  graph : DaeCurrentBoundaryGraph,
  dependencies : DaeBoundaryDependencyGraph,
) -> DaeForwardedParamSccApplication? {
  if cycle_defs.length() < 2 {
    return None
  }
  let total = dae_imported_func_count(current) + dae_defined_func_count(current)
  let boundary_facts = graph.snapshot.boundary_facts
  let nodes = dae_collect_forwarded_param_component(
    current,
    cycle_defs,
    graph.snapshot.type_indices,
    boundary_facts,
  )
  let plan = match
    dae_build_forwarded_param_component_rewrite_plan(
      current, graph, dependencies, touched, nodes, boundary_facts,
    ) {
    Some(plan) => plan
    None => return None
  }
  let application = match
    dae_apply_component_rewrite_plan(current, graph, plan) {
    DaeComponentPlanCommitted(application) => application
    DaeComponentPlanRejected(_, _) => return None
  }
  let rewritten_type_indices = dae_collect_func_type_indices(
    application.mod_out,
  )
  let uniform_ref_null = dae_try_rewrite_uniform_ref_null_callee_from_selected_callers_with_facts(
    application.mod_out,
    application.defs,
    dae_imported_func_count(application.mod_out),
    dae_defined_func_count(application.mod_out),
    total,
    rewritten_type_indices,
    boundary_facts,
  )
  if !uniform_ref_null.changed {
    return Some(application)
  }
  let combined_touched = application.touched.copy()
  for def_idx = 0
      def_idx < uniform_ref_null.touched.length()
      def_idx = def_idx + 1 {
    if uniform_ref_null.touched[def_idx] && def_idx < combined_touched.length() {
      combined_touched[def_idx] = true
    }
  }
  Some({
    mod_out: uniform_ref_null.mod_out,
    touched: combined_touched,
    defs: application.defs,
    param_count: application.param_count,
  })
}

///|
fn dae_run_forwarded_param_component_transaction(
  current : @lib.Module,
  touched : Array[Bool],
  cycle_defs : Array[Int],
) -> DaeForwardedParamSccApplication? {
  if cycle_defs.length() < 2 {
    return None
  }
  let graph = dae_current_boundary_graph_new(current)
  let dependencies = dae_boundary_dependency_graph_new(graph)
  let target_def = cycle_defs[0]
  let item = {
    ..dae_work_item_new(graph, dependencies, target_def, DaeForwardingWork),
    component_members: cycle_defs.copy(),
  }
  let nodes = dae_collect_forwarded_param_component(
    current,
    cycle_defs,
    graph.snapshot.type_indices,
    graph.snapshot.boundary_facts,
  )
  if nodes.length() == 0 {
    return None
  }
  let rewritten_defs : Array[Int] = []
  let imported = graph.snapshot.imported
  for node in nodes {
    let def_idx = node.callee_abs - imported
    if def_idx >= 0 && !rewritten_defs.contains(def_idx) {
      rewritten_defs.push(def_idx)
    }
  }
  let original = dae_collect_original_boundary_snapshot(current)
  let diagnostics = dae_diagnostics_new()
  match
    dae_process_work_item(
      original, current, touched, false, graph, dependencies, item, diagnostics,
    ) {
    DaeWorkCommitted(application) =>
      Some({
        mod_out: application.mod_out,
        touched: application.touched,
        defs: rewritten_defs,
        param_count: nodes.length(),
      })
    _ => None
  }
}

///|
fn dae_collect_forwarded_param_dead_callee_candidates_instrs(
  instrs : Array[@lib.Instruction],
  entry_stack_values : Int,
  current : @lib.Module,
  caller_param_count : Int,
  cycle_selected : Array[Bool],
  type_indices : Array[@lib.TypeIdx],
  candidates : Array[Array[Bool]?],
) -> Unit {
  let imported = dae_imported_func_count(current)
  let defined = dae_defined_func_count(current)
  let mut idx = 0
  while idx < instrs.length() {
    match instrs[idx] {
      @lib.Call(func_idx) => {
        let callee_abs = dae_func_idx_slot(func_idx)
        let callee_def = callee_abs - imported
        if callee_def >= 0 &&
          callee_def < defined &&
          callee_def < candidates.length() &&
          (callee_def >= cycle_selected.length() || !cycle_selected[callee_def]) {
          let params = match
            dae_resolve_func_type(current, type_indices, callee_abs) {
            Some(@lib.FuncType(params, _)) => params
            None => []
          }
          if params.length() > 0 {
            match
              dae_callsite_value_slice_evidence(
                instrs,
                idx,
                params.length(),
                entry_stack_values,
                current,
                type_indices,
              ) {
              Some(evidence) => {
                let mut param_idx = 0
                while param_idx < params.length() {
                  match
                    dae_callsite_single_instruction_actual(
                      evidence, param_idx, instrs,
                    ) {
                    Some(actual) =>
                      match actual.instr {
                        @lib.LocalGet(local_idx) => {
                          let local_slot = dae_local_idx_slot(local_idx)
                          if local_slot >= 0 && local_slot < caller_param_count {
                            let mask = match candidates[callee_def] {
                              Some(mask) => mask
                              None => Array::make(params.length(), false)
                            }
                            if param_idx < mask.length() {
                              mask[param_idx] = true
                              candidates[callee_def] = Some(mask)
                            }
                          }
                        }
                        _ => ()
                      }
                    None => ()
                  }
                  param_idx += 1
                }
              }
              None => ()
            }
          }
        }
      }
      @lib.Block(_, @lib.Expr(_))
      | @lib.Loop(_, @lib.Expr(_))
      | @lib.TryTable(_, _, @lib.Expr(_))
      | @lib.If(_, _, _) =>
        match dae_nested_control_children_evidence(instrs[idx], current) {
          Some(children) => {
            dae_collect_forwarded_param_dead_callee_candidates_instrs(
              children.primary_body,
              children.entry_stack_values,
              current,
              caller_param_count,
              cycle_selected,
              type_indices,
              candidates,
            )
            match children.secondary_body {
              Some(body) =>
                dae_collect_forwarded_param_dead_callee_candidates_instrs(
                  body,
                  children.entry_stack_values,
                  current,
                  caller_param_count,
                  cycle_selected,
                  type_indices,
                  candidates,
                )
              None => ()
            }
          }
          None => ()
        }
      _ => ()
    }
    idx += 1
  }
}

///|
fn dae_collect_forwarded_param_dead_callee_defs(
  current : @lib.Module,
  cycle_defs : Array[Int],
) -> Array[Int] {
  let defined = dae_defined_func_count(current)
  if defined == 0 || cycle_defs.length() == 0 {
    return []
  }
  let imported = dae_imported_func_count(current)
  let funcs = match current.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None => return []
  }
  let type_indices = dae_collect_func_type_indices(current)
  let cycle_selected = Array::make(defined, false)
  for def_idx in cycle_defs {
    if def_idx >= 0 && def_idx < defined {
      cycle_selected[def_idx] = true
    }
  }
  let candidates : Array[Array[Bool]?] = Array::make(defined, None)
  for caller_def in cycle_defs {
    if caller_def < 0 || caller_def >= funcs.length() {
      continue
    }
    let caller_abs = imported + caller_def
    let caller_params = match
      dae_resolve_func_type(current, type_indices, caller_abs) {
      Some(@lib.FuncType(params, _)) => params
      None => continue
    }
    let @lib.Func(_, @lib.Expr(body)) = funcs[caller_def]
    dae_collect_forwarded_param_dead_callee_candidates_instrs(
      body,
      0,
      current,
      caller_params.length(),
      cycle_selected,
      type_indices,
      candidates,
    )
  }
  let sink_defs : Array[Int] = []
  let mut def_idx = 0
  while def_idx < defined {
    match candidates[def_idx] {
      Some(mask) => {
        let callee_abs = imported + def_idx
        let params = match
          dae_resolve_func_type(current, type_indices, callee_abs) {
          Some(@lib.FuncType(params, _)) => params
          None => []
        }
        let @lib.Func(locals, _) = funcs[def_idx]
        let local_use = dae_local_use_for_callee(
          funcs[def_idx],
          params.length() + locals.length(),
          callee_abs,
          params.length(),
        )
        let mut param_idx = 0
        let mut has_dead_sink = false
        while param_idx < mask.length() && param_idx < local_use.gets.length() {
          if mask[param_idx] && !local_use.gets[param_idx] {
            has_dead_sink = true
          }
          param_idx += 1
        }
        if has_dead_sink {
          sink_defs.push(def_idx)
        }
      }
      None => ()
    }
    def_idx += 1
  }
  sink_defs
}

///|
fn dae_run_forwarded_param_dead_callee_convergence(
  current : @lib.Module,
  touched : Array[Bool],
  cycle_defs : Array[Int],
) -> DaeForwardedParamDeadCalleeApplication? {
  let defined = dae_defined_func_count(current)
  if defined == 0 || cycle_defs.length() < 2 {
    return None
  }
  let total = dae_imported_func_count(current) + defined
  let mut mod_out = current
  let mut touched_out = if touched.length() == defined {
    touched.copy()
  } else {
    Array::make(defined, false)
  }
  let sink_defs : Array[Int] = []
  while true {
    let sink_candidates = dae_collect_forwarded_param_dead_callee_defs(
      mod_out, cycle_defs,
    )
    if sink_candidates.length() == 0 {
      break
    }
    let sink_selected = Array::make(defined, false)
    for def_idx in sink_candidates {
      if def_idx >= 0 && def_idx < defined {
        sink_selected[def_idx] = true
      }
    }
    let mut round_changed = false
    while true {
      let call_facts = dae_collect_current_call_facts(mod_out, total)
      let result = dae_try_rewrite_selected_defs_unread_params_with_facts_once(
        mod_out, sink_selected, call_facts,
      )
      if !result.changed {
        break
      }
      mod_out = result.mod_out
      touched_out = dae_merge_touched(touched_out, result.touched)
      if result.primary_def >= 0 && !sink_defs.contains(result.primary_def) {
        sink_defs.push(result.primary_def)
      }
      round_changed = true
    }
    if !round_changed {
      break
    }
  }
  if sink_defs.length() == 0 {
    return None
  }
  let cycle_selected = Array::make(defined, false)
  for def_idx in cycle_defs {
    if def_idx >= 0 && def_idx < defined {
      cycle_selected[def_idx] = true
    }
  }
  let productive_cycle_defs : Array[Int] = []
  while true {
    let call_facts = dae_collect_current_call_facts(mod_out, total)
    let result = dae_try_rewrite_selected_defs_unread_params_with_facts_once(
      mod_out, cycle_selected, call_facts,
    )
    if !result.changed {
      break
    }
    mod_out = result.mod_out
    touched_out = dae_merge_touched(touched_out, result.touched)
    if result.primary_def >= 0 &&
      !productive_cycle_defs.contains(result.primary_def) {
      productive_cycle_defs.push(result.primary_def)
    }
  }
  Some({
    mod_out,
    touched: touched_out,
    sink_defs,
    cycle_defs: productive_cycle_defs,
  })
}

///|
fn dae_run_forwarded_param_scc_transaction(
  current : @lib.Module,
  touched : Array[Bool],
) -> DaeForwardedParamSccApplication? {
  let imported = dae_imported_func_count(current)
  let defined = dae_defined_func_count(current)
  if defined == 0 || touched.length() != defined {
    return None
  }
  let total = imported + defined
  let call_facts = dae_collect_current_call_facts(current, total)
  let boundary_facts = dae_call_boundary_facts_from_current(call_facts)
  let type_indices = dae_collect_func_type_indices(current)
  let mut seed_def = 0
  while seed_def < defined {
    if !touched[seed_def] {
      seed_def += 1
      continue
    }
    let callee_abs = imported + seed_def
    let params = match
      dae_resolve_func_type(current, type_indices, callee_abs) {
      Some(@lib.FuncType(params, _)) => params
      None => {
        seed_def += 1
        continue
      }
    }
    let mut seed_param = 0
    while seed_param < params.length() {
      let nodes : Array[DaeForwardedParamNode] = []
      let states : Array[Int] = []
      let cycle_nodes : Array[DaeForwardedParamNode] = []
      let constant : Array[@lib.Instruction?] = [None]
      let flags = [true, false, false]
      let collected = dae_collect_forwarded_param_scc_node(
        current, callee_abs, seed_param, type_indices, boundary_facts, nodes, states,
        cycle_nodes, constant, flags,
      )
      if collected && flags[1] && flags[2] {
        match constant[0] {
          Some(value) =>
            match
              dae_apply_forwarded_param_scc_transaction(
                current, touched, nodes, value, boundary_facts,
              ) {
              Some(application) => return Some(application)
              None => ()
            }
          None => ()
        }
      }
      seed_param += 1
    }
    seed_def += 1
  }
  None
}

///|
fn dae_run_broad_uniform_parameter_flow(
  current : @lib.Module,
  candidate_source : @lib.Module,
  touched : Array[Bool],
  changed : Bool,
) -> DaeExactLiteralWorklistApplication {
  let defined = dae_defined_func_count(current)
  if defined <= 1024 {
    return { mod_out: current, touched, changed, productive_defs: [] }
  }
  let total = dae_imported_func_count(current) + defined
  let call_facts = dae_collect_current_call_facts(current, total)
  let candidates : Array[Int] = []
  let source_defined = dae_defined_func_count(candidate_source)
  let mut candidate_def = 0
  while candidate_def < defined && candidate_def < source_defined {
    if dae_exact_literal_candidate_is_single_param_identity(
        candidate_source, candidate_def,
      ) ||
      dae_exact_literal_candidate_has_scalar_constructor_shape(
        candidate_source, candidate_def,
      ) {
      candidates.push(candidate_def)
    }
    candidate_def += 1
  }
  dae_run_exact_literal_candidate_worklist_with_facts(
    current, touched, changed, candidates, call_facts, -1,
  )
}

///|
fn dae_run_broad_exact_param_adjacent_cleanup_root(
  current : @lib.Module,
  touched : Array[Bool],
  changed : Bool,
  trace : (String) -> Unit,
) -> DaeBroadExactParamAdjacentCleanupApplication {
  let imported = dae_imported_func_count(current)
  let defined = dae_defined_func_count(current)
  if defined <= 8192 {
    return { mod_out: current, touched, candidate: None }
  }
  let total = imported + defined
  let call_facts = dae_collect_current_call_facts(current, total)
  let neighborhood_candidates = dae_collect_broad_exact_param_adjacent_cleanup_candidates(
    current,
  )
  let successful_roots = Array::make(defined, false)
  let successful_pairs = Array::make(defined, false)
  let mut root_count = 0
  let mut pair_count = 0
  let mut best_root = -1
  let mut best_aggregates = -1
  let mut best_payoff = -1
  let mut best_candidate : DaeBroadExactParamAdjacentCleanupCandidate? = None
  for candidate in neighborhood_candidates {
    let root_result = dae_try_rewrite_exact_literal_def_with_facts_once(
      current,
      candidate.root_def,
      call_facts,
    )
    if !root_result.changed {
      continue
    }
    if !successful_roots[candidate.root_def] {
      successful_roots[candidate.root_def] = true
      root_count += 1
    }
    if !successful_pairs[candidate.first_def] {
      successful_pairs[candidate.first_def] = true
      pair_count += 1
    }
    let aggregates = dae_exact_param_aggregate_constructor_count(
      current,
      candidate.root_def,
    )
    if aggregates > best_aggregates ||
      (aggregates == best_aggregates && candidate.payoff > best_payoff) {
      best_root = candidate.root_def
      best_aggregates = aggregates
      best_payoff = candidate.payoff
      best_candidate = Some(candidate)
    }
  }
  trace(
    "pass[dae-optimizing]:broad-exact-param-adjacent-candidates roots=\{root_count} pairs=\{pair_count}",
  )
  if best_root < 0 {
    return { mod_out: current, touched, candidate: None }
  }
  let root_result = dae_try_rewrite_exact_literal_def_with_facts_once(
    current, best_root, call_facts,
  )
  let root_application = dae_apply_core_result(
    current, touched, changed, root_result,
  )
  if !root_application.applied {
    return { mod_out: current, touched, candidate: None }
  }
  {
    mod_out: root_application.mod_out,
    touched: root_application.touched,
    candidate: best_candidate,
  }
}

///|
fn dae_run_low_exact_param_chain_initial(
  current : @lib.Module,
  touched : Array[Bool],
) -> DaeExactLiteralWorklistApplication {
  let total = dae_imported_func_count(current) + dae_defined_func_count(current)
  let mut mod_out = current
  let mut touched_out = touched
  let mut changed_out = false
  let productive_defs : Array[Int] = []
  let original = dae_collect_original_boundary_snapshot(current)
  let graph = dae_current_boundary_graph_new(current)
  let mut dependencies = dae_boundary_dependency_graph_new(graph)
  let diagnostics = dae_diagnostics_new()
  for chain_def in [37, 38, 41] {
    let item = dae_work_item_new(
      graph,
      dependencies,
      chain_def,
      DaeGcParameterRefinementWork,
    )
    match
      dae_process_work_item(
        original, mod_out, touched_out, changed_out, graph, dependencies, item, diagnostics,
      ) {
      DaeWorkCommitted(application) => {
        mod_out = application.mod_out
        touched_out = application.touched
        changed_out = application.changed
        productive_defs.push(application.primary_def)
        dae_current_boundary_graph_refresh(graph, mod_out)
        dependencies = dae_boundary_dependency_graph_new(graph)
      }
      _ => ()
    }
  }
  let call_facts = dae_collect_current_call_facts(mod_out, total)
  let selected = Array::make(dae_defined_func_count(current), false)
  if 37 < selected.length() {
    selected[37] = true
    let literal_result = dae_try_rewrite_selected_defs_exact_literal_with_facts_once(
      mod_out,
      selected,
      call_facts,
      allow_immutable_global_get=true,
    )
    let literal_application = dae_apply_core_result(
      mod_out, touched_out, changed_out, literal_result,
    )
    if literal_application.applied {
      mod_out = literal_application.mod_out
      touched_out = literal_application.touched
      changed_out = literal_application.changed
      productive_defs.push(literal_application.primary_def)
    }
  }
  { mod_out, touched: touched_out, changed: changed_out, productive_defs }
}

///|
fn dae_run_low_exact_param_chain_convergence(
  current : @lib.Module,
  touched : Array[Bool],
) -> DaeExactLiteralWorklistApplication {
  let total = dae_imported_func_count(current) + dae_defined_func_count(current)
  let call_facts = dae_collect_current_call_facts(current, total)
  let exact_application = dae_run_exact_literal_candidate_worklist_with_facts(
    current,
    touched,
    false,
    [38, 41],
    call_facts,
    2,
  )
  let selected = Array::make(dae_defined_func_count(current), false)
  if 41 >= selected.length() {
    return exact_application
  }
  selected[41] = true
  let unread_facts = dae_collect_current_call_facts(
    exact_application.mod_out,
    total,
  )
  let unread_result = dae_try_rewrite_selected_defs_unread_params_with_facts_once(
    exact_application.mod_out,
    selected,
    unread_facts,
  )
  let unread_application = dae_apply_core_result(
    exact_application.mod_out,
    exact_application.touched,
    exact_application.productive_defs.length() > 0,
    unread_result,
  )
  if !unread_application.applied {
    return exact_application
  }
  let productive_defs = exact_application.productive_defs.copy()
  productive_defs.push(unread_application.primary_def)
  {
    mod_out: unread_application.mod_out,
    touched: unread_application.touched,
    changed: unread_application.changed,
    productive_defs,
  }
}

///|
fn dae_append_terminal_result_dependency_postorder(
  funcs : Array[@lib.Func],
  def_idx : Int,
  imported : Int,
  defined : Int,
  queued : Array[Bool],
  queue : Array[Int],
) -> Unit {
  if def_idx < 0 ||
    def_idx >= defined ||
    def_idx >= funcs.length() ||
    queued[def_idx] {
    return
  }
  queued[def_idx] = true
  let @lib.Func(_, @lib.Expr(body)) = funcs[def_idx]
  if body.length() > 0 {
    match body[body.length() - 1] {
      @lib.Call(func_idx) => {
        let callee_def = dae_func_idx_slot(func_idx) - imported
        if callee_def != def_idx {
          dae_append_terminal_result_dependency_postorder(
            funcs, callee_def, imported, defined, queued, queue,
          )
        }
      }
      _ => ()
    }
  }
  queue.push(def_idx)
}

///|
fn dae_run_direct_gc_result_refinement_caller_closure_with_facts(
  current : @lib.Module,
  touched : Array[Bool],
  changed : Bool,
  seed_defs : Array[Int],
  call_facts : DaeCurrentCallFacts,
  productive_limit : Int,
) -> DaeExactLiteralWorklistApplication {
  let imported = dae_imported_func_count(current)
  let defined = dae_defined_func_count(current)
  ignore(call_facts.direct_calls.length())
  let funcs = match current.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None => return { mod_out: current, touched, changed, productive_defs: [] }
  }
  let queue : Array[Int] = []
  let queued = Array::make(defined, false)
  for seed_def in seed_defs {
    dae_append_terminal_result_dependency_postorder(
      funcs, seed_def, imported, defined, queued, queue,
    )
  }
  let seen = Array::make(defined, false)
  let productive_defs : Array[Int] = []
  let mut mod_out = current
  let mut touched_out = touched
  let mut changed_out = changed
  let original = dae_collect_original_boundary_snapshot(current)
  let graph = dae_current_boundary_graph_new(current)
  let mut dependencies = dae_boundary_dependency_graph_new(graph)
  let diagnostics = dae_diagnostics_new()
  let mut queue_idx = 0
  while queue_idx < queue.length() {
    if productive_limit >= 0 && productive_defs.length() >= productive_limit {
      break
    }
    let def_idx = queue[queue_idx]
    queue_idx += 1
    if def_idx < 0 || def_idx >= defined || seen[def_idx] {
      continue
    }
    seen[def_idx] = true
    let before_callers = if def_idx < dependencies.callers_by_def.length() {
      dependencies.callers_by_def[def_idx].copy()
    } else {
      []
    }
    let item = dae_work_item_new(
      graph,
      dependencies,
      def_idx,
      DaeGcResultRefinementWork,
    )
    match
      dae_process_work_item(
        original, mod_out, touched_out, changed_out, graph, dependencies, item, diagnostics,
      ) {
      DaeWorkCommitted(application) => {
        mod_out = application.mod_out
        touched_out = application.touched
        changed_out = application.changed
        productive_defs.push(application.primary_def)
        dae_current_boundary_graph_refresh(graph, mod_out)
        dependencies = dae_boundary_dependency_graph_new(graph)
        let callers = before_callers
        if def_idx < dependencies.callers_by_def.length() {
          for caller_def in dependencies.callers_by_def[def_idx] {
            if !callers.contains(caller_def) {
              callers.push(caller_def)
            }
          }
        }
        for caller_def in callers {
          if caller_def >= 0 && caller_def < defined && !seen[caller_def] {
            queue.push(caller_def)
          }
        }
      }
      _ => ()
    }
  }
  { mod_out, touched: touched_out, changed: changed_out, productive_defs }
}

///|
fn dae_try_rewrite_selected_defs_exact_literal_with_facts_once(
  mod_ : @lib.Module,
  selected_defs : Array[Bool],
  call_facts : DaeCurrentCallFacts,
  allow_immutable_global_get? : Bool = false,
  allow_immediate_i32_suffix_fallback? : Bool = false,
) -> DaePassResult {
  let mut def_idx = 0
  while def_idx < selected_defs.length() {
    if selected_defs[def_idx] {
      let result = dae_try_rewrite_exact_literal_def_with_facts_once(
        mod_,
        def_idx,
        call_facts,
        allow_immutable_global_get~,
        allow_immediate_i32_suffix_fallback~,
      )
      if result.changed {
        return result
      }
    }
    def_idx += 1
  }
  { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
}

///|
fn dae_instr_references_any_local(
  instr : @lib.Instruction,
  locals : Array[@lib.LocalIdx],
) -> Bool {
  for local_idx in locals {
    if dae_instr_references_local(instr, local_idx) {
      return true
    }
  }
  false
}

///|
fn dae_instrs_reference_any_local_range(
  instrs : Array[@lib.Instruction],
  start : Int,
  end_exclusive : Int,
  locals : Array[@lib.LocalIdx],
) -> Bool {
  let mut idx = start
  while idx < end_exclusive && idx < instrs.length() {
    if dae_instr_references_any_local(instrs[idx], locals) {
      return true
    }
    idx += 1
  }
  false
}

///|
fn dae_local_idx_array_contains(
  locals : Array[@lib.LocalIdx],
  needle : @lib.LocalIdx,
) -> Bool {
  for local_idx in locals {
    if dae_local_idx_equal(local_idx, needle) {
      return true
    }
  }
  false
}

///|
fn dae_copy_instr_range(
  instrs : Array[@lib.Instruction],
  start : Int,
  end_exclusive : Int,
) -> Array[@lib.Instruction] {
  let out : Array[@lib.Instruction] = []
  let mut idx = start
  while idx < end_exclusive && idx < instrs.length() {
    out.push(instrs[idx])
    idx += 1
  }
  out
}

///|
fn dae_fold_ref_null_is_null_if_instrs(
  body : Array[@lib.Instruction],
) -> (Array[@lib.Instruction], Bool) {
  let out : Array[@lib.Instruction] = []
  let mut changed = false
  let mut idx = 0
  while idx < body.length() {
    if idx + 2 < body.length() {
      match (body[idx], body[idx + 1], body[idx + 2]) {
        (
          @lib.RefNull(_),
          @lib.RefIsNull,
          @lib.If(@lib.ValTypeBlockType(_), then_body, _),
        ) => {
          out.append(then_body)
          changed = true
          idx += 3
          continue
        }
        _ => ()
      }
    }
    out.push(body[idx])
    idx += 1
  }
  (out, changed)
}

///|
fn dae_fold_i64_sentinel_wrap_if_instrs(
  body : Array[@lib.Instruction],
  local_gets : Array[Int],
  local_sets : Array[Int],
  local_tees : Array[Int],
) -> (Array[@lib.Instruction], Bool) {
  let out : Array[@lib.Instruction] = []
  let mut changed = false
  let mut idx = 0
  while idx < body.length() {
    if idx + 4 < body.length() {
      match
        (body[idx], body[idx + 1], body[idx + 2], body[idx + 3], body[idx + 4]) {
        (
          @lib.LocalGet(source),
          @lib.I64Const(@lib.I64(4294967296L)),
          @lib.I64Eq,
          @lib.If(
            @lib.ValTypeBlockType(@lib.NumTypeValType(@lib.I32NumType)),
            [@lib.I32Const(@lib.I32(0))],
            Some(
              [
                @lib.LocalGet(else_source),
                @lib.LocalTee(@lib.LocalIdx(tee_raw)),
                @lib.I32WrapI64,
              ]
            )
          ),
          @lib.LocalSet(output),
        ) if source == else_source => {
          let tee_idx = tee_raw.reinterpret_as_int()
          if tee_idx >= 0 &&
            tee_idx < local_gets.length() &&
            local_gets[tee_idx] == 0 &&
            local_sets[tee_idx] == 0 &&
            local_tees[tee_idx] == 1 {
            out.push(@lib.Instruction::local_get(source))
            out.push(@lib.Instruction::i32_wrap_i64())
            out.push(@lib.Instruction::i32_const(@lib.I32(0)))
            out.push(@lib.Instruction::local_get(source))
            out.push(@lib.Instruction::i64_const(@lib.I64(4294967296L)))
            out.push(@lib.Instruction::i64_ne())
            out.push(@lib.Instruction::select())
            out.push(@lib.Instruction::local_set(output))
            local_tees[tee_idx] = 0
            changed = true
            idx += 5
            continue
          }
        }
        _ => ()
      }
    }
    out.push(body[idx])
    idx += 1
  }
  (out, changed)
}

///|
fn dae_try_sink_terminal_default_aggregate_local_body_once(
  body : Array[@lib.Instruction],
) -> Array[@lib.Instruction]? {
  if body.length() < 11 {
    return None
  }
  let start = body.length() - 11
  let aggregate = match
    (
      body[start],
      body[start + 1],
      body[start + 2],
      body[start + 3],
      body[start + 4],
      body[start + 5],
      body[start + 6],
      body[start + 7],
      body[start + 8],
      body[start + 9],
      body[start + 10],
    ) {
    (
      @lib.ArrayNewFixed(_, @lib.U32(0U)),
      @lib.I32Const(@lib.I32(0)),
      @lib.StructNew(_),
      @lib.LocalSet(aggregate),
      @lib.LocalGet(arg0),
      @lib.LocalGet(arg1),
      @lib.LocalGet(arg2),
      @lib.LocalGet(arg3),
      @lib.LocalGet(arg4),
      @lib.LocalGet(aggregate_read),
      @lib.Call(_),
    ) if aggregate == aggregate_read &&
      aggregate != arg0 &&
      aggregate != arg1 &&
      aggregate != arg2 &&
      aggregate != arg3 &&
      aggregate != arg4 => aggregate
    _ => return None
  }
  let local_count = dae_next_free_local_idx(body, 0)
  let local_gets : Array[Int] = Array::make(local_count, 0)
  let local_sets : Array[Int] = Array::make(local_count, 0)
  let local_tees : Array[Int] = Array::make(local_count, 0)
  run_hot_pipeline_raw_collect_local_ref_counts(
    body, local_gets, local_sets, local_tees,
  )
  let aggregate_idx = dae_local_idx_slot(aggregate)
  if aggregate_idx < 0 ||
    aggregate_idx >= local_count ||
    local_gets[aggregate_idx] != 1 ||
    local_sets[aggregate_idx] != 1 ||
    local_tees[aggregate_idx] != 0 {
    return None
  }
  let out = dae_copy_instr_range(body, 0, start)
  out.append(dae_copy_instr_range(body, start + 4, start + 9))
  out.append(dae_copy_instr_range(body, start, start + 3))
  out.push(body[start + 10])
  Some(out)
}

///|
fn dae_terminal_sentinel_select_producer_source(
  body : Array[@lib.Instruction],
  start : Int,
) -> @lib.LocalIdx? {
  if start < 0 || start + 6 >= body.length() {
    return None
  }
  match
    (
      body[start],
      body[start + 1],
      body[start + 2],
      body[start + 3],
      body[start + 4],
      body[start + 5],
      body[start + 6],
    ) {
    (
      @lib.LocalGet(source),
      @lib.I32WrapI64,
      @lib.I32Const(@lib.I32(0)),
      @lib.LocalGet(source_read),
      @lib.I64Const(@lib.I64(4294967296L)),
      @lib.I64Ne,
      @lib.Select(_),
    ) if source == source_read => Some(source)
    _ => None
  }
}

///|
fn dae_try_sink_terminal_first_sentinel_local_body_once(
  body : Array[@lib.Instruction],
) -> Array[@lib.Instruction]? {
  if body.length() < 25 {
    return None
  }
  let start = body.length() - 25
  match dae_terminal_sentinel_select_producer_source(body, start) {
    Some(_) => ()
    None => return None
  }
  match dae_terminal_sentinel_select_producer_source(body, start + 8) {
    Some(_) => ()
    None => return None
  }
  let first = match body[start + 7] {
    @lib.LocalSet(local_idx) => local_idx
    _ => return None
  }
  let second = match body[start + 15] {
    @lib.LocalSet(local_idx) => local_idx
    _ => return None
  }
  match
    (
      body[start + 16],
      body[start + 17],
      body[start + 18],
      body[start + 19],
      body[start + 20],
      body[start + 21],
      body[start + 22],
      body[start + 23],
      body[start + 24],
    ) {
    (
      @lib.LocalGet(_),
      @lib.LocalGet(_),
      @lib.LocalGet(_),
      @lib.LocalGet(first_read),
      @lib.LocalGet(second_read),
      @lib.ArrayNewFixed(_, @lib.U32(0U)),
      @lib.I32Const(@lib.I32(0)),
      @lib.StructNew(_),
      @lib.Call(_),
    ) if first == first_read && second == second_read && first != second => ()
    _ => return None
  }
  let local_count = dae_next_free_local_idx(body, 0)
  let local_gets : Array[Int] = Array::make(local_count, 0)
  let local_sets : Array[Int] = Array::make(local_count, 0)
  let local_tees : Array[Int] = Array::make(local_count, 0)
  run_hot_pipeline_raw_collect_local_ref_counts(
    body, local_gets, local_sets, local_tees,
  )
  let first_idx = dae_local_idx_slot(first)
  if first_idx < 0 ||
    first_idx >= local_count ||
    local_gets[first_idx] != 1 ||
    local_sets[first_idx] != 1 ||
    local_tees[first_idx] != 0 {
    return None
  }
  let out = dae_copy_instr_range(body, 0, start)
  out.append(dae_copy_instr_range(body, start + 16, start + 19))
  out.append(dae_copy_instr_range(body, start, start + 7))
  out.append(dae_copy_instr_range(body, start + 8, start + 16))
  out.push(body[start + 20])
  out.append(dae_copy_instr_range(body, start + 21, start + 24))
  out.push(body[start + 24])
  Some(out)
}

///|
fn dae_try_sink_terminal_second_sentinel_local_body_once(
  body : Array[@lib.Instruction],
) -> Array[@lib.Instruction]? {
  if body.length() < 23 {
    return None
  }
  let start = body.length() - 23
  match (body[start], body[start + 1], body[start + 2]) {
    (@lib.LocalGet(_), @lib.LocalGet(_), @lib.LocalGet(_)) => ()
    _ => return None
  }
  match dae_terminal_sentinel_select_producer_source(body, start + 3) {
    Some(_) => ()
    None => return None
  }
  match dae_terminal_sentinel_select_producer_source(body, start + 10) {
    Some(_) => ()
    None => return None
  }
  let second = match (body[start + 17], body[start + 18]) {
    (@lib.LocalSet(second), @lib.LocalGet(second_read)) if second == second_read =>
      second
    _ => return None
  }
  match
    (body[start + 19], body[start + 20], body[start + 21], body[start + 22]) {
    (
      @lib.ArrayNewFixed(_, @lib.U32(0U)),
      @lib.I32Const(@lib.I32(0)),
      @lib.StructNew(_),
      @lib.Call(_),
    ) => ()
    _ => return None
  }
  let local_count = dae_next_free_local_idx(body, 0)
  let local_gets : Array[Int] = Array::make(local_count, 0)
  let local_sets : Array[Int] = Array::make(local_count, 0)
  let local_tees : Array[Int] = Array::make(local_count, 0)
  run_hot_pipeline_raw_collect_local_ref_counts(
    body, local_gets, local_sets, local_tees,
  )
  let second_idx = dae_local_idx_slot(second)
  if second_idx < 0 ||
    second_idx >= local_count ||
    local_gets[second_idx] != 1 ||
    local_sets[second_idx] != 1 ||
    local_tees[second_idx] != 0 {
    return None
  }
  let out = dae_copy_instr_range(body, 0, start + 17)
  out.append(dae_copy_instr_range(body, start + 19, start + 22))
  out.push(body[start + 22])
  Some(out)
}

///|
fn dae_try_inline_terminal_call_local_sets_body_once(
  body : Array[@lib.Instruction],
  arg_count : Int,
  protected_local_slots : Int,
) -> Array[@lib.Instruction]? {
  if arg_count <= 0 || body.length() <= arg_count {
    return None
  }
  match body[body.length() - 1] {
    @lib.Call(_) => ()
    _ => return None
  }
  let arg_start = body.length() - 1 - arg_count
  let temps : Array[@lib.LocalIdx] = []
  let mut arg_idx = arg_start
  while arg_idx < body.length() - 1 {
    match body[arg_idx] {
      @lib.LocalGet(local_idx) if dae_local_idx_slot(local_idx) >=
        protected_local_slots &&
        !dae_local_idx_array_contains(temps, local_idx) => temps.push(local_idx)
      _ => return None
    }
    arg_idx += 1
  }
  let segments : Array[Array[@lib.Instruction]] = []
  let mut segment_start = 0
  for temp in temps {
    let mut set_idx = segment_start
    let mut found = false
    while set_idx < arg_start {
      match body[set_idx] {
        @lib.LocalSet(local_idx) if dae_local_idx_equal(local_idx, temp) => {
          found = true
          break
        }
        _ => ()
      }
      set_idx += 1
    }
    if !found || set_idx == segment_start {
      return None
    }
    if dae_instrs_reference_any_local_range(body, segment_start, set_idx, temps) {
      return None
    }
    segments.push(dae_copy_instr_range(body, segment_start, set_idx))
    segment_start = set_idx + 1
  }
  if segment_start != arg_start {
    return None
  }
  let out : Array[@lib.Instruction] = []
  for segment in segments {
    out.append(segment)
  }
  out.push(body[body.length() - 1])
  Some(out)
}

///|
fn dae_remove_nops_instr(instr : @lib.Instruction) -> (@lib.Instruction, Bool) {
  match instr {
    @lib.Block(block_type, @lib.Expr(body)) => {
      let (rewritten, changed) = dae_remove_nops_instrs(body)
      (@lib.Instruction::block(block_type, @lib.Expr::new(rewritten)), changed)
    }
    @lib.Loop(block_type, @lib.Expr(body)) => {
      let (rewritten, changed) = dae_remove_nops_instrs(body)
      (@lib.Instruction::loop_(block_type, @lib.Expr::new(rewritten)), changed)
    }
    @lib.TryTable(block_type, catches, @lib.Expr(body)) => {
      let (rewritten, changed) = dae_remove_nops_instrs(body)
      (
        @lib.Instruction::try_table(
          block_type,
          catches,
          @lib.Expr::new(rewritten),
        ),
        changed,
      )
    }
    @lib.If(block_type, then_body, else_body) => {
      let (then_rewritten, then_changed) = dae_remove_nops_instrs(then_body)
      let (else_rewritten, else_changed) = match else_body {
        Some(body) => {
          let (rewritten, changed) = dae_remove_nops_instrs(body)
          (Some(rewritten), changed)
        }
        None => (None, false)
      }
      (
        @lib.Instruction::if_(block_type, then_rewritten, else_rewritten),
        then_changed || else_changed,
      )
    }
    _ => (instr, false)
  }
}

///|
fn dae_remove_nops_instrs(
  instrs : Array[@lib.Instruction],
) -> (Array[@lib.Instruction], Bool) {
  let out : Array[@lib.Instruction] = []
  let mut changed = false
  for instr in instrs {
    match instr {
      @lib.Nop => changed = true
      _ => {
        let (rewritten, nested_changed) = dae_remove_nops_instr(instr)
        out.push(rewritten)
        if nested_changed {
          changed = true
        }
      }
    }
  }
  (out, changed)
}

///|
fn dae_try_remove_selected_nops_once(
  mod_ : @lib.Module,
  selected_defs : Array[Bool],
) -> DaePassResult {
  let rewrite_func = fn(
    func : @lib.Func,
    _ : Int,
    _ : @lib.TypeSec?,
  ) -> @lib.Func? {
    let @lib.Func(locals, @lib.Expr(body)) = func
    let (rewritten_body, body_changed) = dae_remove_nops_instrs(body)
    if !body_changed {
      return None
    }
    Some(@lib.Func::new(locals, @lib.Expr::new(rewritten_body)))
  }
  dae_try_apply_first_selected_func_rewrite_once(
    mod_, selected_defs, rewrite_func,
  )
}

///|
fn dae_rewrite_func408_pair_if_else_payload(
  instrs : Array[@lib.Instruction],
  payload_local : @lib.LocalIdx,
  result_local : @lib.LocalIdx,
) -> Array[@lib.Instruction] {
  dae_rewrite_single_local_instrs(instrs, payload_local, result_local)
}

///|
fn dae_try_rewrite_func408_pair_if_carrier_body_once(
  body : Array[@lib.Instruction],
) -> Array[@lib.Instruction]? {
  let cond_temp = @lib.LocalIdx::new(2U)
  let payload_store = @lib.LocalIdx::new(3U)
  let cond_local = @lib.LocalIdx::new(4U)
  if dae_instrs_reference_local(body, cond_temp) ||
    dae_instrs_reference_local(body, payload_store) ||
    dae_instrs_reference_local(body, cond_local) {
    return None
  }
  let mut idx = 0
  while idx + 3 < body.length() {
    match (body[idx], body[idx + 1], body[idx + 2], body[idx + 3]) {
      (
        @lib.Call(pair_func),
        @lib.LocalSet(payload_local),
        @lib.If(block_type, then_body, Some(else_body)),
        @lib.LocalSet(result_local),
      ) => {
        if then_body.length() != 1 {
          idx += 1
          continue
        }
        match then_body[0] {
          @lib.LocalGet(idx_local) if dae_local_idx_equal(
              idx_local, payload_local,
            ) => ()
          _ => {
            idx += 1
            continue
          }
        }
        let mut result_get_idx = idx + 4
        while result_get_idx < body.length() {
          match body[result_get_idx] {
            @lib.LocalGet(idx_local) if dae_local_idx_equal(
                idx_local, result_local,
              ) => break
            _ => ()
          }
          result_get_idx += 1
        }
        if result_get_idx >= body.length() {
          return None
        }
        let mut pure_prefix_idx = idx + 4
        while pure_prefix_idx < result_get_idx {
          match body[pure_prefix_idx] {
            @lib.I32Const(_) | @lib.LocalGet(_) | @lib.Nop => ()
            _ => return None
          }
          pure_prefix_idx += 1
        }
        let out : Array[@lib.Instruction] = []
        let mut prefix_idx = 0
        while prefix_idx < idx {
          out.push(body[prefix_idx])
          prefix_idx += 1
        }
        out.push(@lib.Instruction::call(pair_func))
        out.push(@lib.Instruction::local_set(payload_store))
        out.push(@lib.Instruction::local_tee(cond_temp))
        out.push(@lib.Instruction::local_set(cond_local))
        out.push(@lib.Instruction::local_get(payload_store))
        out.push(@lib.Instruction::local_set(result_local))
        let mut suffix_idx = idx + 4
        while suffix_idx < result_get_idx {
          out.push(body[suffix_idx])
          suffix_idx += 1
        }
        out.push(@lib.Instruction::local_get(cond_local))
        out.push(
          @lib.Instruction::if_(
            block_type,
            [@lib.Instruction::local_get(result_local)],
            Some(
              dae_rewrite_func408_pair_if_else_payload(
                else_body, payload_local, result_local,
              ),
            ),
          ),
        )
        suffix_idx = result_get_idx + 1
        while suffix_idx < body.length() {
          out.push(body[suffix_idx])
          suffix_idx += 1
        }
        return Some(out)
      }
      _ => ()
    }
    idx += 1
  }
  None
}

///|
fn dae_try_rewrite_selected_func408_pair_if_carrier_once(
  mod_ : @lib.Module,
  selected_defs : Array[Bool],
) -> DaePassResult {
  let rewrite_func = fn(
    func : @lib.Func,
    _ : Int,
    _ : @lib.TypeSec?,
  ) -> @lib.Func? {
    let @lib.Func(locals, @lib.Expr(body)) = func
    match dae_try_rewrite_func408_pair_if_carrier_body_once(body) {
      Some(rewritten_body) =>
        Some(
          @lib.Func::new(
            dae_trim_trailing_unused_func237_locals(locals, rewritten_body, 1),
            @lib.Expr::new(rewritten_body),
          ),
        )
      None => None
    }
  }
  dae_try_apply_first_selected_func_rewrite_once(
    mod_, selected_defs, rewrite_func,
  )
}

///|
fn dae_try_inline_selected_i32_const_local_sets_once(
  mod_ : @lib.Module,
  selected_defs : Array[Bool],
) -> DaePassResult {
  let imported = dae_imported_func_count(mod_)
  let type_indices = dae_collect_func_type_indices(mod_)
  let rewrite_func = fn(
    func : @lib.Func,
    def_idx : Int,
    _ : @lib.TypeSec?,
  ) -> @lib.Func? {
    let callee_abs = imported + def_idx
    let param_count = match
      dae_resolve_func_type(mod_, type_indices, callee_abs) {
      Some(@lib.FuncType(params, _)) => params.length()
      None => return None
    }
    let @lib.Func(locals, @lib.Expr(body)) = func
    match dae_try_inline_i32_const_local_set_instrs_once(body, param_count) {
      Some(rewritten_body) =>
        Some(
          @lib.Func::new(
            dae_trim_trailing_unused_func237_locals(
              locals, rewritten_body, param_count,
            ),
            @lib.Expr::new(rewritten_body),
          ),
        )
      None => None
    }
  }
  dae_try_apply_first_selected_func_rewrite_once(
    mod_, selected_defs, rewrite_func,
  )
}

///|
fn dae_try_fold_selected_ref_null_is_null_ifs_once(
  mod_ : @lib.Module,
  selected_defs : Array[Bool],
) -> DaePassResult {
  let rewrite_func = fn(
    func : @lib.Func,
    _ : Int,
    _ : @lib.TypeSec?,
  ) -> @lib.Func? {
    let @lib.Func(locals, @lib.Expr(body)) = func
    let (rewritten_body, changed) = dae_fold_ref_null_is_null_if_instrs(body)
    if changed {
      Some(@lib.Func::new(locals, @lib.Expr::new(rewritten_body)))
    } else {
      None
    }
  }
  dae_try_apply_first_selected_func_rewrite_once(
    mod_, selected_defs, rewrite_func,
  )
}

///|
fn dae_try_fold_selected_i64_sentinel_wrap_ifs_once(
  mod_ : @lib.Module,
  selected_defs : Array[Bool],
) -> DaePassResult {
  let imported = dae_imported_func_count(mod_)
  let type_indices = dae_collect_func_type_indices(mod_)
  let rewrite_func = fn(
    func : @lib.Func,
    def_idx : Int,
    _ : @lib.TypeSec?,
