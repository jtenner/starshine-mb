  active_parameterized_nonself_call_count : Int
  nonself_undropped_call_count : Int
  self_call_count : Int
  private_result_dead_suffix_calls_from_escaped_operand_callees : Int
  escaped_dead_suffix_call_count : Int
  dead_suffix_undropped_self_call : Bool
  dead_suffix_dropped_self_call : Bool
  dead_suffix_block_undropped_self_call : Bool
  dead_suffix_result_calls_from_undropped_self_caller : Int
  dead_suffix_result_calls_from_no_param_undropped_self_caller : Int
  dead_suffix_same_self_result_operand_call : Bool
  dead_suffix_undropped_self_call_param_operand : Bool
  dead_suffix_result_other_call : Bool
  dead_suffix_dropped_escaped_result_call : Bool
  dead_suffix_mutual_call : Bool
  dead_suffix_calls_from_param_operand_self_result_caller : Int
  dead_suffix_escaped_result_operand_call_count : Int
  dead_suffix_dropped_calls_from_parameterized_self_caller : Int
}

///|
priv struct DaeOriginalResultBoundaryRow {
  preservation : DaeOriginalResultPreservationRow
  escape : DaeOriginalResultEscapeRow
  side_call : DaeOriginalResultSideCallRow
  prune : DaeOriginalResultRemovalPruneRow
}

///|
priv struct DaeOriginalResultEscapeRow {
  private_result_escaped_operand_call_count : Int
  dead_suffix_undropped_escaped_result_call : Bool
  private_result_dead_suffix_calls_from_escaped_operand_callees : Int
  escaped_dead_suffix_call_count : Int
  dead_suffix_result_calls_from_undropped_self_caller : Int
  dead_suffix_result_calls_from_no_param_undropped_self_caller : Int
  dead_suffix_calls_from_param_operand_self_result_caller : Int
  dead_suffix_escaped_result_operand_call_count : Int
}

///|
priv struct DaeOriginalResultSideCallRow {
  dead_suffix_other_call : Bool
  dead_suffix_result_other_call : Bool
  dead_suffix_self_recursive_void_side_call : Bool
  dead_suffix_self_recursive_result_side_call : Bool
  dead_suffix_mutual_call : Bool
}

///|
priv struct DaeOriginalResultRemovalPruneRow {
  param_count : Int
  call_count : Int
  active_nonself_call_count : Int
  active_parameterized_nonself_call_count : Int
  active_parameterized_result_nonself_call_count : Int
  nonself_undropped_call_count : Int
  self_call_count : Int
  escaped_dead_suffix_call_count : Int
  dead_suffix_undropped_self_call : Bool
  dead_suffix_dropped_self_call : Bool
  dead_suffix_block_undropped_self_call : Bool
  dead_suffix_same_self_result_operand_call : Bool
  dead_suffix_dropped_self_call_full_param_forward : Bool
  dead_suffix_dropped_escaped_result_call : Bool
  dead_suffix_dropped_earlier_result_call : Bool
  later_dead_suffix_dropped_call_count : Int
  dead_suffix_mutual_call : Bool
  private_result_dead_suffix_call_count : Int
  dead_suffix_result_other_call : Bool
  dead_suffix_dropped_calls_from_no_param_result_caller : Int
  dead_suffix_mixed_dropped_undropped_call_count : Int
}

///|
priv struct DaeOriginalResultRemovalPruneEvidence {
  dropped_self_result_with_void_side_callers : Bool
  later_mutual_dropped_result : Bool
  mixed_dropped_undropped_caller : Bool
  dropped_only_private_result_side_caller : Bool
  dropped_only_no_param_result_side_caller : Bool
  params_absent_result_cleanup_prune : Bool
  uncalled_after_param_cleanup_prune : Bool
}

///|
priv struct DaeOriginalResultBoundaryEvidence {
  preservation : DaeOriginalResultPreservationEvidence
  cleanup_preservation : DaeOriginalResultCleanupPreservationEvidence
  prune : DaeOriginalResultRemovalPruneEvidence
}

///|
priv struct DaeOriginalDeadSuffixSideCallEvidence {
  dead_suffix_undropped_self_call : Bool
  dead_suffix_mutual_call : Bool
  void_side_cleanup_preservation : Bool
  result_side_chain_preservation : Bool
  same_self_result_operand_preservation : Bool
}

///|
fn dae_make_call_boundary_facts(
  escaped : Array[Bool],
  tail_calls : Array[Bool],
  direct_callers : Array[Array[Int]],
) -> DaeCallBoundaryFacts {
  { escaped, tail_calls, direct_callers, direct_calls: [], dropped_calls: [] }
}

///|
fn dae_call_boundary_facts_from_current(
  current : DaeCurrentCallFacts,
) -> DaeCallBoundaryFacts {
  {
    escaped: current.escaped,
    tail_calls: current.tail_calls,
    direct_callers: current.direct_callers,
    direct_calls: current.direct_calls,
    dropped_calls: current.dropped_calls,
  }
}

///|
fn dae_collect_module_boundary_snapshot(
  mod_ : @lib.Module,
) -> DaeModuleBoundarySnapshot {
  let imported = dae_imported_func_count(mod_)
  let defined = dae_defined_func_count(mod_)
  let total = imported + defined
  let analysis = dae_collect_current_function_analysis(mod_, total)
  let call_facts = analysis.call_facts
  let type_indices = dae_collect_func_type_indices(mod_)
  let function_types : Array[@lib.FuncType?] = []
  let mut func_abs = 0
  while func_abs < total {
    function_types.push(dae_resolve_func_type(mod_, type_indices, func_abs))
    func_abs += 1
  }
  {
    imported,
    defined,
    total,
    type_indices,
    function_types,
    funcs: match mod_.code_sec {
      Some(@lib.CodeSec(funcs)) => funcs
      None => []
    },
    call_facts,
    boundary_facts: dae_call_boundary_facts_from_current(call_facts),
    function_infos: analysis.function_infos,
  }
}

///|
fn dae_current_call_facts_equal(
  left : DaeCurrentCallFacts,
  right : DaeCurrentCallFacts,
) -> Bool {
  left.direct_calls == right.direct_calls &&
  left.tail_calls == right.tail_calls &&
  left.direct_callers == right.direct_callers &&
  left.dropped_calls == right.dropped_calls &&
  left.escaped == right.escaped
}

///|
fn dae_make_function_epochs(
  count : Int,
  signature_epoch : Int,
  body_epoch : Int,
) -> Array[DaeFunctionEpochs] {
  let epochs : Array[DaeFunctionEpochs] = []
  let mut def_idx = 0
  while def_idx < count {
    epochs.push({ signature_epoch, body_epoch })
    def_idx += 1
  }
  epochs
}

///|
fn dae_current_boundary_graph_new(
  mod_ : @lib.Module,
) -> DaeCurrentBoundaryGraph {
  let snapshot = dae_collect_module_boundary_snapshot(mod_)
  {
    mod_,
    snapshot,
    function_epochs: dae_make_function_epochs(snapshot.defined, 0, 0),
    module_epoch: 0,
    call_epoch: 0,
  }
}

///|
fn dae_boundary_candidate_epoch(
  graph : DaeCurrentBoundaryGraph,
  def_idx : Int,
) -> DaeCandidateEpoch {
  if def_idx < 0 || def_idx >= graph.function_epochs.length() {
    return {
      def_idx,
      module_epoch: graph.module_epoch,
      call_epoch: graph.call_epoch,
      signature_epoch: -1,
      body_epoch: -1,
    }
  }
  let epochs = graph.function_epochs[def_idx]
  {
    def_idx,
    module_epoch: graph.module_epoch,
    call_epoch: graph.call_epoch,
    signature_epoch: epochs.signature_epoch,
    body_epoch: epochs.body_epoch,
  }
}

///|
fn dae_candidate_epoch_is_current(
  graph : DaeCurrentBoundaryGraph,
  candidate : DaeCandidateEpoch,
) -> Bool {
  if candidate.def_idx < 0 ||
    candidate.def_idx >= graph.function_epochs.length() {
    return false
  }
  let epochs = graph.function_epochs[candidate.def_idx]
  candidate.module_epoch == graph.module_epoch &&
  candidate.call_epoch == graph.call_epoch &&
  candidate.signature_epoch == epochs.signature_epoch &&
  candidate.body_epoch == epochs.body_epoch
}

///|
fn dae_current_boundary_graph_refresh(
  graph : DaeCurrentBoundaryGraph,
  mod_ : @lib.Module,
) -> Unit {
  let previous = graph.snapshot
  let next = dae_collect_module_boundary_snapshot(mod_)
  let shape_changed = previous.imported != next.imported ||
    previous.defined != next.defined ||
    previous.total != next.total ||
    graph.function_epochs.length() != next.defined
  let mut changed = shape_changed
  if shape_changed {
    graph.function_epochs = dae_make_function_epochs(
      next.defined,
      graph.module_epoch + 1,
      graph.module_epoch + 1,
    )
  } else {
    let mut def_idx = 0
    while def_idx < next.defined {
      let previous_abs = previous.imported + def_idx
      let next_abs = next.imported + def_idx
      let signature_changed = previous_abs < 0 ||
        previous_abs >= previous.function_types.length() ||
        next_abs < 0 ||
        next_abs >= next.function_types.length() ||
        previous.function_types[previous_abs] != next.function_types[next_abs]
      if signature_changed {
        graph.function_epochs[def_idx].signature_epoch += 1
        changed = true
      }
      let body_changed = def_idx >= previous.funcs.length() ||
        def_idx >= next.funcs.length() ||
        previous.funcs[def_idx] != next.funcs[def_idx]
      if body_changed {
        graph.function_epochs[def_idx].body_epoch += 1
        changed = true
      }
      def_idx += 1
    }
  }
  if !dae_current_call_facts_equal(previous.call_facts, next.call_facts) {
    graph.call_epoch += 1
    changed = true
  }
  if changed {
    graph.module_epoch += 1
  }
  graph.mod_ = mod_
  graph.snapshot = next
}

///|
fn dae_dependency_adjacency_new(defined : Int) -> Array[Array[Int]] {
  let out : Array[Array[Int]] = []
  let mut def_idx = 0
  while def_idx < defined {
    out.push([])
    def_idx += 1
  }
  out
}

///|
fn dae_dependency_adjacency_copy(
  source : Array[Array[Int]],
) -> Array[Array[Int]] {
  let out : Array[Array[Int]] = []
  for row in source {
    out.push(row.copy())
  }
  out
}

///|
fn dae_dependency_adjacency_union(
  left : Array[Array[Int]],
  right : Array[Array[Int]],
) -> Array[Array[Int]] {
  let count = if left.length() > right.length() {
    left.length()
  } else {
    right.length()
  }
  let out = dae_dependency_adjacency_new(count)
  let mut def_idx = 0
  while def_idx < count {
    if def_idx < left.length() {
      for dependency in left[def_idx] {
        if !out[def_idx].contains(dependency) {
          out[def_idx].push(dependency)
        }
      }
    }
    if def_idx < right.length() {
      for dependency in right[def_idx] {
        if !out[def_idx].contains(dependency) {
          out[def_idx].push(dependency)
        }
      }
    }
    def_idx += 1
  }
  out
}

///|
fn dae_boundary_scc_visit(
  node : Int,
  edges : Array[Array[Int]],
  next_index : Array[Int],
  indices : Array[Int],
  lowlinks : Array[Int],
  stack : Array[Int],
  on_stack : Array[Bool],
  raw_component_by_def : Array[Int],
  raw_component_count : Array[Int],
) -> Unit {
  indices[node] = next_index[0]
  lowlinks[node] = next_index[0]
  next_index[0] += 1
  stack.push(node)
  on_stack[node] = true
  for dependency in edges[node] {
    if dependency < 0 || dependency >= edges.length() {
      continue
    }
    if indices[dependency] < 0 {
      dae_boundary_scc_visit(
        dependency, edges, next_index, indices, lowlinks, stack, on_stack, raw_component_by_def,
        raw_component_count,
      )
      if lowlinks[dependency] < lowlinks[node] {
        lowlinks[node] = lowlinks[dependency]
      }
    } else if on_stack[dependency] && indices[dependency] < lowlinks[node] {
      lowlinks[node] = indices[dependency]
    }
  }
  if lowlinks[node] != indices[node] {
    return
  }
  while stack.length() > 0 {
    let component_def = stack.pop().unwrap()
    on_stack[component_def] = false
    raw_component_by_def[component_def] = raw_component_count[0]
    if component_def == node {
      break
    }
  }
  raw_component_count[0] += 1
}

///|
fn dae_boundary_components(
  callees_by_def : Array[Array[Int]],
) -> (Array[Int], Array[Array[Int]]) {
  let defined = callees_by_def.length()
  let indices = Array::make(defined, -1)
  let lowlinks = Array::make(defined, -1)
  let on_stack = Array::make(defined, false)
  let stack : Array[Int] = []
  let raw_component_by_def = Array::make(defined, -1)
  let next_index = [0]
  let raw_component_count = [0]
  let mut def_idx = 0
  while def_idx < defined {
    if indices[def_idx] < 0 {
      dae_boundary_scc_visit(
        def_idx, callees_by_def, next_index, indices, lowlinks, stack, on_stack,
        raw_component_by_def, raw_component_count,
      )
    }
    def_idx += 1
  }
  let normalized_by_raw = Array::make(raw_component_count[0], -1)
  let component_by_def = Array::make(defined, -1)
  let component_members : Array[Array[Int]] = []
  def_idx = 0
  while def_idx < defined {
    let raw_component = raw_component_by_def[def_idx]
    if normalized_by_raw[raw_component] < 0 {
      normalized_by_raw[raw_component] = component_members.length()
      component_members.push([])
    }
    let component_id = normalized_by_raw[raw_component]
    component_by_def[def_idx] = component_id
    component_members[component_id].push(def_idx)
    def_idx += 1
  }
  (component_by_def, component_members)
}

///|
fn dae_record_parameter_forwarding_dependency(
  instrs : Array[@lib.Instruction],
  call_idx : Int,
  entry_stack_values : Int,
  current : @lib.Module,
  caller_def : Int,
  caller_param_count : Int,
  type_indices : Array[@lib.TypeIdx],
  target_abs : Int,
  direct_tail : Bool,
  function_epochs : Array[DaeFunctionEpochs],
  edges : Array[DaeParameterForwardingEdge],
  out : Array[Array[Int]],
) -> Unit {
  let imported = dae_imported_func_count(current)
  let target_def = target_abs - imported
  if target_def < 0 ||
    target_def >= out.length() ||
    caller_def < 0 ||
    caller_def >= function_epochs.length() ||
    target_def >= function_epochs.length() {
    return
  }
  let target_params = match
    dae_resolve_func_type(current, type_indices, target_abs) {
    Some(@lib.FuncType(params, _)) => params
    None => return
  }
  let caller_params = match
    dae_resolve_func_type(current, type_indices, imported + caller_def) {
    Some(@lib.FuncType(params, _)) => params
    None => return
  }
  if target_params.length() == 0 {
    return
  }
  let evidence = match
    dae_callsite_value_slice_evidence(
      instrs,
      call_idx,
      target_params.length(),
      entry_stack_values,
      current,
      type_indices,
    ) {
    Some(value) => value
    None => return
  }
  let mut param_idx = 0
  while param_idx < target_params.length() {
    match dae_callsite_single_instruction_actual(evidence, param_idx, instrs) {
      Some(actual) =>
        match actual.instr {
          @lib.LocalGet(local_idx) => {
            let local_slot = dae_local_idx_slot(local_idx)
            if local_slot >= 0 &&
              local_slot < caller_param_count &&
              local_slot < caller_params.length() &&
              caller_params[local_slot] == target_params[param_idx] {
              if !edges.any(fn(edge) {
                  edge.caller_def == caller_def &&
                  edge.caller_param_idx == local_slot &&
                  edge.callee_def == target_def &&
                  edge.callee_param_idx == param_idx &&
                  edge.direct_tail == direct_tail
                }) {
                let caller_epochs = function_epochs[caller_def]
                let callee_epochs = function_epochs[target_def]
                edges.push({
                  caller_def,
                  caller_param_idx: local_slot,
                  callee_def: target_def,
                  callee_param_idx: param_idx,
                  direct_tail,
                  source_type: caller_params[local_slot],
                  caller_signature_epoch: caller_epochs.signature_epoch,
                  caller_body_epoch: caller_epochs.body_epoch,
                  callee_signature_epoch: callee_epochs.signature_epoch,
                  callee_body_epoch: callee_epochs.body_epoch,
                })
              }
              if !out[target_def].contains(caller_def) {
                out[target_def].push(caller_def)
              }
            }
          }
          _ => ()
        }
      None => ()
    }
    param_idx += 1
  }
}

///|
fn dae_collect_parameter_forwarding_dependencies_instrs(
  instrs : Array[@lib.Instruction],
  entry_stack_values : Int,
  current : @lib.Module,
  caller_def : Int,
  caller_param_count : Int,
  type_indices : Array[@lib.TypeIdx],
  function_epochs : Array[DaeFunctionEpochs],
  edges : Array[DaeParameterForwardingEdge],
  out : Array[Array[Int]],
) -> Unit {
  let mut idx = 0
  while idx < instrs.length() {
    match instrs[idx] {
      @lib.Call(func_idx) =>
        dae_record_parameter_forwarding_dependency(
          instrs,
          idx,
          entry_stack_values,
          current,
          caller_def,
          caller_param_count,
          type_indices,
          dae_func_idx_slot(func_idx),
          false,
          function_epochs,
          edges,
          out,
        )
      @lib.ReturnCall(func_idx) =>
        dae_record_parameter_forwarding_dependency(
          instrs,
          idx,
          entry_stack_values,
          current,
          caller_def,
          caller_param_count,
          type_indices,
          dae_func_idx_slot(func_idx),
          true,
          function_epochs,
          edges,
          out,
        )
      @lib.Block(_, @lib.Expr(_))
      | @lib.Loop(_, @lib.Expr(_))
      | @lib.TryTable(_, _, @lib.Expr(_))
      | @lib.If(_, _, _) =>
        match dae_nested_control_children_evidence(instrs[idx], current) {
          Some(children) => {
            dae_collect_parameter_forwarding_dependencies_instrs(
              children.primary_body,
              children.entry_stack_values,
              current,
              caller_def,
              caller_param_count,
              type_indices,
              function_epochs,
              edges,
              out,
            )
            match children.secondary_body {
              Some(body) =>
                dae_collect_parameter_forwarding_dependencies_instrs(
                  body,
                  children.entry_stack_values,
                  current,
                  caller_def,
                  caller_param_count,
                  type_indices,
                  function_epochs,
                  edges,
                  out,
                )
              None => ()
            }
          }
          None => ()
        }
      _ => ()
    }
    idx += 1
  }
}

///|
fn dae_boundary_dependency_graph_new(
  graph : DaeCurrentBoundaryGraph,
) -> DaeBoundaryDependencyGraph {
  let imported = graph.snapshot.imported
  let defined = graph.snapshot.defined
  let callers_by_def = dae_dependency_adjacency_new(defined)
  let callees_by_def = dae_dependency_adjacency_new(defined)
  let return_callers_by_def = dae_dependency_adjacency_new(defined)
  let direct_callers = graph.snapshot.call_facts.direct_callers
  let mut callee_def = 0
  while callee_def < defined {
    let callee_abs = imported + callee_def
    if callee_abs >= 0 && callee_abs < direct_callers.length() {
      for caller_def in direct_callers[callee_abs] {
        if caller_def >= 0 && caller_def < defined {
          if !callers_by_def[callee_def].contains(caller_def) {
            callers_by_def[callee_def].push(caller_def)
          }
          if !callees_by_def[caller_def].contains(callee_def) {
            callees_by_def[caller_def].push(callee_def)
          }
        }
      }
    }
    callee_def += 1
  }
  let mut caller_def = 0
  while caller_def < defined &&
        caller_def < graph.snapshot.function_infos.length() {
    for callee_abs in graph.snapshot.function_infos[caller_def].tail_callees {
      let target_def = callee_abs - imported
      if target_def >= 0 &&
        target_def < defined &&
        !return_callers_by_def[target_def].contains(caller_def) {
        return_callers_by_def[target_def].push(caller_def)
      }
    }
    caller_def += 1
  }
  let parameter_forwarding_edges : Array[DaeParameterForwardingEdge] = []
  let parameter_forwarders_by_def = dae_dependency_adjacency_new(defined)
  caller_def = 0
  while caller_def < defined && caller_def < graph.snapshot.funcs.length() {
    let caller_abs = imported + caller_def
    let caller_param_count = match
      dae_resolve_func_type(graph.mod_, graph.snapshot.type_indices, caller_abs) {
      Some(@lib.FuncType(params, _)) => params.length()
      None => 0
    }
    let @lib.Func(_, @lib.Expr(body)) = graph.snapshot.funcs[caller_def]
    dae_collect_parameter_forwarding_dependencies_instrs(
      body,
      0,
      graph.mod_,
      caller_def,
      caller_param_count,
      graph.snapshot.type_indices,
      graph.function_epochs,
      parameter_forwarding_edges,
      parameter_forwarders_by_def,
    )
    caller_def += 1
  }
  let (component_by_def, component_members) = dae_boundary_components(
    callees_by_def,
  )
  let forwarding_adjacency = dae_dependency_adjacency_new(defined)
  let mut target_def = 0
  while target_def < parameter_forwarders_by_def.length() {
    for forwarder_def in parameter_forwarders_by_def[target_def] {
      if forwarder_def >= 0 && forwarder_def < defined {
        if !forwarding_adjacency[target_def].contains(forwarder_def) {
          forwarding_adjacency[target_def].push(forwarder_def)
        }
        if !forwarding_adjacency[forwarder_def].contains(target_def) {
          forwarding_adjacency[forwarder_def].push(target_def)
        }
      }
    }
    target_def += 1
  }
  let (forwarding_component_by_def, forwarding_component_members) = dae_boundary_components(
    forwarding_adjacency,
  )
  let caller_callee_dependencies = dae_dependency_adjacency_union(
    callers_by_def, callees_by_def,
  )
  {
    callers_by_def,
    callees_by_def,
    return_callers_by_def,
    parameter_forwarding_edges,
    parameter_forwarders_by_def,
    // Uniform-value evidence is invalidated by the bodies of every exact
    // current direct caller, but not by unrelated callees of the target.
    uniform_value_forwarders_by_def: dae_dependency_adjacency_copy(
      callers_by_def,
    ),
    result_forwarders_by_def: dae_dependency_adjacency_copy(
      caller_callee_dependencies,
    ),
    result_observers_by_def: dae_dependency_adjacency_copy(callers_by_def),
    tail_result_dependencies_by_def: dae_dependency_adjacency_copy(
      return_callers_by_def,
    ),
    type_dependencies_by_def: dae_dependency_adjacency_copy(
      caller_callee_dependencies,
    ),
    body_use_dependencies_by_def: dae_dependency_adjacency_copy(
      caller_callee_dependencies,
    ),
    nested_cleanup_dependencies_by_def: dae_dependency_adjacency_copy(
      caller_callee_dependencies,
    ),
    component_by_def,
    component_members,
    forwarding_component_by_def,
    forwarding_component_members,
  }
}

///|
fn dae_boundary_dependency_invalidations(
  before : DaeBoundaryDependencyGraph,
  after : DaeBoundaryDependencyGraph,
  touched : Array[Bool],
  primary_def : Int,
) -> Array[Int] {
  let defined = if before.callers_by_def.length() >
    after.callers_by_def.length() {
    before.callers_by_def.length()
  } else {
    after.callers_by_def.length()
  }
  let invalidated = Array::make(defined, false)
  let mut def_idx = 0
  while def_idx < defined {
    let is_touched = def_idx == primary_def ||
      (def_idx < touched.length() && touched[def_idx])
    if is_touched {
      invalidated[def_idx] = true
      if def_idx < before.callers_by_def.length() {
        for dependency in before.callers_by_def[def_idx] {
          if dependency >= 0 && dependency < defined {
            invalidated[dependency] = true
          }
        }
        for dependency in before.callees_by_def[def_idx] {
          if dependency >= 0 && dependency < defined {
            invalidated[dependency] = true
          }
        }
      }
      if def_idx < after.callers_by_def.length() {
        for dependency in after.callers_by_def[def_idx] {
          if dependency >= 0 && dependency < defined {
            invalidated[dependency] = true
          }
        }
        for dependency in after.callees_by_def[def_idx] {
          if dependency >= 0 && dependency < defined {
            invalidated[dependency] = true
          }
        }
      }
    }
    def_idx += 1
  }
  let out : Array[Int] = []
  def_idx = 0
  while def_idx < defined {
    if invalidated[def_idx] {
      out.push(def_idx)
    }
    def_idx += 1
  }
  out
}

///|
fn dae_work_family_slot(family : DaeWorkFamily) -> Int {
  match family {
    DaeUnusedParameterWork => 0
    DaeUniformActualWork => 1
    DaeForwardingWork => 2
    DaeLocalizationRetryWork => 3
    DaeGcParameterRefinementWork => 4
    DaeGcResultRefinementWork => 5
    DaeDroppedResultWork => 6
    DaeControlReconstructionWork => 7
    DaeTypeRepairRetryWork => 8
    DaePostCleanupBoundaryRevisitWork => 9
  }
}

///|
fn dae_work_item_new(
  graph : DaeCurrentBoundaryGraph,
  dependencies : DaeBoundaryDependencyGraph,
  target_def : Int,
  family : DaeWorkFamily,
) -> DaeWorkItem {
  let epoch = dae_boundary_candidate_epoch(graph, target_def)
  let component_id = if family == DaeForwardingWork &&
    target_def >= 0 &&
    target_def < dependencies.forwarding_component_by_def.length() {
    dependencies.forwarding_component_by_def[target_def]
  } else if target_def >= 0 &&
    target_def < dependencies.component_by_def.length() {
    dependencies.component_by_def[target_def]
  } else {
    -1
  }
  let component_members = if family == DaeForwardingWork &&
    component_id >= 0 &&
    component_id < dependencies.forwarding_component_members.length() {
    dependencies.forwarding_component_members[component_id].copy()
  } else if component_id >= 0 &&
    component_id < dependencies.component_members.length() {
    dependencies.component_members[component_id].copy()
  } else {
    []
  }
  {
    target_def,
    component_id,
    component_members,
    family,
    uniform_values: [],
    allow_immutable_global_get: false,
    expected_module_epoch: epoch.module_epoch,
    expected_call_epoch: epoch.call_epoch,
    expected_signature_epoch: epoch.signature_epoch,
    expected_body_epoch: epoch.body_epoch,
  }
}

///|
fn dae_work_item_epoch_is_current(
  graph : DaeCurrentBoundaryGraph,
  item : DaeWorkItem,
) -> Bool {
  dae_candidate_epoch_is_current(graph, {
    def_idx: item.target_def,
    module_epoch: item.expected_module_epoch,
    call_epoch: item.expected_call_epoch,
    signature_epoch: item.expected_signature_epoch,
    body_epoch: item.expected_body_epoch,
  })
}

///|
fn dae_process_work_item(
  original : DaeOriginalBoundarySnapshot,
  current : @lib.Module,
  touched : Array[Bool],
  changed : Bool,
  graph : DaeCurrentBoundaryGraph,
  dependencies : DaeBoundaryDependencyGraph,
  item : DaeWorkItem,
  diagnostics : DaeDiagnostics,
) -> DaeWorkOutcome {
  ignore(original.imported)
  diagnostics.boundaries_analyzed += 1
  if !dae_work_item_epoch_is_current(graph, item) {
    dae_diagnostics_record_reason(diagnostics, DaeStaleCandidateFacts)
    if item.target_def < 0 || item.target_def >= graph.snapshot.defined {
      return DaeWorkNoChange(DaeStaleCandidateFacts)
    }
    diagnostics.candidate_stale_retries += 1
    diagnostics.candidate_requeues += 1
    return DaeWorkRequeue([
      {
        ..dae_work_item_new(graph, dependencies, item.target_def, item.family),
        allow_immutable_global_get: item.allow_immutable_global_get,
      },
    ])
  }
  if item.family == DaeForwardingWork {
    match
      dae_run_forwarded_param_component_transaction_with_graph(
        current,
        touched,
        item.component_members,
        graph,
        dependencies,
      ) {
      Some(candidate) => {
        diagnostics.candidates_applied += 1
        dae_diagnostics_record_reason(diagnostics, DaeCandidateApplied)
        return DaeWorkCommitted({
          mod_out: candidate.mod_out,
          touched: dae_merge_touched(touched, candidate.touched),
          changed: true,
          applied: true,
          primary_def: item.target_def,
        })
      }
      None => {
        dae_diagnostics_record_reason(diagnostics, DaeNoStrictImprovement)
        return DaeWorkNoChange(DaeNoStrictImprovement)
      }
    }
  }
  let result = match item.family {
    DaeUnusedParameterWork
    | DaeLocalizationRetryWork
    | DaePostCleanupBoundaryRevisitWork =>
      Some(
        dae_try_rewrite_unread_params_for_def_with_facts(
          current,
          item.target_def,
          graph.snapshot.call_facts,
          allow_stack_carried_void_effects=true,
          require_localization_retry=item.family == DaeLocalizationRetryWork,
          type_indices_override=Some(graph.snapshot.type_indices),
        ),
      )
    DaeUniformActualWork =>
      if item.uniform_values.length() > 0 {
        Some(
          dae_try_rewrite_uniform_values_def_with_facts_once(
            current,
            item.target_def,
            graph.snapshot.call_facts,
            item.uniform_values,
          ),
        )
      } else {
        Some(
          dae_try_rewrite_exact_literal_def_with_facts_once(
            current,
            item.target_def,
            graph.snapshot.call_facts,
            allow_immutable_global_get=item.allow_immutable_global_get,
          ),
        )
      }
    DaeGcParameterRefinementWork =>
      Some(
        dae_try_refine_direct_gc_types_for_def_with_facts(
          current,
          item.target_def,
          graph.snapshot.call_facts,
          true,
          true,
        ),
      )
    DaeGcResultRefinementWork =>
      Some(
        dae_try_refine_direct_gc_types_for_def_with_facts(
          current,
          item.target_def,
          graph.snapshot.call_facts,
          false,
          true,
        ),
      )
    DaeDroppedResultWork =>
      Some(
        dae_try_remove_dropped_result_def_with_facts(
          current,
          item.target_def,
          graph.snapshot.call_facts,
        ),
      )
    DaeControlReconstructionWork | DaeTypeRepairRetryWork =>
      Some(
        dae_try_refine_direct_gc_types_for_def_with_facts(
          current,
          item.target_def,
          graph.snapshot.call_facts,
          false,
          true,
        ),
      )
    DaeForwardingWork => None
  }
  match result {
    None => {
      dae_diagnostics_record_reason(diagnostics, DaeNoStrictImprovement)
      DaeWorkDeferred(DaeNoStrictImprovement)
    }
    Some(candidate) => {
      let application = dae_apply_core_result(
        current, touched, changed, candidate,
      )
      if application.applied {
        diagnostics.candidates_applied += 1
        dae_diagnostics_record_reason(diagnostics, DaeCandidateApplied)
        DaeWorkCommitted(application)
      } else {
        dae_diagnostics_record_reason(diagnostics, DaeNoStrictImprovement)
        DaeWorkNoChange(DaeNoStrictImprovement)
      }
    }
  }
}

///|
fn dae_boundary_worklist_all(defined : Int) -> DaeBoundaryWorklist {
  let queue : Array[Int] = []
  let queued = Array::make(defined, false)
  let mut def_idx = 0
  while def_idx < defined {
    queue.push(def_idx)
    queued[def_idx] = true
    def_idx += 1
  }
  {
    queue,
    queued,
    cursor: 0,
    family_queue: [],
    family_queued: [],
    family_cursor: 0,
  }
}

///|
fn dae_boundary_worklist_families(
  graph : DaeCurrentBoundaryGraph,
  dependencies : DaeBoundaryDependencyGraph,
  families : Array[DaeWorkFamily],
) -> DaeBoundaryWorklist {
  let family_queue : Array[DaeWorkItem] = []
  let family_queued : Array[Array[Bool]] = []
  let mut def_idx = 0
  while def_idx < graph.snapshot.defined {
    family_queued.push(Array::make(10, false))
    def_idx += 1
  }
  let mut component_id = 0
  while component_id < dependencies.component_members.length() {
    for member_def in dependencies.component_members[component_id] {
      for family in families {
        let slot = dae_work_family_slot(family)
        if !family_queued[member_def][slot] {
          family_queue.push(
            dae_work_item_new(graph, dependencies, member_def, family),
          )
          family_queued[member_def][slot] = true
        }
      }
    }
    component_id += 1
  }
  {
    queue: [],
    queued: Array::make(graph.snapshot.defined, false),
    cursor: 0,
    family_queue,
    family_queued,
    family_cursor: 0,
  }
}

///|
fn dae_boundary_worklist_take(worklist : DaeBoundaryWorklist) -> Int? {
  if worklist.cursor >= worklist.queue.length() {
    return None
  }
  let def_idx = worklist.queue[worklist.cursor]
  worklist.cursor += 1
  if def_idx >= 0 && def_idx < worklist.queued.length() {
    worklist.queued[def_idx] = false
  }
  Some(def_idx)
}

///|
fn dae_boundary_worklist_requeue(
  worklist : DaeBoundaryWorklist,
  defs : Array[Int],
) -> Unit {
  for def_idx in defs {
    if def_idx >= 0 &&
      def_idx < worklist.queued.length() &&
      !worklist.queued[def_idx] {
      worklist.queue.push(def_idx)
      worklist.queued[def_idx] = true
    }
  }
}

///|
fn dae_boundary_worklist_take_item(
  worklist : DaeBoundaryWorklist,
) -> DaeWorkItem? {
  if worklist.family_cursor >= worklist.family_queue.length() {
    return None
  }
  let item = worklist.family_queue[worklist.family_cursor]
  worklist.family_cursor += 1
  if item.target_def >= 0 && item.target_def < worklist.family_queued.length() {
    let slot = dae_work_family_slot(item.family)
    worklist.family_queued[item.target_def][slot] = false
  }
  Some(item)
}

///|
fn dae_boundary_worklist_requeue_items(
  worklist : DaeBoundaryWorklist,
  items : Array[DaeWorkItem],
) -> Unit {
  for item in items {
    if item.target_def < 0 || item.target_def >= worklist.family_queued.length() {
      continue
    }
    let slot = dae_work_family_slot(item.family)
    if !worklist.family_queued[item.target_def][slot] {
      worklist.family_queue.push(item)
      worklist.family_queued[item.target_def][slot] = true
    }
  }
}

///|
fn dae_work_items_for_defs(
  graph : DaeCurrentBoundaryGraph,
  dependencies : DaeBoundaryDependencyGraph,
  defs : Array[Int],
  family : DaeWorkFamily,
) -> Array[DaeWorkItem] {
  let items : Array[DaeWorkItem] = []
  for def_idx in defs {
    if def_idx >= 0 && def_idx < graph.snapshot.defined {
      items.push(dae_work_item_new(graph, dependencies, def_idx, family))
    }
  }
  items
}

///|
fn dae_boundary_facts_for_epoch(
  graph : DaeCurrentBoundaryGraph,
  expected_call_epoch : Int,
  facts_override : DaeCallBoundaryFacts?,
) -> DaeCallBoundaryFacts {
  if expected_call_epoch >= 0 && expected_call_epoch != graph.call_epoch {
    return graph.snapshot.boundary_facts
  }
  match facts_override {
    Some(facts) => facts
    None => graph.snapshot.boundary_facts
  }
}

///|
fn dae_call_boundary_allows_forwarding(
  facts : DaeCallBoundaryFacts,
  caller_abs : Int,
) -> Bool {
  if caller_abs < 0 {
    return false
  }
  if caller_abs < facts.escaped.length() && facts.escaped[caller_abs] {
    return false
  }
  if caller_abs < facts.tail_calls.length() && facts.tail_calls[caller_abs] {
    return false
  }
  true
}

///|
fn dae_call_boundary_direct_callers(
  facts : DaeCallBoundaryFacts,
  callee_abs : Int,
) -> Array[Int] {
  if callee_abs >= 0 && callee_abs < facts.direct_callers.length() {
    facts.direct_callers[callee_abs]
  } else {
    []
  }
}

///|
fn dae_call_boundary_count_at(counts : Array[Int], callee_abs : Int) -> Int {
  if callee_abs >= 0 && callee_abs < counts.length() {
    counts[callee_abs]
  } else {
    0
  }
}

///|
fn dae_target_callsite_evidence_is_consistent(
  evidence : DaeTargetCallsiteEvidence,
  callee_abs : Int,
  mode : DaeTargetCallsiteMode,
) -> Bool {
  evidence.callee_abs == callee_abs &&
  evidence.callee_abs >= 0 &&
  (match mode {
    DaeTargetDirectCallOnly => !evidence.is_return_call
    DaeTargetDirectOrReturnCall => true
  })
}

///|
fn dae_target_callsite_evidence(
  instr : @lib.Instruction,
  callee_abs : Int,
  mode : DaeTargetCallsiteMode,
) -> DaeTargetCallsiteEvidence? {
  if callee_abs < 0 {
    return None
  }
  let make = fn(is_return_call : Bool) -> DaeTargetCallsiteEvidence? {
    let evidence = { callee_abs, is_return_call }
    if dae_target_callsite_evidence_is_consistent(evidence, callee_abs, mode) {
      Some(evidence)
    } else {
      None
    }
  }
  match instr {
    @lib.Call(func_idx) if dae_func_idx_slot(func_idx) == callee_abs =>
      make(false)
    @lib.ReturnCall(func_idx) if dae_func_idx_slot(func_idx) == callee_abs =>
      make(true)
    _ => None
  }
}

///|
fn dae_call_boundary_direct_callers_contain_def(
  direct_callers : Array[Int],
  def_idx : Int,
) -> Bool {
  if def_idx < 0 {
    return false
  }
  for direct_caller in direct_callers {
    if direct_caller == def_idx {
      return true
    }
  }
  false
}

///|
fn dae_call_boundary_candidate(
  facts : DaeCallBoundaryFacts,
  callee_abs : Int,
  def_idx? : Int = -1,
) -> DaeCallBoundaryCandidate? {
  if callee_abs < 0 ||
    callee_abs >= facts.escaped.length() ||
    callee_abs >= facts.tail_calls.length() ||
    callee_abs >= facts.direct_callers.length() {
    return None
  }
  let escaped = facts.escaped[callee_abs]
  let tail_call = facts.tail_calls[callee_abs]
  let direct_callers = facts.direct_callers[callee_abs]
  let direct_call_count = dae_call_boundary_count_at(
    facts.direct_calls,
    callee_abs,
  )
  let has_self_direct_caller = dae_call_boundary_direct_callers_contain_def(
    direct_callers, def_idx,
  )
  Some({
    owned: !escaped,
    tail_callee: tail_call,
    decision_reason: if escaped {
      DaeVisibleBoundary
    } else if tail_call {
      DaeDirectTailDependency
    } else {
      DaeCandidateProduced
    },
    direct_call_count,
    dropped_call_count: dae_call_boundary_count_at(
      facts.dropped_calls,
      callee_abs,
    ),
    direct_callers,
    has_self_direct_caller,
    allows_nonself_direct_rewrite: direct_call_count > 0 &&
    !has_self_direct_caller,
  })
}

///|
fn dae_dropped_result_candidate_from_boundary_facts(
  facts : DaeCallBoundaryFacts,
  callee_abs : Int,
) -> DaeDroppedResultCandidate? {
  let boundary_candidate = match
    dae_call_boundary_candidate(facts, callee_abs) {
    Some(candidate) => candidate
    None => return None
  }
  let all_direct_calls_dropped = boundary_candidate.direct_call_count > 0 &&
    boundary_candidate.dropped_call_count ==
    boundary_candidate.direct_call_count
  Some({
    callee_abs,
    direct_call_count: boundary_candidate.direct_call_count,
    dropped_call_count: boundary_candidate.dropped_call_count,
    direct_callers: boundary_candidate.direct_callers,
    owned: boundary_candidate.owned && !boundary_candidate.tail_callee,
    all_direct_calls_dropped,
    owned_dropped_result_candidate: boundary_candidate.owned &&
    !boundary_candidate.tail_callee &&
    all_direct_calls_dropped,
  })
}

///|
fn dae_dropped_result_candidate_from_current_call_facts(
  call_facts : DaeCurrentCallFacts,
  callee_abs : Int,
) -> DaeDroppedResultCandidate? {
  dae_dropped_result_candidate_from_boundary_facts(
    dae_call_boundary_facts_from_current(call_facts),
    callee_abs,
  )
}

///|
fn dae_imported_func_count(mod_ : @lib.Module) -> Int {
  let mut count = 0
  match mod_.import_sec {
    Some(@lib.ImportSec(imports)) =>
      for import_ in imports {
        match import_ {
          @lib.Import(_, _, @lib.FuncExternType(_)) => count += 1
          _ => ()
        }
      }
    None => ()
  }
  count
}

///|
fn dae_defined_func_count(mod_ : @lib.Module) -> Int {
  match mod_.func_sec {
    Some(@lib.FuncSec(type_idxs)) => type_idxs.length()
    None => 0
  }
}

///|
fn dae_func_idx_slot(idx : @lib.FuncIdx) -> Int {
  let @lib.FuncIdx(raw) = idx
  raw.reinterpret_as_int()
}

///|
fn dae_global_idx_slot(idx : @lib.GlobalIdx) -> Int {
  let @lib.GlobalIdx(raw) = idx
  raw.reinterpret_as_int()
}

///|
fn dae_local_idx_slot(idx : @lib.LocalIdx) -> Int {
  let @lib.LocalIdx(raw) = idx
  raw.reinterpret_as_int()
}

///|
fn dae_rewrite_local_idx(raw : Int, local_map : Array[Int]) -> @lib.LocalIdx {
  @lib.LocalIdx::new(local_map[raw].reinterpret_as_uint())
}

///|
fn dae_collect_func_type_indices(mod_ : @lib.Module) -> Array[@lib.TypeIdx] {
  let out : Array[@lib.TypeIdx] = []
  match mod_.import_sec {
    Some(@lib.ImportSec(imports)) =>
      for import_ in imports {
        match import_ {
          @lib.Import(_, _, @lib.FuncExternType(type_idx)) => out.push(type_idx)
          _ => ()
        }
      }
    None => ()
  }
  match mod_.func_sec {
    Some(@lib.FuncSec(type_idxs)) => out.append(type_idxs)
    None => ()
  }
  out
}

///|
fn dae_type_sec_flattened_length(type_sec : @lib.TypeSec) -> Int {
  let @lib.TypeSec(rec_types) = type_sec
  let mut length = 0
  for rec_type in rec_types {
    match rec_type {
      @lib.SingleRecType(_) => length += 1
      @lib.GroupRecType(group) => length += group.length()
    }
  }
  length
}

///|
fn dae_type_sec_rec_entry_location(
  type_sec : @lib.TypeSec,
  type_idx : @lib.TypeIdx,
) -> (Int, Int)? {
  let target = match type_idx {
    @lib.TypeIdx(raw) => raw.reinterpret_as_int()
    @lib.RecIdx(_) => return None
  }
  if target < 0 {
    return None
  }
  let @lib.TypeSec(rec_types) = type_sec
  let mut flat_idx = 0
  let mut entry_idx = 0
  while entry_idx < rec_types.length() {
    match rec_types[entry_idx] {
      @lib.SingleRecType(_) => {
        if flat_idx == target {
          return Some((entry_idx, 0))
        }
        flat_idx += 1
      }
      @lib.GroupRecType(group) => {
        let group_end = flat_idx + group.length()
        if target >= flat_idx && target < group_end {
          return Some((entry_idx, target - flat_idx))
        }
        flat_idx = group_end
      }
    }
    entry_idx += 1
  }
  None
}

///|
fn dae_type_sec_subtype(
  type_sec : @lib.TypeSec,
  type_idx : @lib.TypeIdx,
) -> @lib.SubType? {
  let target = match type_idx {
    @lib.TypeIdx(raw) => raw.reinterpret_as_int()
    @lib.RecIdx(_) => return None
  }
  if target < 0 {
    return None
  }
  let @lib.TypeSec(rec_types) = type_sec
  let mut flat_idx = 0
  for rec_type in rec_types {
    match rec_type {
      @lib.SingleRecType(subtype) => {
        if flat_idx == target {
          return Some(subtype)
        }
        flat_idx += 1
      }
      @lib.GroupRecType(group) => {
        let group_end = flat_idx + group.length()
        if target >= flat_idx && target < group_end {
          return Some(group[target - flat_idx])
        }
        flat_idx = group_end
      }
    }
  }
  None
}

///|
fn dae_type_sec_func_type(
  type_sec : @lib.TypeSec,
  type_idx : @lib.TypeIdx,
) -> @lib.FuncType? {
  match dae_type_sec_subtype(type_sec, type_idx) {
    Some(subtype) =>
      match subtype.get_comptype() {
        @lib.FuncCompType(params, results) =>
          Some(@lib.FuncType::new(params, results))
        _ => None
      }
    None => None
  }
}

///|
fn dae_control_block_type_signature_evidence_from_type_sec(
  block_type : @lib.BlockType,
  type_sec : @lib.TypeSec?,
) -> DaeControlBlockTypeSignatureEvidence? {
  match block_type {
    @lib.VoidBlockType =>
      Some({
        params: [],
        results: [],
        input_count: 0,
        output_count: 0,
        type_idx: None,
      })
    @lib.ValTypeBlockType(result) =>
      Some({
        params: [],
        results: [result],
        input_count: 0,
        output_count: 1,
        type_idx: None,
      })
    @lib.TypeIdxBlockType(type_idx) =>
      match type_sec {
        Some(type_sec) =>
          match dae_type_sec_func_type(type_sec, type_idx) {
            Some(@lib.FuncType(params, results)) =>
              Some({
                params,
                results,
                input_count: params.length(),
                output_count: results.length(),
                type_idx: Some(type_idx),
              })
            None => None
          }
        None => None
      }
  }
}

///|
fn dae_control_block_type_signature_evidence(
  block_type : @lib.BlockType,
  mod_ : @lib.Module,
) -> DaeControlBlockTypeSignatureEvidence? {
  dae_control_block_type_signature_evidence_from_type_sec(
    block_type,
    mod_.type_sec,
  )
}

///|
fn dae_control_block_type_stack_shape_evidence(
  block_type : @lib.BlockType,
  type_sec : @lib.TypeSec?,
  input_count : Int,
  output_count : Int,
) -> DaeControlBlockTypeSignatureEvidence? {
  match
    dae_control_block_type_signature_evidence_from_type_sec(
      block_type, type_sec,
    ) {
    Some(evidence) if evidence.input_count == input_count &&
      evidence.output_count == output_count => Some(evidence)
    _ => None
  }
}

///|
fn dae_control_block_type_stack_shape_accepts(
  block_type : @lib.BlockType,
  type_sec : @lib.TypeSec?,
  input_count : Int,
  output_count : Int,
) -> Bool {
  match
    dae_control_block_type_stack_shape_evidence(
      block_type, type_sec, input_count, output_count,
    ) {
    Some(_) => true
    None => false
  }
}

///|
fn dae_control_block_type_exact_signature_evidence(
  block_type : @lib.BlockType,
  type_sec : @lib.TypeSec?,
  params : Array[@lib.ValType],
  results : Array[@lib.ValType],
) -> DaeControlBlockTypeSignatureEvidence? {
  match
    dae_control_block_type_stack_shape_evidence(
      block_type,
      type_sec,
      params.length(),
      results.length(),
    ) {
    Some(evidence) if evidence.params == params && evidence.results == results =>
      Some(evidence)
    _ => None
  }
}

///|
fn dae_control_block_type_exact_signature_accepts(
  block_type : @lib.BlockType,
  type_sec : @lib.TypeSec?,
  params : Array[@lib.ValType],
  results : Array[@lib.ValType],
) -> Bool {
  match
    dae_control_block_type_exact_signature_evidence(
      block_type, type_sec, params, results,
    ) {
    Some(_) => true
    None => false
  }
}

///|
fn dae_control_single_result_block_type_evidence(
  block_type : @lib.BlockType,
  mod_ : @lib.Module,
) -> DaeControlBlockTypeSignatureEvidence? {
  dae_control_block_type_stack_shape_evidence(block_type, mod_.type_sec, 0, 1)
}

///|
fn dae_control_block_type_zero_input_evidence(
  block_type : @lib.BlockType,
  type_sec : @lib.TypeSec?,
) -> DaeControlBlockTypeSignatureEvidence? {
  match
    dae_control_block_type_signature_evidence_from_type_sec(
      block_type, type_sec,
    ) {
    Some(evidence) if evidence.input_count == 0 => Some(evidence)
    _ => None
  }
}

///|
fn dae_control_block_type_zero_input_output_count_evidence(
  block_type : @lib.BlockType,
  type_sec : @lib.TypeSec?,
  output_count : Int,
) -> DaeControlBlockTypeSignatureEvidence? {
  if output_count < 0 {
    return None
  }
  dae_control_block_type_stack_shape_evidence(
    block_type, type_sec, 0, output_count,
  )
}

///|
fn dae_val_type_is_non_null_concrete_gc_ref_candidate(
  vt : @lib.ValType,
) -> Bool {
  match vt {
    @lib.RefTypeValType(@lib.HeapTypeRefType(false, _, @lib.HeapType(_))) =>
      true
    _ => false
  }
}

///|
fn dae_control_block_type_non_null_concrete_gc_result_from_signature_evidence(
  signature : DaeControlBlockTypeSignatureEvidence,
  result_index : Int,
) -> DaeControlBlockTypeGcResultEvidence? {
  if result_index < 0 || result_index >= signature.output_count {
    return None
  }
  let candidate = signature.results[result_index]
  if dae_val_type_is_non_null_concrete_gc_ref_candidate(candidate) {
    Some({ signature, result_index, candidate })
  } else {
    None
  }
}

///|
fn dae_control_block_type_non_null_concrete_gc_result_evidence(
  block_type : @lib.BlockType,
  type_sec : @lib.TypeSec?,
  result_index : Int,
) -> DaeControlBlockTypeGcResultEvidence? {
  match
    dae_control_block_type_signature_evidence_from_type_sec(
      block_type, type_sec,
    ) {
    Some(signature) =>
      dae_control_block_type_non_null_concrete_gc_result_from_signature_evidence(
        signature, result_index,
      )
    None => None
  }
}

///|
fn dae_control_block_type_non_null_concrete_gc_result_slot_evidence(
  block_type : @lib.BlockType,
  type_sec : @lib.TypeSec?,
  slot : DaeControlBlockTypeGcResultSlot,
) -> DaeControlBlockTypeGcResultEvidence? {
  let signature = match
    dae_control_block_type_signature_evidence_from_type_sec(
      block_type, type_sec,
    ) {
    Some(signature) => signature
    None => return None
  }
  let result_index = match slot {
    DaeSingleControlGcResultSlot =>
      if signature.output_count == 1 {
        0
      } else {
        return None
      }
    DaeLastControlGcResultSlot =>
      if signature.output_count > 0 {
        signature.output_count - 1
      } else {
        return None
      }
  }
  dae_control_block_type_non_null_concrete_gc_result_evidence(
    block_type, type_sec, result_index,
  )
}

///|
fn dae_control_block_type_single_non_null_concrete_gc_result_evidence(
  block_type : @lib.BlockType,
  type_sec : @lib.TypeSec?,
) -> DaeControlBlockTypeGcResultEvidence? {
  dae_control_block_type_non_null_concrete_gc_result_slot_evidence(
    block_type,
    type_sec,
    DaeSingleControlGcResultSlot,
  )
}

///|
fn dae_control_block_type_last_non_null_concrete_gc_result_evidence(
  block_type : @lib.BlockType,
  type_sec : @lib.TypeSec?,
) -> DaeControlBlockTypeGcResultEvidence? {
  dae_control_block_type_non_null_concrete_gc_result_slot_evidence(
    block_type,
    type_sec,
    DaeLastControlGcResultSlot,
  )
}

///|
fn dae_resolve_func_type(
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  func_abs : Int,
) -> @lib.FuncType? {
  if func_abs < 0 || func_abs >= func_type_indices.length() {
    return None
  }
  match mod_.type_sec {
    Some(type_sec) =>
      dae_type_sec_func_type(type_sec, func_type_indices[func_abs])
    None => None
  }
}

///|
fn dae_collect_exported_funcs(
  mod_ : @lib.Module,
  total_funcs : Int,
) -> Array[Bool] {
  let escaped = Array::make(total_funcs, false)
  match mod_.export_sec {
    Some(@lib.ExportSec(exports)) =>
      for export_ in exports {
        match export_ {
          @lib.Export(_, @lib.FuncExternIdx(func_idx)) => {
            let slot = dae_func_idx_slot(func_idx)
            if slot >= 0 && slot < escaped.length() {
              escaped[slot] = true
            }
          }
          _ => ()
        }
      }
    None => ()
  }
  match mod_.start_sec {
    Some(@lib.StartSec(func_idx)) => {
      let slot = dae_func_idx_slot(func_idx)
      if slot >= 0 && slot < escaped.length() {
        escaped[slot] = true
      }
    }
    None => ()
  }
  escaped
}

///|
fn dae_mark_elem_escapes(kind : @lib.ElemKind, escaped : Array[Bool]) -> Unit {
  match kind {
    @lib.FuncsElemKind(funcs) =>
      for func_idx in funcs {
        let slot = dae_func_idx_slot(func_idx)
        if slot >= 0 && slot < escaped.length() {
          escaped[slot] = true
        }
      }
    @lib.FuncExprsElemKind(exprs) | @lib.TypedExprsElemKind(_, exprs) =>
      for expr in exprs {
        let @lib.Expr(instrs) = expr
        dae_scan_escapes_instrs(instrs, escaped)
      }
  }
}

///|
fn dae_scan_escapes_instrs(
  instrs : Array[@lib.Instruction],
  escaped : Array[Bool],
) -> Unit {
  for instr in instrs {
    match instr {
      @lib.RefFunc(func_idx) => {
        let slot = dae_func_idx_slot(func_idx)
        if slot >= 0 && slot < escaped.length() {
          escaped[slot] = true
        }
      }
      @lib.Block(_, @lib.Expr(body))
      | @lib.Loop(_, @lib.Expr(body))
      | @lib.TryTable(_, _, @lib.Expr(body)) =>
        dae_scan_escapes_instrs(body, escaped)
      @lib.If(_, then_body, Some(else_body)) => {
        dae_scan_escapes_instrs(then_body, escaped)
        dae_scan_escapes_instrs(else_body, escaped)
      }
      @lib.If(_, then_body, None) => dae_scan_escapes_instrs(then_body, escaped)
      _ => ()
    }
  }
}

///|
fn dae_collect_escapes(mod_ : @lib.Module, total_funcs : Int) -> Array[Bool] {
  let escaped = dae_collect_exported_funcs(mod_, total_funcs)
  match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) =>
      for func in funcs {
        let @lib.Func(_, @lib.Expr(body)) = func
        dae_scan_escapes_instrs(body, escaped)
      }
    None => ()
  }
  match mod_.elem_sec {
    Some(@lib.ElemSec(elems)) =>
      for elem in elems {
        let @lib.Elem(_, kind) = elem
        dae_mark_elem_escapes(kind, escaped)
      }
    None => ()
  }
  escaped
}

///|
fn dae_make_direct_callers(total_funcs : Int) -> Array[Array[Int]] {
  let direct_callers : Array[Array[Int]] = []
  let mut idx = 0
  while idx < total_funcs {
    direct_callers.push([])
    idx += 1
  }
  direct_callers
}

///|
fn dae_new_function_info(has_unseen_calls : Bool) -> DaeFunctionInfo {
  {
    stale: true,
    unused_params: [],
    calls: [],
    dropped_calls: [],
    has_tail_calls: false,
    tail_callees: [],
    has_unseen_calls,
  }
}

///|
fn dae_make_function_infos(
  total_funcs : Int,
  escaped : Array[Bool],
) -> Array[DaeFunctionInfo] {
  let infos : Array[DaeFunctionInfo] = []
  let mut idx = 0
  while idx < total_funcs {
    infos.push(dae_new_function_info(idx < escaped.length() && escaped[idx]))
    idx += 1
  }
  infos
}

///|
fn dae_callsite_child_path(
  path : Array[Int],
  instr_idx : Int,
  child_kind : Int,
) -> Array[Int] {
  let child = path.copy()
  child.push(instr_idx)
  child.push(child_kind)
  child
}

///|
fn dae_callsite_path(path : Array[Int], instr_idx : Int) -> Array[Int] {
  let callsite = path.copy()
  callsite.push(instr_idx)
  callsite
}

///|
fn dae_function_info_add_tail_callee(
  info : DaeFunctionInfo,
  callee_abs : Int,
) -> Unit {
  if !info.tail_callees.contains(callee_abs) {
    info.tail_callees.push(callee_abs)
  }
}

///|
fn dae_scan_current_call_facts_instrs(
  instrs : Array[@lib.Instruction],
  caller_def : Int,
  caller_abs : Int,
  path : Array[Int],
  direct_calls : Array[Int],
  tail_calls : Array[Bool],
  direct_callers : Array[Array[Int]],
  dropped_calls : Array[Int],
  escaped : Array[Bool],
  function_infos : Array[DaeFunctionInfo],
  caller_seen_stamps : Array[Int],
  active : Bool,
) -> Unit {
  let mut idx = 0
  let mut current_active = active
  while idx < instrs.length() {
    if current_active && dae_instr_is_unreachable_root(instrs[idx]) {
      current_active = false
    }
    match instrs[idx] {
      @lib.Call(func_idx) => {
        let slot = dae_func_idx_slot(func_idx)
        if slot >= 0 && slot < direct_calls.length() {
          let dropped = current_active &&
            idx + 1 < instrs.length() &&
            instrs[idx + 1] == @lib.Instruction::drop()
          let callsite = {
            caller_def,
            path: dae_callsite_path(path, idx),
            callee_abs: slot,
            active: current_active,
            dropped,
            tail: false,
          }
          if slot < function_infos.length() {
            function_infos[slot].calls.push(callsite)
            if dropped {
              function_infos[slot].dropped_calls.push(callsite)
            }
          }
          if current_active {
            direct_calls[slot] = direct_calls[slot] + 1
            if dropped {
              dropped_calls[slot] = dropped_calls[slot] + 1
            }
          }
          if caller_seen_stamps[slot] != caller_def {
            direct_callers[slot].push(caller_def)
            caller_seen_stamps[slot] = caller_def
          }
        }
      }
      @lib.ReturnCall(func_idx) =>
        if current_active {
          let slot = dae_func_idx_slot(func_idx)
          if slot >= 0 && slot < direct_calls.length() {
            let callsite = {
              caller_def,
              path: dae_callsite_path(path, idx),
              callee_abs: slot,
              active: true,
              dropped: false,
              tail: true,
            }
            direct_calls[slot] = direct_calls[slot] + 1
            tail_calls[slot] = true
            if slot < function_infos.length() {
              function_infos[slot].calls.push(callsite)
            }
            if caller_abs >= 0 && caller_abs < function_infos.length() {
              function_infos[caller_abs].has_tail_calls = true
              dae_function_info_add_tail_callee(
                function_infos[caller_abs],
                slot,
              )
            }
            if caller_seen_stamps[slot] != caller_def {
              direct_callers[slot].push(caller_def)
              caller_seen_stamps[slot] = caller_def
            }
          }
        }
      @lib.ReturnCallIndirect(_, _) | @lib.ReturnCallRef(_) =>
        if current_active &&
          caller_abs >= 0 &&
          caller_abs < function_infos.length() {
          function_infos[caller_abs].has_tail_calls = true
        }
      @lib.RefFunc(func_idx) => {
        let slot = dae_func_idx_slot(func_idx)
        if slot >= 0 && slot < escaped.length() {
          escaped[slot] = true
          if slot < function_infos.length() {
            function_infos[slot].has_unseen_calls = true
          }
        }
      }
      @lib.Block(_, @lib.Expr(body)) =>
        dae_scan_current_call_facts_instrs(
          body,
          caller_def,
          caller_abs,
          dae_callsite_child_path(path, idx, 0),
          direct_calls,
          tail_calls,
          direct_callers,
          dropped_calls,
          escaped,
          function_infos,
          caller_seen_stamps,
          current_active,
        )
      @lib.Loop(_, @lib.Expr(body)) =>
        dae_scan_current_call_facts_instrs(
          body,
          caller_def,
          caller_abs,
          dae_callsite_child_path(path, idx, 1),
          direct_calls,
          tail_calls,
          direct_callers,
          dropped_calls,
          escaped,
          function_infos,
          caller_seen_stamps,
          current_active,
        )
      @lib.If(_, then_body, Some(else_body)) => {
        dae_scan_current_call_facts_instrs(
          then_body,
          caller_def,
          caller_abs,
          dae_callsite_child_path(path, idx, 2),
          direct_calls,
          tail_calls,
          direct_callers,
          dropped_calls,
          escaped,
          function_infos,
          caller_seen_stamps,
          current_active,
        )
        dae_scan_current_call_facts_instrs(
          else_body,
          caller_def,
          caller_abs,
          dae_callsite_child_path(path, idx, 3),
          direct_calls,
          tail_calls,
          direct_callers,
          dropped_calls,
          escaped,
          function_infos,
          caller_seen_stamps,
          current_active,
        )
      }
      @lib.If(_, then_body, None) =>
        dae_scan_current_call_facts_instrs(
          then_body,
          caller_def,
          caller_abs,
          dae_callsite_child_path(path, idx, 2),
          direct_calls,
          tail_calls,
          direct_callers,
          dropped_calls,
          escaped,
          function_infos,
          caller_seen_stamps,
          current_active,
        )
      @lib.TryTable(_, _, @lib.Expr(body)) =>
        dae_scan_current_call_facts_instrs(
          body,
          caller_def,
          caller_abs,
          dae_callsite_child_path(path, idx, 4),
          direct_calls,
          tail_calls,
          direct_callers,
          dropped_calls,
          escaped,
          function_infos,
          caller_seen_stamps,
          current_active,
        )
      _ => ()
    }
    idx += 1
  }
}

///|
fn dae_call_facts_from_function_infos(
  function_infos : Array[DaeFunctionInfo],
) -> DaeCurrentCallFacts {
  let total_funcs = function_infos.length()
  let direct_calls = Array::make(total_funcs, 0)
  let tail_calls = Array::make(total_funcs, false)
  let direct_callers = dae_make_direct_callers(total_funcs)
  let dropped_calls = Array::make(total_funcs, 0)
  let escaped = Array::make(total_funcs, false)
  let mut callee_abs = 0
  while callee_abs < total_funcs {
    let info = function_infos[callee_abs]
    escaped[callee_abs] = info.has_unseen_calls
    for callsite in info.calls {
      if callsite.callee_abs != callee_abs || callsite.path.length() == 0 {
        continue
      }
      if callsite.active {
        direct_calls[callee_abs] += 1
        if callsite.dropped {
          dropped_calls[callee_abs] += 1
        }
        if callsite.tail {
          tail_calls[callee_abs] = true
        }
      }
      if (callsite.active || !callsite.tail) &&
        !direct_callers[callee_abs].contains(callsite.caller_def) {
        direct_callers[callee_abs].push(callsite.caller_def)
      }
    }
    if info.dropped_calls.any(fn(callsite) {
        callsite.active && callsite.dropped && callsite.callee_abs == callee_abs
      }) {
      // The exact dropped-call list is intentionally redundant with `calls`:
      // callers that remove results consume locations, while aggregate guards
      // consume the count reconstructed above.
      ignore(info.dropped_calls.length())
    }
    if info.has_tail_calls {
      for tail_callee in info.tail_callees {
        if tail_callee >= 0 && tail_callee < tail_calls.length() {
          tail_calls[tail_callee] = true
        }
      }
    }
    callee_abs += 1
  }
  { direct_calls, tail_calls, direct_callers, dropped_calls, escaped }
}

///|
fn dae_collect_current_function_analysis(
  mod_ : @lib.Module,
  total_funcs : Int,
) -> DaeFunctionAnalysis {
  let direct_calls = Array::make(total_funcs, 0)
  let tail_calls = Array::make(total_funcs, false)
  let direct_callers = dae_make_direct_callers(total_funcs)
  let dropped_calls = Array::make(total_funcs, 0)
  let escaped = dae_collect_exported_funcs(mod_, total_funcs)
  let function_infos = dae_make_function_infos(total_funcs, escaped)
  let caller_seen_stamps = Array::make(total_funcs, -1)
  let imported = dae_imported_func_count(mod_)
  match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => {
      let mut caller_def = 0
      while caller_def < funcs.length() {
        let @lib.Func(_, @lib.Expr(body)) = funcs[caller_def]
        dae_scan_current_call_facts_instrs(
          body,
          caller_def,
          imported + caller_def,
          [],
          direct_calls,
          tail_calls,
          direct_callers,
          dropped_calls,
          escaped,
          function_infos,
          caller_seen_stamps,
          true,
        )
        caller_def += 1
      }
    }
    None => ()
  }
  match mod_.elem_sec {
    Some(@lib.ElemSec(elems)) =>
      for elem in elems {
        let @lib.Elem(_, kind) = elem
        dae_mark_elem_escapes(kind, escaped)
      }
    None => ()
  }
  let mut escaped_idx = 0
  while escaped_idx < escaped.length() && escaped_idx < function_infos.length() {
    function_infos[escaped_idx].has_unseen_calls = escaped[escaped_idx]
    escaped_idx += 1
  }
  ignore(direct_calls)
  ignore(tail_calls)
  ignore(direct_callers)
  ignore(dropped_calls)
  {
    call_facts: dae_call_facts_from_function_infos(function_infos),
    function_infos,
  }
}

///|
fn dae_collect_current_call_facts(
  mod_ : @lib.Module,
  total_funcs : Int,
) -> DaeCurrentCallFacts {
  dae_collect_current_function_analysis(mod_, total_funcs).call_facts
}

///|
fn dae_adjacent_param_forward_evidence(
  instrs : Array[@lib.Instruction],
  call_idx : Int,
  param_count : Int,
) -> DaeAdjacentParamForwardEvidence? {
  if call_idx < 0 || call_idx > instrs.length() || param_count < 0 {
    return None
  }
  let start = call_idx - param_count
  if start < 0 {
    return None
  }
  let mut p = 0
  while p < param_count {
    match instrs[start + p] {
      @lib.LocalGet(local_idx) if dae_local_idx_slot(local_idx) == p => ()
      _ => return None
    }
    p += 1
  }
  Some({ start, end: call_idx, param_count })
}

///|
fn dae_mark_self_forwarded_param_gets(
  instrs : Array[@lib.Instruction],
  callee_abs : Int,
  param_count : Int,
  ignored : Array[Bool],
) -> Unit {
  if param_count == 0 {
    return
  }
  let mut idx = 0
  while idx < instrs.length() {
    match
      dae_target_callsite_evidence(
        instrs[idx],
        callee_abs,
        DaeTargetDirectCallOnly,
      ) {
      Some(_) =>
        match dae_adjacent_param_forward_evidence(instrs, idx, param_count) {
          Some(evidence) => {
            let mut operand_idx = evidence.start
            while operand_idx < evidence.start + evidence.param_count {
              ignored[operand_idx] = true
              operand_idx += 1
            }
          }
          None => ()
        }
      None => ()
    }
    idx += 1
  }
}

///|
fn dae_scan_local_use_ignoring_instrs(
  instrs : Array[@lib.Instruction],
  local_use : DaeLocalUse,
  callee_abs : Int,
  param_count : Int,
) -> Unit {
  let ignored = Array::make(instrs.length(), false)
  dae_mark_self_forwarded_param_gets(instrs, callee_abs, param_count, ignored)
  let mut idx = 0
  while idx < instrs.length() {
    if dae_instr_is_unreachable_root(instrs[idx]) {
      break
    }
    if !ignored[idx] {
      match instrs[idx] {
        @lib.LocalGet(local_idx) => {
          let slot = dae_local_idx_slot(local_idx)
          if slot >= 0 && slot < local_use.gets.length() {
            local_use.gets[slot] = true
          }
        }
        @lib.LocalSet(local_idx) | @lib.LocalTee(local_idx) => {
          let slot = dae_local_idx_slot(local_idx)
          if slot >= 0 && slot < local_use.writes.length() {
            local_use.writes[slot] = true
          }
        }
        @lib.Block(_, @lib.Expr(body))
        | @lib.Loop(_, @lib.Expr(body))
        | @lib.TryTable(_, _, @lib.Expr(body)) =>
          dae_scan_local_use_ignoring_instrs(
            body, local_use, callee_abs, param_count,
          )
        @lib.If(_, then_body, Some(else_body)) => {
          dae_scan_local_use_ignoring_instrs(
            then_body, local_use, callee_abs, param_count,
          )
          dae_scan_local_use_ignoring_instrs(
            else_body, local_use, callee_abs, param_count,
          )
        }
        @lib.If(_, then_body, None) =>
          dae_scan_local_use_ignoring_instrs(
            then_body, local_use, callee_abs, param_count,
          )
        _ => ()
      }
    }
    idx += 1
  }
}

///|
fn dae_instr_supports_param_entry_liveness(instr : @lib.Instruction) -> Bool {
  match instr {
    @lib.Br(_) | @lib.BrIf(_) | @lib.BrTable(_, _) => false
    @lib.Throw(_) | @lib.ThrowRef => false
    @lib.TryTable(_, _, _) => false
    @lib.Block(_, @lib.Expr(body)) | @lib.Loop(_, @lib.Expr(body)) =>
      body.all(fn(child) { dae_instr_supports_param_entry_liveness(child) })
    @lib.If(_, then_body, Some(else_body)) =>
      then_body.all(fn(child) { dae_instr_supports_param_entry_liveness(child) }) &&
      else_body.all(fn(child) { dae_instr_supports_param_entry_liveness(child) })
    @lib.If(_, then_body, None) =>
      then_body.all(fn(child) { dae_instr_supports_param_entry_liveness(child) })
    _ => true
  }
}

///|
fn dae_instr_contains_call(instr : @lib.Instruction) -> Bool {
  match instr {
    @lib.Call(_)
    | @lib.CallIndirect(_, _)
    | @lib.CallRef(_)
    | @lib.ReturnCall(_)
    | @lib.ReturnCallIndirect(_, _)
    | @lib.ReturnCallRef(_) => true
    @lib.Block(_, @lib.Expr(body))
    | @lib.Loop(_, @lib.Expr(body))
    | @lib.TryTable(_, _, @lib.Expr(body)) =>
      body.any(fn(child) { dae_instr_contains_call(child) })
    @lib.If(_, then_body, Some(else_body)) =>
      then_body.any(fn(child) { dae_instr_contains_call(child) }) ||
      else_body.any(fn(child) { dae_instr_contains_call(child) })
    @lib.If(_, then_body, None) =>
      then_body.any(fn(child) { dae_instr_contains_call(child) })
    _ => false
  }
}

///|
fn dae_instrs_support_param_entry_liveness(
  instrs : Array[@lib.Instruction],
) -> Bool {
  instrs.all(fn(instr) { dae_instr_supports_param_entry_liveness(instr) }) &&
  !instrs.any(fn(instr) { dae_instr_contains_call(instr) })
}

///|
fn dae_instr_supports_hot_param_entry_liveness(
  instr : @lib.Instruction,
) -> Bool {
  match instr {
    @lib.Suspend(_)
    | @lib.Resume(_, _)
    | @lib.ResumeThrow(_, _, _)
    | @lib.ResumeThrowRef(_, _)
    | @lib.StackSwitch(_, _)
    | @lib.Try(_, _, _, _) => false
    @lib.Block(_, @lib.Expr(body)) | @lib.Loop(_, @lib.Expr(body)) =>
      body.all(fn(child) { dae_instr_supports_hot_param_entry_liveness(child) })
    @lib.TryTable(_, _, @lib.Expr(body)) =>
      !body.any(fn(child) { dae_instr_contains_call(child) }) &&
      body.all(fn(child) { dae_instr_supports_hot_param_entry_liveness(child) })
    @lib.If(_, then_body, Some(else_body)) =>
      then_body.all(fn(child) {
        dae_instr_supports_hot_param_entry_liveness(child)
      }) &&
      else_body.all(fn(child) {
        dae_instr_supports_hot_param_entry_liveness(child)
      })
    @lib.If(_, then_body, None) =>
      then_body.all(fn(child) {
        dae_instr_supports_hot_param_entry_liveness(child)
      })
    _ => true
  }
}

///|
fn dae_hot_param_entry_liveness(
  mod_ : @lib.Module,
  callee_abs : Int,
  param_count : Int,
) -> Array[Bool]? {
  if callee_abs < 0 || param_count < 0 {
    return None
  }
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None => return None
  }
  let def_idx = callee_abs - dae_imported_func_count(mod_)
  if def_idx < 0 || def_idx >= funcs.length() {
    return None
  }
  let @lib.Func(_, @lib.Expr(body)) = funcs[def_idx]
  if !body.all(fn(instr) { dae_instr_supports_hot_param_entry_liveness(instr) }) {
    return None
  }
  let ctx = @ir.hot_module_context_from_module(mod_)
  let hot = match
    @ir.hot_lift_func_with_context_result(
      mod_,
      @lib.FuncIdx::new(callee_abs.reinterpret_as_uint()),
      ctx,
    ) {
    Ok(func) => func
    Err(_) => return None
  }
  let cfg = @ir.cfg_build(hot, conservative_exception_entries=false)
  let use_def = @ir.use_def_build(hot, cfg=Some(cfg))
  let liveness = @ir.liveness_build(
    cfg,
    use_def,
    include_exceptional_edges=true,
  )
  let entry = @ir.cfg_entry_block(cfg)
  let live = Array::make(param_count, false)
  let mut param_idx = 0
  while param_idx < param_count {
    live[param_idx] = @ir.local_live_in(liveness, entry, param_idx)
    param_idx += 1
  }
  Some(live)
}

///|
fn dae_scan_param_entry_liveness_instrs(
  instrs : Array[@lib.Instruction],
  live : Array[Bool],
  callee_abs : Int,
  param_count : Int,
) -> Unit {
  let ignored = Array::make(instrs.length(), false)
  dae_mark_self_forwarded_param_gets(instrs, callee_abs, param_count, ignored)
  let mut idx = instrs.length()
  while idx > 0 {
    idx -= 1
    match instrs[idx] {
      @lib.LocalGet(local_idx) => {
        let slot = dae_local_idx_slot(local_idx)
        if !ignored[idx] && slot >= 0 && slot < live.length() {
          live[slot] = true
        }
      }
      @lib.LocalSet(local_idx) | @lib.LocalTee(local_idx) => {
        let slot = dae_local_idx_slot(local_idx)
        if slot >= 0 && slot < live.length() {
          live[slot] = false
        }
      }
      @lib.Return
      | @lib.ReturnCall(_)
      | @lib.ReturnCallIndirect(_, _)
      | @lib.ReturnCallRef(_)
      | @lib.Unreachable => {
        let mut local_idx = 0
        while local_idx < live.length() {
          live[local_idx] = false
          local_idx += 1
        }
      }
      @lib.Block(_, @lib.Expr(body))
      | @lib.Loop(_, @lib.Expr(body))
      | @lib.TryTable(_, _, @lib.Expr(body)) =>
        dae_scan_param_entry_liveness_instrs(
          body, live, callee_abs, param_count,
        )
      @lib.If(_, then_body, else_body) => {
        let then_live = live.copy()
        dae_scan_param_entry_liveness_instrs(
          then_body, then_live, callee_abs, param_count,
        )
        let else_live = live.copy()
        match else_body {
          Some(body) =>
            dae_scan_param_entry_liveness_instrs(
              body, else_live, callee_abs, param_count,
            )
          None => ()
        }
        let mut local_idx = 0
        while local_idx < live.length() {
          live[local_idx] = then_live[local_idx] || else_live[local_idx]
          local_idx += 1
        }
      }
      _ => ()
    }
  }
}

///|
fn dae_strip_function_terminal_suffix_instrs(
  instrs : Array[@lib.Instruction],
) -> (Array[@lib.Instruction], Bool) {
  let out : Array[@lib.Instruction] = []
  let mut changed = false
  let mut idx = 0
  while idx < instrs.length() {
    let rewritten = match instrs[idx] {
      @lib.Block(block_type, @lib.Expr(body)) => {
        let (next_body, nested_changed) = dae_strip_function_terminal_suffix_instrs(
          body,
        )
        changed = changed || nested_changed
        @lib.Instruction::block(block_type, @lib.Expr::new(next_body))
      }
      @lib.Loop(block_type, @lib.Expr(body)) => {
        let (next_body, nested_changed) = dae_strip_function_terminal_suffix_instrs(
          body,
        )
        changed = changed || nested_changed
        @lib.Instruction::loop_(block_type, @lib.Expr::new(next_body))
      }
      @lib.If(block_type, then_body, else_body) => {
        let (next_then, then_changed) = dae_strip_function_terminal_suffix_instrs(
          then_body,
        )
        changed = changed || then_changed
        let next_else = match else_body {
          Some(body) => {
            let (next_body, else_changed) = dae_strip_function_terminal_suffix_instrs(
              body,
            )
            changed = changed || else_changed
            Some(next_body)
          }
          None => None
        }
        @lib.Instruction::if_(block_type, next_then, next_else)
      }
      _ => instrs[idx]
    }
    out.push(rewritten)
    match instrs[idx] {
      @lib.Return
      | @lib.ReturnCall(_)
      | @lib.ReturnCallIndirect(_, _)
      | @lib.ReturnCallRef(_)
      | @lib.Unreachable => {
        if idx + 1 < instrs.length() {
          changed = true
        }
        break
      }
      _ => ()
    }
    idx += 1
  }
  (out, changed)
}

///|
fn dae_strip_function_terminal_suffix_for_def(
  mod_ : @lib.Module,
  def_idx : Int,
) -> @lib.Module {
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None => return mod_
  }
  if def_idx < 0 || def_idx >= funcs.length() {
    return mod_
  }
  let @lib.Func(locals, @lib.Expr(body)) = funcs[def_idx]
  let (next_body, changed) = dae_strip_function_terminal_suffix_instrs(body)
  if !changed {
    return mod_
  }
  let next_funcs = funcs.copy()
  next_funcs[def_idx] = @lib.Func::new(locals, @lib.Expr::new(next_body))
  mod_.with_code_sec(@lib.CodeSec::new(next_funcs))
}

///|
fn dae_function_info_refresh_unused_params(
  function_infos : Array[DaeFunctionInfo],
  callee_abs : Int,
  local_use : DaeLocalUse,
  param_count : Int,
) -> Array[Bool] {
  if callee_abs < 0 || callee_abs >= function_infos.length() {
    let unused = Array::make(param_count, false)
    let mut param_idx = 0
    while param_idx < param_count {
      unused[param_idx] = !local_use.gets[param_idx]
      param_idx += 1
    }
    return unused
  }
  let info = function_infos[callee_abs]
  if info.stale || info.unused_params.length() != param_count {
    let unused = Array::make(param_count, false)
    let mut param_idx = 0
    while param_idx < param_count {
      unused[param_idx] = !local_use.gets[param_idx]
      param_idx += 1
    }
    info.unused_params = unused
    info.stale = false
  }
  info.unused_params
}

///|
fn dae_local_use_for_callee(
  func : @lib.Func,
  total_locals : Int,
  callee_abs : Int,
  param_count : Int,
) -> DaeLocalUse {
  let local_use = {
    gets: Array::make(total_locals, false),
    writes: Array::make(total_locals, false),
  }
  let @lib.Func(_, @lib.Expr(body)) = func
  dae_scan_local_use_ignoring_instrs(body, local_use, callee_abs, param_count)
  local_use
}

///|
fn dae_instr_result_arity_from_block_type(block_type : @lib.BlockType) -> Int? {
  match block_type {
    @lib.VoidBlockType => Some(0)
    @lib.ValTypeBlockType(_) => Some(1)
    @lib.TypeIdxBlockType(_) => None
  }
}

///|
fn dae_instr_stack_effect_from_block_type(
  block_type : @lib.BlockType,
  mod_ : @lib.Module,
) -> (Int, Int)? {
  match dae_control_block_type_signature_evidence(block_type, mod_) {
    Some(evidence) => Some((evidence.input_count, evidence.output_count))
    None => None
  }
}

///|
fn dae_instr_stack_effect(
  instr : @lib.Instruction,
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
) -> (Int, Int)? {
  match instr {
    @lib.Unreachable | @lib.Nop => Some((0, 0))
    @lib.I32Const(_)
    | @lib.I64Const(_)
    | @lib.F32Const(_)
    | @lib.F64Const(_)
    | @lib.RefNull(_)
    | @lib.RefFunc(_)
    | @lib.StringConst(_)
    | @lib.StructNewDefault(_)
    | @lib.GlobalGet(_)
    | @lib.LocalGet(_)
    | @lib.TableSize(_)
    | @lib.MemorySize(_) => Some((0, 1))
    @lib.StructNew(type_idx) =>
      match mod_.type_sec {
        Some(type_sec) =>
          match dae_type_sec_subtype(type_sec, type_idx) {
            Some(subtype) =>
              match subtype.get_comptype() {
                @lib.StructCompType(fields) => Some((fields.length(), 1))
                _ => None
              }
            None => None
          }
        None => None
      }
    @lib.ArrayNew(_) => Some((2, 1))
    @lib.ArrayNewDefault(_) => Some((1, 1))
    @lib.ArrayNewFixed(_, @lib.U32(raw_len)) =>
      Some((raw_len.reinterpret_as_int(), 1))
    @lib.LocalSet(_) | @lib.GlobalSet(_) => Some((1, 0))
    @lib.LocalTee(_) => Some((1, 1))
    @lib.Drop => Some((1, 0))
    @lib.Select(_) => Some((3, 1))
    @lib.I32Eqz
    | @lib.I64Eqz
    | @lib.RefIsNull
    | @lib.RefAsNonNull
    | @lib.I32Clz
    | @lib.I32Ctz
    | @lib.I32Popcnt
    | @lib.I64Clz
    | @lib.I64Ctz
    | @lib.I64Popcnt
    | @lib.F32Abs
    | @lib.F32Neg
    | @lib.F32Ceil
    | @lib.F32Floor
    | @lib.F32Trunc
    | @lib.F32Nearest
    | @lib.F32Sqrt
    | @lib.F64Abs
    | @lib.F64Neg
    | @lib.F64Ceil
    | @lib.F64Floor
    | @lib.F64Trunc
    | @lib.F64Nearest
    | @lib.F64Sqrt
    | @lib.I32WrapI64
    | @lib.I64ExtendI32S
    | @lib.I64ExtendI32U
    | @lib.F32ConvertI32S
    | @lib.F32ConvertI32U
    | @lib.F32ConvertI64S
    | @lib.F32ConvertI64U
    | @lib.F32DemoteF64
    | @lib.F64ConvertI32S
    | @lib.F64ConvertI32U
    | @lib.F64ConvertI64S
    | @lib.F64ConvertI64U
    | @lib.F64PromoteF32
    | @lib.I32ReinterpretF32
    | @lib.I64ReinterpretF64
    | @lib.F32ReinterpretI32
    | @lib.F64ReinterpretI64
    | @lib.I32Extend8S
    | @lib.I32Extend16S
    | @lib.I64Extend8S
    | @lib.I64Extend16S
    | @lib.I64Extend32S
    | @lib.RefEq
    | @lib.AnyConvertExtern
    | @lib.ExternConvertAny
    | @lib.RefI31
    | @lib.I31GetS
    | @lib.I31GetU
    | @lib.I32TruncSatF32S
    | @lib.I32TruncSatF32U
    | @lib.I32TruncSatF64S
    | @lib.I32TruncSatF64U
    | @lib.I64TruncSatF32S
    | @lib.I64TruncSatF32U
    | @lib.I64TruncSatF64S
    | @lib.I64TruncSatF64U
    | @lib.I32Load(_)
    | @lib.I64Load(_)
    | @lib.F32Load(_)
    | @lib.F64Load(_)
    | @lib.I32Load8S(_)
    | @lib.I32Load8U(_)
    | @lib.I32Load16S(_)
    | @lib.I32Load16U(_)
    | @lib.I64Load8S(_)
    | @lib.I64Load8U(_)
    | @lib.I64Load16S(_)
    | @lib.I64Load16U(_)
    | @lib.I64Load32S(_)
    | @lib.I64Load32U(_)
    | @lib.StructGet(_, _)
    | @lib.StructGetS(_, _)
    | @lib.StructGetU(_, _)
    | @lib.MemoryGrow(_)
    | @lib.TableGet(_) => Some((1, 1))
    @lib.I32Eq
    | @lib.I32Ne
    | @lib.I32LtS
    | @lib.I32LtU
    | @lib.I32GtS
    | @lib.I32GtU
    | @lib.I32LeS
    | @lib.I32LeU
    | @lib.I32GeS
    | @lib.I32GeU
    | @lib.I64Eq
    | @lib.I64Ne
    | @lib.I64LtS
    | @lib.I64LtU
    | @lib.I64GtS
    | @lib.I64GtU
    | @lib.I64LeS
    | @lib.I64LeU
    | @lib.I64GeS
    | @lib.I64GeU
    | @lib.F32Eq
    | @lib.F32Ne
    | @lib.F32Lt
    | @lib.F32Gt
    | @lib.F32Le
    | @lib.F32Ge
    | @lib.F64Eq
    | @lib.F64Ne
    | @lib.F64Lt
    | @lib.F64Gt
    | @lib.F64Le
    | @lib.F64Ge
    | @lib.I32Add
    | @lib.I32Sub
    | @lib.I32Mul
    | @lib.I32DivS
    | @lib.I32DivU
    | @lib.I32RemS
    | @lib.I32RemU
    | @lib.I32And
    | @lib.I32Or
    | @lib.I32Xor
    | @lib.I32Shl
    | @lib.I32ShrS
    | @lib.I32ShrU
    | @lib.I32Rotl
    | @lib.I32Rotr
    | @lib.I64Add
    | @lib.I64Sub
    | @lib.I64Mul
    | @lib.I64DivS
    | @lib.I64DivU
    | @lib.I64RemS
    | @lib.I64RemU
    | @lib.I64And
    | @lib.I64Or
    | @lib.I64Xor
    | @lib.I64Shl
    | @lib.I64ShrS
    | @lib.I64ShrU
    | @lib.I64Rotl
    | @lib.I64Rotr
    | @lib.F32Add
    | @lib.F32Sub
    | @lib.F32Mul
    | @lib.F32Div
    | @lib.F32Min
    | @lib.F32Max
    | @lib.F32Copysign
    | @lib.F64Add
    | @lib.F64Sub
    | @lib.F64Mul
    | @lib.F64Div
    | @lib.F64Min
    | @lib.F64Max
    | @lib.F64Copysign
    | @lib.ArrayGet(_)
    | @lib.ArrayGetS(_)
    | @lib.ArrayGetU(_)
    | @lib.TableGrow(_) => Some((2, 1))
    @lib.Call(func_idx) | @lib.ReturnCall(func_idx) => {
      let slot = dae_func_idx_slot(func_idx)
      match dae_resolve_func_type(mod_, func_type_indices, slot) {
        Some(@lib.FuncType(params, results)) =>
          Some((params.length(), results.length()))
        None => None
      }
    }
    @lib.CallIndirect(type_idx, _) | @lib.ReturnCallIndirect(type_idx, _) =>
      match mod_.type_sec {
        Some(type_sec) =>
          match dae_type_sec_func_type(type_sec, type_idx) {
            Some(@lib.FuncType(params, results)) =>
              Some((params.length() + 1, results.length()))
            None => None
          }
        None => None
      }
    @lib.CallRef(type_idx) | @lib.ReturnCallRef(type_idx) =>
      match mod_.type_sec {
        Some(type_sec) =>
          match dae_type_sec_func_type(type_sec, type_idx) {
            Some(@lib.FuncType(params, results)) =>
              Some((params.length() + 1, results.length()))
            None => None
          }
        None => None
      }
    @lib.Block(block_type, _)
    | @lib.Loop(block_type, _)
    | @lib.TryTable(block_type, _, _) =>
      dae_instr_stack_effect_from_block_type(block_type, mod_)
    @lib.If(block_type, _, _) =>
      match dae_instr_stack_effect_from_block_type(block_type, mod_) {
        Some((inputs, outputs)) => Some((inputs + 1, outputs))
        None => None
      }
    _ => None
  }
}

///|
fn dae_control_entry_stack_evidence(
  block_type : @lib.BlockType,
  mod_ : @lib.Module,
) -> DaeControlEntryStackEvidence? {
  match dae_control_block_type_signature_evidence(block_type, mod_) {
    Some(signature) => {
      let evidence = {
        entry_stack_values: signature.input_count,
        result_stack_values: signature.output_count,
      }
      if evidence.entry_stack_values < 0 || evidence.result_stack_values < 0 {
        None
      } else {
        Some(evidence)
      }
    }
    None => None
  }
}

///|
fn dae_control_entry_stack_values(
  block_type : @lib.BlockType,
  mod_ : @lib.Module,
) -> Int? {
  match dae_control_entry_stack_evidence(block_type, mod_) {
    Some(evidence) => Some(evidence.entry_stack_values)
    None => None
  }
}

///|
fn dae_nested_control_entry_evidence_is_consistent(
  evidence : DaeNestedControlEntryEvidence,
) -> Bool {
  evidence.entry_stack_values >= 0 &&
  evidence.result_stack_values >= 0 &&
  evidence.control_kind >= 0 &&
  evidence.control_kind <= 3 &&
  (!evidence.has_else_arm || evidence.control_kind == 3)
}

///|
fn dae_nested_control_entry_evidence(
  instr : @lib.Instruction,
  mod_ : @lib.Module,
) -> DaeNestedControlEntryEvidence? {
  let (block_type, control_kind, has_else_arm) = match instr {
    @lib.Block(block_type, _) => (block_type, 0, false)
    @lib.Loop(block_type, _) => (block_type, 1, false)
    @lib.TryTable(block_type, _, _) => (block_type, 2, false)
    @lib.If(block_type, _, else_body) => (block_type, 3, else_body is Some(_))
    _ => return None
  }
  let entry_stack_values = match
    dae_control_entry_stack_values(block_type, mod_) {
    Some(value) => value
    None => return None
  }
  match dae_control_entry_stack_evidence(block_type, mod_) {
    Some(evidence) => {
      if evidence.entry_stack_values != entry_stack_values {
        return None
      }
      let nested = {
        entry_stack_values,
        result_stack_values: evidence.result_stack_values,
        control_kind,
        has_else_arm,
      }
      if dae_nested_control_entry_evidence_is_consistent(nested) {
        Some(nested)
      } else {
        None
      }
    }
    None => None
  }
}

///|
fn dae_nested_control_children_evidence_is_consistent(
  evidence : DaeNestedControlChildrenEvidence,
) -> Bool {
  evidence.entry_stack_values >= 0 &&
  evidence.result_stack_values >= 0 &&
  evidence.control_kind >= 0 &&
  evidence.control_kind <= 3 &&
  evidence.primary_body.length() >= 0 &&
  evidence.has_else_arm == (evidence.secondary_body is Some(_)) &&
  (!evidence.has_else_arm || evidence.control_kind == 3)
}

///|
fn dae_nested_control_children_evidence(
  instr : @lib.Instruction,
  mod_ : @lib.Module,
) -> DaeNestedControlChildrenEvidence? {
  let nested = match dae_nested_control_entry_evidence(instr, mod_) {
    Some(evidence) => evidence
    None => return None
  }
  let (primary_body, secondary_body, expected_kind, expected_else) = match
    instr {
    @lib.Block(_, @lib.Expr(body)) => (body, None, 0, false)
    @lib.Loop(_, @lib.Expr(body)) => (body, None, 1, false)
    @lib.TryTable(_, _, @lib.Expr(body)) => (body, None, 2, false)
    @lib.If(_, then_body, else_body) =>
      (then_body, else_body, 3, else_body is Some(_))
    _ => return None
  }
  if nested.control_kind != expected_kind ||
    nested.has_else_arm != expected_else {
    return None
  }
  let evidence = {
    entry_stack_values: nested.entry_stack_values,
    result_stack_values: nested.result_stack_values,
    control_kind: nested.control_kind,
    has_else_arm: nested.has_else_arm,
    primary_body,
    secondary_body,
  }
  if dae_nested_control_children_evidence_is_consistent(evidence) {
    Some(evidence)
  } else {
    None
  }
}

///|
fn dae_rebuild_nested_control_children(
  instr : @lib.Instruction,
  evidence : DaeNestedControlChildrenEvidence,
  primary_body : Array[@lib.Instruction],
  secondary_body : Array[@lib.Instruction]?,
) -> @lib.Instruction? {
  if !dae_nested_control_children_evidence_is_consistent(evidence) {
    return None
  }
  match instr {
    @lib.Block(block_type, _) if evidence.control_kind == 0 &&
      !evidence.has_else_arm &&
      secondary_body is None =>
      Some(@lib.Instruction::block(block_type, @lib.Expr::new(primary_body)))
    @lib.Loop(block_type, _) if evidence.control_kind == 1 &&
      !evidence.has_else_arm &&
      secondary_body is None =>
      Some(@lib.Instruction::loop_(block_type, @lib.Expr::new(primary_body)))
    @lib.TryTable(block_type, catches, _) if evidence.control_kind == 2 &&
      !evidence.has_else_arm &&
      secondary_body is None =>
      Some(
        @lib.Instruction::try_table(
          block_type,
          catches,
          @lib.Expr::new(primary_body),
        ),
      )
    @lib.If(block_type, _, _) if evidence.control_kind == 3 =>
      if evidence.has_else_arm {
        match secondary_body {
          Some(body) =>
            Some(@lib.Instruction::if_(block_type, primary_body, Some(body)))
          None => None
        }
      } else {
        match secondary_body {
          Some(_) => None
          None => Some(@lib.Instruction::if_(block_type, primary_body, None))
        }
      }
    _ => None
  }
}

///|
fn dae_instr_is_trivially_droppable(instr : @lib.Instruction) -> Bool {
  match instr {
    @lib.I32Const(_)
    | @lib.I64Const(_)
    | @lib.F32Const(_)
    | @lib.F64Const(_)
    | @lib.RefNull(_)
    | @lib.RefFunc(_)
    | @lib.StringConst(_)
    | @lib.LocalGet(_)
    | @lib.GlobalGet(_)
    | @lib.StructNew(_)
    | @lib.StructNewDefault(_)
    | @lib.ArrayNew(_)
    | @lib.ArrayNewDefault(_)
    | @lib.ArrayNewFixed(_, _) => true
    _ => false
  }
}

///|
fn dae_operand_rewrite_action(
  disposition : DaeOperandDisposition,
  localization_available : Bool,
  has_escaping_branch : Bool,
) -> DaeOperandRewriteAction {
  if disposition.droppable_without_repair {
    DaeDropOperandDirectly
  } else if has_escaping_branch {
    DaeRejectEscapingOperandRewrite
  } else if localization_available {
    DaeLocalizeOperandAndRetry
  } else {
    DaePreserveOperandEffectsAndDropValue
  }
}

///|
fn dae_operand_rewrite_disposition(
  operand : DaeOperandDisposition,
  localization_available~ : Bool,
  has_escaping_branch~ : Bool,
) -> DaeOperandRewriteDisposition {
  let action = dae_operand_rewrite_action(
    operand, localization_available, has_escaping_branch,
  )
  let reason = match action {
    DaeDropOperandDirectly => DaeOperandDirectlyDroppable
    DaePreserveOperandEffectsAndDropValue => DaeOperandEffectsMustBeReplayed
    DaeLocalizeOperandAndRetry => DaeOperandRequiresLocalization
    DaeRejectEscapingOperandRewrite => DaeOperandContainsEscapingControl
  }
  { operand, localization_available, has_escaping_branch, action, reason }
}

///|
fn dae_operand_rewrite_drops_directly(
  disposition : DaeOperandRewriteDisposition,
) -> Bool {
  match disposition.action {
    DaeDropOperandDirectly => true
    _ => false
  }
}

///|
fn dae_operand_rewrite_preserves_effects_and_drops_value(
  disposition : DaeOperandRewriteDisposition,
) -> Bool {
  match disposition.action {
    DaePreserveOperandEffectsAndDropValue => true
    _ => false
  }
}

///|
fn dae_operand_rewrite_localizes_and_retries(
  disposition : DaeOperandRewriteDisposition,
) -> Bool {
  match disposition.action {
    DaeLocalizeOperandAndRetry => true
    _ => false
  }
}

///|
fn dae_operand_rewrite_rejects_escaping_branch(
  disposition : DaeOperandRewriteDisposition,
) -> Bool {
  match disposition.action {
    DaeRejectEscapingOperandRewrite => true
    _ => false
  }
}

///|
fn dae_operand_rewrite_disposition_is_consistent(
  disposition : DaeOperandRewriteDisposition,
) -> Bool {
  let operand = disposition.operand
  if operand.start < 0 ||
    operand.end < operand.start ||
    operand.preserve_effects_on_removal == operand.droppable_without_repair ||
    (disposition.has_escaping_branch && !operand.has_branch) {
    return false
  }
  match
    (
      disposition.action,
      dae_operand_rewrite_action(
        operand,
        disposition.localization_available,
        disposition.has_escaping_branch,
      ),
    ) {
    (DaeDropOperandDirectly, DaeDropOperandDirectly)
    | (
      DaePreserveOperandEffectsAndDropValue,
      DaePreserveOperandEffectsAndDropValue,
    )
    | (DaeLocalizeOperandAndRetry, DaeLocalizeOperandAndRetry)
    | (DaeRejectEscapingOperandRewrite, DaeRejectEscapingOperandRewrite) => true
    _ => false
  }
}

///|
fn dae_operand_removal_plan(
  disposition : DaeOperandRewriteDisposition,
  keep : Bool,
) -> DaeOperandRemovalPlan {
  let preserve_effects = dae_operand_rewrite_preserves_effects_and_drops_value(
    disposition,
  )
  let requires_localization_retry = !keep &&
    dae_operand_rewrite_localizes_and_retries(disposition)
  let rejects_direct_removal = !keep &&
    dae_operand_rewrite_rejects_escaping_branch(disposition)
  let replay_operand = keep || preserve_effects || rejects_direct_removal
  {
    start: disposition.operand.start,
    end: disposition.operand.end,
    keep_operand: keep,
    replay_operand,
    append_drop: !keep && replay_operand,
    requires_localization_retry,
    rejects_direct_removal,
  }
}

///|
fn dae_operand_removal_plan_is_consistent(
  disposition : DaeOperandRewriteDisposition,
  plan : DaeOperandRemovalPlan,
) -> Bool {
  if !dae_operand_rewrite_disposition_is_consistent(disposition) ||
    plan.start != disposition.operand.start ||
    plan.end != disposition.operand.end {
    return false
  }
  let expected = dae_operand_removal_plan(disposition, plan.keep_operand)
  plan.replay_operand == expected.replay_operand &&
  plan.append_drop == expected.append_drop &&
  plan.requires_localization_retry == expected.requires_localization_retry &&
  plan.rejects_direct_removal == expected.rejects_direct_removal
}

///|
fn dae_operand_removal_plan_drops_without_repair(
  plan : DaeOperandRemovalPlan,
) -> Bool {
  !plan.keep_operand &&
  !plan.replay_operand &&
  !plan.append_drop &&
  !plan.requires_localization_retry &&
  !plan.rejects_direct_removal
}

///|
fn dae_operand_disposition_from_range(
  instrs : Array[@lib.Instruction],
  start : Int,
  end : Int,
) -> DaeOperandDisposition? {
  if start < 0 || end < start || end > instrs.length() {
    return None
  }
  let mut droppable_without_repair = true
  let mut has_branch = false
  let mut has_effect_or_branch = false
  let mut idx = start
  while idx < end {
    let instr = instrs[idx]
    if !dae_instr_is_trivially_droppable(instr) {
      droppable_without_repair = false
    }
    if dae_instr_has_branch(instr) {
      has_branch = true
    }
    if dae_instr_has_observable_effect_or_branch(instr) {
      has_effect_or_branch = true
    }
    idx += 1
  }
  Some({
    start,
    end,
    droppable_without_repair,
    preserve_effects_on_removal: !droppable_without_repair,
    has_branch,
    has_effect_or_branch,
  })
}

///|
fn dae_operand_disposition_from_call_shape(
  instrs : Array[@lib.Instruction],
  shape : DaeCallShape,
) -> DaeOperandDisposition {
  let base = match
    dae_operand_disposition_from_range(instrs, shape.start, shape.end) {
    Some(disposition) => disposition
    None =>
      {
        start: shape.start,
        end: shape.end,
        droppable_without_repair: shape.pure,
        preserve_effects_on_removal: !shape.pure,
        has_branch: false,
        has_effect_or_branch: !shape.pure,
      }
  }
  {
    start: shape.start,
    end: shape.end,
    droppable_without_repair: shape.pure,
    preserve_effects_on_removal: !shape.pure,
    has_branch: base.has_branch,
    has_effect_or_branch: base.has_effect_or_branch,
  }
}

///|
fn dae_append_operand_with_removal_plan(
  out : Array[@lib.Instruction],
  instrs : Array[@lib.Instruction],
  plan : DaeOperandRemovalPlan,
) -> Unit {
  if plan.replay_operand {
    let mut idx = plan.start
    while idx < plan.end {
      out.push(instrs[idx])
      idx += 1
    }
    if plan.append_drop {
      out.push(@lib.Instruction::drop())
    }
  }
}

///|
fn dae_slice_is_trivially_droppable(
  instrs : Array[@lib.Instruction],
  start : Int,
  end : Int,
) -> Bool {
  match dae_operand_disposition_from_range(instrs, start, end) {
    Some(disposition) =>
      dae_operand_removal_plan_drops_without_repair(
        dae_operand_removal_plan(
          dae_operand_rewrite_disposition(
            disposition,
            localization_available=false,
            has_escaping_branch=disposition.has_branch,
          ),
          false,
        ),
      )
    None => false
  }
}

///|
fn dae_trivially_dropped_prefix_evidence(
  instrs : Array[@lib.Instruction],
  end : Int,
) -> DaeDroppedOperandPairSkipEvidence? {
  let skipped = match dae_dropped_operand_pair_skip_evidence(instrs, 0, end) {
    Some(evidence) => evidence
    None => return None
  }
  if skipped.next == end {
    Some(skipped)
  } else {
    None
  }
}

///|
fn dae_find_value_slice(
  instrs : Array[@lib.Instruction],
  end : Int,
  entry_stack_values : Int,
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  allow_stack_carried_void_effects? : Bool = false,
) -> (DaeCallShape, Int, Int)? {
  let mut need = 1
  let mut idx = end - 1
  while idx >= 0 {
    let effect = match
      dae_stack_effect_evidence(instrs[idx], mod_, func_type_indices) {
      Some(effect) => effect
      None => return None
    }
    let ins = effect.inputs
    let outs = effect.outputs
    if outs == 0 && need > 0 && !allow_stack_carried_void_effects {
      if need <= entry_stack_values {
        return Some(
          (
            { start: idx + 1, end, pure: false },
            idx + 1,
            entry_stack_values - need,
          ),
        )
      }
      return None
    }
    need = need - outs + ins
    if need <= 0 {
      return Some(
        (
          {
            start: idx,
            end,
            pure: dae_slice_is_trivially_droppable(instrs, idx, end),
          },
          idx,
          entry_stack_values,
        ),
      )
    }
    idx -= 1
  }
  if need <= entry_stack_values {
    return Some(({ start: 0, end, pure: false }, 0, entry_stack_values - need))
  }
  None
}

///|
fn dae_value_slice_from_operand_disposition_with_purity(
  disposition : DaeOperandDisposition,
  pure : Bool,
) -> DaeValueSlice {
  {
    start: disposition.start,
    end: disposition.end,
    pure,
    has_branch: disposition.has_branch,
    has_effect_or_branch: disposition.has_effect_or_branch,
    disposition,
  }
}

///|
fn dae_value_slice_from_operand_disposition(
  disposition : DaeOperandDisposition,
) -> DaeValueSlice {
  dae_value_slice_from_operand_disposition_with_purity(
    disposition,
    disposition.droppable_without_repair,
  )
}

///|
fn dae_value_slice_from_call_shape(
  instrs : Array[@lib.Instruction],
  shape : DaeCallShape,
) -> DaeValueSlice {
  dae_value_slice_from_operand_disposition(
    dae_operand_disposition_from_call_shape(instrs, shape),
  )
}

///|
fn dae_value_slice_from_range(
  instrs : Array[@lib.Instruction],
  start : Int,
  end : Int,
) -> DaeValueSlice {
  let disposition = match
    dae_operand_disposition_from_range(instrs, start, end) {
    Some(disposition) => disposition
    None =>
      {
        start,
        end,
        droppable_without_repair: true,
        preserve_effects_on_removal: false,
        has_branch: false,
        has_effect_or_branch: false,
      }
  }
  dae_value_slice_from_operand_disposition_with_purity(
    disposition,
    !disposition.has_effect_or_branch,
  )
}

///|
fn dae_call_shape_from_value_slice(slice : DaeValueSlice) -> DaeCallShape {
  { start: slice.start, end: slice.end, pure: slice.pure }
}

///|
fn dae_value_slice_single_instruction_index(slice : DaeValueSlice) -> Int? {
  if slice.end == slice.start + 1 {
    Some(slice.start)
  } else {
    None
  }
}

///|
fn dae_find_select_value_slices(
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  body : Array[@lib.Instruction],
  select_idx : Int,
  required_left_start? : Int = -1,
  require_dropped_prefix? : Bool = false,
) -> DaeSelectValueSlices? {
  if select_idx < 0 || select_idx >= body.length() {
    return None
  }
  match body[select_idx] {
    @lib.Select(_) => ()
    _ => return None
  }
  let mut condition_start = select_idx - 1
  while condition_start >= 2 {
    let condition = match
      dae_select_condition_localization_evidence(
        mod_, body, condition_start, select_idx, func_type_indices,
      ) {
      Some(evidence) => evidence
      None => {
        condition_start -= 1
        continue
      }
    }
    let right_shape = match
      dae_find_value_slice(body, condition_start, 0, mod_, func_type_indices) {
      Some((shape, _, 0)) => shape
      _ => {
        condition_start -= 1
        continue
      }
    }
    let left_shape = match
      dae_find_value_slice(body, right_shape.start, 0, mod_, func_type_indices) {
      Some((shape, _, 0)) => shape
      _ => {
        condition_start -= 1
        continue
      }
    }
    if required_left_start >= 0 && left_shape.start != required_left_start {
      condition_start -= 1
      continue
    }
    if require_dropped_prefix &&
      dae_trivially_dropped_prefix_evidence(body, left_shape.start) is None {
      condition_start -= 1
      continue
    }
    return Some({
      left: dae_value_slice_from_call_shape(body, left_shape),
      right: dae_value_slice_from_call_shape(body, right_shape),
      condition,
      select_idx,
    })
  }
  None
}

///|
fn dae_value_slice_disposition_is_consistent(slice : DaeValueSlice) -> Bool {
  if slice.start != slice.disposition.start ||
    slice.end != slice.disposition.end {
    return false
  }
  if slice.has_branch != slice.disposition.has_branch ||
    slice.has_effect_or_branch != slice.disposition.has_effect_or_branch {
    return false
  }
  let direct_rewrite = dae_operand_rewrite_disposition(
    slice.disposition,
    localization_available=false,
    has_escaping_branch=slice.disposition.has_branch,
  )
  if !dae_operand_rewrite_disposition_is_consistent(direct_rewrite) ||
    slice.disposition.preserve_effects_on_removal ==
    dae_operand_rewrite_drops_directly(direct_rewrite) {
    return false
  }
  if slice.pure && slice.has_effect_or_branch {
    return false
  }
  if slice.has_branch && !slice.has_effect_or_branch {
    return false
  }
  true
}

///|
fn dae_select_value_slices_are_consistent(
  slices : DaeSelectValueSlices,
  select_idx : Int,
) -> Bool {
  slices.select_idx == select_idx &&
  slices.left.start < slices.left.end &&
  slices.left.end == slices.right.start &&
  slices.right.start < slices.right.end &&
  slices.right.end <= slices.condition.start &&
  slices.condition.end == slices.select_idx &&
  dae_select_condition_localization_evidence_is_consistent(slices.condition) &&
  dae_value_slice_disposition_is_consistent(slices.left) &&
  dae_value_slice_disposition_is_consistent(slices.right)
}

///|
fn dae_control_result_slice_is_consistent(
  result_slice : DaeControlResultSlice,
) -> Bool {
  if result_slice.result_count <= 0 {
    return false
  }
  if result_slice.carrier_kind < 0 || result_slice.carrier_kind > 4 {
    return false
  }
  if result_slice.slice.start < 0 ||
    result_slice.slice.end > result_slice.body.length() {
    return false
  }
  if result_slice.slice.end - result_slice.slice.start !=
    result_slice.result_count {
    return false
  }
  if !dae_value_slice_disposition_is_consistent(result_slice.slice) {
    return false
  }
  if result_slice.terminal_return {
    if result_slice.slice.end >= result_slice.body.length() {
      return false
    }
    match result_slice.body[result_slice.body.length() - 1] {
      @lib.Return => ()
      _ => return false
    }
  }
  true
}

///|
fn dae_make_multi_result_control_slice(
  body : Array[@lib.Instruction],
  start : Int,
  result_count : Int,
  carrier_kind : Int,
  flattened : Bool,
  terminal_return : Bool,
) -> DaeControlResultSlice? {
  if start < 0 || result_count <= 0 {
    return None
  }
  let end = start + result_count
  let result_slice = {
    body,
    slice: dae_value_slice_from_range(body, start, end),
    result_count,
    carrier_kind,
    flattened,
    terminal_return,
  }
  if dae_control_result_slice_is_consistent(result_slice) {
    Some(result_slice)
  } else {
    None
  }
}

///|
fn dae_effect_free_body_evidence_is_consistent(
  evidence : DaeEffectFreeBodyEvidence,
) -> Bool {
  evidence.body_length == evidence.body.length() &&
  evidence.effect_free == !evidence.has_observable_effect_or_branch &&
  evidence.effect_free
}

///|
fn dae_effect_free_body_evidence(
  body : Array[@lib.Instruction],
) -> DaeEffectFreeBodyEvidence? {
  let has_observable_effect_or_branch = dae_instrs_have_observable_effect_or_branch(
    body,
  )
  let evidence = {
    body,
    body_length: body.length(),
    has_observable_effect_or_branch,
    effect_free: !has_observable_effect_or_branch,
  }
  if dae_effect_free_body_evidence_is_consistent(evidence) {
    Some(evidence)
  } else {
    None
  }
}

///|
fn dae_terminal_return_body_evidence_is_consistent(
  evidence : DaeTerminalReturnBodyEvidence,
) -> Bool {
  if evidence.body_length != evidence.body.length() || evidence.body_length == 0 {
    return false
  }
  if evidence.return_idx != evidence.body_length - 1 ||
    evidence.prefix_length != evidence.return_idx {
    return false
  }
  match evidence.body[evidence.return_idx] {
    @lib.Return => ()
    _ => return false
  }
  evidence.terminal_return_only ==
  !evidence.prefix_has_observable_effect_or_branch &&
  evidence.terminal_return_only
}

///|
fn dae_terminal_return_body_evidence(
  body : Array[@lib.Instruction],
) -> DaeTerminalReturnBodyEvidence? {
  if body.length() == 0 {
    return None
  }
  let return_idx = body.length() - 1
  match body[return_idx] {
    @lib.Return => ()
    _ => return None
  }
  let mut prefix_has_observable_effect_or_branch = false
  let mut idx = 0
  while idx < return_idx {
    if dae_instr_has_observable_effect_or_branch(body[idx]) {
      prefix_has_observable_effect_or_branch = true
    }
    idx += 1
  }
  let evidence = {
    body,
    body_length: body.length(),
    return_idx,
    prefix_length: return_idx,
    prefix_has_observable_effect_or_branch,
    terminal_return_only: !prefix_has_observable_effect_or_branch,
  }
  if dae_terminal_return_body_evidence_is_consistent(evidence) {
    Some(evidence)
  } else {
    None
  }
}

///|
fn dae_single_block_result_carrier_evidence(
  mod_ : @lib.Module,
  body : Array[@lib.Instruction],
  result_count : Int,
) -> DaeSingleBlockResultCarrierEvidence? {
  if result_count <= 0 {
    return None
  }
  match body {
    [@lib.Block(block_type, @lib.Expr(block_body))] => {
      match
        dae_control_block_type_zero_input_output_count_evidence(
          block_type,
          mod_.type_sec,
          result_count,
        ) {
        Some(_) => ()
        None => return None
      }
      match dae_effect_free_body_evidence(block_body) {
        Some(effect_free_body) =>
          Some({
            body: block_body,
            result_count,
            body_has_effect_or_branch: effect_free_body.has_observable_effect_or_branch,
            effect_free_body,
          })
        None => None
      }
    }
    _ => None
  }
}

///|
fn dae_multi_result_control_carrier_chain_slice(
  mod_ : @lib.Module,
  body : Array[@lib.Instruction],
  result_count : Int,
  terminal_return~ : Bool,
  match_terminal_return~ : Bool,
  append_terminal_return~ : Bool,
) -> DaeControlResultSlice? {
  if result_count <= 0 {
    return None
  }
  let mut candidate_body = body
  let mut flattened = false
  let mut carrier_kind = 0
  let mut keep_unwrapping = true
  while keep_unwrapping {
    match
      dae_flat_multi_result_suffix_evidence(
        candidate_body, result_count, match_terminal_return,
      ) {
      Some(flat_suffix) => {
        let result_body = if append_terminal_return {
          let flattened_body = candidate_body.copy()
          flattened_body.push(@lib.Instruction::return_())
          flattened_body
        } else {
          candidate_body
        }
        return dae_make_multi_result_control_slice(
          result_body,
          flat_suffix.start,
          flat_suffix.result_count,
          carrier_kind,
          flattened,
          terminal_return,
        )
      }
      None => ()
    }
    keep_unwrapping = false
    match
      dae_single_block_result_carrier_evidence(
        mod_, candidate_body, result_count,
      ) {
      Some(evidence) =>
        if evidence.result_count == result_count &&
          !evidence.body_has_effect_or_branch &&
          evidence.effect_free_body.effect_free {
          candidate_body = evidence.body
          flattened = true
          carrier_kind = 1
          keep_unwrapping = true
        }
      None => ()
    }
  }
  None
}

///|
fn dae_next_free_local_idx(
  instrs : Array[@lib.Instruction],
  declared_total : Int,
) -> Int {
  let mut next = if declared_total < 0 { 0 } else { declared_total }
  for instr in instrs {
    match instr {
      @lib.LocalGet(idx) | @lib.LocalSet(idx) | @lib.LocalTee(idx) => {
        let candidate = dae_local_idx_slot(idx) + 1
        if candidate > next {
          next = candidate
        }
      }
      @lib.Block(_, @lib.Expr(body))
      | @lib.Loop(_, @lib.Expr(body))
      | @lib.TryTable(_, _, @lib.Expr(body)) => {
        let candidate = dae_next_free_local_idx(body, next)
        if candidate > next {
          next = candidate
        }
      }
      @lib.If(_, then_body, else_body) => {
        let then_candidate = dae_next_free_local_idx(then_body, next)
        if then_candidate > next {
          next = then_candidate
        }
        match else_body {
          Some(body) => {
            let else_candidate = dae_next_free_local_idx(body, next)
            if else_candidate > next {
              next = else_candidate
            }
          }
          None => ()
        }
      }
      _ => ()
    }
  }
  next
}

///|
fn dae_local_indices_fit_instrs(
  instrs : Array[@lib.Instruction],
  total_locals : Int,
) -> Bool {
  total_locals >= 0 && dae_next_free_local_idx(instrs, 0) <= total_locals
}

///|
fn dae_rewrite_instruction_locals(
  instr : @lib.Instruction,
  local_map : Array[Int],
) -> @lib.Instruction {
  match instr {
    @lib.LocalGet(idx) =>
      @lib.Instruction::local_get(
        dae_rewrite_local_idx(dae_local_idx_slot(idx), local_map),
      )
    @lib.LocalSet(idx) =>
      @lib.Instruction::local_set(
        dae_rewrite_local_idx(dae_local_idx_slot(idx), local_map),
      )
    @lib.LocalTee(idx) =>
      @lib.Instruction::local_tee(
        dae_rewrite_local_idx(dae_local_idx_slot(idx), local_map),
      )
    @lib.Block(block_type, @lib.Expr(body)) =>
      @lib.Instruction::block(
        block_type,
        @lib.Expr::new(dae_rewrite_locals_instrs(body, local_map)),
      )
    @lib.Loop(block_type, @lib.Expr(body)) =>
      @lib.Instruction::loop_(
        block_type,
        @lib.Expr::new(dae_rewrite_locals_instrs(body, local_map)),
      )
    @lib.TryTable(block_type, catches, @lib.Expr(body)) =>
      @lib.Instruction::try_table(
        block_type,
        catches,
        @lib.Expr::new(dae_rewrite_locals_instrs(body, local_map)),
      )
    @lib.If(block_type, then_body, else_body) =>
      @lib.Instruction::if_(
        block_type,
        dae_rewrite_locals_instrs(then_body, local_map),
        match else_body {
          Some(body) => Some(dae_rewrite_locals_instrs(body, local_map))
          None => None
        },
      )
    _ => instr
  }
}

///|
fn dae_rewrite_locals_instrs(
  instrs : Array[@lib.Instruction],
  local_map : Array[Int],
) -> Array[@lib.Instruction] {
  let out : Array[@lib.Instruction] = []
  for instr in instrs {
    out.push(dae_rewrite_instruction_locals(instr, local_map))
  }
  out
}

///|
fn dae_negate_compare_instr(instr : @lib.Instruction) -> @lib.Instruction? {
  match instr {
    @lib.I32Eq => Some(@lib.Instruction::i32_ne())
    @lib.I32Ne => Some(@lib.Instruction::i32_eq())
    @lib.I32LtS => Some(@lib.Instruction::i32_ge_s())
    @lib.I32LtU => Some(@lib.Instruction::i32_ge_u())
    @lib.I32LeS => Some(@lib.Instruction::i32_gt_s())
    @lib.I32LeU => Some(@lib.Instruction::i32_gt_u())
    @lib.I32GtS => Some(@lib.Instruction::i32_le_s())
    @lib.I32GtU => Some(@lib.Instruction::i32_le_u())
    @lib.I32GeS => Some(@lib.Instruction::i32_lt_s())
    @lib.I32GeU => Some(@lib.Instruction::i32_lt_u())
    @lib.I64Eq => Some(@lib.Instruction::i64_ne())
    @lib.I64Ne => Some(@lib.Instruction::i64_eq())
    @lib.I64LtS => Some(@lib.Instruction::i64_ge_s())
    @lib.I64LtU => Some(@lib.Instruction::i64_ge_u())
    @lib.I64LeS => Some(@lib.Instruction::i64_gt_s())
    @lib.I64LeU => Some(@lib.Instruction::i64_gt_u())
    @lib.I64GtS => Some(@lib.Instruction::i64_le_s())
    @lib.I64GtU => Some(@lib.Instruction::i64_le_u())
    @lib.I64GeS => Some(@lib.Instruction::i64_lt_s())
    @lib.I64GeU => Some(@lib.Instruction::i64_lt_u())
    @lib.F32Eq => Some(@lib.Instruction::f32_ne())
    @lib.F32Ne => Some(@lib.Instruction::f32_eq())
    @lib.F32Lt => Some(@lib.Instruction::f32_ge())
    @lib.F32Gt => Some(@lib.Instruction::f32_le())
    @lib.F32Le => Some(@lib.Instruction::f32_gt())
    @lib.F32Ge => Some(@lib.Instruction::f32_lt())
    @lib.F64Eq => Some(@lib.Instruction::f64_ne())
    @lib.F64Ne => Some(@lib.Instruction::f64_eq())
    @lib.F64Lt => Some(@lib.Instruction::f64_ge())
    @lib.F64Gt => Some(@lib.Instruction::f64_le())
    @lib.F64Le => Some(@lib.Instruction::f64_gt())
    @lib.F64Ge => Some(@lib.Instruction::f64_lt())
    _ => None
  }
}

///|
fn dae_collect_written_locals_instr(
  instr : @lib.Instruction,
  written : Array[Bool],
) -> Unit {
  match instr {
    @lib.LocalSet(idx) | @lib.LocalTee(idx) => {
      let slot = dae_local_idx_slot(idx)
      if slot >= 0 && slot < written.length() {
        written[slot] = true
      }
    }
    @lib.Block(_, @lib.Expr(body))
    | @lib.Loop(_, @lib.Expr(body))
    | @lib.TryTable(_, _, @lib.Expr(body)) =>
      for child in body {
        dae_collect_written_locals_instr(child, written)
      }
    @lib.If(_, then_body, Some(else_body)) => {
      for child in then_body {
        dae_collect_written_locals_instr(child, written)
      }
      for child in else_body {
        dae_collect_written_locals_instr(child, written)
      }
    }
    @lib.If(_, then_body, None) =>
      for child in then_body {
        dae_collect_written_locals_instr(child, written)
      }
    _ => ()
  }
}

///|
fn dae_collect_written_locals(
  instrs : Array[@lib.Instruction],
  total_locals : Int,
) -> Array[Bool] {
  let written = Array::make(total_locals, false)
  for instr in instrs {
    dae_collect_written_locals_instr(instr, written)
  }
  written
}

///|
fn dae_default_zero_high_guard_is_false(
  instrs : Array[@lib.Instruction],
  param_count : Int,
  written : Array[Bool],
) -> Bool {
  match instrs {
    [@lib.LocalGet(local_idx), @lib.I32Const(@lib.I32(57)), @lib.I32GtS] => {
      let slot = dae_local_idx_slot(local_idx)
      slot >= param_count && slot < written.length() && !written[slot]
    }
    _ => false
  }
}

///|
fn dae_simplify_default_zero_high_guard_instr(
  instr : @lib.Instruction,
  param_count : Int,
  written : Array[Bool],
) -> @lib.Instruction {
  match instr {
    @lib.Block(block_type, @lib.Expr(body)) =>
      @lib.Instruction::block(
        block_type,
        @lib.Expr::new(
          dae_simplify_default_zero_high_guard_instrs(
            body, param_count, written,
          ),
        ),
      )
    @lib.Loop(block_type, @lib.Expr(body)) =>
      @lib.Instruction::loop_(
        block_type,
        @lib.Expr::new(
          dae_simplify_default_zero_high_guard_instrs(
            body, param_count, written,
          ),
        ),
      )
    @lib.TryTable(block_type, catches, @lib.Expr(body)) =>
      @lib.Instruction::try_table(
        block_type,
        catches,
        @lib.Expr::new(
          dae_simplify_default_zero_high_guard_instrs(
            body, param_count, written,
          ),
        ),
      )
    @lib.If(block_type, then_body, Some(else_body)) => {
      let simplified_then = dae_simplify_default_zero_high_guard_instrs(
        then_body, param_count, written,
      )
      let simplified_else = dae_simplify_default_zero_high_guard_instrs(
        else_body, param_count, written,
      )
      if block_type != @lib.BlockType::void_() &&
        simplified_then.length() == 1 &&
        simplified_then[0] == @lib.Instruction::i32_const(@lib.I32(1)) &&
        dae_default_zero_high_guard_is_false(
          simplified_else, param_count, written,
        ) {
        @lib.Instruction::if_(
          block_type,
          simplified_then,
          Some([@lib.Instruction::i32_const(@lib.I32(0))]),
        )
      } else {
        @lib.Instruction::if_(
          block_type,
          simplified_then,
          Some(simplified_else),
        )
      }
    }
    @lib.If(block_type, then_body, None) =>
      @lib.Instruction::if_(
        block_type,
        dae_simplify_default_zero_high_guard_instrs(
          then_body, param_count, written,
        ),
        None,
      )
    _ => instr
  }
}

///|
fn dae_simplify_default_zero_high_guard_instrs(
  instrs : Array[@lib.Instruction],
  param_count : Int,
  written : Array[Bool],
) -> Array[@lib.Instruction] {
  let out : Array[@lib.Instruction] = []
  for instr in instrs {
    out.push(
      dae_simplify_default_zero_high_guard_instr(instr, param_count, written),
    )
  }
  out
}

///|
fn dae_known_i32_const_for_local_before(
  instrs : Array[@lib.Instruction],
  local_idx : @lib.LocalIdx,
) -> Int? {
  let local_slot = dae_local_idx_slot(local_idx)
  let mut idx = instrs.length() - 1
  while idx >= 0 {
    if dae_instr_references_local(instrs[idx], local_idx) {
      match instrs[idx] {
        @lib.LocalSet(set_idx) if dae_local_idx_slot(set_idx) == local_slot &&
          idx > 0 =>
          match instrs[idx - 1] {
            @lib.I32Const(@lib.I32(value)) => return Some(value)
            _ => return None
          }
        _ => return None
      }
    }
    idx -= 1
  }
  None
}

///|
fn dae_simplify_rewritten_control_instrs(
  instrs : Array[@lib.Instruction],
  invert_zero_eq_if : Bool,
) -> Array[@lib.Instruction] {
  let rewritten : Array[@lib.Instruction] = []
  for instr in instrs {
    rewritten.push(
      match instr {
        @lib.Block(block_type, @lib.Expr(body)) =>
          @lib.Instruction::block(
            block_type,
            @lib.Expr::new(
              dae_simplify_rewritten_control_instrs(body, invert_zero_eq_if),
            ),
          )
        @lib.Loop(block_type, @lib.Expr(body)) =>
          @lib.Instruction::loop_(
            block_type,
            @lib.Expr::new(
              dae_simplify_rewritten_control_instrs(body, invert_zero_eq_if),
            ),
          )
        @lib.TryTable(block_type, catches, @lib.Expr(body)) =>
          @lib.Instruction::try_table(
            block_type,
            catches,
            @lib.Expr::new(
              dae_simplify_rewritten_control_instrs(body, invert_zero_eq_if),
            ),
          )
        @lib.If(block_type, then_body, Some(else_body)) =>
          @lib.Instruction::if_(
            block_type,
            dae_simplify_rewritten_control_instrs(then_body, invert_zero_eq_if),
            Some(
              dae_simplify_rewritten_control_instrs(
                else_body, invert_zero_eq_if,
              ),
            ),
          )
        @lib.If(block_type, then_body, None) =>
          @lib.Instruction::if_(
            block_type,
            dae_simplify_rewritten_control_instrs(then_body, invert_zero_eq_if),
            None,
          )
        _ => instr
      },
    )
  }
  let out : Array[@lib.Instruction] = []
  let mut idx = 0
  while idx < rewritten.length() {
    if idx + 1 < rewritten.length() {
      match (rewritten[idx], rewritten[idx + 1]) {
        (@lib.I32Const(@lib.I32(condition)), @lib.If(_, then_body, else_body)) => {
          let selected_body = if condition == 0 {
            match else_body {
              Some(body) => body
              None => []
            }
          } else {
            then_body
          }
          // Removing the selected `if` label is safe only when the retained arm
          // has no label-sensitive branch. The discarded arm is unreachable
          // under the materialized constant and may contain arbitrary effects.
          if !selected_body.any(fn(instr) { dae_instr_has_branch(instr) }) {
            for selected_instr in selected_body {
              out.push(selected_instr)
            }
            idx += 2
            continue
          }
        }
        _ => ()
      }
    }
    if idx + 1 < rewritten.length() {
      match (rewritten[idx], rewritten[idx + 1]) {
        (@lib.LocalGet(local_idx), @lib.If(_, then_body, else_body)) =>
          match dae_known_i32_const_for_local_before(out, local_idx) {
            Some(condition) => {
              let selected_body = if condition == 0 {
                match else_body {
                  Some(body) => body
                  None => []
                }
              } else {
                then_body
              }
              if !selected_body.any(fn(instr) { dae_instr_has_branch(instr) }) {
                for selected_instr in selected_body {
                  out.push(selected_instr)
                }
                idx += 2
                continue
              }
            }
            None => ()
          }
        _ => ()
      }
    }
    if invert_zero_eq_if && idx + 2 < rewritten.length() {
      match (rewritten[idx], rewritten[idx + 1], rewritten[idx + 2]) {
        (
          @lib.I32Const(@lib.I32(0)),
          @lib.I32Eq,
          @lib.If(block_type, then_body, Some(else_body)),
        ) => {
          out.push(
            @lib.Instruction::if_(block_type, else_body, Some(then_body)),
          )
          idx += 3
          continue
        }
        (
          condition,
          @lib.If(bool_block_type, bool_then, Some(bool_else)),
          @lib.If(use_block_type, use_then, None),
        ) if dae_block_type_is_zero_param_single_result(bool_block_type, None) &&
          dae_block_type_is_zero_param_zero_result(use_block_type, None) &&
          bool_then.length() == 1 &&
          bool_then[0] == @lib.Instruction::i32_const(@lib.I32(1)) &&
          bool_else.length() == 1 &&
          bool_else[0] == @lib.Instruction::i32_const(@lib.I32(0)) => {
          out.push(condition)
          out.push(@lib.Instruction::if_(use_block_type, use_then, None))
          idx += 3
          continue
        }
        _ => ()
      }
    }
    if idx + 1 < rewritten.length() {
      match (dae_negate_compare_instr(rewritten[idx]), rewritten[idx + 1]) {
        (Some(negated), @lib.If(block_type, then_body, Some(else_body))) if block_type ==
          @lib.BlockType::void_() &&
          then_body.length() == 0 &&
          else_body.length() == 1 &&
          else_body[0] == @lib.Instruction::unreachable_() => {
          out.push(negated)
          out.push(
            @lib.Instruction::if_(
              @lib.BlockType::void_(),
              [@lib.Instruction::unreachable_()],
              None,
            ),
          )
          idx += 2
          continue
        }
        (Some(negated), @lib.I32Eqz) => {
          out.push(negated)
          idx += 2
          continue
        }
        _ => ()
      }
    }
    out.push(rewritten[idx])
    idx += 1
  }
  out
}

///|
fn dae_simplify_rewritten_add_zero_instrs(
  instrs : Array[@lib.Instruction],
) -> Array[@lib.Instruction] {
  let rewritten : Array[@lib.Instruction] = []
  for instr in instrs {
    rewritten.push(
      match instr {
        @lib.Block(block_type, @lib.Expr(body)) =>
          @lib.Instruction::block(
            block_type,
            @lib.Expr::new(dae_simplify_rewritten_add_zero_instrs(body)),
          )
        @lib.Loop(block_type, @lib.Expr(body)) =>
          @lib.Instruction::loop_(
            block_type,
            @lib.Expr::new(dae_simplify_rewritten_add_zero_instrs(body)),
          )
        @lib.TryTable(block_type, catches, @lib.Expr(body)) =>
          @lib.Instruction::try_table(
            block_type,
            catches,
            @lib.Expr::new(dae_simplify_rewritten_add_zero_instrs(body)),
          )
        @lib.If(block_type, then_body, else_body) =>
          @lib.Instruction::if_(
            block_type,
            dae_simplify_rewritten_add_zero_instrs(then_body),
            match else_body {
              Some(body) => Some(dae_simplify_rewritten_add_zero_instrs(body))
              None => None
            },
          )
        _ => instr
      },
    )
  }
  let out : Array[@lib.Instruction] = []
  let mut idx = 0
  while idx < rewritten.length() {
    if idx + 2 < rewritten.length() {
      match (rewritten[idx], rewritten[idx + 1], rewritten[idx + 2]) {
        (@lib.I32Const(_), @lib.LocalGet(_), @lib.I32Add)
        | (@lib.I64Const(_), @lib.LocalGet(_), @lib.I64Add) => {
          out.push(rewritten[idx + 1])
          out.push(rewritten[idx])
          out.push(rewritten[idx + 2])
          idx += 3
          continue
        }
        _ => ()
      }
    }
    if idx + 1 < rewritten.length() {
      match (rewritten[idx], rewritten[idx + 1]) {
        (@lib.I32Const(@lib.I32(0)), @lib.I32Add)
        | (@lib.I64Const(@lib.I64(0L)), @lib.I64Add) => {
          idx += 2
          continue
        }
        _ => ()
      }
    }
    out.push(rewritten[idx])
    idx += 1
  }
  out
}

///|
fn dae_instr_is_materializable_const(instr : @lib.Instruction) -> Bool {
  match instr {
    @lib.I32Const(_)
    | @lib.I64Const(_)
    | @lib.F32Const(_)
    | @lib.F64Const(_)
    | @lib.RefNull(_)
    | @lib.StringConst(_) => true
    _ => false
  }
}

///|
fn dae_global_get_is_immutable(
  mod_ : @lib.Module,
  global_idx : @lib.GlobalIdx,
) -> Bool {
  let slot = dae_global_idx_slot(global_idx)
  let mut imported_globals = 0
  match mod_.import_sec {
    Some(@lib.ImportSec(imports)) =>
      for import_ in imports {
        match import_ {
          @lib.Import(_, _, @lib.GlobalExternType(@lib.GlobalType(_, mutable))) => {
            if imported_globals == slot {
              return !mutable
            }
            imported_globals += 1
          }
          _ => ()
        }
      }
    None => ()
  }
  let defined_slot = slot - imported_globals
  if defined_slot < 0 {
    return false
  }
  match mod_.global_sec {
    Some(@lib.GlobalSec(globals)) if defined_slot < globals.length() =>
      match globals[defined_slot] {
        @lib.Global(@lib.GlobalType(_, mutable), _) => !mutable
      }
    _ => false
  }
}

///|
fn dae_instr_is_materializable_const_with_immutable_global(
  mod_ : @lib.Module,
  instr : @lib.Instruction,
) -> Bool {
  if dae_instr_is_materializable_const(instr) {
    return true
  }
  match instr {
    @lib.GlobalGet(global_idx) => dae_global_get_is_immutable(mod_, global_idx)
    _ => false
  }
}

///|
fn dae_instruction_node_count(instrs : Array[@lib.Instruction]) -> Int {
  let mut count = instrs.length()
  for instr in instrs {
    match instr {
      @lib.Block(_, @lib.Expr(body))
      | @lib.Loop(_, @lib.Expr(body))
      | @lib.TryTable(_, _, @lib.Expr(body)) =>
        count += dae_instruction_node_count(body)
      @lib.If(_, then_body, else_body) => {
        count += dae_instruction_node_count(then_body)
        match else_body {
          Some(body) => count += dae_instruction_node_count(body)
          None => ()
        }
      }
      _ => ()
    }
  }
  count
}

///|
fn dae_collect_immediate_materializable_call_targets_instrs(
  mod_ : @lib.Module,
  instrs : Array[@lib.Instruction],
  imported : Int,
  large_defs : Array[Bool],
  selected : Array[Bool],
) -> Unit {
  for idx = 0; idx < instrs.length(); idx = idx + 1 {
    match instrs[idx] {
      @lib.Call(func_idx) if idx > 0 => {
        let def_idx = dae_func_idx_slot(func_idx) - imported
        if def_idx >= 0 && def_idx < selected.length() {
          let immediate = instrs[idx - 1]
          let immutable_global = match immediate {
            @lib.GlobalGet(global_idx) =>
              dae_global_get_is_immutable(mod_, global_idx)
            _ => false
          }
          if immutable_global ||
            (
              large_defs[def_idx] &&
              dae_instr_is_materializable_const(immediate)
            ) {
            selected[def_idx] = true
          }
        }
      }
      @lib.Block(_, @lib.Expr(body))
      | @lib.Loop(_, @lib.Expr(body))
      | @lib.TryTable(_, _, @lib.Expr(body)) =>
        dae_collect_immediate_materializable_call_targets_instrs(
          mod_, body, imported, large_defs, selected,
        )
      @lib.If(_, then_body, else_body) => {
        dae_collect_immediate_materializable_call_targets_instrs(
          mod_, then_body, imported, large_defs, selected,
        )
        match else_body {
          Some(body) =>
            dae_collect_immediate_materializable_call_targets_instrs(
              mod_, body, imported, large_defs, selected,
            )
          None => ()
        }
      }
      _ => ()
    }
  }
}

///|
fn dae_collect_large_uniform_const_revisit_defs(
  mod_ : @lib.Module,
) -> Array[Bool] {
  let imported = dae_imported_func_count(mod_)
  let selected = Array::make(dae_defined_func_count(mod_), false)
  match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => {
      let large_defs = Array::make(funcs.length(), false)
      for def_idx = 0; def_idx < funcs.length(); def_idx = def_idx + 1 {
        let @lib.Func(_, @lib.Expr(body)) = funcs[def_idx]
        large_defs[def_idx] = dae_instruction_node_count(body) >= 64
      }
      for func in funcs {
        let @lib.Func(_, @lib.Expr(body)) = func
        dae_collect_immediate_materializable_call_targets_instrs(
          mod_, body, imported, large_defs, selected,
        )
      }
    }
    None => ()
  }
  selected
}

///|
fn dae_materializable_dropped_const_prefix_leaf(
  body : Array[@lib.Instruction],
  resolve_leaf : (@lib.Instruction) -> @lib.Instruction?,
) -> @lib.Instruction? {
  if body.length() == 1 {
    return resolve_leaf(body[0])
  }
  if body.length() < 3 || body.length() % 2 == 0 {
    return None
  }
  let mut idx = 0
  while idx + 1 < body.length() {
    match resolve_leaf(body[idx]) {
      Some(_) => ()
      None => return None
    }
    match body[idx + 1] {
      @lib.Drop => ()
      _ => return None
    }
    idx += 2
  }
  resolve_leaf(body[body.length() - 1])
}

///|
fn dae_materializable_control_const(
  mod_ : @lib.Module,
  instr : @lib.Instruction,
  allow_immutable_global_get : Bool,
) -> @lib.Instruction? {
  let resolve_leaf = fn(candidate : @lib.Instruction) -> @lib.Instruction? {
    if allow_immutable_global_get {
      if dae_instr_is_materializable_const_with_immutable_global(
          mod_, candidate,
        ) {
        Some(candidate)
      } else {
        None
      }
    } else if dae_instr_is_materializable_const(candidate) {
      Some(candidate)
    } else {
      None
    }
  }
  match instr {
    @lib.Block(_, @lib.Expr(body)) if body.length() == 1 =>
      match resolve_leaf(body[0]) {
        Some(leaf) => Some(leaf)
        None =>
          dae_materializable_control_const(
            mod_,
            body[0],
            allow_immutable_global_get,
          )
      }
    @lib.Block(_, @lib.Expr(body)) => {
      let resolve_control_leaf = fn(
        candidate : @lib.Instruction,
      ) -> @lib.Instruction? {
        match resolve_leaf(candidate) {
          Some(leaf) => Some(leaf)
          None =>
            dae_materializable_control_const(
              mod_, candidate, allow_immutable_global_get,
            )
        }
      }
      dae_materializable_dropped_const_prefix_leaf(body, resolve_control_leaf)
    }
    @lib.Loop(_, @lib.Expr(body)) if body.length() == 1 =>
      match resolve_leaf(body[0]) {
        Some(leaf) => Some(leaf)
        None =>
          dae_materializable_control_const(
            mod_,
            body[0],
            allow_immutable_global_get,
          )
      }
    @lib.Loop(_, @lib.Expr(body)) => {
      let resolve_control_leaf = fn(
        candidate : @lib.Instruction,
      ) -> @lib.Instruction? {
        match resolve_leaf(candidate) {
          Some(leaf) => Some(leaf)
          None =>
            dae_materializable_control_const(
              mod_, candidate, allow_immutable_global_get,
            )
        }
      }
      dae_materializable_dropped_const_prefix_leaf(body, resolve_control_leaf)
    }
    @lib.TryTable(_, _, @lib.Expr(body)) if body.length() == 1 =>
      match resolve_leaf(body[0]) {
        Some(leaf) => Some(leaf)
        None =>
          dae_materializable_control_const(
            mod_,
            body[0],
            allow_immutable_global_get,
          )
      }
    @lib.TryTable(_, _, @lib.Expr(body)) => {
      let resolve_control_leaf = fn(
        candidate : @lib.Instruction,
      ) -> @lib.Instruction? {
        match resolve_leaf(candidate) {
          Some(leaf) => Some(leaf)
          None =>
            dae_materializable_control_const(
              mod_, candidate, allow_immutable_global_get,
            )
        }
      }
      dae_materializable_dropped_const_prefix_leaf(body, resolve_control_leaf)
    }
    @lib.If(_, then_body, Some(else_body)) => {
      let resolve_arm_leaf = fn(
        candidate : @lib.Instruction,
      ) -> @lib.Instruction? {
        match resolve_leaf(candidate) {
          Some(leaf) => Some(leaf)
          None =>
            dae_materializable_control_const(
              mod_, candidate, allow_immutable_global_get,
            )
        }
      }
      match
        (
          dae_materializable_dropped_const_prefix_leaf(
            then_body, resolve_arm_leaf,
          ),
          dae_materializable_dropped_const_prefix_leaf(
            else_body, resolve_arm_leaf,
          ),
        ) {
        (Some(then_const), Some(else_const)) =>
          if dae_materialized_const_equal(then_const, else_const) {
            Some(then_const)
          } else {
            None
          }
        _ => None
      }
    }
    _ => None
  }
}

///|
fn dae_rewrite_instruction_param_consts(
  instr : @lib.Instruction,
  const_params : Array[@lib.Instruction?],
) -> @lib.Instruction {
  match instr {
    @lib.LocalGet(local_idx) => {
      let slot = dae_local_idx_slot(local_idx)
      if slot >= 0 && slot < const_params.length() {
        match const_params[slot] {
          Some(const_instr) => const_instr
          None => instr
        }
      } else {
        instr
      }
    }
    @lib.Block(block_type, @lib.Expr(body)) =>
      @lib.Instruction::block(
        block_type,
        @lib.Expr::new(dae_rewrite_param_const_instrs(body, const_params)),
      )
    @lib.Loop(block_type, @lib.Expr(body)) =>
      @lib.Instruction::loop_(
        block_type,
        @lib.Expr::new(dae_rewrite_param_const_instrs(body, const_params)),
      )
    @lib.TryTable(block_type, catches, @lib.Expr(body)) =>
      @lib.Instruction::try_table(
        block_type,
        catches,
        @lib.Expr::new(dae_rewrite_param_const_instrs(body, const_params)),
      )
    @lib.If(block_type, then_body, else_body) =>
      @lib.Instruction::if_(
        block_type,
        dae_rewrite_param_const_instrs(then_body, const_params),
        match else_body {
          Some(body) => Some(dae_rewrite_param_const_instrs(body, const_params))
          None => None
        },
      )
    _ => instr
  }
}

///|
fn dae_rewrite_param_const_instrs(
  instrs : Array[@lib.Instruction],
  const_params : Array[@lib.Instruction?],
) -> Array[@lib.Instruction] {
  let out : Array[@lib.Instruction] = []
  for instr in instrs {
    out.push(dae_rewrite_instruction_param_consts(instr, const_params))
  }
  out
}

///|
fn dae_build_local_map(
  param_types : Array[@lib.ValType],
  body_local_count : Int,
  remove : Array[Bool],
  local_use : DaeLocalUse,
  preserve_removed_params? : Array[Bool]? = None,
) -> Array[Int] {
  let param_count = param_types.length()
  let local_map = Array::make(param_count + body_local_count, -1)
  let mut next_param = 0
  let mut removed_local_count = 0
  for idx = 0; idx < param_count; idx = idx + 1 {
    if remove[idx] {
      let localized = match preserve_removed_params {
        Some(preserve) if idx < preserve.length() => preserve[idx]
        _ => false
      }
      let projection = dae_removed_param_local_projection_evidence(
        param_types[idx],
        written=local_use.writes[idx],
        localized~,
      )
      if projection.preserve_as_body_local {
        // Writes and caller-side localization both preserve the removed param's
        // former slot as a body local until later cleanup owns its deletion.
        local_map[idx] = -1 - removed_local_count
        removed_local_count += 1
      }
    } else {
      local_map[idx] = next_param
      next_param += 1
    }
  }
  let mut idx = 0
  while idx < param_count {
    if local_map[idx] < 0 {
      local_map[idx] = next_param + (-1 - local_map[idx])
    }
    idx += 1
  }
  let mut body_idx = 0
  while body_idx < body_local_count {
    local_map[param_count + body_idx] = next_param +
      removed_local_count +
      body_idx
    body_idx += 1
  }
  local_map
}

///|
fn dae_collect_callsite_value_slices(
  instrs : Array[@lib.Instruction],
  call_idx : Int,
  arg_count : Int,
  entry_stack_values : Int,
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  allow_stack_carried_void_effects? : Bool = false,
) -> (Array[DaeValueSlice], Int)? {
  let empty_disposition = {
    start: 0,
    end: 0,
    droppable_without_repair: false,
    preserve_effects_on_removal: true,
    has_branch: false,
    has_effect_or_branch: false,
  }
  let slices = Array::make(
    arg_count,
    dae_value_slice_from_operand_disposition_with_purity(
      empty_disposition, false,
    ),
  )
  let mut cursor = call_idx
  let mut ambient_remaining = entry_stack_values
  let mut arg_idx = arg_count - 1
  while arg_idx >= 0 {
    match
      dae_find_value_slice(
        instrs,
        cursor,
        ambient_remaining,
        mod_,
        func_type_indices,
        allow_stack_carried_void_effects~,
      ) {
      Some((shape, next_cursor, next_ambient_remaining)) => {
        slices[arg_idx] = dae_value_slice_from_call_shape(instrs, shape)
        cursor = next_cursor
        ambient_remaining = next_ambient_remaining
      }
      None => return None
    }
    arg_idx -= 1
  }
  Some((slices, cursor))
}

///|
fn dae_callsite_value_slice_evidence_is_consistent(
  evidence : DaeCallsiteValueSliceEvidence,
  call_idx : Int,
  arg_count : Int,
  entry_stack_values : Int,
) -> Bool {
  if evidence.call_idx != call_idx ||
    evidence.arg_count != arg_count ||
    evidence.entry_stack_values != entry_stack_values ||
    evidence.slices.length() != arg_count ||
    evidence.cursor < 0 ||
    evidence.cursor > call_idx {
    return false
  }
  let mut idx = 0
  while idx < evidence.slices.length() {
    if !dae_value_slice_disposition_is_consistent(evidence.slices[idx]) {
      return false
    }
    idx += 1
  }
  true
}

///|
fn dae_callsite_value_slice_evidence(
  instrs : Array[@lib.Instruction],
  call_idx : Int,
  arg_count : Int,
  entry_stack_values : Int,
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  allow_stack_carried_void_effects? : Bool = false,
) -> DaeCallsiteValueSliceEvidence? {
  match
    dae_collect_callsite_value_slices(
      instrs,
      call_idx,
      arg_count,
      entry_stack_values,
      mod_,
      func_type_indices,
      allow_stack_carried_void_effects~,
    ) {
    Some((slices, cursor)) => {
      let evidence = { call_idx, arg_count, entry_stack_values, slices, cursor }
      if dae_callsite_value_slice_evidence_is_consistent(
          evidence, call_idx, arg_count, entry_stack_values,
        ) {
        Some(evidence)
      } else {
        None
      }
    }
    None => None
  }
}

///|
fn dae_callsite_operand_removal_plan(
  evidence : DaeCallsiteValueSliceEvidence,
  param_idx : Int,
  remove : Bool,
) -> DaeOperandRemovalPlan? {
  if param_idx < 0 || param_idx >= evidence.slices.length() {
    return None
  }
  let disposition = evidence.slices[param_idx].disposition
  let rewrite_disposition = dae_operand_rewrite_disposition(
    disposition,
    localization_available=false,
    has_escaping_branch=disposition.has_branch,
  )
  let plan = dae_operand_removal_plan(rewrite_disposition, !remove)
  if dae_operand_removal_plan_is_consistent(rewrite_disposition, plan) {
    Some(plan)
  } else {
    None
  }
}

///|
fn dae_callsite_single_instruction_actual_is_consistent(
  actual : DaeCallsiteSingleInstructionActualEvidence,
  param_idx : Int,
  instrs : Array[@lib.Instruction],
) -> Bool {
  actual.param_idx == param_idx &&
  actual.actual_idx >= 0 &&
  actual.actual_idx < instrs.length() &&
  actual.instr == instrs[actual.actual_idx]
}

///|
fn dae_callsite_single_instruction_actual(
  evidence : DaeCallsiteValueSliceEvidence,
  param_idx : Int,
  instrs : Array[@lib.Instruction],
) -> DaeCallsiteSingleInstructionActualEvidence? {
  if param_idx < 0 || param_idx >= evidence.slices.length() {
    return None
  }
  match dae_value_slice_single_instruction_index(evidence.slices[param_idx]) {
    Some(actual_idx) if actual_idx >= 0 && actual_idx < instrs.length() => {
      let actual = { param_idx, actual_idx, instr: instrs[actual_idx] }
      if dae_callsite_single_instruction_actual_is_consistent(
          actual, param_idx, instrs,
        ) {
        Some(actual)
      } else {
        None
      }
    }
    _ => None
  }
}

///|
fn dae_callsite_rewrite_application_evidence_is_consistent(
  evidence : DaeCallsiteRewriteApplicationEvidence,
) -> Bool {
  evidence.new_call_idx >= 0 &&
  evidence.new_call_idx < evidence.instrs.length() &&
  evidence.localization_count == dae_count_touched(evidence.localized_params) &&
  evidence.scratch_local_types.all(fn(vt) { @lib.has_default(vt) })
}

///|
fn dae_localization_scratch_type(param_type : @lib.ValType) -> @lib.ValType? {
  if @lib.has_default(param_type) {
    return Some(param_type)
  }
  match param_type {
    @lib.RefTypeValType(ref_type) =>
      Some(@lib.ValType::ref_type(ref_type.make_nullable()))
    _ => None
  }
}

///|
fn dae_localization_scratch_slot(
  first_scratch_local : Int,
  scratch_local_types : Array[@lib.ValType],
  scratch_type : @lib.ValType,
) -> Int {
  if first_scratch_local < 0 || !@lib.has_default(scratch_type) {
    return -1
  }
  let mut scratch_offset = 0
  while scratch_offset < scratch_local_types.length() {
    if scratch_local_types[scratch_offset] == scratch_type {
      return first_scratch_local + scratch_offset
    }
    scratch_offset += 1
  }
  let scratch_idx = first_scratch_local + scratch_local_types.length()
  scratch_local_types.push(scratch_type)
  scratch_idx
}

///|
fn dae_removed_param_local_projection_evidence(
  param_type : @lib.ValType,
  written~ : Bool,
  localized~ : Bool,
) -> DaeRemovedParamLocalProjectionEvidence {
  let body_local_type = if localized {
    dae_localization_scratch_type(param_type)
  } else if written {
    Some(param_type)
  } else {
    None
  }
  match body_local_type {
    Some(_) => { valid: true, preserve_as_body_local: true, body_local_type }
    None =>
      {
        valid: !localized,
        preserve_as_body_local: false,
        body_local_type: None,
      }
  }
}

///|
fn dae_removed_param_callee_rewrite_evidence(
  func : @lib.Func,
  params : Array[@lib.ValType],
  remove : Array[Bool],
  const_params : Array[@lib.Instruction?],
  local_use : DaeLocalUse,
  localized_params : Array[Bool],
) -> DaeRemovedParamCalleeRewriteEvidence? {
  if remove.length() != params.length() ||
    const_params.length() != params.length() ||
    local_use.writes.length() < params.length() ||
    localized_params.length() != params.length() {
    return None
  }
  let kept_params : Array[@lib.ValType] = []
  let removed_local_types : Array[@lib.ValType] = []
  let mut p = 0
  while p < params.length() {
    if remove[p] {
      let projection = dae_removed_param_local_projection_evidence(
        params[p],
        written=local_use.writes[p],
        localized=localized_params[p],
      )
      if !projection.valid {
        return None
      }
      match projection.body_local_type {
        Some(local_type) => removed_local_types.push(local_type)
        None => ()
      }
    } else {
      kept_params.push(params[p])
    }
    p += 1
  }
  let @lib.Func(old_locals, @lib.Expr(old_body)) = func
  if !dae_local_indices_fit_instrs(
      old_body,
      params.length() + old_locals.length(),
    ) {
    return None
  }
  let local_map = dae_build_local_map(
    params,
    old_locals.length(),
    remove,
    local_use,
    preserve_removed_params=Some(localized_params),
  )
  let direct_const_params = const_params.copy()
  let entry_initializers : Array[@lib.Instruction] = []
  p = 0
  while p < params.length() {
    if remove[p] && local_use.writes[p] {
      match const_params[p] {
        Some(value) => {
          if local_map[p] < 0 {
            return None
          }
          direct_const_params[p] = None
          entry_initializers.push(value)
          entry_initializers.push(
            @lib.Instruction::local_set(
              @lib.LocalIdx::new(local_map[p].reinterpret_as_uint()),
            ),
          )
        }
        None => ()
      }
    }
    p += 1
  }
  let body = entry_initializers
  body.append(
    dae_rewrite_locals_instrs(
      dae_rewrite_param_const_instrs(old_body, direct_const_params),
      local_map,
    ),
  )
  let locals = @lib.Locals::from_types(removed_local_types)
  locals.append(old_locals)
  if !dae_local_indices_fit_instrs(body, kept_params.length() + locals.length()) {
    return None
  }
  Some({ kept_params, locals, body })
}

///|
fn dae_callsite_rewrite_plan_is_consistent(
  plan : DaeCallsiteRewritePlan,
) -> Bool {
  let callsite = plan.callsite
  if !dae_callsite_value_slice_evidence_is_consistent(
      callsite,
      callsite.call_idx,
      callsite.arg_count,
      callsite.entry_stack_values,
    ) ||
    plan.operand_plans.length() != callsite.arg_count ||
    plan.scratch_local_types_by_param.length() != callsite.arg_count ||
    plan.localized_params.length() != callsite.arg_count {
    return false
  }
  let mut cursor = callsite.cursor
  let mut p = 0
  while p < callsite.arg_count {
    let operand_plan = plan.operand_plans[p]
    let slice = callsite.slices[p]
    if operand_plan.start != slice.start ||
      operand_plan.end != slice.end ||
      operand_plan.start != cursor ||
      operand_plan.end > callsite.call_idx {
      return false
    }
    cursor = operand_plan.end
    match plan.scratch_local_types_by_param[p] {
      Some(scratch_type) =>
        if !operand_plan.requires_localization_retry ||
          operand_plan.rejects_direct_removal ||
          !plan.localized_params[p] ||
          !@lib.has_default(scratch_type) {
          return false
        }
      None =>
        if operand_plan.requires_localization_retry ||
          operand_plan.rejects_direct_removal ||
          plan.localized_params[p] {
          return false
        }
    }
    p += 1
  }
  cursor == callsite.call_idx
}

///|
fn dae_callsite_rewrite_plan(
  callsite : DaeCallsiteValueSliceEvidence,
  remove : Array[Bool],
  localization_param_types : Array[@lib.ValType]?,
) -> DaeCallsiteRewritePlan? {
  if remove.length() != callsite.arg_count {
    return None
  }
  match localization_param_types {
    Some(param_types) if param_types.length() != callsite.arg_count =>
      return None
    _ => ()
  }
  let operand_plans : Array[DaeOperandRemovalPlan] = []
  let scratch_local_types_by_param : Array[@lib.ValType?] = []
  let localized_params = Array::make(callsite.arg_count, false)
  let mut p = 0
  while p < callsite.arg_count {
    let (operand_plan, scratch_type) = match localization_param_types {
      Some(param_types) => {
        let disposition = callsite.slices[p].disposition
        let rewrite_disposition = dae_operand_rewrite_disposition(
          disposition,
          localization_available=remove[p],
          has_escaping_branch=disposition.has_branch,
        )
        let operand_plan = dae_operand_removal_plan(
          rewrite_disposition,
          !remove[p],
        )
        if !dae_operand_removal_plan_is_consistent(
            rewrite_disposition, operand_plan,
          ) {
          return None
        }
        let scratch_type = if operand_plan.requires_localization_retry {
          match dae_localization_scratch_type(param_types[p]) {
            Some(scratch_type) => Some(scratch_type)
            None => return None
          }
        } else {
          None
        }
        (operand_plan, scratch_type)
      }
      None => {
        let operand_plan = match
          dae_callsite_operand_removal_plan(callsite, p, remove[p]) {
          Some(operand_plan) => operand_plan
          None => return None
        }
        (operand_plan, None)
      }
    }
    if operand_plan.rejects_direct_removal {
      return None
    }
    localized_params[p] = scratch_type.is_some()
    operand_plans.push(operand_plan)
    scratch_local_types_by_param.push(scratch_type)
    p += 1
  }
  let plan = {
    callsite,
    operand_plans,
    scratch_local_types_by_param,
    localized_params,
  }
  if dae_callsite_rewrite_plan_is_consistent(plan) {
    Some(plan)
  } else {
    None
  }
}

///|
fn dae_apply_callsite_rewrite_plan(
  instrs : Array[@lib.Instruction],
  plan : DaeCallsiteRewritePlan,
  first_scratch_local : Int,
  existing_scratch_local_types? : Array[@lib.ValType] = [],
) -> DaeCallsiteRewriteApplicationEvidence? {
  if first_scratch_local < 0 ||
    !dae_callsite_rewrite_plan_is_consistent(plan) ||
    plan.callsite.call_idx < 0 ||
    plan.callsite.call_idx >= instrs.length() ||
    plan.callsite.cursor < 0 ||
    plan.callsite.cursor > plan.callsite.call_idx ||
    !existing_scratch_local_types.all(fn(vt) { @lib.has_default(vt) }) {
    return None
  }
  let out : Array[@lib.Instruction] = []
  let scratch_local_types = existing_scratch_local_types.copy()
  let mut idx = 0
  while idx < plan.callsite.cursor {
    out.push(instrs[idx])
    idx += 1
  }
  let mut p = 0
  while p < plan.callsite.arg_count {
    let operand_plan = plan.operand_plans[p]
    match plan.scratch_local_types_by_param[p] {
      Some(scratch_type) => {
        let mut operand_idx = operand_plan.start
        while operand_idx < operand_plan.end {
          out.push(instrs[operand_idx])
          operand_idx += 1
        }
        let scratch_idx = dae_localization_scratch_slot(
          first_scratch_local, scratch_local_types, scratch_type,
        )
        if scratch_idx < 0 {
          return None
        }
        out.push(
          @lib.Instruction::local_set(
            @lib.LocalIdx::new(scratch_idx.reinterpret_as_uint()),
          ),
        )
      }
      None => dae_append_operand_with_removal_plan(out, instrs, operand_plan)
    }
    p += 1
  }
  let new_call_idx = out.length()
  out.push(instrs[plan.callsite.call_idx])
  idx = plan.callsite.call_idx + 1
  while idx < instrs.length() {
    out.push(instrs[idx])
    idx += 1
  }
  let evidence = {
    instrs: out,
    new_call_idx,
    scratch_local_types,
    localized_params: plan.localized_params,
    localization_count: dae_count_touched(plan.localized_params),
  }
  if dae_callsite_rewrite_application_evidence_is_consistent(evidence) {
    Some(evidence)
  } else {
    None
  }
}

///|
fn dae_rewrite_callsite_with_localization_at(
  instrs : Array[@lib.Instruction],
  call_idx : Int,
  remove : Array[Bool],
  param_types : Array[@lib.ValType],
  entry_stack_values : Int,
  first_scratch_local : Int,
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  existing_scratch_local_types? : Array[@lib.ValType] = [],
  allow_stack_carried_void_effects? : Bool = false,
) -> DaeCallsiteRewriteApplicationEvidence? {
  if remove.length() != param_types.length() || first_scratch_local < 0 {
    return None
  }
  let callsite = match
    dae_callsite_value_slice_evidence(
      instrs,
      call_idx,
      remove.length(),
      entry_stack_values,
      mod_,
      func_type_indices,
      allow_stack_carried_void_effects~,
    ) {
    Some(evidence) => evidence
    None => return None
  }
  let plan = match
    dae_callsite_rewrite_plan(callsite, remove, Some(param_types)) {
    Some(plan) => plan
    None => return None
  }
  dae_apply_callsite_rewrite_plan(
    instrs,
    plan,
    first_scratch_local,
    existing_scratch_local_types~,
  )
}

///|
fn dae_rewrite_callsite_at(
  instrs : Array[@lib.Instruction],
  call_idx : Int,
  remove : Array[Bool],
  entry_stack_values : Int,
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
) -> (Array[@lib.Instruction], Int, Bool) {
  let evidence = match
    dae_callsite_value_slice_evidence(
      instrs,
      call_idx,
      remove.length(),
      entry_stack_values,
      mod_,
      func_type_indices,
    ) {
    Some(result) => result
    None => return ([], -1, false)
  }
  let plan = match dae_callsite_rewrite_plan(evidence, remove, None) {
    Some(plan) => plan
    None => return ([], -1, false)
  }
  match dae_apply_callsite_rewrite_plan(instrs, plan, 0) {
    Some(application) => (application.instrs, application.new_call_idx, true)
    None => ([], -1, false)
  }
}

///|
fn dae_rewrite_refined_gc_actual_slice(
  instrs : Array[@lib.Instruction],
  slice : DaeValueSlice,
  refined_type : @lib.ValType,
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
) -> Bool {
  let shape = match
    dae_gc_actual_value_slice_shape_evidence(
      instrs, slice, mod_, func_type_indices,
    ) {
    Some(evidence) => evidence
    None => return true
  }
  match
    dae_gc_actual_type_evidence(
      instrs,
      shape,
      mod_,
      refined_type,
      func_type_indices,
      rewrite_type=Some(refined_type),
    ) {
    Some(evidence) => {
      match evidence.select {
        Some(select) => {
          let slices = select.slices
          let (rewritten, _) = match
            dae_apply_select_value_rewrites_to_body(
              instrs,
              slices.left.start,
              slices.right.start,
              slices.select_idx,
              select.gc.left_rewrite,
              select.gc.right_rewrite,
              evidence.terminal_rewrite,
            ) {
            Some(application) => application
            None => return false
          }
          instrs.clear()
          instrs.append(rewritten)
        }
        None =>
          match evidence.terminal_rewrite {
            Some(instr) => instrs[slice.end - 1] = instr
            None => ()
          }
      }
      true
    }
    None => true
  }
}

///|
fn dae_rewrite_refined_gc_actuals_instr(
  instr : @lib.Instruction,
  callee_abs : Int,
  refine_params : Array[Bool],
  next_params : Array[@lib.ValType],
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
) -> (@lib.Instruction, Int, Bool, Bool) {
  let children = match dae_nested_control_children_evidence(instr, mod_) {
    Some(evidence) => evidence
    None =>
      match instr {
        @lib.Block(_, _)
        | @lib.Loop(_, _)
        | @lib.TryTable(_, _, _)
        | @lib.If(_, _, _) => return (instr, 0, false, false)
        _ => return (instr, 0, true, false)
      }
  }
  let entry_stack_values = children.entry_stack_values
  let (rewritten_primary, primary_calls, primary_ok, primary_changed) = dae_rewrite_refined_gc_actuals_instrs(
    children.primary_body,
    callee_abs,
    refine_params,
    next_params,
    entry_stack_values,
    mod_,
    func_type_indices,
  )
  if !primary_ok {
    return (instr, primary_calls, false, primary_changed)
  }
  let mut calls = primary_calls
  let mut changed = primary_changed
  let rewritten_secondary = match children.secondary_body {
    Some(body) => {
      let (next_body, secondary_calls, secondary_ok, secondary_changed) = dae_rewrite_refined_gc_actuals_instrs(
        body, callee_abs, refine_params, next_params, entry_stack_values, mod_, func_type_indices,
      )
      calls += secondary_calls
      changed = changed || secondary_changed
      if !secondary_ok {
        return (instr, calls, false, changed)
      }
      Some(next_body)
    }
    None => None
  }
  if !changed {
    return (instr, calls, true, false)
  }
  match
    dae_rebuild_nested_control_children(
      instr, children, rewritten_primary, rewritten_secondary,
    ) {
    Some(rewritten) => (rewritten, calls, true, true)
    None => (instr, calls, false, true)
  }
}

///|
fn dae_rewrite_refined_gc_actuals_instrs(
  instrs : Array[@lib.Instruction],
  callee_abs : Int,
  refine_params : Array[Bool],
  next_params : Array[@lib.ValType],
  entry_stack_values : Int,
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
) -> (Array[@lib.Instruction], Int, Bool, Bool) {
  let current = instrs.copy()
  let mut idx = 0
  let mut calls = 0
  let mut changed = false
  while idx < current.length() {
    if dae_instr_is_unreachable_root(current[idx]) {
      break
    }
    match
      dae_target_callsite_evidence(
        current[idx],
        callee_abs,
        DaeTargetDirectOrReturnCall,
      ) {
      Some(_) => {
        let evidence = match
          dae_callsite_value_slice_evidence(
            current,
            idx,
            refine_params.length(),
            entry_stack_values,
            mod_,
            func_type_indices,
          ) {
          Some(result) => result
          None => return ([], calls, false, changed)
        }
        let mut p = 0
        while p < refine_params.length() {
          if refine_params[p] {
            if !dae_rewrite_refined_gc_actual_slice(
                current,
                evidence.slices[p],
                next_params[p],
                mod_,
                func_type_indices,
              ) {
              return ([], calls, false, changed)
            }
          }
          p += 1
        }
        calls += 1
        changed = true
        idx += 1
      }
      None => {
        let (rewritten, nested_calls, ok, nested_changed) = dae_rewrite_refined_gc_actuals_instr(
          current[idx],
          callee_abs,
          refine_params,
          next_params,
          mod_,
          func_type_indices,
        )
        if !ok {
          return ([], calls + nested_calls, false, changed || nested_changed)
        }
        calls += nested_calls
        if nested_changed {
          current[idx] = rewritten
          changed = true
        }
        idx += 1
      }
    }
  }
  (current, calls, true, changed)
}

///|
fn dae_rewrite_calls_instr(
  instr : @lib.Instruction,
  callee_abs : Int,
  remove : Array[Bool],
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  localization? : DaeCallsiteLocalizationContext? = None,
  allow_stack_carried_void_effects? : Bool = false,
) -> (@lib.Instruction, Int, Bool) {
  let children = match dae_nested_control_children_evidence(instr, mod_) {
    Some(evidence) => evidence
    None =>
      match instr {
        @lib.Block(_, _)
        | @lib.Loop(_, _)
        | @lib.TryTable(_, _, _)
        | @lib.If(_, _, _) => return (instr, 0, false)
        _ => return (instr, 0, true)
      }
  }
  let entry_stack_values = children.entry_stack_values
  let primary_result = dae_rewrite_calls_instrs(
    children.primary_body,
    callee_abs,
    remove,
    entry_stack_values,
    mod_,
    func_type_indices,
    localization~,
    allow_stack_carried_void_effects~,
  )
  if !primary_result.ok {
    return (instr, primary_result.calls_rewritten, false)
  }
  let mut calls = primary_result.calls_rewritten
  let rewritten_secondary = match children.secondary_body {
    Some(body) => {
      let secondary_result = dae_rewrite_calls_instrs(
        body,
        callee_abs,
        remove,
        entry_stack_values,
        mod_,
        func_type_indices,
        localization~,
        allow_stack_carried_void_effects~,
      )
      calls += secondary_result.calls_rewritten
      if !secondary_result.ok {
        return (instr, calls, false)
      }
      Some(secondary_result.instrs)
    }
    None => None
  }
  match
    dae_rebuild_nested_control_children(
      instr,
      children,
      primary_result.instrs,
      rewritten_secondary,
    ) {
    Some(rewritten) => (rewritten, calls, true)
    None => (instr, calls, false)
  }
}

///|
fn dae_rewrite_calls_instrs(
  instrs : Array[@lib.Instruction],
  callee_abs : Int,
  remove : Array[Bool],
  entry_stack_values : Int,
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  localization? : DaeCallsiteLocalizationContext? = None,
  allow_stack_carried_void_effects? : Bool = false,
) -> DaeRewriteResult {
  let current = instrs.copy()
  let mut idx = 0
  let mut calls = 0
  while idx < current.length() {
    if dae_instr_is_unreachable_root(current[idx]) {
      break
    }
    match
      dae_target_callsite_evidence(
        current[idx],
        callee_abs,
        DaeTargetDirectOrReturnCall,
      ) {
      Some(_) => {
        let (rewritten, new_call_idx, ok) = match localization {
          Some(context) =>
            match
              dae_rewrite_callsite_with_localization_at(
                current,
                idx,
                remove,
                context.param_types,
                entry_stack_values,
                context.first_scratch_local,
                mod_,
                func_type_indices,
                existing_scratch_local_types=context.scratch_local_types,
                allow_stack_carried_void_effects~,
              ) {
              Some(evidence) => {
                context.scratch_local_types.clear()
                context.scratch_local_types.append(evidence.scratch_local_types)
                let mut p = 0
                while p < evidence.localized_params.length() &&
                      p < context.localized_params.length() {
                  context.localized_params[p] = context.localized_params[p] ||
                    evidence.localized_params[p]
                  p += 1
                }
                (evidence.instrs, evidence.new_call_idx, true)
              }
              None => ([], -1, false)
            }
          None =>
            dae_rewrite_callsite_at(
              current, idx, remove, entry_stack_values, mod_, func_type_indices,
            )
        }
        if !ok {
          return { instrs: [], calls_rewritten: calls, ok: false }
        }
        current.clear()
        current.append(rewritten)
        calls += 1
        idx = new_call_idx + 1
      }
      None => {
        let (rewritten, nested_calls, ok) = dae_rewrite_calls_instr(
          current[idx],
          callee_abs,
          remove,
          mod_,
          func_type_indices,
          localization~,
          allow_stack_carried_void_effects~,
        )
        if !ok {
          return {
            instrs: [],
            calls_rewritten: calls + nested_calls,
            ok: false,
          }
        }
        calls += nested_calls
        current[idx] = rewritten
        idx += 1
      }
    }
  }
  { instrs: current, calls_rewritten: calls, ok: true }
}

///|
fn dae_materialized_const_equal(
  lhs : @lib.Instruction,
  rhs : @lib.Instruction,
) -> Bool {
  match (lhs, rhs) {
    (@lib.I32Const(a), @lib.I32Const(b)) => a == b
    (@lib.I64Const(a), @lib.I64Const(b)) => a == b
    (@lib.F32Const(a), @lib.F32Const(b)) => a == b
    (@lib.F64Const(a), @lib.F64Const(b)) => a == b
    (@lib.RefNull(a), @lib.RefNull(b)) => a == b
    (@lib.StringConst(a), @lib.StringConst(b)) => a == b
    (@lib.GlobalGet(a), @lib.GlobalGet(b)) => a == b
    _ => false
  }
}

///|
fn dae_record_uniform_const_candidate(
  seen : Array[Bool],
  invalid : Array[Bool],
  candidates : Array[@lib.Instruction?],
  param_idx : Int,
  candidate : @lib.Instruction,
) -> Unit {
  if param_idx < 0 ||
    param_idx >= seen.length() ||
    param_idx >= invalid.length() ||
    param_idx >= candidates.length() ||
    invalid[param_idx] {
    return
  }
  if !seen[param_idx] {
    seen[param_idx] = true
    candidates[param_idx] = Some(candidate)
    return
  }
  match candidates[param_idx] {
    Some(existing) =>
      if !dae_materialized_const_equal(existing, candidate) {
        invalid[param_idx] = true
      }
    None => invalid[param_idx] = true
  }
}

///|
fn dae_resolve_forwarded_uniform_const_local_get(
  mod_ : @lib.Module,
  caller_abs : Int,
  local_slot : Int,
  func_type_indices : Array[@lib.TypeIdx],
  boundary_facts : DaeCallBoundaryFacts,
  visited : Array[Bool],
  allow_immutable_global_get? : Bool = false,
) -> @lib.Instruction? {
  if caller_abs < 0 ||
    caller_abs >= func_type_indices.length() ||
    caller_abs >= visited.length() ||
    visited[caller_abs] {
    return None
  }
  if !dae_call_boundary_allows_forwarding(boundary_facts, caller_abs) {
    return None
  }
  let imported = dae_imported_func_count(mod_)
  let def_idx = caller_abs - imported
  if def_idx < 0 {
    return None
  }
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None => return None
  }
  if def_idx >= funcs.length() {
    return None
  }
  let func_type = match
    dae_resolve_func_type(mod_, func_type_indices, caller_abs) {
    Some(ft) => ft
    None => return None
  }
  let @lib.FuncType(params, _) = func_type
  if local_slot < 0 || local_slot >= params.length() {
    return None
  }
  let func = funcs[def_idx]
  if dae_count_self_calls_anywhere(func, caller_abs) > 0 {
    return None
  }
  let @lib.Func(locals, _) = func
  let local_use = dae_local_use_for_callee(
    func,
    params.length() + locals.length(),
    caller_abs,
    params.length(),
  )
  if local_use.writes[local_slot] {
    return None
  }
  visited[caller_abs] = true
  let collect_params = Array::make(params.length(), false)
  collect_params[local_slot] = true
  let resolved = match
    dae_collect_uniform_const_actuals_visited(
      mod_,
      caller_abs,
      params.length(),
      func_type_indices,
      boundary_facts,
      visited,
      allow_immutable_global_get~,
      collect_params=Some(collect_params),
    ) {
    Some(values) => values[local_slot]
    None => None
  }
  visited[caller_abs] = false
  resolved
}

///|
fn dae_resolve_local_set_const_carrier(
  instrs : Array[@lib.Instruction],
  end : Int,
  local_slot : Int,
  mod_ : @lib.Module,
  allow_immutable_global_get : Bool,
) -> @lib.Instruction? {
  let mut idx = 0
  let mut found : @lib.Instruction? = None
  while idx < end {
    match instrs[idx] {
      @lib.LocalGet(local_idx) if dae_local_idx_slot(local_idx) == local_slot =>
        return None
      @lib.LocalTee(local_idx) if dae_local_idx_slot(local_idx) == local_slot =>
        return None
      @lib.LocalSet(local_idx) if dae_local_idx_slot(local_idx) == local_slot => {
        if idx == 0 {
          return None
        }
        let candidate = instrs[idx - 1]
        let resolved_candidate = match
          dae_materializable_control_const(
            mod_, candidate, allow_immutable_global_get,
          ) {
          Some(inner) => inner
          None => {
            let materializable = if allow_immutable_global_get {
              dae_instr_is_materializable_const_with_immutable_global(
                mod_, candidate,
              )
            } else {
              dae_instr_is_materializable_const(candidate)
            }
            if !materializable {
              return None
            }
            candidate
          }
        }
        match found {
          Some(_) => return None
          None => found = Some(resolved_candidate)
        }
      }
      @lib.LocalSet(local_idx) | @lib.LocalTee(local_idx) if dae_local_idx_slot(
          local_idx,
        ) ==
        local_slot => return None
      _ => ()
    }
    idx += 1
  }
  found
}

///|
fn dae_resolve_uniform_const_candidate(
  mod_ : @lib.Module,
  caller_abs : Int,
  candidate : @lib.Instruction,
  func_type_indices : Array[@lib.TypeIdx],
  boundary_facts : DaeCallBoundaryFacts,
  visited : Array[Bool],
  allow_immutable_global_get? : Bool = false,
) -> @lib.Instruction? {
  match
    dae_materializable_control_const(
      mod_, candidate, allow_immutable_global_get,
    ) {
    Some(materialized) => return Some(materialized)
    None => ()
  }
  if allow_immutable_global_get {
    if dae_instr_is_materializable_const_with_immutable_global(mod_, candidate) {
      return Some(candidate)
    }
  } else if dae_instr_is_materializable_const(candidate) {
    return Some(candidate)
  }
  match candidate {
    @lib.LocalGet(local_idx) =>
      dae_resolve_forwarded_uniform_const_local_get(
        mod_,
        caller_abs,
        dae_local_idx_slot(local_idx),
        func_type_indices,
        boundary_facts,
        visited,
        allow_immutable_global_get~,
      )
    _ => None
  }
}

///|
fn dae_collect_uniform_const_actuals_instrs(
  instrs : Array[@lib.Instruction],
  callee_abs : Int,
  param_count : Int,
  entry_stack_values : Int,
  caller_abs : Int,
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  boundary_facts : DaeCallBoundaryFacts,
  visited : Array[Bool],
  seen : Array[Bool],
  invalid : Array[Bool],
  candidates : Array[@lib.Instruction?],
  allow_immutable_global_get? : Bool = false,
  collect_params? : Array[Bool]? = None,
) -> Bool {
  let active_params = match collect_params {
    Some(active) if active.length() == param_count => active
    Some(_) => return false
    None => Array::make(param_count, true)
  }
  let mut idx = 0
  while idx < instrs.length() {
    match
      dae_target_callsite_evidence(
        instrs[idx],
        callee_abs,
        DaeTargetDirectCallOnly,
      ) {
      Some(_) =>
        match
          dae_callsite_value_slice_evidence(
            instrs, idx, param_count, entry_stack_values, mod_, func_type_indices,
          ) {
          Some(evidence) => {
            let mut p = 0
            while p < param_count {
              if active_params[p] && !invalid[p] {
                match
                  dae_callsite_single_instruction_actual(evidence, p, instrs) {
                  Some(actual) =>
                    match
                      dae_resolve_uniform_const_candidate(
                        mod_,
                        caller_abs,
                        actual.instr,
                        func_type_indices,
                        boundary_facts,
                        visited,
                        allow_immutable_global_get~,
                      ) {
                      Some(candidate) =>
                        dae_record_uniform_const_candidate(
                          seen, invalid, candidates, p, candidate,
                        )
                      None =>
                        match actual.instr {
                          @lib.LocalGet(local_idx) =>
                            match
                              dae_resolve_local_set_const_carrier(
                                instrs,
                                actual.actual_idx,
                                dae_local_idx_slot(local_idx),
                                mod_,
                                allow_immutable_global_get,
                              ) {
                              Some(candidate) =>
                                dae_record_uniform_const_candidate(
                                  seen, invalid, candidates, p, candidate,
                                )
                              None => invalid[p] = true
                            }
                          _ => invalid[p] = true
                        }
                    }
                  None => invalid[p] = true
                }
              }
              p += 1
            }
          }
          None => return false
        }
      None =>
        match instrs[idx] {
          @lib.Block(_, @lib.Expr(_))
          | @lib.Loop(_, @lib.Expr(_))
          | @lib.TryTable(_, _, @lib.Expr(_))
          | @lib.If(_, _, _) => {
            let child_evidence = match
              dae_nested_control_children_evidence(instrs[idx], mod_) {
              Some(evidence) => evidence
              None => return false
            }
            if !dae_collect_uniform_const_actuals_instrs(
                child_evidence.primary_body,
                callee_abs,
                param_count,
                child_evidence.entry_stack_values,
                caller_abs,
                mod_,
                func_type_indices,
                boundary_facts,
                visited,
                seen,
                invalid,
                candidates,
                allow_immutable_global_get~,
                collect_params=Some(active_params),
              ) {
              return false
            }
            match child_evidence.secondary_body {
              Some(body) =>
                if !dae_collect_uniform_const_actuals_instrs(
                    body,
                    callee_abs,
                    param_count,
                    child_evidence.entry_stack_values,
                    caller_abs,
                    mod_,
                    func_type_indices,
                    boundary_facts,
                    visited,
                    seen,
                    invalid,
                    candidates,
                    allow_immutable_global_get~,
                    collect_params=Some(active_params),
                  ) {
                  return false
                }
              None => ()
            }
          }
          _ => ()
        }
    }
    idx += 1
  }
  true
}

///|
fn dae_collect_uniform_const_actuals_visited(
  mod_ : @lib.Module,
  callee_abs : Int,
  param_count : Int,
  func_type_indices : Array[@lib.TypeIdx],
  boundary_facts : DaeCallBoundaryFacts,
  visited : Array[Bool],
  allow_immutable_global_get? : Bool = false,
  collect_params? : Array[Bool]? = None,
) -> Array[@lib.Instruction?]? {
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None => return Some(Array::make(param_count, None))
  }
  let imported = dae_imported_func_count(mod_)
  let seen = Array::make(param_count, false)
  let invalid = Array::make(param_count, false)
  let candidates : Array[@lib.Instruction?] = Array::make(param_count, None)
  let caller_defs = dae_call_boundary_direct_callers(boundary_facts, callee_abs)
  let mut caller_idx = 0
  while caller_idx < caller_defs.length() {
    let def_idx = caller_defs[caller_idx]
    if def_idx >= 0 && def_idx < funcs.length() {
      let @lib.Func(_, @lib.Expr(body)) = funcs[def_idx]
      if !dae_collect_uniform_const_actuals_instrs(
          body,
          callee_abs,
          param_count,
          0,
          imported + def_idx,
          mod_,
          func_type_indices,
          boundary_facts,
          visited,
          seen,
          invalid,
          candidates,
          allow_immutable_global_get~,
          collect_params~,
        ) {
        return None
      }
    }
    caller_idx += 1
  }
  let out : Array[@lib.Instruction?] = []
  let mut p = 0
  while p < param_count {
    if invalid[p] || !seen[p] {
      out.push(None)
    } else {
      out.push(candidates[p])
    }
    p += 1
  }
  Some(out)
}

///|
fn dae_collect_uniform_const_actuals_from_boundary_facts(
  mod_ : @lib.Module,
  callee_abs : Int,
  param_count : Int,
  func_type_indices : Array[@lib.TypeIdx],
  boundary_facts : DaeCallBoundaryFacts,
  allow_immutable_global_get? : Bool = false,
  collect_params? : Array[Bool]? = None,
) -> Array[@lib.Instruction?]? {
  let total = func_type_indices.length()
  dae_collect_uniform_const_actuals_visited(
    mod_,
    callee_abs,
    param_count,
    func_type_indices,
    boundary_facts,
    Array::make(total, false),
    allow_immutable_global_get~,
    collect_params~,
  )
}

///|
fn dae_resolve_stable_callsite_scope(
  instrs : Array[@lib.Instruction],
  path : Array[Int],
  path_idx : Int,
  entry_stack_values : Int,
  mod_ : @lib.Module,
) -> (Array[@lib.Instruction], Int, Int)? {
  if path_idx < 0 || path_idx >= path.length() {
    return None
  }
  let instr_idx = path[path_idx]
  if instr_idx < 0 || instr_idx >= instrs.length() {
    return None
  }
  if path_idx + 1 == path.length() {
    return Some((instrs, instr_idx, entry_stack_values))
  }
  if path_idx + 2 >= path.length() {
    return None
  }
  let child_kind = path[path_idx + 1]
  let child_evidence = match
    dae_nested_control_children_evidence(instrs[instr_idx], mod_) {
    Some(evidence) => evidence
    None => return None
  }
  let child_body = match (instrs[instr_idx], child_kind) {
    (@lib.Block(_, _), 0)
    | (@lib.Loop(_, _), 1)
    | (@lib.TryTable(_, _, _), 4) => child_evidence.primary_body
    (@lib.If(_, _, _), 2) => child_evidence.primary_body
    (@lib.If(_, _, _), 3) =>
      match child_evidence.secondary_body {
        Some(body) => body
        None => return None
      }
    _ => return None
  }
  dae_resolve_stable_callsite_scope(
    child_body,
    path,
    path_idx + 2,
    child_evidence.entry_stack_values,
    mod_,
  )
}

///|
fn dae_collect_uniform_const_actuals_from_function_infos(
  mod_ : @lib.Module,
  callee_abs : Int,
  param_count : Int,
  func_type_indices : Array[@lib.TypeIdx],
  boundary_facts : DaeCallBoundaryFacts,
  function_infos : Array[DaeFunctionInfo],
  allow_immutable_global_get? : Bool = false,
  collect_params? : Array[Bool]? = None,
) -> Array[@lib.Instruction?]? {
  if callee_abs < 0 || callee_abs >= function_infos.length() {
    return None
  }
  let active_params = match collect_params {
    Some(active) if active.length() == param_count => active
    Some(_) => return None
    None => Array::make(param_count, true)
  }
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None => return Some(Array::make(param_count, None))
  }
  let imported = dae_imported_func_count(mod_)
  let seen = Array::make(param_count, false)
  let invalid = Array::make(param_count, false)
  let candidates : Array[@lib.Instruction?] = Array::make(param_count, None)
  let visited = Array::make(func_type_indices.length(), false)
  for callsite in function_infos[callee_abs].calls {
    if !callsite.active || callsite.tail || callsite.callee_abs != callee_abs {
      continue
    }
    let caller_def = callsite.caller_def
    if caller_def < 0 || caller_def >= funcs.length() {
      return None
    }
    let @lib.Func(_, @lib.Expr(body)) = funcs[caller_def]
    let (scope, call_idx, entry_stack_values) = match
      dae_resolve_stable_callsite_scope(body, callsite.path, 0, 0, mod_) {
      Some(resolved) => resolved
      None => return None
    }
    match
      dae_target_callsite_evidence(
        scope[call_idx],
        callee_abs,
        DaeTargetDirectCallOnly,
      ) {
      Some(_) => ()
      None => return None
    }
    let evidence = match
      dae_callsite_value_slice_evidence(
        scope, call_idx, param_count, entry_stack_values, mod_, func_type_indices,
      ) {
      Some(evidence) => evidence
      None => return None
    }
    let mut p = 0
    while p < param_count {
      if active_params[p] && !invalid[p] {
        match dae_callsite_single_instruction_actual(evidence, p, scope) {
          Some(actual) =>
            match
              dae_resolve_uniform_const_candidate(
                mod_,
                imported + caller_def,
                actual.instr,
                func_type_indices,
                boundary_facts,
                visited,
                allow_immutable_global_get~,
              ) {
              Some(candidate) =>
                dae_record_uniform_const_candidate(
                  seen, invalid, candidates, p, candidate,
                )
              None =>
                match actual.instr {
                  @lib.LocalGet(local_idx) =>
                    match
                      dae_resolve_local_set_const_carrier(
                        scope,
                        actual.actual_idx,
                        dae_local_idx_slot(local_idx),
                        mod_,
                        allow_immutable_global_get,
                      ) {
                      Some(candidate) =>
                        dae_record_uniform_const_candidate(
                          seen, invalid, candidates, p, candidate,
                        )
                      None => invalid[p] = true
                    }
                  _ => invalid[p] = true
                }
            }
          None => invalid[p] = true
        }
      }
      p += 1
    }
  }
  let out : Array[@lib.Instruction?] = []
  let mut p = 0
  while p < param_count {
    if invalid[p] || !seen[p] {
      out.push(None)
    } else {
      out.push(candidates[p])
    }
    p += 1
  }
  Some(out)
}

///|
fn dae_collect_uniform_const_actuals_from_current_call_facts(
  mod_ : @lib.Module,
  callee_abs : Int,
  param_count : Int,
  func_type_indices : Array[@lib.TypeIdx],
  boundary_facts : DaeCallBoundaryFacts,
  function_infos : Array[DaeFunctionInfo],
  allow_immutable_global_get? : Bool = false,
  collect_params? : Array[Bool]? = None,
) -> Array[@lib.Instruction?]? {
  let mut has_inactive_direct_call = false
  if function_infos.length() < 1024 &&
    callee_abs >= 0 &&
    callee_abs < function_infos.length() {
    for callsite in function_infos[callee_abs].calls {
      if !callsite.active && !callsite.tail {
        has_inactive_direct_call = true
        break
      }
    }
  }
  // Stable paths keep inactive suffix calls from poisoning current-value facts.
  // On artifact-scale modules, resolving every nested path is still slower than
  // the caller-scope walker; retain that lane until paths carry cached scopes.
  if has_inactive_direct_call {
    dae_collect_uniform_const_actuals_from_function_infos(
      mod_,
      callee_abs,
      param_count,
      func_type_indices,
      boundary_facts,
      function_infos,
      allow_immutable_global_get~,
      collect_params~,
    )
  } else {
    dae_collect_uniform_const_actuals_from_boundary_facts(
      mod_,
      callee_abs,
      param_count,
      func_type_indices,
      boundary_facts,
      allow_immutable_global_get~,
      collect_params~,
    )
  }
}

///|
fn dae_type_idx_slot(idx : @lib.TypeIdx) -> Int? {
  match idx {
    @lib.TypeIdx(raw) => Some(raw.reinterpret_as_int())
    @lib.RecIdx(_) => None
  }
}

///|
fn dae_simple_func_type_section(rec_types : Array[@lib.RecType]) -> Bool {
  for rec_type in rec_types {
    match rec_type {
      @lib.SingleRecType(subtype) =>
        if subtype.super_types().length() > 0 ||
          subtype.describes_type() is Some(_) ||
          subtype.descriptor_type() is Some(_) {
          return false
        }
      @lib.GroupRecType(_) => return false
    }
  }
  true
}

///|
fn dae_mark_used_type_idx(idx : @lib.TypeIdx, used : Array[Bool]) -> Unit {
  match dae_type_idx_slot(idx) {
    Some(slot) => if slot >= 0 && slot < used.length() { used[slot] = true }
    None => ()
  }
}

///|
fn dae_mark_used_heap_type(ht : @lib.HeapType, used : Array[Bool]) -> Unit {
  match ht {
    @lib.HeapType(type_idx) => dae_mark_used_type_idx(type_idx, used)
    @lib.DefTypeHeapType(_) => {
      let mut idx = 0
      while idx < used.length() {
        used[idx] = true
        idx += 1
      }
    }
    _ => ()
  }
}

///|
fn dae_mark_used_ref_type(rt : @lib.RefType, used : Array[Bool]) -> Unit {
  match rt {
    @lib.HeapTypeRefType(_, _, ht) => dae_mark_used_heap_type(ht, used)
    _ => ()
  }
}

///|
fn dae_mark_used_val_type(vt : @lib.ValType, used : Array[Bool]) -> Unit {
  match vt {
    @lib.RefTypeValType(rt) => dae_mark_used_ref_type(rt, used)
    _ => ()
  }
}

///|
fn dae_mark_used_table_type(tt : @lib.TableType, used : Array[Bool]) -> Unit {
  let @lib.TableType(rt, _) = tt
  dae_mark_used_ref_type(rt, used)
}

///|
fn dae_mark_used_global_type(gt : @lib.GlobalType, used : Array[Bool]) -> Unit {
  let @lib.GlobalType(vt, _) = gt
  dae_mark_used_val_type(vt, used)
}

///|
fn dae_collect_used_type_idx_instrs(
  instrs : Array[@lib.Instruction],
  used : Array[Bool],
) -> Unit {
  for instr in instrs {
    match instr {
      @lib.Block(@lib.TypeIdxBlockType(type_idx), @lib.Expr(body))
      | @lib.Loop(@lib.TypeIdxBlockType(type_idx), @lib.Expr(body))
      | @lib.TryTable(@lib.TypeIdxBlockType(type_idx), _, @lib.Expr(body)) => {
        dae_mark_used_type_idx(type_idx, used)
        dae_collect_used_type_idx_instrs(body, used)
      }
      @lib.Block(_, @lib.Expr(body))
      | @lib.Loop(_, @lib.Expr(body))
      | @lib.TryTable(_, _, @lib.Expr(body)) =>
        dae_collect_used_type_idx_instrs(body, used)
      @lib.If(@lib.TypeIdxBlockType(type_idx), then_body, else_body) => {
        dae_mark_used_type_idx(type_idx, used)
        dae_collect_used_type_idx_instrs(then_body, used)
        match else_body {
          Some(body) => dae_collect_used_type_idx_instrs(body, used)
          None => ()
        }
      }
      @lib.If(_, then_body, else_body) => {
        dae_collect_used_type_idx_instrs(then_body, used)
        match else_body {
          Some(body) => dae_collect_used_type_idx_instrs(body, used)
          None => ()
        }
      }
      @lib.CallIndirect(type_idx, _)
      | @lib.ReturnCallIndirect(type_idx, _)
      | @lib.CallRef(type_idx)
      | @lib.ReturnCallRef(type_idx)
      | @lib.StructNew(type_idx)
      | @lib.StructNewDefault(type_idx)
      | @lib.StructNewDesc(type_idx)
      | @lib.StructNewDefaultDesc(type_idx)
      | @lib.ArrayNew(type_idx)
      | @lib.ArrayNewDefault(type_idx)
      | @lib.ArrayNewFixed(type_idx, _)
      | @lib.ArrayNewData(type_idx, _)
      | @lib.ArrayNewElem(type_idx, _)
      | @lib.ArrayGet(type_idx)
      | @lib.ArrayGetS(type_idx)
      | @lib.ArrayGetU(type_idx)
      | @lib.ArraySet(type_idx)
      | @lib.ArrayFill(type_idx)
      | @lib.ArrayInitData(type_idx, _)
      | @lib.ArrayInitElem(type_idx, _)
      | @lib.RefGetDesc(type_idx) => dae_mark_used_type_idx(type_idx, used)
      @lib.StructGet(type_idx, _)
      | @lib.StructGetS(type_idx, _)
      | @lib.StructGetU(type_idx, _)
      | @lib.StructAtomicGet(_, type_idx, _)
      | @lib.StructAtomicGetS(_, type_idx, _)
      | @lib.StructAtomicGetU(_, type_idx, _)
      | @lib.StructSet(type_idx, _) => dae_mark_used_type_idx(type_idx, used)
      @lib.RefNull(rt) => dae_mark_used_ref_type(rt, used)
      @lib.RefTest(_, _, ht)
      | @lib.RefCast(_, _, ht)
      | @lib.RefTestDesc(_, ht)
      | @lib.RefCastDescEq(_, _, ht) => dae_mark_used_heap_type(ht, used)
      @lib.BrOnCast(_, _, source_ht, target_ht)
      | @lib.BrOnCastFail(_, _, source_ht, target_ht) => {
        dae_mark_used_heap_type(source_ht, used)
        dae_mark_used_heap_type(target_ht, used)
      }
      _ => ()
    }
  }
}

///|
fn dae_rewrite_pruned_heap_type(
  ht : @lib.HeapType,
  remap : Array[Int],
) -> @lib.HeapType {
  match ht {
    @lib.HeapType(type_idx) =>
      @lib.HeapType::new(dae_rewrite_pruned_type_idx(type_idx, remap))
    _ => ht
  }
}

///|
fn dae_rewrite_pruned_ref_type(
  rt : @lib.RefType,
  remap : Array[Int],
) -> @lib.RefType {
  match rt {
    @lib.HeapTypeRefType(nullable, exact, heap_type) =>
      @lib.RefType::new(
        nullable,
        dae_rewrite_pruned_heap_type(heap_type, remap),
        exact~,
      )
    _ => rt
  }
}

///|
fn dae_rewrite_pruned_val_type(
  vt : @lib.ValType,
  remap : Array[Int],
) -> @lib.ValType {
  match vt {
    @lib.RefTypeValType(rt) =>
      @lib.ValType::ref_type(dae_rewrite_pruned_ref_type(rt, remap))
    _ => vt
  }
}

///|
fn dae_rewrite_pruned_table_type(
  tt : @lib.TableType,
  remap : Array[Int],
) -> @lib.TableType {
  let @lib.TableType(rt, limits) = tt
  @lib.TableType::new(dae_rewrite_pruned_ref_type(rt, remap), limits)
}

///|
fn dae_rewrite_pruned_global_type(
  gt : @lib.GlobalType,
  remap : Array[Int],
) -> @lib.GlobalType {
  let @lib.GlobalType(vt, mutable) = gt
  @lib.GlobalType::new(dae_rewrite_pruned_val_type(vt, remap), mutable)
}

///|
fn dae_rewrite_pruned_type_idx(
  idx : @lib.TypeIdx,
  remap : Array[Int],
) -> @lib.TypeIdx {
  match idx {
    @lib.TypeIdx(raw) => {
      let slot = raw.reinterpret_as_int()
      if slot >= 0 && slot < remap.length() && remap[slot] >= 0 {
        @lib.TypeIdx::new(remap[slot].reinterpret_as_uint())
      } else {
        idx
      }
    }
    @lib.RecIdx(_) => idx
  }
}

///|
fn dae_rewrite_pruned_type_idx_instr(
  instr : @lib.Instruction,
  remap : Array[Int],
) -> @lib.Instruction {
  let rewrite_block_type = fn(block_type : @lib.BlockType) -> @lib.BlockType {
    match block_type {
      @lib.TypeIdxBlockType(type_idx) =>
        @lib.BlockType::type_idx(dae_rewrite_pruned_type_idx(type_idx, remap))
      _ => block_type
    }
  }
  match instr {
    @lib.Block(block_type, @lib.Expr(body)) =>
      @lib.Instruction::block(
        rewrite_block_type(block_type),
        @lib.Expr::new(dae_rewrite_pruned_type_idx_instrs(body, remap)),
      )
    @lib.Loop(block_type, @lib.Expr(body)) =>
      @lib.Instruction::loop_(
        rewrite_block_type(block_type),
        @lib.Expr::new(dae_rewrite_pruned_type_idx_instrs(body, remap)),
      )
    @lib.TryTable(block_type, catches, @lib.Expr(body)) =>
      @lib.Instruction::try_table(
        rewrite_block_type(block_type),
        catches,
        @lib.Expr::new(dae_rewrite_pruned_type_idx_instrs(body, remap)),
      )
    @lib.If(block_type, then_body, else_body) =>
      @lib.Instruction::if_(
        rewrite_block_type(block_type),
        dae_rewrite_pruned_type_idx_instrs(then_body, remap),
        match else_body {
          Some(body) => Some(dae_rewrite_pruned_type_idx_instrs(body, remap))
          None => None
        },
      )
    @lib.CallIndirect(type_idx, table_idx) =>
      @lib.Instruction::call_indirect(
        dae_rewrite_pruned_type_idx(type_idx, remap),
        table_idx,
      )
    @lib.ReturnCallIndirect(type_idx, table_idx) =>
      @lib.Instruction::return_call_indirect(
        dae_rewrite_pruned_type_idx(type_idx, remap),
        table_idx,
      )
    @lib.CallRef(type_idx) =>
      @lib.Instruction::call_ref(dae_rewrite_pruned_type_idx(type_idx, remap))
    @lib.ReturnCallRef(type_idx) =>
      @lib.Instruction::return_call_ref(
        dae_rewrite_pruned_type_idx(type_idx, remap),
      )
    @lib.RefNull(rt) =>
      @lib.Instruction::ref_null_type(dae_rewrite_pruned_ref_type(rt, remap))
    @lib.RefTest(nullable, exact, ht) =>
      @lib.Instruction::ref_test_type(
        @lib.RefType::new(
          nullable,
          dae_rewrite_pruned_heap_type(ht, remap),
          exact~,
        ),
      )
    @lib.RefCast(nullable, exact, ht) =>
      @lib.Instruction::ref_cast_type(
        @lib.RefType::new(
          nullable,
          dae_rewrite_pruned_heap_type(ht, remap),
          exact~,
        ),
      )
    _ => instr
  }
}

///|
fn dae_rewrite_pruned_type_idx_instrs(
  instrs : Array[@lib.Instruction],
  remap : Array[Int],
) -> Array[@lib.Instruction] {
  let out : Array[@lib.Instruction] = []
  for instr in instrs {
    out.push(dae_rewrite_pruned_type_idx_instr(instr, remap))
  }
  out
}

///|
fn dae_val_type_has_indexed_heap_type(vt : @lib.ValType) -> Bool {
  match vt {
    @lib.RefTypeValType(@lib.HeapTypeRefType(_, _, @lib.HeapType(_))) => true
    @lib.RefTypeValType(@lib.HeapTypeRefType(_, _, @lib.DefTypeHeapType(_))) =>
      true
    _ => false
  }
}

///|
fn dae_storage_type_has_indexed_heap_type(storage : @lib.StorageType) -> Bool {
  match storage {
    @lib.ValTypeStorageType(vt) => dae_val_type_has_indexed_heap_type(vt)
    _ => false
  }
}

///|
fn dae_comp_type_has_indexed_heap_type(comp_type : @lib.CompType) -> Bool {
  match comp_type {
    @lib.FuncCompType(params, results) =>
      params.any(dae_val_type_has_indexed_heap_type) ||
      results.any(dae_val_type_has_indexed_heap_type)
    @lib.StructCompType(fields) =>
      fields.any(fn(field) {
        let @lib.FieldType(storage, _) = field
        dae_storage_type_has_indexed_heap_type(storage)
      })
    @lib.ArrayCompType(field) => {
      let @lib.FieldType(storage, _) = field
      dae_storage_type_has_indexed_heap_type(storage)
    }
    @lib.ContCompType(_) => true
  }
}

///|
fn dae_prune_unused_simple_func_types(mod_ : @lib.Module) -> @lib.Module {
  let rec_types = match mod_.type_sec {
    Some(@lib.TypeSec(rec_types)) => rec_types
    None => return mod_
  }
  if !dae_simple_func_type_section(rec_types) {
    return mod_
  }
  let used = Array::make(rec_types.length(), false)
  match mod_.import_sec {
    Some(@lib.ImportSec(imports)) =>
      for import_ in imports {
        match import_ {
          @lib.Import(_, _, @lib.FuncExternType(type_idx)) =>
            dae_mark_used_type_idx(type_idx, used)
          @lib.Import(_, _, @lib.TableExternType(table_type)) =>
            dae_mark_used_table_type(table_type, used)
          @lib.Import(_, _, @lib.GlobalExternType(global_type)) =>
            dae_mark_used_global_type(global_type, used)
          @lib.Import(_, _, @lib.TagExternType(tag_type)) => {
            let @lib.TagType(type_idx) = tag_type
            dae_mark_used_type_idx(type_idx, used)
          }
          _ => ()
        }
      }
    None => ()
  }
  match mod_.func_sec {
    Some(@lib.FuncSec(type_idxs)) =>
      for type_idx in type_idxs {
        dae_mark_used_type_idx(type_idx, used)
      }
    None => ()
  }
  match mod_.tag_sec {
    Some(@lib.TagSec(tags)) =>
      for tag in tags {
        let @lib.TagType(type_idx) = tag
        dae_mark_used_type_idx(type_idx, used)
      }
    None => ()
  }
  match mod_.table_sec {
    Some(@lib.TableSec(tables)) =>
      for table in tables {
        let @lib.Table(table_type, _) = table
        dae_mark_used_table_type(table_type, used)
      }
    None => ()
  }
  match mod_.global_sec {
    Some(@lib.GlobalSec(globals)) =>
      for global in globals {
        let @lib.Global(global_type, @lib.Expr(body)) = global
        dae_mark_used_global_type(global_type, used)
        dae_collect_used_type_idx_instrs(body, used)
      }
    None => ()
  }
  match mod_.elem_sec {
    Some(@lib.ElemSec(elems)) =>
      for elem in elems {
        let @lib.Elem(_, kind) = elem
        match kind {
          @lib.TypedExprsElemKind(ref_type, exprs) => {
            dae_mark_used_ref_type(ref_type, used)
            for expr in exprs {
              let @lib.Expr(body) = expr
              dae_collect_used_type_idx_instrs(body, used)
            }
          }
          @lib.FuncExprsElemKind(exprs) =>
            for expr in exprs {
              let @lib.Expr(body) = expr
              dae_collect_used_type_idx_instrs(body, used)
            }
          _ => ()
        }
      }
    None => ()
  }
  match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) =>
      for func in funcs {
        let @lib.Func(locals, @lib.Expr(body)) = func
        for local_run in locals.runs() {
          dae_mark_used_val_type(local_run.val_type(), used)
        }
        dae_collect_used_type_idx_instrs(body, used)
      }
    None => ()
  }
  // The current remapper rewrites every module-level reference but does not
  // reconstruct retained type definitions. Prune a mixed flat section only
  // when each retained definition is internally index-free; unused function
  // signatures may still reference GC types and disappear safely.
  for old_idx = 0; old_idx < rec_types.length(); old_idx = old_idx + 1 {
    if !used[old_idx] {
      continue
    }
    match rec_types[old_idx] {
      @lib.SingleRecType(subtype) =>
        if dae_comp_type_has_indexed_heap_type(subtype.get_comptype()) {
          return mod_
        }
      @lib.GroupRecType(_) => return mod_
    }
  }
  let remap = Array::make(rec_types.length(), -1)
  let next_types : Array[@lib.RecType] = []
  let mut old_idx = 0
  while old_idx < rec_types.length() {
    if used[old_idx] {
      remap[old_idx] = next_types.length()
      next_types.push(rec_types[old_idx])
    }
    old_idx += 1
  }
  if next_types.length() == rec_types.length() {
    return mod_
  }
  // Type-index-bearing GC instructions are conservatively left untouched by
  // this compact remapper. Require every retained non-function definition to
  // keep its original slot; function types may shift because all function,
  // block, tag, call-ref, import, and signature references are rewritten.
  for old_idx = 0; old_idx < rec_types.length(); old_idx = old_idx + 1 {
    if !used[old_idx] || remap[old_idx] == old_idx {
      continue
    }
    match rec_types[old_idx] {
      @lib.SingleRecType(subtype) =>
        match subtype.get_comptype() {
          @lib.FuncCompType(_, _) => ()
          _ => return mod_
        }
      @lib.GroupRecType(_) => return mod_
    }
  }
  let mut next = mod_
    .with_type_sec(@lib.TypeSec::new(next_types))
    .without_name_sec()
  match mod_.import_sec {
    Some(@lib.ImportSec(imports)) => {
      let rewritten : Array[@lib.Import] = []
      for import_ in imports {
        match import_ {
          @lib.Import(module_name, base_name, @lib.FuncExternType(type_idx)) =>
            rewritten.push(
              @lib.Import::new(
                module_name,
                base_name,
                @lib.ExternType::func(
                  dae_rewrite_pruned_type_idx(type_idx, remap),
                ),
              ),
            )
          @lib.Import(module_name, base_name, @lib.TableExternType(table_type)) =>
            rewritten.push(
              @lib.Import::new(
                module_name,
                base_name,
                @lib.ExternType::table(
                  dae_rewrite_pruned_table_type(table_type, remap),
                ),
              ),
            )
          @lib.Import(
            module_name,
            base_name,
            @lib.GlobalExternType(global_type)
          ) =>
            rewritten.push(
              @lib.Import::new(
                module_name,
                base_name,
                @lib.ExternType::global(
                  dae_rewrite_pruned_global_type(global_type, remap),
                ),
              ),
            )
          @lib.Import(module_name, base_name, @lib.TagExternType(tag_type)) => {
            let @lib.TagType(type_idx) = tag_type
            rewritten.push(
              @lib.Import::new(
                module_name,
                base_name,
                @lib.ExternType::tag(
                  @lib.TagType::new(
                    dae_rewrite_pruned_type_idx(type_idx, remap),
                  ),
                ),
              ),
            )
          }
          _ => rewritten.push(import_)
        }
      }
      next = next.with_import_sec(@lib.ImportSec::new(rewritten))
    }
    None => ()
  }
  match mod_.func_sec {
    Some(@lib.FuncSec(type_idxs)) => {
      let rewritten : Array[@lib.TypeIdx] = []
      for type_idx in type_idxs {
        rewritten.push(dae_rewrite_pruned_type_idx(type_idx, remap))
      }
      next = next.with_func_sec(@lib.FuncSec::new(rewritten))
    }
    None => ()
  }
  match mod_.tag_sec {
    Some(@lib.TagSec(tags)) => {
      let rewritten : Array[@lib.TagType] = []
      for tag in tags {
        let @lib.TagType(type_idx) = tag
        rewritten.push(
          @lib.TagType::new(dae_rewrite_pruned_type_idx(type_idx, remap)),
        )
      }
      next = next.with_tag_sec(@lib.TagSec::new(rewritten))
    }
    None => ()
  }
  match mod_.table_sec {
    Some(@lib.TableSec(tables)) => {
      let rewritten : Array[@lib.Table] = []
      for table in tables {
        let @lib.Table(table_type, init) = table
        rewritten.push(
          @lib.Table::new(
            dae_rewrite_pruned_table_type(table_type, remap),
            init,
          ),
        )
      }
      next = next.with_table_sec(@lib.TableSec::new(rewritten))
    }
    None => ()
  }
  match mod_.global_sec {
    Some(@lib.GlobalSec(globals)) => {
      let rewritten : Array[@lib.Global] = []
      for global in globals {
        let @lib.Global(global_type, @lib.Expr(body)) = global
        rewritten.push(
          @lib.Global::new(
            dae_rewrite_pruned_global_type(global_type, remap),
            @lib.Expr::new(dae_rewrite_pruned_type_idx_instrs(body, remap)),
          ),
        )
      }
      next = next.with_global_sec(@lib.GlobalSec::new(rewritten))
    }
    None => ()
  }
  match mod_.elem_sec {
    Some(@lib.ElemSec(elems)) => {
      let rewritten : Array[@lib.Elem] = []
      for elem in elems {
        let @lib.Elem(mode, kind) = elem
        let next_kind = match kind {
          @lib.TypedExprsElemKind(ref_type, exprs) => {
            let next_exprs : Array[@lib.Expr] = []
            for expr in exprs {
              let @lib.Expr(body) = expr
              next_exprs.push(
                @lib.Expr::new(dae_rewrite_pruned_type_idx_instrs(body, remap)),
              )
            }
            @lib.ElemKind::typed_exprs(
              dae_rewrite_pruned_ref_type(ref_type, remap),
              next_exprs,
            )
          }
          @lib.FuncExprsElemKind(exprs) => {
            let next_exprs : Array[@lib.Expr] = []
            for expr in exprs {
              let @lib.Expr(body) = expr
              next_exprs.push(
                @lib.Expr::new(dae_rewrite_pruned_type_idx_instrs(body, remap)),
              )
            }
            @lib.ElemKind::func_exprs(next_exprs)
          }
          _ => kind
        }
        rewritten.push(@lib.Elem::new(mode, next_kind))
      }
      next = next.with_elem_sec(@lib.ElemSec::new(rewritten))
    }
    None => ()
  }
  match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => {
      let rewritten : Array[@lib.Func] = []
      for func in funcs {
        let @lib.Func(locals, @lib.Expr(body)) = func
        let next_runs : Array[@lib.LocalRun] = []
        for run in locals.runs() {
          next_runs.push(
            @lib.LocalRun::new(
              run.count(),
              dae_rewrite_pruned_val_type(run.val_type(), remap),
            ),
          )
        }
        rewritten.push(
          @lib.Func::new(
            @lib.Locals::new(next_runs),
            @lib.Expr::new(dae_rewrite_pruned_type_idx_instrs(body, remap)),
          ),
        )
      }
      next = next.with_code_sec(@lib.CodeSec::new(rewritten))
    }
    None => ()
  }
  next
}

///|
fn dae_append_new_func_type(
  type_sec : @lib.TypeSec,
  params : Array[@lib.ValType],
  results : Array[@lib.ValType],
) -> (@lib.TypeSec, @lib.TypeIdx) {
  let @lib.TypeSec(rec_types) = type_sec
  let next = rec_types.copy()
  let idx = @lib.TypeIdx::new(
    dae_type_sec_flattened_length(type_sec).reinterpret_as_uint(),
  )
  next.push(
    @lib.RecType::new(
      @lib.SubType::comp_type(@lib.CompType::func(params, results)),
    ),
  )
  (@lib.TypeSec::new(next), idx)
}

///|
fn dae_simple_func_type_key(
  params : Array[@lib.ValType],
  results : Array[@lib.ValType],
) -> String {
  params.to_string() + "->" + results.to_string()
}

///|
fn dae_simple_func_type_lookup(
  type_sec : @lib.TypeSec,
) -> @hashmap.HashMap[String, @lib.TypeIdx] {
  let @lib.TypeSec(rec_types) = type_sec
  let lookup : @hashmap.HashMap[String, @lib.TypeIdx] = @hashmap.new(
    capacity=dae_type_sec_flattened_length(type_sec) * 2 + 1,
  )
  let mut flat_idx = 0
  for rec_type in rec_types {
    match rec_type {
      @lib.SingleRecType(subtype) => {
        if subtype.super_types().is_empty() &&
          subtype.describes_type() is None &&
          subtype.descriptor_type() is None {
          match subtype.get_comptype() {
            @lib.FuncCompType(params, results) => {
              let key = dae_simple_func_type_key(params, results)
              if lookup.get(key) is None {
                lookup.set(
                  key,
                  @lib.TypeIdx::new(flat_idx.reinterpret_as_uint()),
                )
              }
            }
            _ => ()
          }
        }
        flat_idx += 1
      }
      @lib.GroupRecType(group) => flat_idx += group.length()
    }
  }
  lookup
}

///|
fn dae_find_equivalent_simple_func_type(
  type_sec : @lib.TypeSec,
  params : Array[@lib.ValType],
  results : Array[@lib.ValType],
) -> @lib.TypeIdx? {
  let @lib.TypeSec(rec_types) = type_sec
  let mut flat_idx = 0
  for rec_type in rec_types {
    match rec_type {
      @lib.SingleRecType(subtype) => {
        if subtype.super_types().is_empty() &&
          subtype.describes_type() is None &&
          subtype.descriptor_type() is None {
          match subtype.get_comptype() {
            @lib.FuncCompType(existing_params, existing_results) if existing_params ==
              params &&
              existing_results == results =>
              return Some(@lib.TypeIdx::new(flat_idx.reinterpret_as_uint()))
            _ => ()
          }
        }
        flat_idx += 1
      }
      @lib.GroupRecType(group) => flat_idx += group.length()
    }
  }
  None
}

///|
fn dae_type_idx_equal(lhs : @lib.TypeIdx, rhs : @lib.TypeIdx) -> Bool {
  lhs == rhs
}

///|
fn dae_type_idx_references_slot(
  type_idx : @lib.TypeIdx,
  target_slot : Int,
  rec_group_base : Int,
) -> Bool {
  match type_idx {
    @lib.TypeIdx(raw) => raw.reinterpret_as_int() == target_slot
    @lib.RecIdx(raw) =>
      rec_group_base >= 0 &&
      rec_group_base + raw.reinterpret_as_int() == target_slot
  }
}

///|
fn dae_heap_type_references_slot(
  heap_type : @lib.HeapType,
  target_slot : Int,
  rec_group_base : Int,
) -> Bool {
  match heap_type {
    @lib.HeapType(type_idx) =>
      dae_type_idx_references_slot(type_idx, target_slot, rec_group_base)
    @lib.DefTypeHeapType(_) => true
    _ => false
  }
}

///|
fn dae_ref_type_references_slot(
  ref_type : @lib.RefType,
  target_slot : Int,
  rec_group_base : Int,
) -> Bool {
  match ref_type {
    @lib.HeapTypeRefType(_, _, heap_type) =>
      dae_heap_type_references_slot(heap_type, target_slot, rec_group_base)
    _ => false
  }
}

///|
fn dae_val_type_references_slot(
  val_type : @lib.ValType,
  target_slot : Int,
  rec_group_base : Int,
) -> Bool {
  match val_type {
    @lib.RefTypeValType(ref_type) =>
      dae_ref_type_references_slot(ref_type, target_slot, rec_group_base)
    _ => false
  }
}

///|
fn dae_storage_type_references_slot(
  storage_type : @lib.StorageType,
  target_slot : Int,
  rec_group_base : Int,
) -> Bool {
  match storage_type {
    @lib.ValTypeStorageType(val_type) =>
      dae_val_type_references_slot(val_type, target_slot, rec_group_base)
    _ => false
  }
}

///|
fn dae_field_type_references_slot(
  field_type : @lib.FieldType,
  target_slot : Int,
  rec_group_base : Int,
) -> Bool {
  let @lib.FieldType(storage_type, _) = field_type
  dae_storage_type_references_slot(storage_type, target_slot, rec_group_base)
}

///|
fn dae_comp_type_references_slot(
  comp_type : @lib.CompType,
  target_slot : Int,
  rec_group_base : Int,
) -> Bool {
  match comp_type {
    @lib.ArrayCompType(field_type) =>
      dae_field_type_references_slot(field_type, target_slot, rec_group_base)
    @lib.StructCompType(fields) =>
      fields.any(fn(field_type) {
        dae_field_type_references_slot(field_type, target_slot, rec_group_base)
      })
    @lib.FuncCompType(params, results) =>
      params.any(fn(param) {
        dae_val_type_references_slot(param, target_slot, rec_group_base)
      }) ||
      results.any(fn(result) {
        dae_val_type_references_slot(result, target_slot, rec_group_base)
      })
    @lib.ContCompType(func_type) =>
      dae_type_idx_references_slot(func_type, target_slot, rec_group_base)
  }
}

///|
fn dae_subtype_references_slot(
  subtype : @lib.SubType,
  target_slot : Int,
  rec_group_base : Int,
) -> Bool {
  let (supers, metadata, comp_type) = match subtype {
    @lib.SubType(_, supers, metadata, comp_type) =>
      (supers, metadata, comp_type)
    @lib.CompTypeSubType(metadata, comp_type) => ([], metadata, comp_type)
  }
  for super_type in supers {
    if dae_type_idx_references_slot(super_type, target_slot, rec_group_base) {
      return true
    }
  }
  let { describes, descriptor } = metadata
  match describes {
    Some(type_idx) =>
      if dae_type_idx_references_slot(type_idx, target_slot, rec_group_base) {
        return true
      }
    None => ()
  }
  match descriptor {
    Some(type_idx) =>
      if dae_type_idx_references_slot(type_idx, target_slot, rec_group_base) {
        return true
      }
    None => ()
  }
  dae_comp_type_references_slot(comp_type, target_slot, rec_group_base)
}

///|
fn dae_type_sec_references_slot(
  type_sec : @lib.TypeSec,
  target_slot : Int,
) -> Bool {
  let @lib.TypeSec(rec_types) = type_sec
  let mut flat_idx = 0
  for rec_type in rec_types {
    match rec_type {
      @lib.SingleRecType(subtype) => {
        if dae_subtype_references_slot(subtype, target_slot, flat_idx) {
          return true
        }
        flat_idx += 1
      }
      @lib.GroupRecType(group) => {
        for subtype in group {
          if dae_subtype_references_slot(subtype, target_slot, flat_idx) {
            return true
          }
        }
        flat_idx += group.length()
      }
    }
  }
  false
}

///|
fn dae_instrs_reference_type_slot(
  instrs : Array[@lib.Instruction],
  target_slot : Int,
) -> Bool {
  for instr in instrs {
    match instr {
      @lib.Block(block_type, @lib.Expr(body))
      | @lib.Loop(block_type, @lib.Expr(body))
      | @lib.TryTable(block_type, _, @lib.Expr(body)) => {
        match block_type {
          @lib.ValTypeBlockType(val_type) =>
            if dae_val_type_references_slot(val_type, target_slot, -1) {
              return true
            }
          @lib.TypeIdxBlockType(type_idx) =>
            if dae_type_idx_references_slot(type_idx, target_slot, -1) {
              return true
            }
          _ => ()
        }
        if dae_instrs_reference_type_slot(body, target_slot) {
          return true
        }
      }
      @lib.If(block_type, then_body, else_body) => {
        match block_type {
          @lib.ValTypeBlockType(val_type) =>
            if dae_val_type_references_slot(val_type, target_slot, -1) {
              return true
            }
          @lib.TypeIdxBlockType(type_idx) =>
            if dae_type_idx_references_slot(type_idx, target_slot, -1) {
              return true
            }
          _ => ()
        }
        if dae_instrs_reference_type_slot(then_body, target_slot) {
          return true
        }
        match else_body {
          Some(body) =>
            if dae_instrs_reference_type_slot(body, target_slot) {
              return true
            }
          None => ()
        }
      }
      @lib.CallIndirect(type_idx, _)
      | @lib.ReturnCallIndirect(type_idx, _)
      | @lib.CallRef(type_idx)
      | @lib.ReturnCallRef(type_idx)
      | @lib.StructNew(type_idx)
      | @lib.StructNewDefault(type_idx)
      | @lib.StructNewDesc(type_idx)
      | @lib.StructNewDefaultDesc(type_idx)
      | @lib.ArrayNew(type_idx)
      | @lib.ArrayNewDefault(type_idx)
      | @lib.ArrayNewFixed(type_idx, _)
      | @lib.ArrayNewData(type_idx, _)
      | @lib.ArrayNewElem(type_idx, _)
      | @lib.ArrayGet(type_idx)
      | @lib.ArrayGetS(type_idx)
      | @lib.ArrayGetU(type_idx)
      | @lib.ArraySet(type_idx)
      | @lib.ArrayFill(type_idx)
      | @lib.ArrayInitData(type_idx, _)
      | @lib.ArrayInitElem(type_idx, _)
      | @lib.RefGetDesc(type_idx)
      | @lib.StructGet(type_idx, _)
      | @lib.StructGetS(type_idx, _)
      | @lib.StructGetU(type_idx, _)
      | @lib.StructAtomicGet(_, type_idx, _)
      | @lib.StructAtomicGetS(_, type_idx, _)
      | @lib.StructAtomicGetU(_, type_idx, _)
      | @lib.StructSet(type_idx, _) =>
        if dae_type_idx_references_slot(type_idx, target_slot, -1) {
          return true
        }
      @lib.ArrayCopy(source_type, target_type) =>
        if dae_type_idx_references_slot(source_type, target_slot, -1) ||
          dae_type_idx_references_slot(target_type, target_slot, -1) {
          return true
        }
      @lib.Select(Some(types)) =>
        if types.any(fn(val_type) {
            dae_val_type_references_slot(val_type, target_slot, -1)
          }) {
          return true
        }
      @lib.RefNull(ref_type) =>
        if dae_ref_type_references_slot(ref_type, target_slot, -1) {
          return true
        }
      @lib.RefTest(_, _, heap_type)
      | @lib.RefCast(_, _, heap_type)
      | @lib.RefTestDesc(_, heap_type)
      | @lib.RefCastDescEq(_, _, heap_type) =>
        if dae_heap_type_references_slot(heap_type, target_slot, -1) {
          return true
        }
      @lib.BrOnCast(_, _, source_type, target_type)
      | @lib.BrOnCastFail(_, _, source_type, target_type) =>
        if dae_heap_type_references_slot(source_type, target_slot, -1) ||
          dae_heap_type_references_slot(target_type, target_slot, -1) {
          return true
        }
      _ => ()
    }
  }
  false
}

///|
fn dae_non_funcsec_references_type_slot(
  mod_ : @lib.Module,
  target_slot : Int,
) -> Bool {
  match mod_.import_sec {
    Some(@lib.ImportSec(imports)) =>
      for import_ in imports {
        match import_ {
          @lib.Import(_, _, @lib.TableExternType(@lib.TableType(ref_type, _))) =>
            if dae_ref_type_references_slot(ref_type, target_slot, -1) {
              return true
            }
          @lib.Import(_, _, @lib.GlobalExternType(@lib.GlobalType(val_type, _))) =>
            if dae_val_type_references_slot(val_type, target_slot, -1) {
              return true
            }
          @lib.Import(_, _, @lib.TagExternType(@lib.TagType(type_idx))) =>
            if dae_type_idx_references_slot(type_idx, target_slot, -1) {
              return true
            }
          _ => ()
        }
      }
    None => ()
  }
  match mod_.tag_sec {
    Some(@lib.TagSec(tags)) =>
      for tag in tags {
        let @lib.TagType(type_idx) = tag
        if dae_type_idx_references_slot(type_idx, target_slot, -1) {
          return true
        }
      }
    None => ()
  }
  match mod_.table_sec {
    Some(@lib.TableSec(tables)) =>
      for table in tables {
        let @lib.Table(@lib.TableType(ref_type, _), init) = table
        if dae_ref_type_references_slot(ref_type, target_slot, -1) {
          return true
        }
        match init {
          Some(@lib.Expr(body)) =>
            if dae_instrs_reference_type_slot(body, target_slot) {
              return true
            }
          None => ()
        }
      }
    None => ()
  }
  match mod_.global_sec {
    Some(@lib.GlobalSec(globals)) =>
      for global in globals {
        let @lib.Global(@lib.GlobalType(val_type, _), @lib.Expr(body)) = global
        if dae_val_type_references_slot(val_type, target_slot, -1) ||
          dae_instrs_reference_type_slot(body, target_slot) {
          return true
        }
      }
    None => ()
  }
  match mod_.elem_sec {
    Some(@lib.ElemSec(elems)) =>
      for elem in elems {
        let @lib.Elem(_, kind) = elem
        match kind {
          @lib.TypedExprsElemKind(ref_type, exprs) => {
            if dae_ref_type_references_slot(ref_type, target_slot, -1) {
              return true
            }
            for expr in exprs {
              let @lib.Expr(body) = expr
              if dae_instrs_reference_type_slot(body, target_slot) {
                return true
              }
            }
          }
          @lib.FuncExprsElemKind(exprs) =>
            for expr in exprs {
              let @lib.Expr(body) = expr
              if dae_instrs_reference_type_slot(body, target_slot) {
                return true
              }
            }
          _ => ()
        }
      }
    None => ()
  }
  match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) =>
      for func in funcs {
        let @lib.Func(locals, @lib.Expr(body)) = func
        for local_run in locals.runs() {
          if dae_val_type_references_slot(local_run.val_type(), target_slot, -1) {
            return true
          }
        }
        if dae_instrs_reference_type_slot(body, target_slot) {
          return true
        }
      }
    None => ()
  }
  false
}

///|
fn dae_can_replace_unique_defined_func_type(
  mod_ : @lib.Module,
  func_types : Array[@lib.TypeIdx],
  def_idx : Int,
  old_type_idx : @lib.TypeIdx,
) -> Bool {
  let old_slot = match dae_type_idx_slot(old_type_idx) {
    Some(slot) => slot
    None => return false
  }
  let type_sec = match mod_.type_sec {
    Some(type_sec) => type_sec
    None => return false
  }
  let flat_len = dae_type_sec_flattened_length(type_sec)
  if old_slot < 0 || old_slot >= flat_len {
    return false
  }
  if dae_type_sec_rec_entry_location(type_sec, old_type_idx) is None {
    return false
  }
  match dae_type_sec_subtype(type_sec, old_type_idx) {
    Some(@lib.CompTypeSubType(metadata, @lib.FuncCompType(_, _))) => {
      let { describes, descriptor } = metadata
      if describes is Some(_) || descriptor is Some(_) {
        return false
      }
    }
    _ => return false
  }
  match mod_.import_sec {
    Some(@lib.ImportSec(imports)) =>
      for import_ in imports {
        match import_ {
          @lib.Import(_, _, @lib.FuncExternType(type_idx)) if dae_type_idx_equal(
              type_idx, old_type_idx,
            ) => return false
          _ => ()
        }
      }
    None => ()
  }
  let mut user_count = 0
  let mut idx = 0
  while idx < func_types.length() {
    if dae_type_idx_equal(func_types[idx], old_type_idx) {
      user_count += 1
      if idx != def_idx {
        return false
      }
    }
    idx += 1
  }
  if user_count != 1 {
    return false
  }
  !dae_non_funcsec_references_type_slot(mod_, old_slot) &&
  !dae_type_sec_references_slot(type_sec, old_slot)
}

///|
fn dae_replace_defined_func_type_in_place(
  type_sec : @lib.TypeSec,
  type_idx : @lib.TypeIdx,
  params : Array[@lib.ValType],
  results : Array[@lib.ValType],
) -> @lib.TypeSec? {
  let (entry_slot, subtype_slot) = match
    dae_type_sec_rec_entry_location(type_sec, type_idx) {
    Some(location) => location
    None => return None
  }
  let @lib.TypeSec(rec_types) = type_sec
  if entry_slot < 0 || entry_slot >= rec_types.length() {
    return None
  }
  let replacement = @lib.SubType::comp_type(
    @lib.CompType::func(params, results),
  )
  let next = rec_types.copy()
  match rec_types[entry_slot] {
    @lib.SingleRecType(_) => {
      if subtype_slot != 0 {
        return None
      }
      next[entry_slot] = @lib.RecType::new(replacement)
    }
    @lib.GroupRecType(group) => {
      if subtype_slot < 0 || subtype_slot >= group.length() {
        return None
      }
      let rewritten_group = group.copy()
      rewritten_group[subtype_slot] = replacement
      next[entry_slot] = @lib.RecType::group(rewritten_group)
    }
  }
  Some(@lib.TypeSec::new(next))
}

///|
fn dae_update_defined_func_type(
  mod_ : @lib.Module,
  type_sec : @lib.TypeSec,
  func_types : Array[@lib.TypeIdx],
  def_idx : Int,
  params : Array[@lib.ValType],
  results : Array[@lib.ValType],
) -> (@lib.TypeSec, @lib.TypeIdx) {
  let old_type_idx = func_types[def_idx]
  match dae_find_equivalent_simple_func_type(type_sec, params, results) {
    Some(existing_idx) => return (type_sec, existing_idx)
    None => ()
  }
  if dae_can_replace_unique_defined_func_type(
      mod_, func_types, def_idx, old_type_idx,
    ) {
    match
      dae_replace_defined_func_type_in_place(
        type_sec, old_type_idx, params, results,
      ) {
      Some(next_type_sec) => return (next_type_sec, old_type_idx)
      None => ()
    }
  }
  dae_append_new_func_type(type_sec, params, results)
}

///|
fn dae_type_idx_is_subtype_of_visit(
  mod_ : @lib.Module,
  candidate : @lib.TypeIdx,
  target : @lib.TypeIdx,
  visited : Array[Bool],
) -> Bool {
  if candidate == target {
    return true
  }
  let slot = match dae_type_idx_slot(candidate) {
    Some(slot) => slot
    None => return false
  }
  if slot < 0 || slot >= visited.length() || visited[slot] {
    return false
  }
  visited[slot] = true
  match mod_.type_sec {
    Some(@lib.TypeSec(rec_types)) if slot < rec_types.length() =>
      match rec_types[slot] {
        @lib.SingleRecType(subtype) => {
          for super_type in subtype.super_types() {
            if dae_type_idx_is_subtype_of_visit(
                mod_, super_type, target, visited,
              ) {
              return true
            }
          }
          false
        }
        @lib.GroupRecType(_) => false
      }
    _ => false
  }
}

///|
fn dae_type_idx_is_subtype_of(
  mod_ : @lib.Module,
  candidate : @lib.TypeIdx,
  target : @lib.TypeIdx,
) -> Bool {
  let rec_len = match mod_.type_sec {
    Some(@lib.TypeSec(rec_types)) => rec_types.length()
    None => return false
  }
  dae_type_idx_is_subtype_of_visit(
    mod_,
    candidate,
    target,
    Array::make(rec_len, false),
  )
}

///|
fn dae_collect_type_ancestors_visit(
  mod_ : @lib.Module,
  type_idx : @lib.TypeIdx,
  out : Array[@lib.TypeIdx],
  visited : Array[Bool],
) -> Unit {
  let slot = match dae_type_idx_slot(type_idx) {
    Some(slot) => slot
    None => return
  }
  if slot < 0 || slot >= visited.length() || visited[slot] {
    return
  }
  visited[slot] = true
  out.push(type_idx)
  match mod_.type_sec {
    Some(@lib.TypeSec(rec_types)) if slot < rec_types.length() =>
      match rec_types[slot] {
        @lib.SingleRecType(subtype) =>
          for super_type in subtype.super_types() {
            dae_collect_type_ancestors_visit(mod_, super_type, out, visited)
          }
        @lib.GroupRecType(_) => ()
      }
    _ => ()
  }
}

///|
fn dae_collect_type_ancestors(
  mod_ : @lib.Module,
  type_idx : @lib.TypeIdx,
) -> Array[@lib.TypeIdx] {
  let rec_len = match mod_.type_sec {
    Some(@lib.TypeSec(rec_types)) => rec_types.length()
    None => return []
  }
  let out : Array[@lib.TypeIdx] = []
  dae_collect_type_ancestors_visit(
    mod_,
    type_idx,
    out,
    Array::make(rec_len, false),
  )
  out
}

///|
fn dae_common_supertype_idx(
  mod_ : @lib.Module,
  left : @lib.TypeIdx,
  right : @lib.TypeIdx,
  old : @lib.TypeIdx,
) -> @lib.TypeIdx? {
  let left_ancestors = dae_collect_type_ancestors(mod_, left)
  let mut best : @lib.TypeIdx? = None
  for candidate in left_ancestors {
    if dae_type_idx_is_subtype_of(mod_, right, candidate) &&
      dae_type_idx_is_subtype_of(mod_, candidate, old) {
      match best {
        Some(best_idx) =>
          if dae_type_idx_is_subtype_of(mod_, candidate, best_idx) {
            best = Some(candidate)
          }
        None => best = Some(candidate)
      }
    }
  }
  best
}

///|
fn dae_lub_gc_candidate_ref_type(
  mod_ : @lib.Module,
  left_type : @lib.ValType,
  right_type : @lib.ValType,
  old_type : @lib.ValType,
) -> @lib.ValType? {
  match (left_type, right_type, old_type) {
    (
      @lib.RefTypeValType(
        @lib.HeapTypeRefType(left_nullable, left_exact, @lib.HeapType(left_idx))
      ),
      @lib.RefTypeValType(
        @lib.HeapTypeRefType(
          right_nullable,
          right_exact,
          @lib.HeapType(right_idx)
        )
      ),
      @lib.RefTypeValType(
        @lib.HeapTypeRefType(old_nullable, _, @lib.HeapType(old_idx))
      ),
    ) => {
      let nullable = left_nullable || right_nullable
      if nullable && !old_nullable {
        return None
      }
      if left_idx == right_idx {
        if !dae_type_idx_is_subtype_of(mod_, left_idx, old_idx) {
          return None
        }
        let exact = left_exact && right_exact
        return Some(
          @lib.ValType::ref_type(
            @lib.RefType::new(nullable, @lib.HeapType::new(left_idx), exact~),
          ),
        )
      }
      match dae_common_supertype_idx(mod_, left_idx, right_idx, old_idx) {
        Some(common_idx) =>
          Some(
            @lib.ValType::ref_type(
              @lib.RefType::new(nullable, @lib.HeapType::new(common_idx)),
            ),
          )
        None => None
      }
    }
    _ => None
  }
}

///|
fn dae_refined_gc_candidate_ref_type(
  mod_ : @lib.Module,
  old_type : @lib.ValType,
  candidate_type : @lib.ValType,
) -> @lib.ValType? {
  match (old_type, candidate_type) {
    (
      @lib.RefTypeValType(
        @lib.HeapTypeRefType(old_nullable, _, @lib.HeapType(old_idx))
      ),
      @lib.RefTypeValType(
        @lib.HeapTypeRefType(
          candidate_nullable,
          exact,
          @lib.HeapType(candidate_idx)
        )
      ),
    ) => {
      if candidate_nullable && !old_nullable {
        return None
      }
      if !dae_type_idx_is_subtype_of(mod_, candidate_idx, old_idx) {
        return None
      }
      let next = @lib.ValType::ref_type(
        @lib.RefType::new(
          candidate_nullable,
          @lib.HeapType::new(candidate_idx),
          exact~,
        ),
      )
      if next == old_type {
        None
      } else {
        Some(next)
      }
    }
    _ => None
  }
}

///|
fn dae_block_type_single_non_null_concrete_gc_result_candidate(
  block_type : @lib.BlockType,
  mod_ : @lib.Module,
) -> @lib.ValType? {
  dae_control_block_type_single_non_null_concrete_gc_result_evidence(
    block_type,
    mod_.type_sec,
  ).map(fn(evidence) { evidence.candidate })
}

///|
fn dae_block_type_last_non_null_concrete_gc_result_candidate(
  block_type : @lib.BlockType,
  mod_ : @lib.Module,
) -> @lib.ValType? {
  dae_control_block_type_last_non_null_concrete_gc_result_evidence(
    block_type,
    mod_.type_sec,
  ).map(fn(evidence) { evidence.candidate })
}

///|
fn dae_direct_call_gc_result_signature_evidence(
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  func_idx : @lib.FuncIdx,
) -> DaeDirectGcCallResultEvidence? {
  let slot = dae_func_idx_slot(func_idx)
  match dae_resolve_func_type(mod_, func_type_indices, slot) {
    Some(@lib.FuncType(params, [result])) =>
      match result {
        @lib.RefTypeValType(@lib.HeapTypeRefType(_, _, @lib.HeapType(_))) =>
          Some({
            candidate: result,
            refined_candidate: None,
            param_count: params.length(),
          })
        _ => None
      }
    _ => None
  }
}

///|
fn dae_direct_call_gc_result_refinement_evidence(
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  func_idx : @lib.FuncIdx,
  old_type : @lib.ValType,
) -> DaeDirectGcCallResultEvidence? {
  let signature = match
    dae_direct_call_gc_result_signature_evidence(
      mod_, func_type_indices, func_idx,
    ) {
    Some(evidence) => evidence
    None => return None
  }
  match dae_refined_gc_candidate_ref_type(mod_, old_type, signature.candidate) {
    Some(refined_type) =>
      Some({
        candidate: signature.candidate,
        refined_candidate: Some(refined_type),
        param_count: signature.param_count,
      })
    None => None
  }
}

///|
fn dae_direct_gc_actual_candidate_type(
  instr : @lib.Instruction,
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
) -> @lib.ValType? {
  match instr {
    @lib.StructNewDefault(type_idx) =>
      Some(
        @lib.ValType::ref_type(
          @lib.RefType::new(false, @lib.HeapType::new(type_idx), exact=true),
        ),
      )
    @lib.Call(func_idx) =>
      dae_direct_call_gc_result_signature_evidence(
        mod_, func_type_indices, func_idx,
      ).map(fn(evidence) { evidence.candidate })
    @lib.Block(block_type, _)
    | @lib.Loop(block_type, _)
    | @lib.If(block_type, _, _) =>
      dae_block_type_single_non_null_concrete_gc_result_candidate(
        block_type, mod_,
      )
    _ => None
  }
}

///|
fn dae_nullable_gc_candidate_ref_type(
  candidate : @lib.ValType,
  old_type : @lib.ValType,
  mod_ : @lib.Module,
) -> @lib.ValType? {
  match (candidate, old_type) {
    (
      @lib.RefTypeValType(
        @lib.HeapTypeRefType(_, exact, @lib.HeapType(candidate_idx))
      ),
      @lib.RefTypeValType(@lib.HeapTypeRefType(_, _, @lib.HeapType(old_idx))),
    ) =>
      if dae_type_idx_is_subtype_of(mod_, candidate_idx, old_idx) {
        Some(
          @lib.ValType::ref_type(
            @lib.RefType::new(true, @lib.HeapType::new(candidate_idx), exact~),
          ),
        )
      } else {
        None
      }
    _ => None
  }
}

///|
fn dae_gc_select_actual_value_slices_evidence(
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  body : Array[@lib.Instruction],
  slices : DaeSelectValueSlices,
  old_type : @lib.ValType,
  require_refined? : Bool = false,
  rewrite_type? : @lib.ValType? = None,
) -> DaeGcSelectValueSlicesEvidence? {
  if !dae_select_value_slices_are_consistent(slices, slices.select_idx) ||
    slices.select_idx >= body.length() ||
    slices.right.end != slices.condition.start {
    return None
  }
  match body[slices.select_idx] {
    @lib.Select(_) => ()
    _ => return None
  }
  let left_idx = match dae_value_slice_single_instruction_index(slices.left) {
    Some(idx) if idx >= 0 && idx < body.length() => idx
    _ => return None
  }
  let right_idx = match dae_value_slice_single_instruction_index(slices.right) {
    Some(idx) if idx >= 0 && idx < body.length() => idx
    _ => return None
  }
  let candidate = match (body[left_idx], body[right_idx]) {
    (@lib.RefNull(_), @lib.RefNull(_)) => return None
    (@lib.RefNull(_), right_instr) =>
      match
        dae_direct_gc_actual_candidate_type(
          right_instr, mod_, func_type_indices,
        ) {
        Some(right_candidate) =>
          match
            dae_nullable_gc_candidate_ref_type(right_candidate, old_type, mod_) {
            Some(nullable_candidate) => nullable_candidate
            None => return None
          }
        None => return None
      }
    (left_instr, @lib.RefNull(_)) =>
      match
        dae_direct_gc_actual_candidate_type(left_instr, mod_, func_type_indices) {
        Some(left_candidate) =>
          match
            dae_nullable_gc_candidate_ref_type(left_candidate, old_type, mod_) {
            Some(nullable_candidate) => nullable_candidate
            None => return None
          }
        None => return None
      }
    (left_instr, right_instr) => {
      let left_candidate = match
        dae_direct_gc_actual_candidate_type(left_instr, mod_, func_type_indices) {
        Some(result) => result
        None => return None
      }
      let right_candidate = match
        dae_direct_gc_actual_candidate_type(
          right_instr, mod_, func_type_indices,
        ) {
        Some(result) => result
        None => return None
      }
      match
        dae_lub_gc_candidate_ref_type(
          mod_, left_candidate, right_candidate, old_type,
        ) {
        Some(result) => result
        None => return None
      }
    }
  }
  let refined_candidate = dae_refined_gc_candidate_ref_type(
    mod_, old_type, candidate,
  )
  if require_refined && refined_candidate.is_none() {
    return None
  }
  let left_rewrite = match (body[left_idx], rewrite_type) {
    (@lib.RefNull(_), Some(@lib.RefTypeValType(rt))) =>
      Some(@lib.Instruction::ref_null_type(rt))
    _ => None
  }
  let right_rewrite = match (body[right_idx], rewrite_type) {
    (@lib.RefNull(_), Some(@lib.RefTypeValType(rt))) =>
      Some(@lib.Instruction::ref_null_type(rt))
    _ => None
  }
  Some({
    slices,
    gc: { candidate, refined_candidate, left_rewrite, right_rewrite },
  })
}

///|
fn dae_gc_actual_shape_discovery_evidence(
  instrs : Array[@lib.Instruction],
  shape : DaeCallShape,
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
) -> DaeGcActualShapeDiscoveryEvidence? {
  if shape.start < 0 || shape.start >= shape.end || shape.end > instrs.length() {
    return None
  }
  let kind = match instrs[shape.end - 1] {
    @lib.Block(_, _) => DaeBlockGcActualShape
    @lib.Loop(_, _) => DaeLoopGcActualShape
    @lib.If(_, _, _) => DaeIfGcActualShape
    @lib.Select(_) => {
      if shape.start + 4 > shape.end {
        return None
      }
      let slices = match
        dae_find_select_value_slices(
          mod_,
          func_type_indices,
          instrs,
          shape.end - 1,
          required_left_start=shape.start,
        ) {
        Some(slices) => slices
        None => return None
      }
      DaeSelectGcActualShape(slices)
    }
    _ if shape.start + 1 == shape.end => DaeDirectGcActualShape
    _ => return None
  }
  Some({ start: shape.start, end: shape.end, kind })
}

///|
fn dae_gc_actual_type_evidence(
  instrs : Array[@lib.Instruction],
  shape : DaeGcActualShapeDiscoveryEvidence,
  mod_ : @lib.Module,
  old_type : @lib.ValType,
  func_type_indices : Array[@lib.TypeIdx],
  require_refined? : Bool = false,
  rewrite_type? : @lib.ValType? = None,
) -> DaeGcActualTypeEvidence? {
  if shape.start < 0 || shape.start >= shape.end || shape.end > instrs.length() {
    return None
  }
  let terminal_idx = shape.end - 1
  let candidate = match shape.kind {
    DaeDirectGcActualShape => {
      if shape.start + 1 != shape.end {
        return None
      }
      match instrs[terminal_idx] {
        @lib.Block(_, _)
        | @lib.Loop(_, _)
        | @lib.If(_, _, _)
        | @lib.Select(_) => return None
        instr =>
          dae_direct_gc_actual_candidate_type(instr, mod_, func_type_indices)
      }
    }
    DaeBlockGcActualShape =>
      match instrs[terminal_idx] {
        @lib.Block(block_type, _) =>
          dae_block_type_last_non_null_concrete_gc_result_candidate(
            block_type, mod_,
          )
        _ => return None
      }
    DaeLoopGcActualShape =>
      match instrs[terminal_idx] {
        @lib.Loop(block_type, _) =>
          dae_block_type_last_non_null_concrete_gc_result_candidate(
            block_type, mod_,
          )
        _ => return None
      }
    DaeIfGcActualShape =>
      match instrs[terminal_idx] {
        @lib.If(block_type, _, _) =>
          dae_block_type_last_non_null_concrete_gc_result_candidate(
            block_type, mod_,
          )
        _ => return None
      }
    DaeSelectGcActualShape(slices) => {
      if slices.left.start != shape.start || slices.select_idx != terminal_idx {
        return None
      }
      match
        dae_gc_select_actual_value_slices_evidence(
          mod_,
          func_type_indices,
          instrs,
          slices,
          old_type,
          require_refined~,
          rewrite_type~,
        ) {
        Some(evidence) =>
          return Some({
            candidate: evidence.gc.candidate,
            refined_candidate: evidence.gc.refined_candidate,
            select: Some(evidence),
            terminal_rewrite: rewrite_type.map(fn(refined) {
              @lib.Instruction::select(types=Some([refined]))
            }),
          })
        None => return None
      }
    }
  }
  match candidate {
    Some(candidate_type) => {
      let refined_candidate = dae_refined_gc_candidate_ref_type(
        mod_, old_type, candidate_type,
      )
      if require_refined && refined_candidate.is_none() {
        None
      } else {
        Some({
          candidate: candidate_type,
          refined_candidate,
          select: None,
          terminal_rewrite: None,
        })
      }
    }
    None => None
  }
}

///|
fn dae_gc_actual_value_slice_shape_evidence(
  instrs : Array[@lib.Instruction],
  slice : DaeValueSlice,
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
) -> DaeGcActualShapeDiscoveryEvidence? {
  dae_gc_actual_shape_discovery_evidence(
    instrs,
    dae_call_shape_from_value_slice(slice),
    mod_,
    func_type_indices,
  )
}

///|
fn dae_direct_gc_actual_candidate_type_for_value_slice(
  instrs : Array[@lib.Instruction],
  slice : DaeValueSlice,
  mod_ : @lib.Module,
  old_type : @lib.ValType,
  func_type_indices : Array[@lib.TypeIdx],
  caller_locals : @lib.FunctionLocals?,
) -> @lib.ValType? {
  if slice.start >= 0 &&
    slice.start + 1 == slice.end &&
    slice.end <= instrs.length() {
    match instrs[slice.start] {
      @lib.LocalGet(local_idx) =>
        return dae_gc_candidate_local_get_type(
          mod_, caller_locals, local_idx, old_type,
        )
      _ => ()
    }
  }
  let shape = match
    dae_gc_actual_value_slice_shape_evidence(
      instrs, slice, mod_, func_type_indices,
    ) {
    Some(evidence) => evidence
    None => return None
  }
  match
    dae_gc_actual_type_evidence(
      instrs, shape, mod_, old_type, func_type_indices,
    ) {
    Some(evidence) => {
      let _ = evidence.refined_candidate
      Some(evidence.candidate)
    }
    None => None
  }
}

///|
fn dae_collect_direct_struct_default_actuals_instr(
  instr : @lib.Instruction,
  callee_abs : Int,
  params : Array[@lib.ValType],
  local_use : DaeLocalUse,
  candidates : Array[@lib.ValType?],
  rejected : Array[Bool],
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  caller_locals : @lib.FunctionLocals?,
) -> (Int, Bool) {
  match instr {
    @lib.Block(_, @lib.Expr(_))
    | @lib.Loop(_, @lib.Expr(_))
    | @lib.TryTable(_, _, @lib.Expr(_))
    | @lib.If(_, _, _) => {
      let child_evidence = match
        dae_nested_control_children_evidence(instr, mod_) {
        Some(evidence) => evidence
        None => return (0, false)
      }
      let (primary_count, primary_ok) = dae_collect_direct_struct_default_actuals_instrs(
        child_evidence.primary_body,
        callee_abs,
        params,
        local_use,
        candidates,
        rejected,
        child_evidence.entry_stack_values,
        mod_,
        func_type_indices,
        caller_locals,
      )
      if !primary_ok {
        return (primary_count, false)
      }
      match child_evidence.secondary_body {
        Some(body) => {
          let (secondary_count, secondary_ok) = dae_collect_direct_struct_default_actuals_instrs(
            body,
            callee_abs,
            params,
            local_use,
            candidates,
            rejected,
            child_evidence.entry_stack_values,
            mod_,
            func_type_indices,
            caller_locals,
          )
          (primary_count + secondary_count, secondary_ok)
        }
        None => (primary_count, true)
      }
    }
    _ => (0, true)
  }
}

///|
fn dae_collect_direct_struct_default_actuals_instrs(
  instrs : Array[@lib.Instruction],
  callee_abs : Int,
  params : Array[@lib.ValType],
  local_use : DaeLocalUse,
  candidates : Array[@lib.ValType?],
  rejected : Array[Bool],
  entry_stack_values : Int,
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  caller_locals : @lib.FunctionLocals?,
) -> (Int, Bool) {
  let mut calls = 0
  let mut idx = 0
  while idx < instrs.length() {
    if dae_instr_is_unreachable_root(instrs[idx]) {
      break
    }
    match
      dae_target_callsite_evidence(
        instrs[idx],
        callee_abs,
        DaeTargetDirectCallOnly,
      ) {
      Some(_) => {
        let evidence = match
          dae_callsite_value_slice_evidence(
            instrs,
            idx,
            params.length(),
            entry_stack_values,
            mod_,
            func_type_indices,
          ) {
          Some(result) => result
          None => return (calls, false)
        }
        let mut p = 0
        while p < params.length() {
          if !local_use.writes[p] && !rejected[p] {
            match params[p] {
              @lib.RefTypeValType(@lib.HeapTypeRefType(_, _, @lib.HeapType(_))) =>
                match
                  dae_direct_gc_actual_candidate_type_for_value_slice(
                    instrs,
                    evidence.slices[p],
                    mod_,
                    params[p],
                    func_type_indices,
                    caller_locals,
                  ) {
                  Some(candidate) =>
                    match candidates[p] {
                      Some(prev) =>
                        match
                          dae_lub_gc_candidate_ref_type(
                            mod_,
                            prev,
                            candidate,
                            params[p],
                          ) {
                          Some(lub) => candidates[p] = Some(lub)
                          None => {
                            candidates[p] = None
                            rejected[p] = true
                          }
                        }
                      None => candidates[p] = Some(candidate)
                    }
                  None => {
                    candidates[p] = None
                    rejected[p] = true
                  }
                }
              _ => ()
            }
          }
          p += 1
        }
        calls += 1
      }
      None => {
        let (nested_calls, ok) = dae_collect_direct_struct_default_actuals_instr(
          instrs[idx],
          callee_abs,
          params,
          local_use,
          candidates,
          rejected,
          mod_,
          func_type_indices,
          caller_locals,
        )
        calls += nested_calls
        if !ok {
          return (calls, false)
        }
      }
    }
    idx += 1
  }
  (calls, true)
}

///|
fn dae_collect_direct_gc_batch_actuals_instr(
  instr : @lib.Instruction,
  plans : Array[DaeDirectGcParamBatchPlan?],
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  caller_locals : @lib.FunctionLocals?,
) -> Unit {
  match instr {
    @lib.Block(_, @lib.Expr(_))
    | @lib.Loop(_, @lib.Expr(_))
    | @lib.TryTable(_, _, @lib.Expr(_))
    | @lib.If(_, _, _) => {
      let child_evidence = match
        dae_nested_control_children_evidence(instr, mod_) {
        Some(evidence) => evidence
        None => return
      }
      dae_collect_direct_gc_batch_actuals_instrs(
        child_evidence.primary_body,
        plans,
        child_evidence.entry_stack_values,
        mod_,
        func_type_indices,
        caller_locals,
      )
      match child_evidence.secondary_body {
        Some(body) =>
          dae_collect_direct_gc_batch_actuals_instrs(
            body,
            plans,
            child_evidence.entry_stack_values,
            mod_,
            func_type_indices,
            caller_locals,
          )
        None => ()
      }
    }
    _ => ()
  }
}

///|
fn dae_collect_direct_gc_batch_actuals_instrs(
  instrs : Array[@lib.Instruction],
  plans : Array[DaeDirectGcParamBatchPlan?],
  entry_stack_values : Int,
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  caller_locals : @lib.FunctionLocals?,
) -> Unit {
  let mut idx = 0
  while idx < instrs.length() {
    if dae_instr_is_unreachable_root(instrs[idx]) {
      break
    }
    match instrs[idx] {
      @lib.Call(func_idx) => {
        let callee_abs = dae_func_idx_slot(func_idx)
        if callee_abs >= 0 && callee_abs < plans.length() {
          match plans[callee_abs] {
            Some(plan) if plan.collect_ok[0] => {
              let evidence = match
                dae_callsite_value_slice_evidence(
                  instrs,
                  idx,
                  plan.params.length(),
                  entry_stack_values,
                  mod_,
                  func_type_indices,
                ) {
                Some(evidence) => evidence
                None => {
                  plan.collect_ok[0] = false
                  idx += 1
                  continue
                }
              }
              let mut p = 0
              while p < plan.params.length() {
                if !plan.local_use.writes[p] && !plan.rejected[p] {
                  match plan.params[p] {
                    @lib.RefTypeValType(
                      @lib.HeapTypeRefType(_, _, @lib.HeapType(_))
                    ) =>
                      match
                        dae_direct_gc_actual_candidate_type_for_value_slice(
                          instrs,
                          evidence.slices[p],
                          mod_,
                          plan.params[p],
                          func_type_indices,
                          caller_locals,
                        ) {
                        Some(candidate) =>
                          match plan.candidates[p] {
                            Some(previous) =>
                              match
                                dae_lub_gc_candidate_ref_type(
                                  mod_,
                                  previous,
                                  candidate,
                                  plan.params[p],
                                ) {
                                Some(lub) => plan.candidates[p] = Some(lub)
                                None => {
                                  plan.candidates[p] = None
                                  plan.rejected[p] = true
                                }
                              }
                            None => plan.candidates[p] = Some(candidate)
                          }
                        None => {
                          plan.candidates[p] = None
                          plan.rejected[p] = true
                        }
                      }
                    _ => ()
                  }
                }
                p += 1
              }
              plan.calls_seen[0] += 1
            }
            _ => ()
          }
        }
      }
      _ =>
        dae_collect_direct_gc_batch_actuals_instr(
          instrs[idx],
          plans,
          mod_,
          func_type_indices,
          caller_locals,
        )
    }
    idx += 1
  }
}

///|
fn dae_exact_struct_default_ref_type(type_idx : @lib.TypeIdx) -> @lib.ValType {
  @lib.ValType::ref_type(
    @lib.RefType::new(false, @lib.HeapType::new(type_idx), exact=true),
  )
}

///|
fn dae_gc_candidate_local_get_type(
  mod_ : @lib.Module,
  func_locals : @lib.FunctionLocals?,
  idx : @lib.LocalIdx,
  old_type : @lib.ValType,
) -> @lib.ValType? {
  let candidate_type = match func_locals {
    Some(locals) =>
      match locals.local_type(idx) {
        Some(vt) => vt
        None => return None
      }
    None => return None
  }
  match (old_type, candidate_type) {
    (
      @lib.RefTypeValType(@lib.HeapTypeRefType(_, _, @lib.HeapType(old_idx))),
      @lib.RefTypeValType(
        @lib.HeapTypeRefType(_, _, @lib.HeapType(candidate_idx))
      ),
    ) =>
      if dae_type_idx_is_subtype_of(mod_, candidate_idx, old_idx) {
        Some(candidate_type)
      } else {
        None
      }
    _ => None
  }
}

///|
fn dae_single_result_control_pair_gc_evidence(
  mod_ : @lib.Module,
  then_body : Array[@lib.Instruction],
  then_candidate : @lib.ValType,
  then_rewrite : Array[@lib.Instruction]?,
  else_body : Array[@lib.Instruction],
  else_candidate : @lib.ValType,
  else_rewrite : Array[@lib.Instruction]?,
  old_type : @lib.ValType,
) -> DaeSingleResultControlPairGcEvidence? {
  match
    dae_lub_gc_candidate_ref_type(
      mod_, then_candidate, else_candidate, old_type,
    ) {
    Some(candidate) => {
      let rewritten_then_body = match then_rewrite {
        Some(body) => body
        None => then_body
      }
      let rewritten_else_body = match else_rewrite {
        Some(body) => body
        None => else_body
      }
      Some({ candidate, rewritten_then_body, rewritten_else_body })
    }
    None => None
  }
}

///|
fn dae_single_result_control_pair_application_is_consistent(
  application : DaeSingleResultControlPairApplicationEvidence,
  evidence : DaeSingleResultControlPairGcEvidence,
  result_is_void : Bool,
) -> Bool {
  application.result_is_void == result_is_void &&
  application.then_body_length == evidence.rewritten_then_body.length() &&
  application.else_body_length == evidence.rewritten_else_body.length()
}

///|
fn dae_apply_single_result_control_pair_gc_evidence(
  evidence : DaeSingleResultControlPairGcEvidence,
  result_is_void : Bool,
) -> (@lib.Instruction, DaeSingleResultControlPairApplicationEvidence)? {
  let block_type = if result_is_void {
    @lib.BlockType::void_()
  } else {
    @lib.BlockType::val_type(evidence.candidate)
  }
  let application = {
    result_is_void,
    then_body_length: evidence.rewritten_then_body.length(),
    else_body_length: evidence.rewritten_else_body.length(),
  }
  if dae_single_result_control_pair_application_is_consistent(
      application, evidence, result_is_void,
    ) {
    Some(
      (
        @lib.Instruction::if_(
          block_type,
          evidence.rewritten_then_body,
          Some(evidence.rewritten_else_body),
        ),
        application,
      ),
    )
  } else {
    None
  }
}

///|
fn dae_single_result_control_pair_repair_evidence_is_consistent(
  repair : DaeSingleResultControlPairRepairEvidence,
  result_is_void : Bool,
) -> Bool {
  dae_single_result_control_pair_application_is_consistent(
    repair.application,
    repair.pair,
    result_is_void,
  )
}

///|
fn dae_single_result_control_pair_repair_evidence(
  mod_ : @lib.Module,
  then_body : Array[@lib.Instruction],
  else_body : Array[@lib.Instruction],
  old_type : @lib.ValType,
  result_is_void : Bool,
  arm_candidate : (Array[@lib.Instruction]) -> (
    @lib.ValType,
    Array[@lib.Instruction]?,
  )?,
) -> DaeSingleResultControlPairRepairEvidence? {
  let (then_candidate, then_rewrite) = match arm_candidate(then_body) {
    Some(result) => result
    None => return None
  }
  let (else_candidate, else_rewrite) = match arm_candidate(else_body) {
    Some(result) => result
    None => return None
  }
  let pair = match
    dae_single_result_control_pair_gc_evidence(
      mod_, then_body, then_candidate, then_rewrite, else_body, else_candidate, else_rewrite,
      old_type,
    ) {
    Some(evidence) => evidence
    None => return None
  }
  let (rewritten, application) = match
    dae_apply_single_result_control_pair_gc_evidence(pair, result_is_void) {
    Some(result) => result
    None => return None
  }
  let repair = { pair, application, rewritten }
  if dae_single_result_control_pair_repair_evidence_is_consistent(
      repair, result_is_void,
    ) {
    Some(repair)
  } else {
    None
  }
}

///|
fn dae_single_body_control_shape_evidence(
  instr : @lib.Instruction,
) -> DaeSingleBodyControlShapeEvidence? {
  match instr {
    @lib.Block(block_type, @lib.Expr(body)) =>
      Some({ control_kind: 0, block_type, body })
    @lib.Loop(block_type, @lib.Expr(body)) =>
      Some({ control_kind: 1, block_type, body })
    _ => None
  }
}

///|
fn dae_single_body_control_rewrite_evidence(
  shape : DaeSingleBodyControlShapeEvidence,
  replacement_block_type : @lib.BlockType,
  rewritten_body_opt : Array[@lib.Instruction]?,
) -> DaeSingleBodyControlRewriteEvidence {
  let (rewritten_body, body_changed) = match rewritten_body_opt {
    Some(rewritten_body) => (rewritten_body, true)
    None => (shape.body, false)
  }
  { shape, replacement_block_type, rewritten_body, body_changed }
}

///|
fn dae_apply_single_body_control_rewrite_evidence(
  evidence : DaeSingleBodyControlRewriteEvidence,
) -> @lib.Instruction? {
  let body = if evidence.body_changed {
    evidence.rewritten_body
  } else {
    evidence.shape.body
  }
  let expr = @lib.Expr::new(body)
  match evidence.shape.control_kind {
    0 => Some(@lib.Instruction::block(evidence.replacement_block_type, expr))
    1 => Some(@lib.Instruction::loop_(evidence.replacement_block_type, expr))
    _ => None
  }
}

///|
fn dae_single_body_control_rewrite_changes_instruction(
  evidence : DaeSingleBodyControlRewriteEvidence,
) -> Bool {
  evidence.body_changed ||
  evidence.shape.block_type != evidence.replacement_block_type
}

///|
fn dae_direct_gc_result_explicit_return_candidate_instr(
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  func_locals : @lib.FunctionLocals?,
  instr : @lib.Instruction,
  old_type : @lib.ValType,
) -> (@lib.ValType, @lib.Instruction?)? {
  match instr {
    @lib.Block(_, _) | @lib.Loop(_, _) => {
      let shape = match dae_single_body_control_shape_evidence(instr) {
        Some(shape) => shape
        None => return None
      }
      match
        dae_control_block_type_zero_input_evidence(
          shape.block_type,
          mod_.type_sec,
        ) {
        Some(_) => ()
        None => return None
      }
      match
        dae_direct_gc_result_explicit_return_candidate_body(
          mod_,
          func_type_indices,
          func_locals,
          shape.body,
          old_type,
        ) {
        Some((candidate_type, rewritten_body_opt)) => {
          let rewrite = dae_single_body_control_rewrite_evidence(
            shape,
            @lib.BlockType::void_(),
            rewritten_body_opt,
          )
          let rewritten = if dae_single_body_control_rewrite_changes_instruction(
              rewrite,
            ) {
            dae_apply_single_body_control_rewrite_evidence(rewrite)
          } else {
            None
          }
          Some((candidate_type, rewritten))
        }
        None => None
      }
    }
    @lib.If(block_type, then_body, Some(else_body)) =>
      match
        dae_control_block_type_zero_input_evidence(block_type, mod_.type_sec) {
        Some(_) =>
          match
            dae_single_result_control_pair_repair_evidence(
              mod_,
              then_body,
              else_body,
              old_type,
              true,
              fn(body) {
                dae_direct_gc_result_explicit_return_candidate_body(
                  mod_, func_type_indices, func_locals, body, old_type,
                )
              },
            ) {
            Some(repair) =>
              Some((repair.pair.candidate, Some(repair.rewritten)))
            None => None
          }
        None => None
      }
    _ => None
  }
}

///|
fn dae_direct_gc_result_explicit_return_candidate_body(
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  func_locals : @lib.FunctionLocals?,
  body : Array[@lib.Instruction],
  old_type : @lib.ValType,
) -> (@lib.ValType, Array[@lib.Instruction]?)? {
  if body.length() == 0 {
    return None
  }
  match body[body.length() - 1] {
    @lib.Return => {
      if body.length() < 2 {
        return None
      }
      let value_idx = body.length() - 2
      match
        dae_direct_gc_result_candidate_instr(
          mod_,
          func_type_indices,
          func_locals,
          body[value_idx],
          old_type,
        ) {
        Some((candidate_type, Some(rewritten_value))) => {
          let rewritten = body.copy()
          rewritten[value_idx] = rewritten_value
          Some((candidate_type, Some(rewritten)))
        }
        Some((candidate_type, None)) => Some((candidate_type, None))
        None => None
      }
    }
    _ =>
      dae_direct_gc_result_explicit_return_candidate_instr(
        mod_,
        func_type_indices,
        func_locals,
        body[body.length() - 1],
        old_type,
      ).map(fn(result) {
        let (candidate_type, rewritten_instr) = result
        match rewritten_instr {
          Some(instr) => {
            let rewritten = body.copy()
            rewritten[rewritten.length() - 1] = instr
            (candidate_type, Some(rewritten))
          }
          None => (candidate_type, None)
        }
      })
  }
}

///|
fn dae_single_result_control_gc_candidate_evidence(
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  func_locals : @lib.FunctionLocals?,
  instr : @lib.Instruction,
  old_type : @lib.ValType,
) -> DaeSingleResultControlGcCandidateEvidence? {
  let shape = match dae_single_body_control_shape_evidence(instr) {
    Some(shape) => shape
    None => return None
  }
  match dae_control_single_result_block_type_evidence(shape.block_type, mod_) {
    Some(_) => ()
    None => return None
  }
  match
    dae_direct_gc_result_candidate_body(
      mod_,
      func_type_indices,
      func_locals,
      shape.body,
      old_type,
    ) {
    Some((candidate, rewritten_body_opt)) => {
      let rewrite = dae_single_body_control_rewrite_evidence(
        shape,
        @lib.BlockType::val_type(candidate),
        rewritten_body_opt,
      )
      Some({ candidate, rewrite })
    }
    None => None
  }
}

///|
fn dae_single_result_control_gc_candidate_instr_evidence(
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  func_locals : @lib.FunctionLocals?,
  instr : @lib.Instruction,
  old_type : @lib.ValType,
) -> (@lib.ValType, @lib.Instruction?)? {
  let evidence = match
    dae_single_result_control_gc_candidate_evidence(
      mod_, func_type_indices, func_locals, instr, old_type,
    ) {
    Some(evidence) => evidence
    None => return None
  }
  match dae_apply_single_body_control_rewrite_evidence(evidence.rewrite) {
    Some(rewritten) => Some((evidence.candidate, Some(rewritten)))
    None => None
  }
}

///|
fn dae_direct_gc_result_candidate_instr(
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  func_locals : @lib.FunctionLocals?,
  instr : @lib.Instruction,
  old_type : @lib.ValType,
) -> (@lib.ValType, @lib.Instruction?)? {
  match instr {
    @lib.StructNew(type_idx) | @lib.StructNewDefault(type_idx) =>
      Some((dae_exact_struct_default_ref_type(type_idx), None))
    @lib.LocalGet(idx) =>
      dae_gc_candidate_local_get_type(mod_, func_locals, idx, old_type).map(fn(
        candidate_type,
      ) {
        (candidate_type, None)
      })
    @lib.Call(func_idx) =>
      match
        dae_direct_call_gc_result_refinement_evidence(
          mod_, func_type_indices, func_idx, old_type,
        ) {
        Some(evidence) =>
          match evidence.refined_candidate {
            Some(refined_type) => Some((refined_type, None))
            None => None
          }
        None => None
      }
    @lib.Block(_, _) | @lib.Loop(_, _) =>
      dae_single_result_control_gc_candidate_instr_evidence(
        mod_, func_type_indices, func_locals, instr, old_type,
      )
    @lib.If(block_type, then_body, Some(else_body)) =>
      match dae_control_single_result_block_type_evidence(block_type, mod_) {
        Some(_) =>
          match
            dae_single_result_control_pair_repair_evidence(
              mod_,
              then_body,
              else_body,
              old_type,
              false,
              fn(body) {
                dae_direct_gc_result_candidate_body(
                  mod_, func_type_indices, func_locals, body, old_type,
                )
              },
            ) {
            Some(repair) =>
              Some((repair.pair.candidate, Some(repair.rewritten)))
            None => None
          }
        _ => None
      }
    _ => None
  }
}

///|
fn dae_gc_result_slot_evidence(
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  func_locals : @lib.FunctionLocals?,
  instr : @lib.Instruction,
  old_type : @lib.ValType,
  require_refined? : Bool = false,
) -> DaeGcTypeEvidence? {
  let (candidate, rewrite) = match
    dae_direct_gc_result_candidate_instr(
      mod_, func_type_indices, func_locals, instr, old_type,
    ) {
    Some(result) => result
    None => return None
  }
  let refined_candidate = dae_refined_gc_candidate_ref_type(
    mod_, old_type, candidate,
  )
  if require_refined && refined_candidate.is_none() {
    return None
  }
  Some({ candidate, refined_candidate, rewrite })
}

///|
fn dae_indexed_instruction_rewrite_application_is_consistent(
  application : DaeIndexedInstructionRewriteApplicationEvidence,
  body : Array[@lib.Instruction],
  indices : Array[Int],
  rewrites : Array[@lib.Instruction?],
) -> Bool {
  if application.target_count != indices.length() ||
    indices.length() != rewrites.length() ||
    application.body_changed != (application.rewrite_count > 0) {
    return false
  }
  let mut expected_rewrites = 0
  let mut idx = 0
  while idx < indices.length() {
    let target = indices[idx]
    if target < 0 || target >= body.length() {
      return false
    }
    let mut previous = 0
    while previous < idx {
      if indices[previous] == target {
        return false
      }
      previous += 1
    }
    match rewrites[idx] {
      Some(_) => expected_rewrites += 1
      None => ()
    }
    idx += 1
  }
  application.rewrite_count == expected_rewrites
}

///|
fn dae_apply_indexed_instruction_rewrites_to_body(
  body : Array[@lib.Instruction],
  indices : Array[Int],
  rewrites : Array[@lib.Instruction?],
) -> (Array[@lib.Instruction], DaeIndexedInstructionRewriteApplicationEvidence)? {
  if indices.length() != rewrites.length() {
    return None
  }
  let rewritten = body.copy()
  let mut rewrite_count = 0
  let mut idx = 0
  while idx < indices.length() {
    let target = indices[idx]
    if target < 0 || target >= body.length() {
      return None
    }
    let mut previous = 0
    while previous < idx {
      if indices[previous] == target {
        return None
      }
      previous += 1
    }
    match rewrites[idx] {
      Some(instr) => {
        rewritten[target] = instr
        rewrite_count += 1
      }
      None => ()
    }
    idx += 1
  }
  let application = {
    target_count: indices.length(),
    rewrite_count,
    body_changed: rewrite_count > 0,
  }
  if dae_indexed_instruction_rewrite_application_is_consistent(
      application, body, indices, rewrites,
    ) {
    Some((if application.body_changed { rewritten } else { body }, application))
  } else {
    None
  }
}

///|
fn dae_apply_first_instruction_rewrite_to_body(
  body : Array[@lib.Instruction],
  rewrite_instr : (@lib.Instruction) -> @lib.Instruction?,
) -> (Array[@lib.Instruction], DaeIndexedInstructionRewriteApplicationEvidence)? {
  let mut idx = 0
  while idx < body.length() {
    match rewrite_instr(body[idx]) {
      Some(rewritten_instr) =>
        return dae_apply_indexed_instruction_rewrites_to_body(body, [idx], [
          Some(rewritten_instr),
        ])
      None => ()
    }
    idx += 1
  }
  None
}

///|
fn dae_try_rewrite_first_control_child_body(
  instr : @lib.Instruction,
  rewrite_body : (Array[@lib.Instruction]) -> Array[@lib.Instruction]?,
) -> @lib.Instruction? {
  match instr {
    @lib.Block(block_type, @lib.Expr(body)) =>
      match rewrite_body(body) {
        Some(rewritten_body) =>
          Some(
            @lib.Instruction::block(block_type, @lib.Expr::new(rewritten_body)),
          )
        None => None
      }
    @lib.Loop(block_type, @lib.Expr(body)) =>
      match rewrite_body(body) {
        Some(rewritten_body) =>
          Some(
            @lib.Instruction::loop_(block_type, @lib.Expr::new(rewritten_body)),
          )
        None => None
      }
    @lib.If(block_type, then_body, Some(else_body)) =>
      match rewrite_body(then_body) {
        Some(rewritten_then) =>
          Some(
            @lib.Instruction::if_(block_type, rewritten_then, Some(else_body)),
          )
        None =>
          match rewrite_body(else_body) {
            Some(rewritten_else) =>
              Some(
                @lib.Instruction::if_(
                  block_type,
                  then_body,
                  Some(rewritten_else),
                ),
              )
            None => None
          }
      }
    @lib.If(block_type, then_body, None) =>
      match rewrite_body(then_body) {
        Some(rewritten_then) =>
          Some(@lib.Instruction::if_(block_type, rewritten_then, None))
        None => None
      }
    @lib.TryTable(block_type, catches, @lib.Expr(body)) =>
      match rewrite_body(body) {
        Some(rewritten_body) =>
          Some(
            @lib.Instruction::try_table(
              block_type,
              catches,
              @lib.Expr::new(rewritten_body),
            ),
          )
        None => None
      }
    _ => None
  }
}

///|
fn dae_recursive_body_rewrite_application_is_consistent(
  application : DaeRecursiveBodyRewriteApplicationEvidence,
  body : Array[@lib.Instruction],
  rewritten : Array[@lib.Instruction],
) -> Bool {
  if application.body_changed != (rewritten != body) {
    return false
  }
  if application.applied_to_current_body {
    application.target_count == 0 &&
    application.rewrite_count == (if application.body_changed { 1 } else { 0 })
  } else {
    application.target_count == 1 &&
    application.rewrite_count == 1 &&
    application.body_changed
  }
}

///|
fn dae_apply_first_recursive_instruction_body_rewrite(
  body : Array[@lib.Instruction],
  rewrite_instr : (@lib.Instruction) -> @lib.Instruction?,
) -> (Array[@lib.Instruction], DaeRecursiveBodyRewriteApplicationEvidence)? {
  match dae_apply_first_instruction_rewrite_to_body(body, rewrite_instr) {
    Some((rewritten, indexed)) => {
      let application = {
        applied_to_current_body: false,
        target_count: indexed.target_count,
        rewrite_count: indexed.rewrite_count,
        body_changed: indexed.body_changed,
      }
      if dae_recursive_body_rewrite_application_is_consistent(
          application, body, rewritten,
        ) {
        Some((rewritten, application))
      } else {
        None
      }
    }
    None => None
  }
}

///|
fn dae_apply_first_recursive_instruction_body_rewrite_to_body(
  body : Array[@lib.Instruction],
  rewrite_instr : (@lib.Instruction) -> @lib.Instruction?,
) -> Array[@lib.Instruction]? {
  match
    dae_apply_first_recursive_instruction_body_rewrite(body, rewrite_instr) {
    Some((rewritten, _)) => Some(rewritten)
    None => None
  }
}

///|
fn dae_apply_first_recursive_control_child_body_rewrite(
  body : Array[@lib.Instruction],
  rewrite_child_body : (Array[@lib.Instruction]) -> Array[@lib.Instruction]?,
) -> (Array[@lib.Instruction], DaeRecursiveBodyRewriteApplicationEvidence)? {
  let rewrite_instr = fn(instr : @lib.Instruction) -> @lib.Instruction? {
    dae_try_rewrite_first_control_child_body(instr, rewrite_child_body)
  }
  dae_apply_first_recursive_instruction_body_rewrite(body, rewrite_instr)
}

///|
fn dae_apply_first_recursive_body_rewrite(
  body : Array[@lib.Instruction],
  rewrite_current_body : (Array[@lib.Instruction]) -> Array[@lib.Instruction]?,
  rewrite_child_body : (Array[@lib.Instruction]) -> Array[@lib.Instruction]?,
) -> (Array[@lib.Instruction], DaeRecursiveBodyRewriteApplicationEvidence)? {
  match rewrite_current_body(body) {
    Some(rewritten) => {
      let body_changed = rewritten != body
      let application = {
        applied_to_current_body: true,
        target_count: 0,
        rewrite_count: if body_changed {
          1
        } else {
          0
        },
        body_changed,
      }
      if dae_recursive_body_rewrite_application_is_consistent(
          application, body, rewritten,
        ) {
        return Some((rewritten, application))
      }
      return None
    }
    None => ()
  }
  dae_apply_first_recursive_control_child_body_rewrite(body, rewrite_child_body)
}

///|
fn dae_apply_first_current_or_control_child_body_rewrite(
  body : Array[@lib.Instruction],
  rewrite_current_body : (Array[@lib.Instruction]) -> Array[@lib.Instruction]?,
  rewrite_child_body : (Array[@lib.Instruction]) -> Array[@lib.Instruction]?,
) -> Array[@lib.Instruction]? {
  match
    dae_apply_first_recursive_body_rewrite(
      body, rewrite_current_body, rewrite_child_body,
    ) {
    Some((rewritten, _)) => Some(rewritten)
    None => None
  }
}

///|
fn dae_body_rewrite_fixpoint_evidence_is_consistent(
  evidence : DaeBodyRewriteFixpointEvidence,
  body : Array[@lib.Instruction],
  rewritten : Array[@lib.Instruction],
) -> Bool {
  evidence.max_iters > 0 &&
  evidence.iteration_count > 0 &&
  evidence.iteration_count <= evidence.max_iters &&
  evidence.reached_limit == (evidence.iteration_count == evidence.max_iters) &&
  evidence.body_changed == (rewritten != body)
}

///|
fn dae_apply_body_rewrite_until_stable(
  body : Array[@lib.Instruction],
  rewrite_once : (Array[@lib.Instruction]) -> Array[@lib.Instruction]?,
  max_iters : Int,
) -> (Array[@lib.Instruction], DaeBodyRewriteFixpointEvidence)? {
  if max_iters <= 0 {
    return None
  }
  let mut current = body
  let mut iteration_count = 0
  while iteration_count < max_iters {
    match rewrite_once(current) {
      Some(next) => {
        if next == current {
          break
        }
        current = next
        iteration_count += 1
        continue
      }
      None => break
    }
  }
  if iteration_count == 0 {
    return None
  }
  let evidence = {
    max_iters,
    iteration_count,
    reached_limit: iteration_count == max_iters,
    body_changed: current != body,
  }
  if dae_body_rewrite_fixpoint_evidence_is_consistent(evidence, body, current) {
    Some((current, evidence))
  } else {
    None
  }
}

///|
fn dae_apply_body_rewrite_until_stable_or_original(
  body : Array[@lib.Instruction],
  rewrite_once : (Array[@lib.Instruction]) -> Array[@lib.Instruction]?,
  max_iters : Int,
) -> Array[@lib.Instruction] {
  match dae_apply_body_rewrite_until_stable(body, rewrite_once, max_iters) {
    Some((rewritten, _)) => rewritten
    None => body
  }
}

///|
fn dae_result_rewrite_application_is_consistent(
  application : DaeResultRewriteApplicationEvidence,
  body : Array[@lib.Instruction],
  start : Int,
  rewrites : Array[@lib.Instruction?],
  active? : Array[Bool]? = None,
) -> Bool {
  if application.start != start ||
    application.result_count != rewrites.length() ||
    application.body_changed != (application.rewrite_count > 0) ||
    start < 0 ||
    start + rewrites.length() > body.length() {
    return false
  }
  match active {
    Some(mask) => mask.length() == rewrites.length()
    None => true
  }
}

///|
fn dae_apply_result_rewrites_to_body(
  body : Array[@lib.Instruction],
  start : Int,
  rewrites : Array[@lib.Instruction?],
  active? : Array[Bool]? = None,
) -> (Array[@lib.Instruction], DaeResultRewriteApplicationEvidence)? {
  if start < 0 || start + rewrites.length() > body.length() {
    return None
  }
  match active {
    Some(mask) => if mask.length() != rewrites.length() { return None }
    None => ()
  }
  let indices = []
  let effective_rewrites : Array[@lib.Instruction?] = []
  let mut result_idx = 0
  while result_idx < rewrites.length() {
    indices.push(start + result_idx)
    let slot_active = match active {
      Some(mask) => mask[result_idx]
      None => true
    }
    effective_rewrites.push(
      if slot_active {
        rewrites[result_idx]
      } else {
        None
      },
    )
    result_idx += 1
  }
  let (rewritten, shared_application) = match
    dae_apply_indexed_instruction_rewrites_to_body(
      body, indices, effective_rewrites,
    ) {
    Some(result) => result
    None => return None
  }
  let application = {
    start,
    result_count: rewrites.length(),
    rewrite_count: shared_application.rewrite_count,
    body_changed: shared_application.body_changed,
  }
  if dae_result_rewrite_application_is_consistent(
      application,
      body,
      start,
      rewrites,
      active~,
    ) {
    Some((if application.body_changed { rewritten } else { body }, application))
  } else {
    None
  }
}

///|
fn dae_select_value_rewrite_application_is_consistent(
  application : DaeSelectValueRewriteApplicationEvidence,
  body : Array[@lib.Instruction],
  left_idx : Int,
  right_idx : Int,
  select_idx : Int,
  left_rewrite : @lib.Instruction?,
  right_rewrite : @lib.Instruction?,
  select_rewrite : @lib.Instruction?,
) -> Bool {
  if application.left_idx != left_idx ||
    application.right_idx != right_idx ||
    application.select_idx != select_idx ||
    application.body_changed != (application.rewrite_count > 0) ||
    left_idx < 0 ||
    left_idx >= right_idx ||
    right_idx >= select_idx ||
    select_idx >= body.length() {
    return false
  }
  match body[select_idx] {
    @lib.Select(_) => ()
    _ => return false
  }
  let expected_rewrites = (if left_rewrite is Some(_) { 1 } else { 0 }) +
    (if right_rewrite is Some(_) { 1 } else { 0 }) +
    (if select_rewrite is Some(_) { 1 } else { 0 })
  application.rewrite_count == expected_rewrites
}

///|
fn dae_apply_select_value_rewrites_to_body(
  body : Array[@lib.Instruction],
  left_idx : Int,
  right_idx : Int,
  select_idx : Int,
  left_rewrite : @lib.Instruction?,
  right_rewrite : @lib.Instruction?,
  select_rewrite : @lib.Instruction?,
) -> (Array[@lib.Instruction], DaeSelectValueRewriteApplicationEvidence)? {
  if left_idx < 0 ||
    left_idx >= right_idx ||
    right_idx >= select_idx ||
    select_idx >= body.length() {
    return None
  }
  match body[select_idx] {
    @lib.Select(_) => ()
    _ => return None
  }
  let rewrites : Array[@lib.Instruction?] = [
    left_rewrite, right_rewrite, select_rewrite,
  ]
  let (rewritten, shared_application) = match
    dae_apply_indexed_instruction_rewrites_to_body(
      body,
      [left_idx, right_idx, select_idx],
      rewrites,
    ) {
    Some(result) => result
    None => return None
  }
  let application = {
    left_idx,
    right_idx,
    select_idx,
    rewrite_count: shared_application.rewrite_count,
    body_changed: shared_application.body_changed,
  }
  if dae_select_value_rewrite_application_is_consistent(
      application, body, left_idx, right_idx, select_idx, left_rewrite, right_rewrite,
      select_rewrite,
    ) {
    Some((if application.body_changed { rewritten } else { body }, application))
  } else {
    None
  }
}

///|
fn dae_control_result_slice_gc_evidence(
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  func_locals : @lib.FunctionLocals?,
  result_slice : DaeControlResultSlice,
  results : Array[@lib.ValType],
  require_refined? : Bool = false,
) -> DaeControlResultGcEvidence? {
  if results.length() != result_slice.result_count ||
    !dae_control_result_slice_is_consistent(result_slice) {
    return None
  }
  let candidates : Array[@lib.ValType?] = Array::make(results.length(), None)
  let refined_candidates : Array[@lib.ValType?] = Array::make(
    results.length(),
    None,
  )
  let rewrites : Array[@lib.Instruction?] = Array::make(results.length(), None)
  let mut saw_candidate = false
  let mut result_idx = 0
  while result_idx < results.length() {
    let instr_idx = result_slice.slice.start + result_idx
    match
      dae_gc_result_slot_evidence(
        mod_,
        func_type_indices,
        func_locals,
        result_slice.body[instr_idx],
        results[result_idx],
        require_refined~,
      ) {
      Some(evidence) => {
        candidates[result_idx] = Some(evidence.candidate)
        refined_candidates[result_idx] = evidence.refined_candidate
        saw_candidate = true
        rewrites[result_idx] = evidence.rewrite
      }
      None => ()
    }
    result_idx += 1
  }
  if saw_candidate {
    match
      dae_apply_result_rewrites_to_body(
        result_slice.body,
        result_slice.slice.start,
        rewrites,
      ) {
      Some((rewritten_body, application)) =>
        Some({
          candidates,
          refined_candidates,
          rewrites,
          body: result_slice.body,
          result_start: result_slice.slice.start,
          rewritten_body,
          body_changed: application.body_changed,
          saw_candidate,
        })
      None => None
    }
  } else {
    None
  }
}

///|
fn dae_control_result_pair_gc_evidence(
  mod_ : @lib.Module,
  then_evidence : DaeControlResultGcEvidence,
  else_evidence : DaeControlResultGcEvidence,
  results : Array[@lib.ValType],
) -> DaeControlResultPairGcEvidence? {
  if then_evidence.candidates.length() != results.length() ||
    else_evidence.candidates.length() != results.length() ||
    then_evidence.rewrites.length() != results.length() ||
    else_evidence.rewrites.length() != results.length() ||
    then_evidence.result_start < 0 ||
    else_evidence.result_start < 0 ||
    then_evidence.result_start + results.length() > then_evidence.body.length() ||
    else_evidence.result_start + results.length() > else_evidence.body.length() {
    return None
  }
  let refined_results = results.copy()
  let refined_mask = Array::make(results.length(), false)
  let mut saw_refinement = false
  let mut result_idx = 0
  while result_idx < results.length() {
    match
      (
        then_evidence.candidates[result_idx],
        else_evidence.candidates[result_idx],
      ) {
      (Some(then_candidate), Some(else_candidate)) =>
        match
          dae_lub_gc_candidate_ref_type(
            mod_,
            then_candidate,
            else_candidate,
            results[result_idx],
          ) {
          Some(lub) =>
            match
              dae_refined_gc_candidate_ref_type(mod_, results[result_idx], lub) {
              Some(refined) => {
                refined_results[result_idx] = refined
                refined_mask[result_idx] = true
                saw_refinement = true
              }
              None => ()
            }
          None => ()
        }
      _ => ()
    }
    result_idx += 1
  }
  if saw_refinement {
    let (rewritten_then_body, then_application) = match
      dae_apply_result_rewrites_to_body(
        then_evidence.body,
        then_evidence.result_start,
        then_evidence.rewrites,
        active=Some(refined_mask),
      ) {
      Some(result) => result
      None => return None
    }
    let (rewritten_else_body, else_application) = match
      dae_apply_result_rewrites_to_body(
        else_evidence.body,
        else_evidence.result_start,
        else_evidence.rewrites,
        active=Some(refined_mask),
      ) {
      Some(result) => result
      None => return None
    }
    Some({
      refined_results,
      rewritten_then_body,
      rewritten_else_body,
      then_body_changed: then_application.body_changed,
      else_body_changed: else_application.body_changed,
      saw_refinement,
    })
  } else {
    None
  }
}

///|
fn dae_optional_refined_result_slots_application_is_consistent(
  application : DaeOptionalRefinedResultSlotsApplicationEvidence,
  refined_slots : Array[@lib.ValType?],
  next_results : Array[@lib.ValType],
  refined_results_length : Int,
) -> Bool {
  if application.result_count != refined_slots.length() ||
    application.next_results_length != next_results.length() ||
    application.refined_results_length != refined_results_length ||
    application.result_count == 0 ||
    application.next_results_length != application.result_count ||
    application.applied_count <= 0 {
    return false
  }
  let mut expected_applied = 0
  for slot in refined_slots {
    if slot is Some(_) {
      expected_applied += 1
    }
  }
  application.applied_count == expected_applied
}

///|
fn dae_apply_optional_refined_result_slots(
  refined_slots : Array[@lib.ValType?],
  next_results : Array[@lib.ValType],
  refined_results? : Array[@lib.ValType]? = None,
) -> DaeOptionalRefinedResultSlotsApplicationEvidence? {
  let result_count = refined_slots.length()
  if result_count == 0 || next_results.length() != result_count {
    return None
  }
  let refined_results_length = match refined_results {
    Some(refined) => {
      if refined.length() != result_count {
        return None
      }
      refined.length()
    }
    None => 0
  }
  let mut applied_count = 0
  for slot in refined_slots {
    if slot is Some(_) {
      applied_count += 1
    }
  }
  if applied_count == 0 {
    return None
  }
  let mut result_idx = 0
  while result_idx < result_count {
    match refined_slots[result_idx] {
      Some(refined) => {
        next_results[result_idx] = refined
        match refined_results {
          Some(refined_results) => refined_results[result_idx] = refined
          None => ()
        }
      }
      None => ()
    }
    result_idx += 1
  }
  let application = {
    result_count,
    applied_count,
    next_results_length: next_results.length(),
    refined_results_length,
  }
  if dae_optional_refined_result_slots_application_is_consistent(
      application, refined_slots, next_results, refined_results_length,
    ) {
    Some(application)
  } else {
    None
  }
}

///|
fn dae_control_result_pair_refinement_application_is_consistent(
  application : DaeControlResultPairRefinementApplicationEvidence,
  pair : DaeControlResultPairGcEvidence,
  next_results : Array[@lib.ValType],
  refined_results_length : Int,
) -> Bool {
  application.result_count == pair.refined_results.length() &&
  application.next_results_length == next_results.length() &&
  application.refined_results_length == refined_results_length &&
  application.saw_refinement == pair.saw_refinement
}

///|
fn dae_apply_control_result_pair_refinements(
  pair : DaeControlResultPairGcEvidence,
  next_results : Array[@lib.ValType],
  refined_results? : Array[@lib.ValType]? = None,
) -> DaeControlResultPairRefinementApplicationEvidence? {
  let result_count = pair.refined_results.length()
  if result_count == 0 || next_results.length() != result_count {
    return None
  }
  let refined_results_length = match refined_results {
    Some(refined) => {
      if refined.length() != result_count {
        return None
      }
      refined.length()
    }
    None => 0
  }
  let refined_slots : Array[@lib.ValType?] = []
  for refined in pair.refined_results {
    refined_slots.push(Some(refined))
  }
  let shared_application = match
    dae_apply_optional_refined_result_slots(
      refined_slots,
      next_results,
      refined_results~,
    ) {
    Some(application) => application
    None => return None
  }
  let application = {
    result_count: shared_application.result_count,
    next_results_length: shared_application.next_results_length,
    refined_results_length: shared_application.refined_results_length,
    saw_refinement: pair.saw_refinement,
  }
  if dae_control_result_pair_refinement_application_is_consistent(
      application, pair, next_results, refined_results_length,
    ) {
    Some(application)
  } else {
    None
  }
}

///|
fn dae_control_result_single_refinement_application_is_consistent(
  application : DaeControlResultSingleRefinementApplicationEvidence,
  evidence : DaeControlResultGcEvidence,
  next_results : Array[@lib.ValType],
  refined_results_length : Int,
) -> Bool {
  application.result_count == evidence.refined_candidates.length() &&
  application.next_results_length == next_results.length() &&
  application.refined_results_length == refined_results_length &&
  application.body_changed == evidence.body_changed &&
  application.saw_refinement
}

///|
fn dae_apply_control_result_single_refinements(
  evidence : DaeControlResultGcEvidence,
  next_results : Array[@lib.ValType],
  refined_results? : Array[@lib.ValType]? = None,
) -> DaeControlResultSingleRefinementApplicationEvidence? {
  let result_count = evidence.refined_candidates.length()
  if result_count == 0 || next_results.length() != result_count {
    return None
  }
  if evidence.candidates.length() != result_count ||
    evidence.rewrites.length() != result_count {
    return None
  }
  let refined_results_length = match refined_results {
    Some(refined) => {
      if refined.length() != result_count {
        return None
      }
      refined.length()
    }
    None => 0
  }
  let shared_application = match
    dae_apply_optional_refined_result_slots(
      evidence.refined_candidates,
      next_results,
      refined_results~,
    ) {
    Some(application) => application
    None => return None
  }
  let application = {
    result_count: shared_application.result_count,
    next_results_length: shared_application.next_results_length,
    refined_results_length: shared_application.refined_results_length,
    body_changed: evidence.body_changed,
    saw_refinement: shared_application.applied_count > 0,
  }
  if dae_control_result_single_refinement_application_is_consistent(
      application, evidence, next_results, refined_results_length,
    ) {
    Some(application)
  } else {
    None
  }
}

///|
fn dae_multi_result_if_pair_gc_refinement_evidence(
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  func_locals : @lib.FunctionLocals?,
  then_body : Array[@lib.Instruction],
  else_body : Array[@lib.Instruction],
  results : Array[@lib.ValType],
  require_terminal_return? : Bool = false,
) -> DaeMultiResultIfPairGcRefinementEvidence? {
  if results.length() == 0 {
    return None
  }
  let then_slice = match
    dae_find_multi_result_control_slice(
      mod_,
      then_body,
      results.length(),
      require_terminal_return~,
    ) {
    Some(slice) => slice
    None => return None
  }
  let else_slice = match
    dae_find_multi_result_control_slice(
      mod_,
      else_body,
      results.length(),
      require_terminal_return~,
    ) {
    Some(slice) => slice
    None => return None
  }
  let then_evidence = match
    dae_control_result_slice_gc_evidence(
      mod_, func_type_indices, func_locals, then_slice, results,
    ) {
    Some(evidence) => evidence
    None => return None
  }
  let else_evidence = match
    dae_control_result_slice_gc_evidence(
      mod_, func_type_indices, func_locals, else_slice, results,
    ) {
    Some(evidence) => evidence
    None => return None
  }
  let pair = match
    dae_control_result_pair_gc_evidence(
      mod_, then_evidence, else_evidence, results,
    ) {
    Some(evidence) => evidence
    None => return None
  }
  if !pair.saw_refinement {
    return None
  }
  let if_body_changed = then_slice.flattened ||
    else_slice.flattened ||
    pair.then_body_changed ||
    pair.else_body_changed
  Some({ then_slice, else_slice, pair, if_body_changed })
}

///|
fn dae_indirect_call_gc_result_candidate_signature(
  mod_ : @lib.Module,
  type_idx : @lib.TypeIdx,
  old_type : @lib.ValType,
) -> (Int, @lib.ValType)? {
  match mod_.type_sec {
    Some(type_sec) =>
      match dae_type_sec_func_type(type_sec, type_idx) {
        Some(@lib.FuncType(params, [candidate_type])) =>
          match candidate_type {
            @lib.RefTypeValType(@lib.HeapTypeRefType(_, _, @lib.HeapType(_))) =>
              match
                dae_refined_gc_candidate_ref_type(
                  mod_, old_type, candidate_type,
                ) {
                Some(refined_type) => Some((params.length(), refined_type))
                None => None
              }
            _ => None
          }
        _ => None
      }
    None => None
  }
}

///|
fn dae_indirect_call_gc_result_slice_evidence(
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  body : Array[@lib.Instruction],
  start : Int,
  argument_end : Int,
  stack_value_end : Int,
  type_idx : @lib.TypeIdx,
  old_type : @lib.ValType,
) -> DaeIndirectGcResultSliceEvidence? {
  if start < 0 ||
    argument_end < start ||
    stack_value_end < argument_end ||
    stack_value_end > body.length() {
    return None
  }
  let (param_count, candidate_type) = match
    dae_indirect_call_gc_result_candidate_signature(mod_, type_idx, old_type) {
    Some(result) => result
    None => return None
  }
  if argument_end - start != param_count {
    return None
  }
  let mut value_idx = start
  while value_idx < stack_value_end {
    if dae_instr_has_observable_effect_or_branch(body[value_idx]) {
      return None
    }
    match
      dae_stack_single_value_producer_evidence(
        body[value_idx],
        mod_,
        func_type_indices,
      ) {
      Some(_) => ()
      None => return None
    }
    value_idx += 1
  }
  Some({
    candidate: candidate_type,
    param_count,
    stack_value_count: stack_value_end - start,
  })
}

///|
fn dae_call_ref_gc_result_candidate_slice(
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  body : Array[@lib.Instruction],
  start : Int,
  end : Int,
  old_type : @lib.ValType,
) -> (@lib.ValType, @lib.Instruction?)? {
  if start + 2 > end {
    return None
  }
  let target_idx = end - 2
  match (body[target_idx], body[end - 1]) {
    (@lib.RefFunc(_), @lib.CallRef(type_idx)) =>
      match
        dae_indirect_call_gc_result_slice_evidence(
          mod_, func_type_indices, body, start, target_idx, target_idx, type_idx,
          old_type,
        ) {
        Some(evidence) => {
          if evidence.param_count != target_idx - start ||
            evidence.stack_value_count != target_idx - start {
            return None
          }
          Some((evidence.candidate, None))
        }
        None => None
      }
    _ => None
  }
}

///|
fn dae_call_indirect_gc_result_candidate_slice(
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  body : Array[@lib.Instruction],
  start : Int,
  end : Int,
  old_type : @lib.ValType,
) -> (@lib.ValType, @lib.Instruction?)? {
  if start + 2 > end {
    return None
  }
  match body[end - 1] {
    @lib.CallIndirect(type_idx, _) => {
      let table_idx = end - 2
      match
        dae_indirect_call_gc_result_slice_evidence(
          mod_,
          func_type_indices,
          body,
          start,
          table_idx,
          table_idx + 1,
          type_idx,
          old_type,
        ) {
        Some(evidence) => {
          if evidence.param_count != table_idx - start ||
            evidence.stack_value_count != table_idx + 1 - start {
            return None
          }
          Some((evidence.candidate, None))
        }
        None => None
      }
    }
    _ => None
  }
}

///|
fn dae_gc_result_candidate_slice(
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  func_locals : @lib.FunctionLocals?,
  body : Array[@lib.Instruction],
  start : Int,
  end : Int,
  old_type : @lib.ValType,
) -> (@lib.ValType, @lib.Instruction?)? {
  if start < 0 || end > body.length() || start >= end {
    return None
  }
  if start + 1 == end {
    return dae_direct_gc_result_candidate_instr(
      mod_,
      func_type_indices,
      func_locals,
      body[start],
      old_type,
    )
  }
  match
    dae_call_ref_gc_result_candidate_slice(
      mod_, func_type_indices, body, start, end, old_type,
    ) {
    Some(result) => return Some(result)
    None => ()
  }
  dae_call_indirect_gc_result_candidate_slice(
    mod_, func_type_indices, body, start, end, old_type,
  )
}

///|
fn dae_gc_select_value_slices_evidence(
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  func_locals : @lib.FunctionLocals?,
  body : Array[@lib.Instruction],
  slices : DaeSelectValueSlices,
  old_type : @lib.ValType,
  require_refined? : Bool = false,
) -> DaeGcSelectValueEvidence? {
  if !dae_select_value_slices_are_consistent(slices, slices.select_idx) ||
    slices.select_idx >= body.length() {
    return None
  }
  match body[slices.select_idx] {
    @lib.Select(_) => ()
    _ => return None
  }
  let (left_candidate, left_rewrite) = match
    dae_gc_result_candidate_slice(
      mod_,
      func_type_indices,
      func_locals,
      body,
      slices.left.start,
      slices.right.start,
      old_type,
    ) {
    Some(result) => result
    None => return None
  }
  let (right_candidate, right_rewrite) = match
    dae_gc_result_candidate_slice(
      mod_,
      func_type_indices,
      func_locals,
      body,
      slices.right.start,
      slices.condition.start,
      old_type,
    ) {
    Some(result) => result
    None => return None
  }
  let candidate = match
    dae_lub_gc_candidate_ref_type(
      mod_, left_candidate, right_candidate, old_type,
    ) {
    Some(vt) => vt
    None => return None
  }
  let refined_candidate = dae_refined_gc_candidate_ref_type(
    mod_, old_type, candidate,
  )
  if require_refined && refined_candidate.is_none() {
    return None
  }
  Some({ candidate, refined_candidate, left_rewrite, right_rewrite })
}

///|
fn dae_gc_select_value_slices_candidate_evidence(
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  func_locals : @lib.FunctionLocals?,
  body : Array[@lib.Instruction],
  select_idx : Int,
  old_type : @lib.ValType,
  required_left_start? : Int = -1,
  require_dropped_prefix? : Bool = false,
  require_refined? : Bool = false,
) -> DaeGcSelectValueSlicesEvidence? {
  let slices = match
    dae_find_select_value_slices(
      mod_,
      func_type_indices,
      body,
      select_idx,
      required_left_start~,
      require_dropped_prefix~,
    ) {
    Some(slices) => slices
    None => return None
  }
  if !dae_select_value_slices_are_consistent(slices, select_idx) {
    return None
  }
  match
    dae_gc_select_value_slices_evidence(
      mod_,
      func_type_indices,
      func_locals,
      body,
      slices,
      old_type,
      require_refined~,
    ) {
    Some(gc) => Some({ slices, gc })
    None => None
  }
}

///|
fn dae_instr_has_function_return(instr : @lib.Instruction) -> Bool {
  match instr {
    @lib.Return
    | @lib.ReturnCall(_)
    | @lib.ReturnCallIndirect(_, _)
    | @lib.ReturnCallRef(_) => true
    @lib.Block(_, @lib.Expr(body))
    | @lib.Loop(_, @lib.Expr(body))
    | @lib.TryTable(_, _, @lib.Expr(body)) =>
      body.any(fn(child) { dae_instr_has_function_return(child) })
    @lib.If(_, then_body, Some(else_body)) =>
      then_body.any(fn(child) { dae_instr_has_function_return(child) }) ||
      else_body.any(fn(child) { dae_instr_has_function_return(child) })
    @lib.If(_, then_body, None) =>
      then_body.any(fn(child) { dae_instr_has_function_return(child) })
    _ => false
  }
}

///|
fn dae_body_prefix_has_function_return(
  body : Array[@lib.Instruction],
  end_exclusive : Int,
) -> Bool {
  let mut idx = 0
  while idx < end_exclusive && idx < body.length() {
    if dae_instr_has_function_return(body[idx]) {
      return true
    }
    idx += 1
  }
  false
}

///|
fn dae_effect_free_fallthrough_evidence_is_consistent(
  evidence : DaeEffectFreeFallthroughEvidence,
) -> Bool {
  evidence.body_length == evidence.body.length() &&
  evidence.effect_free_fallthrough == !evidence.has_observable_effect_or_branch &&
  evidence.effect_free_fallthrough
}

///|
fn dae_effect_free_fallthrough_evidence(
  arm_body : Array[@lib.Instruction],
) -> DaeEffectFreeFallthroughEvidence? {
  match dae_effect_free_body_evidence(arm_body) {
    Some(body_evidence) => {
      let evidence = {
        body: body_evidence.body,
        body_length: body_evidence.body_length,
        has_observable_effect_or_branch: body_evidence.has_observable_effect_or_branch,
        effect_free_fallthrough: body_evidence.effect_free,
      }
      if dae_effect_free_fallthrough_evidence_is_consistent(evidence) {
        Some(evidence)
      } else {
        None
      }
    }
    None => None
  }
}

///|
fn dae_mixed_single_result_return_arm_gc_evidence_is_consistent(
  evidence : DaeMixedSingleResultReturnArmGcEvidence,
) -> Bool {
  evidence.body_changed == (evidence.rewritten_body is Some(_)) &&
  (evidence.has_return || evidence.effect_free_fallthrough) &&
  !(evidence.has_return && evidence.effect_free_fallthrough)
}

///|
fn dae_mixed_single_result_return_arm_gc_evidence(
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  func_locals : @lib.FunctionLocals?,
  arm_body : Array[@lib.Instruction],
  old_type : @lib.ValType,
  current_candidate : @lib.ValType,
) -> DaeMixedSingleResultReturnArmGcEvidence? {
  match
    dae_direct_gc_result_explicit_return_candidate_body(
      mod_, func_type_indices, func_locals, arm_body, old_type,
    ) {
    Some((return_candidate, arm_rewrite)) => {
      let candidate = match
        dae_lub_gc_candidate_ref_type(
          mod_, return_candidate, current_candidate, old_type,
        ) {
        Some(lub) => lub
        None => return None
      }
      let evidence = {
        candidate,
        rewritten_body: arm_rewrite,
        body_changed: arm_rewrite is Some(_),
        has_return: true,
        effect_free_fallthrough: false,
      }
      if dae_mixed_single_result_return_arm_gc_evidence_is_consistent(evidence) {
        Some(evidence)
      } else {
        None
      }
    }
    None =>
      match dae_effect_free_fallthrough_evidence(arm_body) {
        Some(fallthrough) => {
          let evidence = {
            candidate: current_candidate,
            rewritten_body: None,
            body_changed: false,
            has_return: false,
            effect_free_fallthrough: fallthrough.effect_free_fallthrough,
          }
          if dae_mixed_single_result_return_arm_gc_evidence_is_consistent(
              evidence,
            ) {
            Some(evidence)
          } else {
            None
          }
        }
        None => None
      }
  }
}

///|
fn dae_direct_gc_result_mixed_if_fallthrough_candidate_body(
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  func_locals : @lib.FunctionLocals?,
  body : Array[@lib.Instruction],
  old_type : @lib.ValType,
) -> (@lib.ValType, Array[@lib.Instruction]?)? {
  if body.length() < 2 {
    return None
  }
  let terminal_idx = body.length() - 1
  let if_idx = body.length() - 2
  let (block_type, then_body, else_body_opt) = match body[if_idx] {
    @lib.If(block_type, then_body, else_body_opt) =>
      (block_type, then_body, else_body_opt)
    _ => return None
  }
  match
    dae_control_block_type_zero_input_output_count_evidence(
      block_type,
      mod_.type_sec,
      0,
    ) {
    Some(_) => ()
    None => return None
  }
  let (terminal_candidate, terminal_rewrite) = match
    dae_direct_gc_result_candidate_instr(
      mod_,
      func_type_indices,
      func_locals,
      body[terminal_idx],
      old_type,
    ) {
    Some(result) => result
    None => return None
  }
  let rewritten = body.copy()
  let mut next_then_body = then_body
  let mut next_else_body : Array[@lib.Instruction]? = else_body_opt
  let mut combined_candidate = terminal_candidate
  let mut changed = false
  let mut saw_return_path = false
  let then_evidence = match
    dae_mixed_single_result_return_arm_gc_evidence(
      mod_, func_type_indices, func_locals, then_body, old_type, combined_candidate,
    ) {
    Some(evidence) => evidence
    None => return None
  }
  combined_candidate = then_evidence.candidate
  if then_evidence.has_return {
    saw_return_path = true
  }
  match then_evidence.rewritten_body {
    Some(rewritten_then) => {
      next_then_body = rewritten_then
      changed = true
    }
    None => ()
  }
  match else_body_opt {
    Some(else_body) => {
      let else_evidence = match
        dae_mixed_single_result_return_arm_gc_evidence(
          mod_, func_type_indices, func_locals, else_body, old_type, combined_candidate,
        ) {
        Some(evidence) => evidence
        None => return None
      }
      combined_candidate = else_evidence.candidate
      if else_evidence.has_return {
        saw_return_path = true
      }
      match else_evidence.rewritten_body {
        Some(rewritten_else) => {
          next_else_body = Some(rewritten_else)
          changed = true
        }
        None => ()
      }
    }
    None => ()
  }
  if !saw_return_path {
    return None
  }
  match terminal_rewrite {
    Some(next_terminal) => {
      rewritten[terminal_idx] = next_terminal
      changed = true
    }
    None => ()
  }
  if changed {
    rewritten[if_idx] = @lib.Instruction::if_(
      block_type, next_then_body, next_else_body,
    )
    Some((combined_candidate, Some(rewritten)))
  } else {
    Some((combined_candidate, None))
  }
}

///|
fn dae_instr_has_branch(instr : @lib.Instruction) -> Bool {
  match instr {
    @lib.Br(_)
    | @lib.BrIf(_)
    | @lib.BrTable(_, _)
    | @lib.Return
    | @lib.ReturnCall(_)
    | @lib.ReturnCallIndirect(_, _)
    | @lib.ReturnCallRef(_)
    | @lib.Throw(_)
    | @lib.ThrowRef => true
    @lib.Block(_, @lib.Expr(body))
    | @lib.Loop(_, @lib.Expr(body))
    | @lib.TryTable(_, _, @lib.Expr(body)) =>
      body.any(fn(child) { dae_instr_has_branch(child) })
    @lib.If(_, then_body, Some(else_body)) =>
      then_body.any(fn(child) { dae_instr_has_branch(child) }) ||
      else_body.any(fn(child) { dae_instr_has_branch(child) })
    @lib.If(_, then_body, None) =>
      then_body.any(fn(child) { dae_instr_has_branch(child) })
    _ => false
  }
}

///|
fn dae_select_condition_stack_slice_instr_allowed(
  instr : @lib.Instruction,
) -> Bool {
  if dae_instr_has_branch(instr) {
    return false
  }
  // A branch-free `if (result i32)` is still a stack-local condition
  // producer for typed-select refinement: changing the select/result type
  // does not move or delete the condition control. Keep escaping branches,
  // loops, try_table, and local mutation outside this bounded recognizer.
  match instr {
    @lib.LocalSet(_)
    | @lib.LocalTee(_)
    | @lib.Loop(_, _)
    | @lib.TryTable(_, _, _) => false
    _ => true
  }
}

///|
fn dae_select_condition_localization_evidence_is_consistent(
  evidence : DaeSelectConditionLocalizationEvidence,
) -> Bool {
  if evidence.start < 0 ||
    evidence.end <= evidence.start ||
    evidence.instr_count != evidence.end - evidence.start {
    return false
  }
  if evidence.instr_count == 1 {
    match evidence.stack_slice {
      Some(_) => return false
      None => ()
    }
    if evidence.singleton_trivially_droppable {
      return true
    }
    match evidence.singleton_producer {
      Some(producer) => dae_stack_effect_evidence_is_consistent(producer)
      None => false
    }
  } else {
    if evidence.singleton_trivially_droppable {
      return false
    }
    match evidence.singleton_producer {
      Some(_) => return false
      None => ()
    }
    match evidence.stack_slice {
      Some(slice) =>
        dae_stack_slice_localization_evidence_is_consistent(slice) &&
        slice.transition.simulation.start == evidence.start &&
        slice.transition.simulation.end == evidence.end
      None => false
    }
  }
}

///|
fn dae_select_condition_localization_evidence(
  mod_ : @lib.Module,
  body : Array[@lib.Instruction],
  start : Int,
  end : Int,
  func_type_indices : Array[@lib.TypeIdx],
) -> DaeSelectConditionLocalizationEvidence? {
  if start < 0 || start >= end || end > body.length() {
    return None
  }
  let instr_count = end - start
  if instr_count == 1 {
    let instr = body[start]
    let singleton_trivially_droppable = dae_instr_is_trivially_droppable(instr)
    if !singleton_trivially_droppable && dae_instr_has_branch(instr) {
      return None
    }
    let singleton_producer = dae_stack_single_value_producer_evidence(
      instr, mod_, func_type_indices,
    )
    if !singleton_trivially_droppable && singleton_producer is None {
      return None
    }
    let evidence = {
      start,
      end,
      instr_count,
      singleton_trivially_droppable,
      singleton_producer,
      stack_slice: None,
    }
    if dae_select_condition_localization_evidence_is_consistent(evidence) {
      Some(evidence)
    } else {
      None
    }
  } else {
    let stack_slice = match
      dae_stack_slice_localization_evidence_from_policy(
        mod_,
        func_type_indices,
        body,
        start,
        end,
        dae_select_condition_localization_policy(),
      ) {
      Some(evidence) => evidence
      None => return None
    }
    let evidence = {
      start,
      end,
      instr_count,
      singleton_trivially_droppable: false,
      singleton_producer: None,
      stack_slice: Some(stack_slice),
    }
    if dae_select_condition_localization_evidence_is_consistent(evidence) {
      Some(evidence)
    } else {
      None
    }
  }
}

///|
fn dae_direct_gc_result_select_candidate_body(
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  func_locals : @lib.FunctionLocals?,
  body : Array[@lib.Instruction],
  old_type : @lib.ValType,
) -> (@lib.ValType, Array[@lib.Instruction]?)? {
  let mut mode = 0
  while mode < 2 {
    let has_terminal_return = mode == 1
    let terminal_extra = if has_terminal_return { 1 } else { 0 }
    if body.length() < 4 + terminal_extra {
      mode += 1
      continue
    }
    if has_terminal_return {
      match body[body.length() - 1] {
        @lib.Return => ()
        _ => {
          mode += 1
          continue
        }
      }
    }
    let select_idx = body.length() - 1 - terminal_extra
    match
      dae_gc_select_value_slices_candidate_evidence(
        mod_,
        func_type_indices,
        func_locals,
        body,
        select_idx,
        old_type,
        require_dropped_prefix=true,
      ) {
      Some(evidence) => {
        let slices = evidence.slices
        let gc = evidence.gc
        let (rewritten, _) = match
          dae_apply_select_value_rewrites_to_body(
            body,
            slices.left.start,
            slices.right.start,
            slices.select_idx,
            gc.left_rewrite,
            gc.right_rewrite,
            Some(@lib.Instruction::select(types=Some([gc.candidate]))),
          ) {
          Some(application) => application
          None => {
            mode += 1
            continue
          }
        }
        return Some((gc.candidate, Some(rewritten)))
      }
      None => ()
    }
    mode += 1
  }
  None
}

///|
fn dae_direct_gc_result_candidate_body(
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  func_locals : @lib.FunctionLocals?,
  body : Array[@lib.Instruction],
  old_type : @lib.ValType,
) -> (@lib.ValType, Array[@lib.Instruction]?)? {
  match
    dae_direct_gc_result_select_candidate_body(
      mod_, func_type_indices, func_locals, body, old_type,
    ) {
    Some(result) => return Some(result)
    None => ()
  }
  match
    dae_direct_gc_result_explicit_return_candidate_body(
      mod_, func_type_indices, func_locals, body, old_type,
    ) {
    Some(result) => return Some(result)
    None => ()
  }
  if body.length() >= 2 {
    match body[body.length() - 1] {
      @lib.Unreachable =>
        match
          dae_direct_gc_result_explicit_return_candidate_instr(
            mod_,
            func_type_indices,
            func_locals,
            body[body.length() - 2],
            old_type,
          ) {
          Some((candidate_type, Some(rewritten_terminal))) => {
            let rewritten = body.copy()
            rewritten[rewritten.length() - 2] = rewritten_terminal
            return Some((candidate_type, Some(rewritten)))
          }
          Some((candidate_type, None)) => return Some((candidate_type, None))
          None => ()
        }
      _ => ()
    }
    match
      dae_direct_gc_result_mixed_if_fallthrough_candidate_body(
        mod_, func_type_indices, func_locals, body, old_type,
      ) {
      Some(result) => return Some(result)
      None =>
        if dae_body_prefix_has_function_return(body, body.length() - 1) {
          return None
        }
    }
  }
  match body {
    [@lib.StructNewDefault(type_idx)] =>
      Some((dae_exact_struct_default_ref_type(type_idx), None))
    [@lib.Block(@lib.ValTypeBlockType(_), @lib.Expr(block_body))] =>
      match block_body {
        [@lib.StructNewDefault(type_idx)] =>
          Some(
            (
              dae_exact_struct_default_ref_type(type_idx),
              Some([@lib.Instruction::struct_new_default(type_idx)]),
            ),
          )
        _ =>
          dae_direct_gc_result_candidate_instr(
            mod_,
            func_type_indices,
            func_locals,
            body[0],
            old_type,
          ).map(fn(result) {
            let (candidate_type, rewritten_instr) = result
            let rewritten_body = match rewritten_instr {
              Some(instr) => Some([instr])
              None => None
            }
            (candidate_type, rewritten_body)
          })
      }
    _ => {
      if body.length() == 0 {
        return None
      }
      let terminal = body[body.length() - 1]
      match
        dae_direct_gc_result_candidate_instr(
          mod_, func_type_indices, func_locals, terminal, old_type,
        ) {
        Some((candidate_type, Some(rewritten_terminal))) => {
          let rewritten = body.copy()
          rewritten[rewritten.length() - 1] = rewritten_terminal
          Some((candidate_type, Some(rewritten)))
        }
        Some((candidate_type, None)) => Some((candidate_type, None))
        None => None
      }
    }
  }
}

///|
fn dae_module_signature_context(
  mod_ : @lib.Module,
  def_idx : Int,
  copy_funcs~ : Bool,
) -> DaeModuleSignatureContext? {
  match (mod_.func_sec, mod_.code_sec, mod_.type_sec) {
    (Some(@lib.FuncSec(type_idxs)), Some(@lib.CodeSec(funcs)), Some(type_sec)) => {
      if def_idx < 0 ||
        def_idx >= funcs.length() ||
        def_idx >= type_idxs.length() {
        return None
      }
      Some({
        def_idx,
        type_idxs: type_idxs.copy(),
        funcs: if copy_funcs {
          funcs.copy()
        } else {
          funcs
        },
        type_sec,
      })
    }
    _ => None
  }
}

///|
fn dae_apply_module_signature_finalization(
  mod_ : @lib.Module,
  context : DaeModuleSignatureContext,
  next_params : Array[@lib.ValType],
  next_results : Array[@lib.ValType],
  perf? : HotPerfSession? = None,
  type_update_timer_name? : String = "",
) -> DaePassResult {
  let type_update_start_us = if type_update_timer_name.length() > 0 {
    perf_start_timer_opt(perf, type_update_timer_name)
  } else {
    0UL
  }
  let (next_type_sec, new_type_idx) = dae_update_defined_func_type(
    mod_,
    context.type_sec,
    context.type_idxs,
    context.def_idx,
    next_params,
    next_results,
  )
  if type_update_timer_name.length() > 0 {
    perf_stop_timer_opt(perf, type_update_timer_name, type_update_start_us)
  }
  context.type_idxs[context.def_idx] = new_type_idx
  let touched = Array::make(context.funcs.length(), false)
  touched[context.def_idx] = true
  {
    mod_out: mod_
    .with_type_sec(next_type_sec)
    .with_func_sec(@lib.FuncSec::new(context.type_idxs))
    .without_name_sec(),
    touched,
    changed: true,
    primary_def: context.def_idx,
  }
}

///|
fn dae_try_update_signature_only(
  mod_ : @lib.Module,
  def_idx : Int,
  params : Array[@lib.ValType],
  results : Array[@lib.ValType],
) -> DaePassResult {
  let context = match
    dae_module_signature_context(mod_, def_idx, copy_funcs=false) {
    Some(context) => context
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  dae_apply_module_signature_finalization(mod_, context, params, results)
}

///|
fn dae_flat_multi_result_suffix_evidence_is_consistent(
  evidence : DaeFlatMultiResultSuffixEvidence,
  body : Array[@lib.Instruction],
) -> Bool {
  evidence.result_count > 0 &&
  evidence.start >= 0 &&
  evidence.end == evidence.start + evidence.result_count &&
  evidence.end <= body.length() &&
  (
    !evidence.has_terminal_return ||
    (
      evidence.end + 1 == body.length() &&
      body[body.length() - 1] is @lib.Return
    )
  ) &&
  (evidence.has_terminal_return || evidence.end == body.length())
}

///|
fn dae_flat_multi_result_suffix_evidence(
  body : Array[@lib.Instruction],
  result_count : Int,
  match_terminal_return : Bool,
) -> DaeFlatMultiResultSuffixEvidence? {
  let terminal_extra = if match_terminal_return { 1 } else { 0 }
  if result_count <= 0 || body.length() < result_count + terminal_extra {
    return None
  }
  if match_terminal_return {
    match body[body.length() - 1] {
      @lib.Return => ()
      _ => return None
    }
  }
  let candidate_start = body.length() - terminal_extra - result_count
  match dae_trivially_dropped_prefix_evidence(body, candidate_start) {
    Some(_) => {
      let evidence = {
        start: candidate_start,
        end: candidate_start + result_count,
        result_count,
        has_terminal_return: match_terminal_return,
      }
      if dae_flat_multi_result_suffix_evidence_is_consistent(evidence, body) {
        Some(evidence)
      } else {
        None
      }
    }
    None => None
  }
}

///|
fn dae_find_or_append_func_type(
  type_sec : @lib.TypeSec,
  params : Array[@lib.ValType],
  results : Array[@lib.ValType],
) -> (@lib.TypeSec, @lib.TypeIdx) {
  match dae_find_equivalent_simple_func_type(type_sec, params, results) {
    Some(existing) => (type_sec, existing)
    None => dae_append_new_func_type(type_sec, params, results)
  }
}

///|
fn dae_typeidx_control_rewrite_plan(
  control_kind : Int,
  params : Array[@lib.ValType],
  results : Array[@lib.ValType],
  body : Array[@lib.Instruction],
  else_body : Array[@lib.Instruction]?,
) -> DaeTypeidxControlRewritePlan? {
  if results.length() == 0 {
    return None
  }
  match (control_kind, else_body) {
    (0 | 1, None) =>
      Some({
        control_kind,
        params: params.copy(),
        results: results.copy(),
        body: body.copy(),
        else_body: None,
      })
    (2, Some(else_body)) =>
      Some({
        control_kind,
        params: params.copy(),
        results: results.copy(),
        body: body.copy(),
        else_body: Some(else_body.copy()),
      })
    _ => None
  }
}

///|
fn dae_apply_typeidx_control_rewrite(
  type_sec : @lib.TypeSec,
  plan : DaeTypeidxControlRewritePlan,
) -> DaeTypeidxControlRewriteApplication? {
  let (next_type_sec, block_type_idx) = dae_find_or_append_func_type(
    type_sec,
    plan.params,
    plan.results,
  )
  let block_type = @lib.BlockType::type_idx(block_type_idx)
  let rewritten = match (plan.control_kind, plan.else_body) {
    (0, None) => @lib.Instruction::block(block_type, @lib.Expr::new(plan.body))
    (1, None) => @lib.Instruction::loop_(block_type, @lib.Expr::new(plan.body))
    (2, Some(else_body)) =>
      @lib.Instruction::if_(block_type, plan.body, Some(else_body))
    _ => return None
  }
  Some({ type_sec: next_type_sec, rewritten })
}

///|
fn dae_rebuild_typeidx_control(
  type_sec : @lib.TypeSec,
  control_kind : Int,
  params : Array[@lib.ValType],
  results : Array[@lib.ValType],
  body : Array[@lib.Instruction],
  else_body : Array[@lib.Instruction]?,
) -> DaeTypeidxControlRewriteApplication? {
  let plan = match
    dae_typeidx_control_rewrite_plan(
      control_kind, params, results, body, else_body,
    ) {
    Some(plan) => plan
    None => return None
  }
  dae_apply_typeidx_control_rewrite(type_sec, plan)
}

///|
fn dae_rebuild_typeidx_control_in_body(
  type_sec : @lib.TypeSec,
  outer_body : Array[@lib.Instruction],
  control_idx : Int,
  control_kind : Int,
  params : Array[@lib.ValType],
  results : Array[@lib.ValType],
  control_body : Array[@lib.Instruction],
  else_body : Array[@lib.Instruction]?,
) -> DaeTypeidxControlBodyRewriteApplication? {
  if control_idx < 0 || control_idx >= outer_body.length() {
    return None
  }
  let control_application = match
    dae_rebuild_typeidx_control(
      type_sec, control_kind, params, results, control_body, else_body,
    ) {
    Some(application) => application
    None => return None
  }
  let body = outer_body.copy()
  body[control_idx] = control_application.rewritten
  Some({ type_sec: control_application.type_sec, body })
}

///|
fn dae_dropped_operand_pair_skip_evidence_is_consistent(
  evidence : DaeDroppedOperandPairSkipEvidence,
) -> Bool {
  evidence.start >= 0 &&
  evidence.end >= evidence.start &&
  evidence.next >= evidence.start &&
  evidence.next <= evidence.end &&
  evidence.skipped_pairs >= 0 &&
  evidence.next == evidence.start + evidence.skipped_pairs * 2
}

///|
fn dae_dropped_operand_pair_skip_evidence(
  body : Array[@lib.Instruction],
  start : Int,
  end : Int,
) -> DaeDroppedOperandPairSkipEvidence? {
  if start < 0 || end < start || end > body.length() {
    return None
  }
  let mut next = start
  let mut skipped_pairs = 0
  while next + 1 < end && dae_instr_is_trivially_droppable(body[next]) {
    match body[next + 1] {
      @lib.Drop => {
        next += 2
        skipped_pairs += 1
      }
      _ => break
    }
  }
  let evidence = { start, end, next, skipped_pairs }
  if dae_dropped_operand_pair_skip_evidence_is_consistent(evidence) {
    Some(evidence)
  } else {
    None
  }
}

///|
fn dae_multi_result_operand_slot_evidence_is_consistent(
  evidence : DaeMultiResultOperandSlotEvidence,
  body : Array[@lib.Instruction],
) -> Bool {
  evidence.start >= 0 &&
  evidence.end >= evidence.start &&
  evidence.end <= body.length() &&
  evidence.operand_start >= evidence.start &&
  evidence.operand_start < evidence.end &&
  evidence.next >= evidence.operand_start &&
  evidence.next <= evidence.end &&
  evidence.skipped_pairs >= 0 &&
  evidence.operand_start == evidence.start + evidence.skipped_pairs * 2 &&
  (
    !evidence.consumed_single_producer ||
    evidence.next == evidence.operand_start + 1
  ) &&
  (evidence.consumed_single_producer || evidence.next == evidence.operand_start)
}

///|
fn dae_multi_result_operand_slot_prefix_evidence(
  body : Array[@lib.Instruction],
  start : Int,
  end : Int,
) -> DaeMultiResultOperandSlotEvidence? {
  let skipped = match dae_dropped_operand_pair_skip_evidence(body, start, end) {
    Some(evidence) => evidence
    None => return None
  }
  if skipped.next >= end {
    return None
  }
  let evidence = {
    start,
    end,
    operand_start: skipped.next,
    next: skipped.next,
    skipped_pairs: skipped.skipped_pairs,
    consumed_single_producer: false,
  }
  if dae_multi_result_operand_slot_evidence_is_consistent(evidence, body) {
    Some(evidence)
  } else {
    None
  }
}

///|
fn dae_multi_result_operand_slot_single_producer_evidence(
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  body : Array[@lib.Instruction],
  prefix : DaeMultiResultOperandSlotEvidence,
) -> DaeMultiResultOperandSlotEvidence? {
  if !dae_multi_result_operand_slot_evidence_is_consistent(prefix, body) ||
    prefix.consumed_single_producer {
    return None
  }
  match
    dae_stack_single_value_producer_evidence(
      body[prefix.operand_start],
      mod_,
      func_type_indices,
    ) {
    Some(_) => {
      let evidence = {
        start: prefix.start,
        end: prefix.end,
        operand_start: prefix.operand_start,
        next: prefix.operand_start + 1,
        skipped_pairs: prefix.skipped_pairs,
        consumed_single_producer: true,
      }
      if dae_multi_result_operand_slot_evidence_is_consistent(evidence, body) {
        Some(evidence)
      } else {
        None
      }
    }
    None => None
  }
}

///|
fn dae_multi_result_suffix_bounds_evidence(
  body : Array[@lib.Instruction],
  result_count : Int,
  min_extra_instrs : Int,
) -> Array[DaeMultiResultSuffixBoundsEvidence] {
  let out : Array[DaeMultiResultSuffixBoundsEvidence] = []
  if result_count <= 0 || min_extra_instrs < 0 {
    return out
  }
  let mut mode = 0
  while mode < 2 {
    let has_terminal_return = mode == 1
    let terminal_extra = if has_terminal_return { 1 } else { 0 }
    if body.length() < result_count + min_extra_instrs + terminal_extra {
      mode += 1
      continue
    }
    if has_terminal_return {
      match body[body.length() - 1] {
        @lib.Return => ()
        _ => {
          mode += 1
          continue
        }
      }
    }
    let operand_end = body.length() - terminal_extra
    let max_start = operand_end - result_count
    let mut suffix_start = 0
    while suffix_start <= max_start {
      if dae_trivially_dropped_prefix_evidence(body, suffix_start) is Some(_) {
        out.push({ suffix_start, operand_end, has_terminal_return })
      }
      suffix_start += 1
    }
    mode += 1
  }
  out
}

///|
fn dae_multi_result_operand_sequence_evidence(
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  body : Array[@lib.Instruction],
  result_count : Int,
  min_extra_instrs : Int,
  specialize : (Array[@lib.Instruction], Int, Int, Int) -> (Int, Int)?,
) -> DaeMultiResultOperandSequenceEvidence? {
  if result_count <= 0 {
    return None
  }
  let suffix_bounds = dae_multi_result_suffix_bounds_evidence(
    body, result_count, min_extra_instrs,
  )
  for bounds in suffix_bounds {
    let operand_starts = Array::make(result_count, -1)
    let value_instr_indices = Array::make(result_count, -1)
    let specialized_slots = Array::make(result_count, false)
    let mut instr_idx = bounds.suffix_start
    let mut result_idx = 0
    let mut saw_specialized = false
    let mut suffix_ok = true
    while suffix_ok && result_idx < result_count {
      let slot_prefix = match
        dae_multi_result_operand_slot_prefix_evidence(
          body,
          instr_idx,
          bounds.operand_end,
        ) {
        Some(evidence) => evidence
        None => {
          suffix_ok = false
          break
        }
      }
      let operand_start = slot_prefix.operand_start
      operand_starts[result_idx] = operand_start
      let mut consumed = false
      match specialize(body, operand_start, bounds.operand_end, result_idx) {
        Some((value_instr_idx, next)) =>
          if value_instr_idx >= operand_start &&
            value_instr_idx < next &&
            next > operand_start &&
            next <= bounds.operand_end {
            value_instr_indices[result_idx] = value_instr_idx
            specialized_slots[result_idx] = true
            instr_idx = next
            saw_specialized = true
            consumed = true
          }
        None => ()
      }
      if !consumed {
        match
          dae_multi_result_operand_slot_single_producer_evidence(
            mod_, func_type_indices, body, slot_prefix,
          ) {
          Some(evidence) => {
            value_instr_indices[result_idx] = evidence.operand_start
            instr_idx = evidence.next
            consumed = true
          }
          None => ()
        }
      }
      if consumed {
        result_idx += 1
      } else {
        suffix_ok = false
      }
    }
    if suffix_ok &&
      result_idx == result_count &&
      instr_idx == bounds.operand_end &&
      saw_specialized {
      return Some({
        bounds,
        operand_starts,
        value_instr_indices,
        specialized_slots,
      })
    }
  }
  None
}

///|
fn dae_try_refine_multi_result_single_if_operand_body(
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  func_locals : @lib.FunctionLocals?,
  body : Array[@lib.Instruction],
  results : Array[@lib.ValType],
  next_results : Array[@lib.ValType],
) -> Array[@lib.Instruction]? {
  if results.length() < 2 {
    return None
  }
  let specialize_if = fn(
    candidate_body : Array[@lib.Instruction],
    operand_start : Int,
    operand_end : Int,
    _ : Int,
  ) -> (Int, Int)? {
    if operand_start + 1 >= operand_end {
      return None
    }
    match candidate_body[operand_start + 1] {
      @lib.If(block_type, _, Some(_)) =>
        match dae_control_single_result_block_type_evidence(block_type, mod_) {
          Some(_) =>
            match
              dae_stack_single_value_producer_evidence(
                candidate_body[operand_start],
                mod_,
                func_type_indices,
              ) {
              Some(_) => Some((operand_start + 1, operand_start + 2))
              None => None
            }
          None => None
        }
      _ => None
    }
  }
  let sequence = match
    dae_multi_result_operand_sequence_evidence(
      mod_,
      func_type_indices,
      body,
      results.length(),
      1,
      specialize_if,
    ) {
    Some(evidence) => evidence
    None => return None
  }
  ignore(sequence.bounds.has_terminal_return)
  let rewritten_body = body.copy()
  let mut changed = false
  let mut result_idx = 0
  while result_idx < results.length() {
    let candidate_instr_idx = sequence.value_instr_indices[result_idx]
    match
      dae_gc_result_slot_evidence(
        mod_,
        func_type_indices,
        func_locals,
        body[candidate_instr_idx],
        results[result_idx],
        require_refined=true,
      ) {
      Some(evidence) => {
        let refined = match evidence.refined_candidate {
          Some(vt) => vt
          None => return None
        }
        next_results[result_idx] = refined
        changed = true
        match evidence.rewrite {
          Some(instr) => rewritten_body[candidate_instr_idx] = instr
          None => ()
        }
      }
      None => ()
    }
    result_idx += 1
  }
  if changed {
    Some(rewritten_body)
  } else {
    None
  }
}

///|
fn dae_try_refine_multi_result_select_operand_body(
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  func_locals : @lib.FunctionLocals?,
  body : Array[@lib.Instruction],
  results : Array[@lib.ValType],
  next_results : Array[@lib.ValType],
) -> Array[@lib.Instruction]? {
  if results.length() == 0 {
    return None
  }
  let specialize_select = fn(
    candidate_body : Array[@lib.Instruction],
    operand_start : Int,
    operand_end : Int,
    result_idx : Int,
  ) -> (Int, Int)? {
    let remaining_results = results.length() - result_idx - 1
    let max_select_idx = operand_end - remaining_results - 1
    let mut select_idx = operand_start + 3
    while select_idx <= max_select_idx {
      match
        dae_gc_select_value_slices_candidate_evidence(
          mod_,
          func_type_indices,
          func_locals,
          candidate_body,
          select_idx,
          results[result_idx],
          required_left_start=operand_start,
          require_refined=true,
        ) {
        Some(evidence) =>
          return Some(
            (evidence.slices.select_idx, evidence.slices.select_idx + 1),
          )
        None => ()
      }
      select_idx += 1
    }
    None
  }
  let sequence = match
    dae_multi_result_operand_sequence_evidence(
      mod_,
      func_type_indices,
      body,
      results.length(),
      3,
      specialize_select,
    ) {
    Some(evidence) => evidence
    None => return None
  }
  ignore(sequence.bounds.has_terminal_return)
  let rewritten_body = body.copy()
  let mut changed = false
  let mut result_idx = 0
  while result_idx < results.length() {
    if sequence.specialized_slots[result_idx] {
      let select_idx = sequence.value_instr_indices[result_idx]
      let operand_start = sequence.operand_starts[result_idx]
      let evidence = match
        dae_gc_select_value_slices_candidate_evidence(
          mod_,
          func_type_indices,
          func_locals,
          body,
          select_idx,
          results[result_idx],
          required_left_start=operand_start,
          require_refined=true,
        ) {
        Some(evidence) => evidence
        None => return None
      }
      match evidence.gc.refined_candidate {
        Some(refined) => {
          let slices = evidence.slices
          next_results[result_idx] = refined
          changed = true
          let (next_body, _) = match
            dae_apply_select_value_rewrites_to_body(
              rewritten_body,
              slices.left.start,
              slices.right.start,
              slices.select_idx,
              evidence.gc.left_rewrite,
              evidence.gc.right_rewrite,
              Some(@lib.Instruction::select(types=Some([refined]))),
            ) {
            Some(application) => application
            None => return None
          }
          rewritten_body.clear()
          rewritten_body.append(next_body)
        }
        None => ()
      }
    }
    result_idx += 1
  }
  if changed {
    Some(rewritten_body)
  } else {
    None
  }
}

///|
fn dae_instr_is_parametric_typeidx_stack_safe_effectful_prefix(
  instr : @lib.Instruction,
) -> Bool {
  match instr {
    @lib.Call(_)
    | @lib.I32Load(_)
    | @lib.I64Load(_)
    | @lib.F32Load(_)
    | @lib.F64Load(_)
    | @lib.I32Load8S(_)
    | @lib.I32Load8U(_)
    | @lib.I32Load16S(_)
    | @lib.I32Load16U(_)
    | @lib.I64Load8S(_)
    | @lib.I64Load8U(_)
    | @lib.I64Load16S(_)
    | @lib.I64Load16U(_)
    | @lib.I64Load32S(_)
    | @lib.I64Load32U(_) => true
    _ => false
  }
}

///|
fn dae_parametric_typeidx_stack_slice_instr_allowed(
  instr : @lib.Instruction,
) -> Bool {
  match instr {
    @lib.Drop => true
    _ =>
      dae_instr_is_droppable_pure_leaf(instr) ||
      dae_instr_is_nontrapping_pure_unary(instr) ||
      dae_instr_is_nontrapping_pure_binary(instr) ||
      dae_instr_is_parametric_typeidx_stack_safe_effectful_prefix(instr)
  }
}

///|
fn dae_parametric_typeidx_prefix_consumes_params_stack_safe(
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  arm_body : Array[@lib.Instruction],
  end : Int,
  param_count : Int,
) -> Bool {
  dae_stack_slice_localization_policy_accepts(
    mod_,
    func_type_indices,
    arm_body,
    0,
    end,
    dae_parametric_typeidx_prefix_localization_policy(param_count),
  )
}

///|
fn dae_parametric_typeidx_multi_result_arm_gc_evidence(
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  func_locals : @lib.FunctionLocals?,
  arm_body : Array[@lib.Instruction],
  param_count : Int,
  results : Array[@lib.ValType],
) -> DaeControlResultGcEvidence? {
  if results.length() == 0 || arm_body.length() < results.length() {
    return None
  }
  let result_start = arm_body.length() - results.length()
  if !dae_parametric_typeidx_prefix_consumes_params_stack_safe(
      mod_, func_type_indices, arm_body, result_start, param_count,
    ) {
    return None
  }
  let result_slice = match
    dae_make_multi_result_control_slice(
      arm_body,
      result_start,
      results.length(),
      0,
      false,
      false,
    ) {
    Some(slice) => slice
    None => return None
  }
  match
    dae_control_result_slice_gc_evidence(
      mod_, func_type_indices, func_locals, result_slice, results,
    ) {
    Some(evidence) => if evidence.saw_candidate { Some(evidence) } else { None }
    None => None
  }
}

///|
fn dae_try_refine_parametric_typeidx_multi_result_terminal_control_body(
  mod_ : @lib.Module,
  type_sec : @lib.TypeSec,
  func_type_indices : Array[@lib.TypeIdx],
  func_locals : @lib.FunctionLocals?,
  body : Array[@lib.Instruction],
  results : Array[@lib.ValType],
  next_results : Array[@lib.ValType],
) -> (@lib.TypeSec, Array[@lib.Instruction])? {
  if results.length() < 2 || body.length() == 0 {
    return None
  }
  let terminal_idx = body.length() - 1
  if dae_body_prefix_has_function_return(body, terminal_idx) {
    return None
  }
  let instr = body[terminal_idx]
  let (block_type, arm_body, else_body_opt, kind) = match instr {
    @lib.Block(block_type, @lib.Expr(block_body)) =>
      (block_type, block_body, None, 0)
    @lib.Loop(block_type, @lib.Expr(loop_body)) =>
      (block_type, loop_body, None, 1)
    @lib.If(block_type, then_body, Some(else_body)) =>
      (block_type, then_body, Some(else_body), 2)
    _ => return None
  }
  let control_signature = match
    dae_control_block_type_signature_evidence(block_type, mod_) {
    Some(signature) =>
      match signature.type_idx {
        Some(_) => signature
        None => return None
      }
    None => return None
  }
  let params = control_signature.params
  let control_results = control_signature.results
  if params.length() == 0 || control_results.length() != results.length() {
    return None
  }
  let arm_evidence = match
    dae_parametric_typeidx_multi_result_arm_gc_evidence(
      mod_,
      func_type_indices,
      func_locals,
      arm_body,
      params.length(),
      results,
    ) {
    Some(evidence) => evidence
    None => return None
  }
  let refined_results = results.copy()
  let mut rewritten_arm = arm_evidence.rewritten_body
  let mut changed = false
  let mut body_changed = arm_evidence.body_changed
  let mut next_else_body : Array[@lib.Instruction]? = else_body_opt
  match else_body_opt {
    Some(else_body) => {
      let else_evidence = match
        dae_parametric_typeidx_multi_result_arm_gc_evidence(
          mod_,
          func_type_indices,
          func_locals,
          else_body,
          params.length(),
          results,
        ) {
        Some(evidence) => evidence
        None => return None
      }
      let pair_evidence = match
        dae_control_result_pair_gc_evidence(
          mod_, arm_evidence, else_evidence, results,
        ) {
        Some(evidence) => evidence
        None => return None
      }
      match
        dae_apply_control_result_pair_refinements(
          pair_evidence,
          next_results,
          refined_results=Some(refined_results),
        ) {
        Some(_) => ()
        None => return None
      }
      rewritten_arm = pair_evidence.rewritten_then_body
      next_else_body = Some(pair_evidence.rewritten_else_body)
      body_changed = body_changed ||
        pair_evidence.then_body_changed ||
        pair_evidence.else_body_changed
      changed = true
    }
    None =>
      match
        dae_apply_control_result_single_refinements(
          arm_evidence,
          next_results,
          refined_results=Some(refined_results),
        ) {
        Some(_) => changed = true
        None => ()
      }
  }
  if !changed {
    return None
  }
  let application = match
    dae_rebuild_typeidx_control_in_body(
      type_sec, body, terminal_idx, kind, params, refined_results, rewritten_arm,
      next_else_body,
    ) {
    Some(application) => application
    None => return None
  }
  ignore(body_changed)
  Some((application.type_sec, application.body))
}

///|
fn dae_find_multi_result_control_slice(
  mod_ : @lib.Module,
  body : Array[@lib.Instruction],
  result_count : Int,
  require_terminal_return? : Bool = false,
) -> DaeControlResultSlice? {
  if result_count <= 0 {
    return None
  }
  if !require_terminal_return {
    return dae_multi_result_control_carrier_chain_slice(
      mod_,
      body,
      result_count,
      terminal_return=false,
      match_terminal_return=false,
      append_terminal_return=false,
    )
  }
  match
    dae_multi_result_control_carrier_chain_slice(
      mod_,
      body,
      result_count,
      terminal_return=true,
      match_terminal_return=true,
      append_terminal_return=false,
    ) {
    Some(result_slice) => return Some(result_slice)
    None => ()
  }
  match body {
    [@lib.Block(block_type, @lib.Expr(block_body))] =>
      match
        dae_control_block_type_zero_input_output_count_evidence(
          block_type,
          mod_.type_sec,
          0,
        ) {
        Some(_) if dae_terminal_return_body_evidence(block_body) is Some(_) =>
          match
            dae_multi_result_control_carrier_chain_slice(
              mod_,
              block_body,
              result_count,
              terminal_return=true,
              match_terminal_return=true,
              append_terminal_return=false,
            ) {
            Some(result_slice) => return Some(result_slice)
            None => ()
          }
        _ => ()
      }
    _ => ()
  }
  match body {
    [block_instr, @lib.Return] =>
      dae_multi_result_control_carrier_chain_slice(
        mod_,
        [block_instr],
        result_count,
        terminal_return=true,
        match_terminal_return=false,
        append_terminal_return=true,
      )
    _ => None
  }
}

///|
fn dae_multi_result_if_arm_return_candidate_body(
  mod_ : @lib.Module,
  body : Array[@lib.Instruction],
  result_count : Int,
) -> DaeControlResultSlice? {
  dae_find_multi_result_control_slice(
    mod_,
    body,
    result_count,
    require_terminal_return=true,
  )
}

///|
fn dae_mixed_multi_result_return_arm_gc_evidence(
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  func_locals : @lib.FunctionLocals?,
  arm_body : Array[@lib.Instruction],
  results : Array[@lib.ValType],
  combined_candidates : Array[@lib.ValType?],
  rejected : Array[Bool],
) -> DaeMixedMultiResultReturnArmGcEvidence? {
  if combined_candidates.length() != results.length() ||
    rejected.length() != results.length() {
    return None
  }
  match
    dae_multi_result_if_arm_return_candidate_body(
      mod_,
      arm_body,
      results.length(),
    ) {
    Some(result_slice) => {
      let control_result = match
        dae_control_result_slice_gc_evidence(
          mod_, func_type_indices, func_locals, result_slice, results,
        ) {
        Some(evidence) => evidence
        None => return None
      }
      let mut result_idx = 0
      while result_idx < results.length() {
        match combined_candidates[result_idx] {
          Some(current_candidate) =>
            match control_result.candidates[result_idx] {
              Some(return_candidate) =>
                match
                  dae_lub_gc_candidate_ref_type(
                    mod_,
                    return_candidate,
                    current_candidate,
                    results[result_idx],
                  ) {
                  Some(lub) => combined_candidates[result_idx] = Some(lub)
                  None => rejected[result_idx] = true
                }
              None => rejected[result_idx] = true
            }
          None => ()
        }
        result_idx += 1
      }
      Some({
        body: control_result.body,
        result_start: control_result.result_start,
        flattened: result_slice.flattened,
        has_return: true,
        effect_free_fallthrough: false,
        control_result: Some(control_result),
      })
    }
    None =>
      match dae_effect_free_fallthrough_evidence(arm_body) {
        Some(fallthrough) =>
          Some({
            body: fallthrough.body,
            result_start: -1,
            flattened: false,
            has_return: false,
            effect_free_fallthrough: fallthrough.effect_free_fallthrough,
            control_result: None,
          })
        None => None
      }
  }
}

///|
fn dae_apply_mixed_multi_result_return_arm_refinements(
  evidence : DaeMixedMultiResultReturnArmGcEvidence,
  refined : Array[Bool],
) -> DaeMixedMultiResultReturnArmRewriteEvidence? {
  if !evidence.has_return {
    if evidence.control_result is Some(_) {
      return None
    }
    return Some({ body: evidence.body, body_changed: false })
  }
  let control_result = match evidence.control_result {
    Some(control_result) => control_result
    None => return None
  }
  if refined.length() != control_result.candidates.length() ||
    control_result.rewrites.length() != refined.length() ||
    evidence.result_start != control_result.result_start ||
    evidence.body != control_result.body {
    return None
  }
  match
    dae_apply_result_rewrites_to_body(
      control_result.body,
      control_result.result_start,
      control_result.rewrites,
      active=Some(refined),
    ) {
    Some((rewritten, application)) => {
      let body_changed = evidence.flattened || application.body_changed
      Some({
        body: if body_changed {
          rewritten
        } else {
          evidence.body
        },
        body_changed,
      })
    }
    None => None
  }
}

///|
fn dae_try_refine_mixed_multi_result_if_fallthrough_body(
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  func_locals : @lib.FunctionLocals?,
  body : Array[@lib.Instruction],
  results : Array[@lib.ValType],
  next_results : Array[@lib.ValType],
) -> Array[@lib.Instruction]? {
  if results.length() == 0 || body.length() <= results.length() {
    return None
  }
  let terminal_start = body.length() - results.length()
  let if_idx = terminal_start - 1
  let (block_type, then_body, else_body_opt) = match body[if_idx] {
    @lib.If(block_type, then_body, else_body_opt) =>
      (block_type, then_body, else_body_opt)
    _ => return None
  }
  match
    dae_control_block_type_zero_input_output_count_evidence(
      block_type,
      mod_.type_sec,
      0,
    ) {
    Some(_) => ()
    None => return None
  }
  let combined_candidates : Array[@lib.ValType?] = Array::make(
    results.length(),
    None,
  )
  let terminal_rewrites : Array[@lib.Instruction?] = Array::make(
    results.length(),
    None,
  )
  let rejected = Array::make(results.length(), false)
  let refined = Array::make(results.length(), false)
  let mut result_idx = 0
  while result_idx < results.length() {
    let instr_idx = terminal_start + result_idx
    match
      dae_direct_gc_result_candidate_instr(
        mod_,
        func_type_indices,
        func_locals,
        body[instr_idx],
        results[result_idx],
      ) {
      Some((candidate_type, rewritten_instr)) => {
        combined_candidates[result_idx] = Some(candidate_type)
        terminal_rewrites[result_idx] = rewritten_instr
      }
      None => ()
    }
    result_idx += 1
  }
  let then_evidence = match
    dae_mixed_multi_result_return_arm_gc_evidence(
      mod_, func_type_indices, func_locals, then_body, results, combined_candidates,
      rejected,
    ) {
    Some(evidence) => evidence
    None => return None
  }
  let else_evidence : DaeMixedMultiResultReturnArmGcEvidence? = match
    else_body_opt {
    Some(else_body) =>
      match
        dae_mixed_multi_result_return_arm_gc_evidence(
          mod_, func_type_indices, func_locals, else_body, results, combined_candidates,
          rejected,
        ) {
        Some(evidence) => Some(evidence)
        None => return None
      }
    None => None
  }
  ignore(then_evidence.effect_free_fallthrough)
  let else_has_return = match else_evidence {
    Some(evidence) => {
      ignore(evidence.effect_free_fallthrough)
      evidence.has_return
    }
    None => false
  }
  if !then_evidence.has_return && !else_has_return {
    return None
  }
  let mut changed = false
  result_idx = 0
  while result_idx < results.length() {
    if !rejected[result_idx] {
      match combined_candidates[result_idx] {
        Some(candidate_type) =>
          match
            dae_refined_gc_candidate_ref_type(
              mod_,
              results[result_idx],
              candidate_type,
            ) {
            Some(refined_type) => {
              next_results[result_idx] = refined_type
              refined[result_idx] = true
              changed = true
            }
            None => ()
          }
        None => ()
      }
    }
    result_idx += 1
  }
  if !changed {
    return None
  }
  let (rewritten_body, terminal_application) = match
    dae_apply_result_rewrites_to_body(
      body,
      terminal_start,
      terminal_rewrites,
      active=Some(refined),
    ) {
    Some(result) => result
    None => return None
  }
  let mut body_changed = terminal_application.body_changed
  let mut next_then_body = then_body
  let mut if_body_changed = false
  match
    dae_apply_mixed_multi_result_return_arm_refinements(then_evidence, refined) {
    Some(rewrite) =>
      if rewrite.body_changed {
        next_then_body = rewrite.body
        if_body_changed = true
      }
    None => return None
  }
  let mut next_else_body = else_body_opt
  match else_evidence {
    Some(evidence) =>
      match
        dae_apply_mixed_multi_result_return_arm_refinements(evidence, refined) {
        Some(rewrite) =>
          if rewrite.body_changed {
            next_else_body = Some(rewrite.body)
            if_body_changed = true
          }
        None => return None
      }
    None => ()
  }
  if if_body_changed {
    rewritten_body[if_idx] = @lib.Instruction::if_(
      block_type, next_then_body, next_else_body,
    )
    body_changed = true
  }
  ignore(body_changed)
  Some(rewritten_body)
}

///|
fn dae_apply_direct_caller_scope_rewrite(
  funcs : Array[@lib.Func],
  direct_caller_defs : Array[Int],
  rewrite_caller : (@lib.Func, Int) -> DaeDirectCallerRewriteEvidence,
) -> DaeDirectCallerScopeApplication {
  let rewritten_funcs = funcs.copy()
  let changed_defs = Array::make(funcs.length(), false)
  let mut calls_rewritten = 0
  let mut changed = false
  for caller_def in direct_caller_defs {
    if caller_def >= 0 && caller_def < rewritten_funcs.length() {
      let evidence = rewrite_caller(rewritten_funcs[caller_def], caller_def)
      if !evidence.ok {
        return {
          funcs,
          calls_rewritten: 0,
          changed_defs: Array::make(funcs.length(), false),
          changed: false,
          ok: false,
        }
      }
      calls_rewritten += evidence.calls_rewritten
      if evidence.changed {
        rewritten_funcs[caller_def] = evidence.func
        changed_defs[caller_def] = true
        changed = true
      }
    }
  }
  { funcs: rewritten_funcs, calls_rewritten, changed_defs, changed, ok: true }
}

///|
fn dae_val_type_is_concrete_gc_ref(value : @lib.ValType) -> Bool {
  match value {
    @lib.RefTypeValType(@lib.HeapTypeRefType(_, _, @lib.HeapType(_))) => true
    _ => false
  }
}

///|
fn dae_signature_has_concrete_gc_param(params : Array[@lib.ValType]) -> Bool {
  params.any(dae_val_type_is_concrete_gc_ref)
}

///|
fn dae_signature_has_single_concrete_gc_result(
  results : Array[@lib.ValType],
) -> Bool {
  results.length() == 1 && dae_val_type_is_concrete_gc_ref(results[0])
}

///|
fn dae_signature_has_heap_ref(
  params : Array[@lib.ValType],
  results : Array[@lib.ValType],
) -> Bool {
  for val_type in params {
    match val_type {
      @lib.RefTypeValType(@lib.HeapTypeRefType(_, _, _)) => return true
      _ => ()
    }
  }
  for val_type in results {
    match val_type {
      @lib.RefTypeValType(@lib.HeapTypeRefType(_, _, _)) => return true
      _ => ()
    }
  }
  false
}

///|
fn dae_try_refine_direct_gc_types(
  mod_ : @lib.Module,
  callee_abs : Int,
  direct_call_count : Int,
  direct_caller_defs : Array[Int],
  refine_params? : Bool = true,
  refine_results? : Bool = true,
) -> DaePassResult {
  if direct_call_count == 0 {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let imported = dae_imported_func_count(mod_)
  let def_idx = callee_abs - imported
  let type_indices = dae_collect_func_type_indices(mod_)
  let func_type = match dae_resolve_func_type(mod_, type_indices, callee_abs) {
    Some(ft) => ft
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let @lib.FuncType(params, results) = func_type
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  if def_idx < 0 || def_idx >= funcs.length() {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let @lib.Func(locals, @lib.Expr(body)) = funcs[def_idx]
  let local_use = dae_local_use_for_callee(
    funcs[def_idx],
    params.length() + locals.length(),
    callee_abs,
    params.length(),
  )
  let next_params = params.copy()
  let next_results = results.copy()
  let refined_params = Array::make(params.length(), false)
  let mut rewritten_funcs = funcs.copy()
  let mut caller_body_changed = false
  let mut next_body = body
  let mut result_body_changed = false
  let mut rewrite_type_sec : @lib.TypeSec? = None
  let mut changed = false
  if refine_params && params.length() > 0 {
    let candidates : Array[@lib.ValType?] = Array::make(params.length(), None)
    let rejected = Array::make(params.length(), false)
    let mut calls_seen = 0
    for caller_def in direct_caller_defs {
      if caller_def >= 0 && caller_def < funcs.length() {
        let @lib.Func(caller_body_locals, @lib.Expr(caller_body)) = funcs[caller_def]
        let caller_func_locals = match
          dae_resolve_func_type(mod_, type_indices, imported + caller_def) {
          Some(@lib.FuncType(caller_params, _)) =>
            Some(@lib.FunctionLocals::new(caller_params, caller_body_locals))
          None => None
        }
        let (caller_calls, ok) = dae_collect_direct_struct_default_actuals_instrs(
          caller_body, callee_abs, params, local_use, candidates, rejected, 0, mod_,
          type_indices, caller_func_locals,
        )
        calls_seen += caller_calls
        if !ok {
          return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
        }
      }
    }
    if calls_seen == direct_call_count {
      let mut p = 0
      while p < params.length() {
        if rejected[p] {
          p += 1
          continue
        }
        match candidates[p] {
          Some(type_idx) =>
            match dae_refined_gc_candidate_ref_type(mod_, params[p], type_idx) {
              Some(refined) => {
                next_params[p] = refined
                refined_params[p] = true
                changed = true
              }
              None => ()
            }
          None => ()
        }
        p += 1
      }
    }
    if changed {
      let rewrite_caller = fn(caller_func, _) {
        let @lib.Func(caller_locals, @lib.Expr(caller_body)) = caller_func
        let (rewritten_body, calls, ok, body_changed) = dae_rewrite_refined_gc_actuals_instrs(
          caller_body, callee_abs, refined_params, next_params, 0, mod_, type_indices,
        )
        let rewritten_func = if body_changed {
          @lib.Func::new(caller_locals, @lib.Expr::new(rewritten_body))
        } else {
          caller_func
        }
        {
          func: rewritten_func,
          calls_rewritten: calls,
          changed: body_changed,
          ok,
        }
      }
      let application = dae_apply_direct_caller_scope_rewrite(
        funcs, direct_caller_defs, rewrite_caller,
      )
      if !application.ok || application.calls_rewritten != direct_call_count {
        return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
      }
      rewritten_funcs = application.funcs
      caller_body_changed = application.changed
      if def_idx >= 0 &&
        def_idx < application.changed_defs.length() &&
        application.changed_defs[def_idx] {
        let @lib.Func(_, @lib.Expr(rewritten_body)) = rewritten_funcs[def_idx]
        next_body = rewritten_body
      }
    }
  }
  if refine_results {
    let result_func_locals = Some(@lib.FunctionLocals::new(next_params, locals))
    if results.length() == 1 {
      match
        dae_direct_gc_result_candidate_body(
          mod_,
          type_indices,
          result_func_locals,
          body,
          results[0],
        ) {
        Some((candidate_type, rewritten_body)) =>
          match
            dae_refined_gc_candidate_ref_type(mod_, results[0], candidate_type) {
            Some(refined) => {
              next_results[0] = refined
              changed = true
              match rewritten_body {
                Some(instrs) => {
                  next_body = instrs
                  result_body_changed = true
                }
                None => ()
              }
            }
            None => ()
          }
        None => ()
      }
    } else {
      match
        dae_try_refine_mixed_multi_result_if_fallthrough_body(
          mod_, type_indices, result_func_locals, body, results, next_results,
        ) {
        Some(rewritten_body) => {
          next_body = rewritten_body
          result_body_changed = true
          changed = true
        }
        None => ()
      }
      match
        dae_try_refine_multi_result_single_if_operand_body(
          mod_, type_indices, result_func_locals, body, results, next_results,
        ) {
        Some(rewritten_body) => {
          next_body = rewritten_body
          result_body_changed = true
          changed = true
        }
        None => ()
      }
      match
        dae_try_refine_multi_result_select_operand_body(
          mod_, type_indices, result_func_locals, body, results, next_results,
        ) {
        Some(rewritten_body) => {
          next_body = rewritten_body
          result_body_changed = true
          changed = true
        }
        None => ()
      }
      match mod_.type_sec {
        Some(type_sec) => {
          let active_type_sec = match rewrite_type_sec {
            Some(current_type_sec) => current_type_sec
            None => type_sec
          }
          match
            dae_try_refine_parametric_typeidx_multi_result_terminal_control_body(
              mod_, active_type_sec, type_indices, result_func_locals, body, results,
              next_results,
            ) {
            Some((next_type_sec, rewritten_body)) => {
              rewrite_type_sec = Some(next_type_sec)
              next_body = rewritten_body
              result_body_changed = true
              changed = true
            }
            None => ()
          }
        }
        None => ()
      }
      if body.length() > 0 {
        match body[body.length() - 1] {
          @lib.If(block_type, then_body, Some(else_body)) =>
            match
              dae_control_block_type_zero_input_output_count_evidence(
                block_type,
                mod_.type_sec,
                results.length(),
              ) {
              Some(_) =>
                match
                  dae_multi_result_if_pair_gc_refinement_evidence(
                    mod_, type_indices, result_func_locals, then_body, else_body,
                    results,
                  ) {
                  Some(evidence) => {
                    let pair_evidence = evidence.pair
                    match
                      dae_apply_control_result_pair_refinements(
                        pair_evidence, next_results,
                      ) {
                      Some(_) => changed = true
                      None => ()
                    }
                    match mod_.type_sec {
                      Some(type_sec) => {
                        let active_type_sec = match rewrite_type_sec {
                          Some(current_type_sec) => current_type_sec
                          None => type_sec
                        }
                        let application = match
                          dae_rebuild_typeidx_control_in_body(
                            active_type_sec,
                            body,
                            body.length() - 1,
                            2,
                            [],
                            pair_evidence.refined_results,
                            pair_evidence.rewritten_then_body,
                            Some(pair_evidence.rewritten_else_body),
                          ) {
                          Some(application) => application
                          None =>
                            return {
                              mod_out: mod_,
                              touched: [],
                              changed: false,
                              primary_def: -1,
                            }
                        }
                        rewrite_type_sec = Some(application.type_sec)
                        next_body = application.body
                        result_body_changed = true
                      }
                      None => ()
                    }
                    ignore(evidence.then_slice)
                    ignore(evidence.else_slice)
                  }
                  None => ()
                }
              _ => ()
            }
          _ => ()
        }
      }
      if body.length() >= 2 {
        match (body[body.length() - 2], body[body.length() - 1]) {
          (@lib.If(block_type, then_body, Some(else_body)), @lib.Unreachable) =>
            match
              dae_control_block_type_zero_input_output_count_evidence(
                block_type,
                mod_.type_sec,
                0,
              ) {
              Some(_) =>
                match
                  dae_multi_result_if_pair_gc_refinement_evidence(
                    mod_,
                    type_indices,
                    result_func_locals,
                    then_body,
                    else_body,
                    results,
                    require_terminal_return=true,
                  ) {
                  Some(evidence) => {
                    let pair_evidence = evidence.pair
                    match
                      dae_apply_control_result_pair_refinements(
                        pair_evidence, next_results,
                      ) {
                      Some(_) => changed = true
                      None => ()
                    }
                    if evidence.if_body_changed {
                      let rewritten = @lib.Instruction::if_(
                        block_type,
                        pair_evidence.rewritten_then_body,
                        Some(pair_evidence.rewritten_else_body),
                      )
                      let rewritten_body = body.copy()
                      rewritten_body[rewritten_body.length() - 2] = rewritten
                      next_body = rewritten_body
                      result_body_changed = true
                    }
                    ignore(evidence.then_slice)
                    ignore(evidence.else_slice)
                  }
                  None => ()
                }
              _ => ()
            }
          _ => ()
        }
      }
      let mut candidate_body = body
      let mut flatten_block_carrier = false
      let mut preserve_loop_carrier = false
      match body {
        [@lib.Block(block_type, @lib.Expr(block_body))] =>
          match
            dae_control_block_type_zero_input_output_count_evidence(
              block_type,
              mod_.type_sec,
              results.length(),
            ) {
            Some(_) => {
              candidate_body = block_body
              flatten_block_carrier = true
            }
            None => ()
          }
        [@lib.Loop(block_type, @lib.Expr(loop_body))] =>
          match
            dae_control_block_type_zero_input_output_count_evidence(
              block_type,
              mod_.type_sec,
              results.length(),
            ) {
            Some(_) => {
              candidate_body = loop_body
              preserve_loop_carrier = true
            }
            None => ()
          }
        _ => ()
      }
      if flatten_block_carrier && !preserve_loop_carrier {
        let mut keep_unwrapping = true
        while keep_unwrapping {
          keep_unwrapping = false
          match candidate_body {
            [@lib.Block(block_type, @lib.Expr(block_body))] =>
              match
                dae_control_block_type_zero_input_output_count_evidence(
                  block_type,
                  mod_.type_sec,
                  results.length(),
                ) {
                Some(_) if dae_effect_free_body_evidence(block_body) is Some(_) ||
                  dae_terminal_return_body_evidence(block_body) is Some(_) => {
                  candidate_body = block_body
                  keep_unwrapping = true
                }
                _ => ()
              }
            _ => ()
          }
        }
      }
      let mut result_start = -1
      let mut result_end = candidate_body.length()
      if candidate_body.length() > 0 {
        match candidate_body[candidate_body.length() - 1] {
          @lib.Return => result_end = candidate_body.length() - 1
          _ => ()
        }
      }
      if result_end >= results.length() {
        let candidate_start = result_end - results.length()
        if dae_trivially_dropped_prefix_evidence(
            candidate_body, candidate_start,
          )
          is Some(_) {
          result_start = candidate_start
        }
      }
      if result_start >= 0 &&
        dae_body_prefix_has_function_return(candidate_body, result_start) {
        result_start = -1
      }
      if result_start >= 0 &&
        !(preserve_loop_carrier && result_end != candidate_body.length()) {
        let result_slice = match
          dae_make_multi_result_control_slice(
            candidate_body,
            result_start,
            results.length(),
            0,
            flatten_block_carrier,
            false,
          ) {
          Some(slice) => slice
          None =>
            return {
              mod_out: mod_,
              touched: [],
              changed: false,
              primary_def: -1,
            }
        }
        let mut rewritten_body = candidate_body
        let mut multi_result_changed = false
        let mut multi_result_body_changed = false
        match
          dae_control_result_slice_gc_evidence(
            mod_,
            type_indices,
            result_func_locals,
            result_slice,
            results,
            require_refined=true,
          ) {
          Some(evidence) => {
            rewritten_body = evidence.rewritten_body
            multi_result_body_changed = evidence.body_changed
            match
              dae_apply_control_result_single_refinements(
                evidence, next_results,
              ) {
              Some(_) => {
                changed = true
                multi_result_changed = true
              }
              None => ()
            }
          }
          None => ()
        }
        if multi_result_changed &&
          (
            multi_result_body_changed ||
            flatten_block_carrier ||
            preserve_loop_carrier
          ) {
          if preserve_loop_carrier {
            match mod_.type_sec {
              Some(type_sec) => {
                let active_type_sec = match rewrite_type_sec {
                  Some(current_type_sec) => current_type_sec
                  None => type_sec
                }
                let application = match
                  dae_rebuild_typeidx_control_in_body(
                    active_type_sec,
                    body,
                    0,
                    1,
                    [],
                    next_results,
                    rewritten_body,
                    None,
                  ) {
                  Some(application) => application
                  None =>
                    return {
                      mod_out: mod_,
                      touched: [],
                      changed: false,
                      primary_def: -1,
                    }
                }
                rewrite_type_sec = Some(application.type_sec)
                next_body = application.body
                result_body_changed = true
              }
              None => ()
            }
          } else {
            next_body = rewritten_body
            result_body_changed = true
          }
        }
      }
    }
  }
  if !changed {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let update_mod = match rewrite_type_sec {
    Some(type_sec) => mod_.with_type_sec(type_sec)
    None => mod_
  }
  if result_body_changed || caller_body_changed {
    if result_body_changed {
      rewritten_funcs[def_idx] = @lib.Func::new(
        locals,
        @lib.Expr::new(next_body),
      )
    }
    dae_finalize_module_code_rewrite(
      update_mod,
      def_idx,
      rewritten_funcs,
      next_params,
      next_results,
      DaeTouchModuleCodeCalleeOnly,
    )
  } else {
    dae_try_update_signature_only(
      update_mod, def_idx, next_params, next_results,
    )
  }
}

///|
fn dae_try_refine_direct_gc_types_for_def_with_facts(
  mod_ : @lib.Module,
  def_idx : Int,
  call_facts : DaeCurrentCallFacts,
  refine_params : Bool,
  refine_results : Bool,
) -> DaePassResult {
  let imported = dae_imported_func_count(mod_)
  let callee_abs = imported + def_idx
  let boundary_facts = dae_call_boundary_facts_from_current(call_facts)
  let candidate = match
    dae_call_boundary_candidate(boundary_facts, callee_abs, def_idx~) {
    Some(candidate) => candidate
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  if !candidate.owned ||
    candidate.has_self_direct_caller ||
    !candidate.allows_nonself_direct_rewrite {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  dae_try_refine_direct_gc_types(
    mod_,
    callee_abs,
    candidate.direct_call_count,
    candidate.direct_callers,
    refine_params~,
    refine_results~,
  )
}

///|
fn dae_rewrite_materialized_const_suffix_calls_instrs(
  instrs : Array[@lib.Instruction],
  callee_abs : Int,
  expected_suffix : Array[@lib.Instruction],
) -> (Array[@lib.Instruction], Int, Bool) {
  let out : Array[@lib.Instruction] = []
  let mut calls = 0
  let mut ok = true
  let mut idx = 0
  while idx < instrs.length() && ok {
    match instrs[idx] {
      @lib.Call(func_idx) if dae_func_idx_slot(func_idx) == callee_abs =>
        if out.length() < expected_suffix.length() {
          ok = false
        } else {
          let suffix_start = out.length() - expected_suffix.length()
          let mut suffix_idx = 0
          while suffix_idx < expected_suffix.length() && ok {
            if !dae_materialized_const_equal(
                out[suffix_start + suffix_idx],
                expected_suffix[suffix_idx],
              ) {
              ok = false
            }
            suffix_idx += 1
          }
          if ok {
            suffix_idx = 0
            while suffix_idx < expected_suffix.length() {
              ignore(out.pop())
              suffix_idx += 1
            }
            out.push(instrs[idx])
            calls += 1
          }
        }
      @lib.Block(block_type, @lib.Expr(body)) => {
        let (rewritten, nested_calls, nested_ok) = dae_rewrite_materialized_const_suffix_calls_instrs(
          body, callee_abs, expected_suffix,
        )
        ok = nested_ok
        calls += nested_calls
        out.push(@lib.Instruction::block(block_type, @lib.Expr::new(rewritten)))
      }
      @lib.Loop(block_type, @lib.Expr(body)) => {
        let (rewritten, nested_calls, nested_ok) = dae_rewrite_materialized_const_suffix_calls_instrs(
          body, callee_abs, expected_suffix,
        )
        ok = nested_ok
        calls += nested_calls
        out.push(@lib.Instruction::loop_(block_type, @lib.Expr::new(rewritten)))
      }
      @lib.TryTable(block_type, catches, @lib.Expr(body)) => {
        let (rewritten, nested_calls, nested_ok) = dae_rewrite_materialized_const_suffix_calls_instrs(
          body, callee_abs, expected_suffix,
        )
        ok = nested_ok
        calls += nested_calls
        out.push(
          @lib.Instruction::try_table(
            block_type,
            catches,
            @lib.Expr::new(rewritten),
          ),
        )
      }
      @lib.If(block_type, then_body, else_body) => {
        let (then_rewritten, then_calls, then_ok) = dae_rewrite_materialized_const_suffix_calls_instrs(
          then_body, callee_abs, expected_suffix,
        )
        ok = then_ok
        calls += then_calls
        let rewritten_else = match else_body {
          Some(body) if ok => {
            let (else_rewritten, else_calls, else_ok) = dae_rewrite_materialized_const_suffix_calls_instrs(
              body, callee_abs, expected_suffix,
            )
            ok = else_ok
            calls += else_calls
            Some(else_rewritten)
          }
          Some(body) => Some(body)
          None => None
        }
        out.push(
          @lib.Instruction::if_(block_type, then_rewritten, rewritten_else),
        )
      }
      _ => out.push(instrs[idx])
    }
    idx += 1
  }
  if !ok {
    return ([], calls, false)
  }
  (out, calls, true)
}

///|
fn dae_apply_removed_param_candidate_after_caller_scope(
  mod_ : @lib.Module,
  def_idx : Int,
  params : Array[@lib.ValType],
  results : Array[@lib.ValType],
  remove : Array[Bool],
  const_params : Array[@lib.Instruction?],
  local_use : DaeLocalUse,
  localized_params : Array[Bool],
  application : DaeDirectCallerScopeApplication,
  direct_call_count : Int,
) -> DaePassResult {
  if !application.ok || application.calls_rewritten != direct_call_count {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let rewritten_funcs = application.funcs
  if def_idx < 0 || def_idx >= rewritten_funcs.length() {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let callee_rewrite = match
    dae_removed_param_callee_rewrite_evidence(
      rewritten_funcs[def_idx],
      params,
      remove,
      const_params,
      local_use,
      localized_params,
    ) {
    Some(evidence) => evidence
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let context = match
    dae_module_signature_context(mod_, def_idx, copy_funcs=false) {
    Some(context) => context
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  dae_apply_removed_param_callee_rewrite(
    mod_, context, rewritten_funcs, callee_rewrite, results,
  )
}

///|
fn dae_try_rewrite_verified_materialized_const_suffix_candidate(
  mod_ : @lib.Module,
  callee_abs : Int,
  params : Array[@lib.ValType],
  expected_suffix : Array[@lib.Instruction],
  local_use : DaeLocalUse,
  verified_calls : Int,
  verified_callers : Array[Int],
) -> DaePassResult {
  if verified_calls <= 0 ||
    expected_suffix.length() <= 0 ||
    expected_suffix.length() > params.length() ||
    expected_suffix.any(fn(instr) { !dae_instr_is_materializable_const(instr) }) {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let imported = dae_imported_func_count(mod_)
  let def_idx = callee_abs - imported
  let type_indices = dae_collect_func_type_indices(mod_)
  let func_type = match dae_resolve_func_type(mod_, type_indices, callee_abs) {
    Some(ft) => ft
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let @lib.FuncType(current_params, results) = func_type
  if current_params != params {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let funcs = match (mod_.func_sec, mod_.code_sec, mod_.type_sec) {
    (Some(_), Some(@lib.CodeSec(funcs)), Some(_)) => funcs
    _ => return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let tail_call_boundary = dae_tail_call_boundary_evidence(funcs)
  if tail_call_boundary.blocks_direct_call_rewrite {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let rewrite_caller = fn(caller_func, _) {
    let @lib.Func(locals, @lib.Expr(body)) = caller_func
    let (rewritten_body, calls_rewritten, ok) = dae_rewrite_materialized_const_suffix_calls_instrs(
      body, callee_abs, expected_suffix,
    )
    if !ok {
      return {
        func: caller_func,
        calls_rewritten: 0,
        changed: false,
        ok: false,
      }
    }
    if calls_rewritten > 0 {
      {
        func: @lib.Func::new(locals, @lib.Expr::new(rewritten_body)),
        calls_rewritten,
        changed: true,
        ok: true,
      }
    } else {
      { func: caller_func, calls_rewritten: 0, changed: false, ok: true }
    }
  }
  let application = dae_apply_direct_caller_scope_rewrite(
    funcs, verified_callers, rewrite_caller,
  )
  let suffix_start = params.length() - expected_suffix.length()
  let remove = Array::make(params.length(), false)
  let const_params : Array[@lib.Instruction?] = Array::make(
    params.length(),
    None,
  )
  let mut suffix_idx = 0
  while suffix_idx < expected_suffix.length() {
    remove[suffix_start + suffix_idx] = true
    const_params[suffix_start + suffix_idx] = Some(expected_suffix[suffix_idx])
    suffix_idx += 1
  }
  dae_apply_removed_param_candidate_after_caller_scope(
    mod_,
    def_idx,
    params,
    results,
    remove,
    const_params,
    local_use,
    Array::make(params.length(), false),
    application,
    verified_calls,
  )
}

///|
fn dae_boundary_has_direct_caller_cycle(
  facts : DaeCallBoundaryFacts,
  imported : Int,
  callee_abs : Int,
) -> Bool {
  if callee_abs < 0 || callee_abs >= facts.direct_callers.length() {
    return false
  }
  let seen = Array::make(facts.direct_callers.length(), false)
  let pending : Array[Int] = []
  for caller_def in facts.direct_callers[callee_abs] {
    pending.push(imported + caller_def)
  }
  while pending.length() > 0 {
    let current = pending.pop().unwrap()
    if current == callee_abs {
      return true
    }
    if current < 0 || current >= seen.length() || seen[current] {
      continue
    }
    seen[current] = true
    for caller_def in facts.direct_callers[current] {
      pending.push(imported + caller_def)
    }
  }
  false
}

///|
fn dae_batchable_uniform_literal(instr : @lib.Instruction) -> Bool {
  match instr {
    @lib.I32Const(_) | @lib.I64Const(_) | @lib.F32Const(_) | @lib.F64Const(_) =>
      true
    _ => false
  }
}

///|
fn dae_try_apply_unread_param_batch(mod_ : @lib.Module) -> DaePassResult {
  let snapshot = dae_collect_module_boundary_snapshot(mod_)
  let imported = snapshot.imported
  let defined = snapshot.defined
  if defined < 1024 {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let boundary_facts = snapshot.boundary_facts
  let mut type_sec = match mod_.type_sec {
    Some(type_sec) => type_sec
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let type_idxs = match mod_.func_sec {
    Some(@lib.FuncSec(type_idxs)) => type_idxs.copy()
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let current_type_indices = snapshot.type_indices.copy()
  let type_lookup = dae_simple_func_type_lookup(type_sec)
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  if type_idxs.length() != funcs.length() {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let tail_boundary = dae_tail_call_boundary_evidence(funcs)
  if tail_boundary.blocks_direct_call_rewrite {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let plans : Array[DaeBoundaryParamBatchPlan] = []
  for def_idx = 0; def_idx < defined; def_idx = def_idx + 1 {
    let callee_abs = imported + def_idx
    let boundary = match
      dae_call_boundary_candidate(boundary_facts, callee_abs, def_idx~) {
      Some(candidate) => candidate
      None => continue
    }
    if !boundary.owned ||
      !boundary.allows_nonself_direct_rewrite ||
      boundary.has_self_direct_caller ||
      dae_boundary_has_direct_caller_cycle(boundary_facts, imported, callee_abs) {
      continue
    }
    let @lib.FuncType(params, results) = match
      dae_resolve_func_type(mod_, snapshot.type_indices, callee_abs) {
      Some(func_type) => func_type
      None => continue
    }
    if params.length() == 0 {
      continue
    }
    let @lib.Func(locals, _) = funcs[def_idx]
    let local_use = dae_local_use_for_callee(
      funcs[def_idx],
      params.length() + locals.length(),
      callee_abs,
      params.length(),
    )
    let remove = Array::make(params.length(), false)
    let const_params : Array[@lib.Instruction?] = Array::make(
      params.length(),
      None,
    )
    let mut any = false
    for param_idx = 0; param_idx < params.length(); param_idx = param_idx + 1 {
      if !local_use.gets[param_idx] {
        remove[param_idx] = true
        any = true
      }
    }
    if any {
      plans.push({
        def_idx,
        callee_abs,
        params,
        results,
        remove,
        const_params,
        local_use,
        direct_call_count: boundary.direct_call_count,
        direct_caller_defs: boundary.direct_callers,
      })
    }
  }
  if plans.length() == 0 {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let rewritten_funcs = funcs.copy()
  let touched = Array::make(defined, false)
  let mut applied = 0
  let mut first_def = -1
  for plan in plans {
    let current_view = mod_
      .with_type_sec(type_sec)
      .with_func_sec(@lib.FuncSec::new(type_idxs))
      .with_code_sec(@lib.CodeSec::new(rewritten_funcs))
    let localized_params = Array::make(plan.params.length(), false)
    let caller_rewrites : Array[(Int, @lib.Func)] = []
    let mut calls_rewritten = 0
    let mut ok = true
    for caller_def in plan.direct_caller_defs {
      if caller_def < 0 || caller_def >= rewritten_funcs.length() {
        ok = false
        break
      }
      let caller_params = match
        dae_type_sec_func_type(type_sec, type_idxs[caller_def]) {
        Some(@lib.FuncType(params, _)) => params
        None => {
          ok = false
          break
        }
      }
      let @lib.Func(caller_locals, @lib.Expr(caller_body)) = rewritten_funcs[caller_def]
      let localization = {
        first_scratch_local: dae_next_free_local_idx(
          caller_body,
          caller_params.length() + caller_locals.length(),
        ),
        param_types: plan.params,
        scratch_local_types: [],
        localized_params,
      }
      let rewrite = dae_rewrite_calls_instrs(
        caller_body,
        plan.callee_abs,
        plan.remove,
        0,
        current_view,
        current_type_indices,
        localization=Some(localization),
        allow_stack_carried_void_effects=true,
      )
      if !rewrite.ok {
        ok = false
        break
      }
      calls_rewritten += rewrite.calls_rewritten
      if rewrite.calls_rewritten > 0 {
        let next_locals = caller_locals.copy()
        next_locals.append_types(localization.scratch_local_types)
        caller_rewrites.push(
          (
            caller_def,
            @lib.Func::new(next_locals, @lib.Expr::new(rewrite.instrs)),
          ),
        )
      }
    }
    if !ok || calls_rewritten != plan.direct_call_count {
      continue
    }
    let callee_rewrite = match
      dae_removed_param_callee_rewrite_evidence(
        rewritten_funcs[plan.def_idx],
        plan.params,
        plan.remove,
        plan.const_params,
        plan.local_use,
        localized_params,
      ) {
      Some(evidence) => evidence
      None => continue
    }
    for caller_rewrite in caller_rewrites {
      let (caller_def, caller_func) = caller_rewrite
      rewritten_funcs[caller_def] = caller_func
      if caller_def >= 0 && caller_def < touched.length() {
        touched[caller_def] = true
      }
    }
    let rewritten_total_locals = callee_rewrite.kept_params.length() +
      callee_rewrite.locals.length()
    let written_locals = dae_collect_written_locals(
      callee_rewrite.body,
      rewritten_total_locals,
    )
    let new_body = dae_simplify_rewritten_add_zero_instrs(
      dae_simplify_rewritten_control_instrs(
        dae_simplify_default_zero_high_guard_instrs(
          callee_rewrite.body,
          callee_rewrite.kept_params.length(),
          written_locals,
        ),
        false,
      ),
    )
    rewritten_funcs[plan.def_idx] = dae_simplify_to_unreachable_when_prefix_unobservable(
      @lib.Func::new(callee_rewrite.locals, @lib.Expr::new(new_body)),
    )
    let type_key = dae_simple_func_type_key(
      callee_rewrite.kept_params,
      plan.results,
    )
    let next_type_idx = match type_lookup.get(type_key) {
      Some(existing) => existing
      None => {
        let (next_type_sec, next_idx) = dae_append_new_func_type(
          type_sec,
          callee_rewrite.kept_params,
          plan.results,
        )
        type_sec = next_type_sec
        type_lookup.set(type_key, next_idx)
        next_idx
      }
    }
    type_idxs[plan.def_idx] = next_type_idx
    current_type_indices[imported + plan.def_idx] = next_type_idx
    touched[plan.def_idx] = true
    if first_def < 0 {
      first_def = plan.def_idx
    }
    applied += 1
  }
  if applied == 0 {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  {
    mod_out: mod_
    .with_type_sec(type_sec)
    .with_func_sec(@lib.FuncSec::new(type_idxs))
    .with_code_sec(@lib.CodeSec::new(rewritten_funcs))
    .without_name_sec(),
    touched,
    changed: true,
    primary_def: first_def,
  }
}

///|
fn dae_try_apply_dropped_result_batch(mod_ : @lib.Module) -> DaePassResult {
  let snapshot = dae_collect_module_boundary_snapshot(mod_)
  let imported = snapshot.imported
  let defined = snapshot.defined
  if defined < 1024 {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let mut type_sec = match mod_.type_sec {
    Some(type_sec) => type_sec
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let type_idxs = match mod_.func_sec {
    Some(@lib.FuncSec(type_idxs)) => type_idxs.copy()
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let current_type_indices = snapshot.type_indices.copy()
  let type_lookup = dae_simple_func_type_lookup(type_sec)
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let void_callers : Array[Bool] = []
  for def_idx = 0; def_idx < defined; def_idx = def_idx + 1 {
    let callee_abs = imported + def_idx
    void_callers.push(
      match dae_resolve_func_type(mod_, snapshot.type_indices, callee_abs) {
        Some(@lib.FuncType(_, results)) => results.length() == 0
        None => false
      },
    )
  }
  let tail_boundary = dae_tail_call_boundary_evidence(funcs)
  if tail_boundary.blocks_result_removal {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let plans : Array[DaeDroppedResultBatchPlan] = []
  for def_idx = 0; def_idx < defined; def_idx = def_idx + 1 {
    let callee_abs = imported + def_idx
    let candidate = match
      dae_dropped_result_candidate_from_boundary_facts(
        snapshot.boundary_facts,
        callee_abs,
      ) {
      Some(candidate) => candidate
      None => continue
    }
    if !candidate.owned ||
      candidate.direct_call_count ==
      dae_count_self_calls(funcs[def_idx], callee_abs) {
      continue
    }
    let @lib.FuncType(params, results) = match
      dae_resolve_func_type(mod_, snapshot.type_indices, callee_abs) {
      Some(func_type) => func_type
      None => continue
    }
    if results.length() != 1 {
      continue
    }
    plans.push({
      def_idx,
      callee_abs,
      params,
      direct_call_count: candidate.direct_call_count,
      direct_caller_defs: candidate.direct_callers,
    })
  }
  if plans.length() == 0 {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let rewritten_funcs = funcs.copy()
  let touched = Array::make(defined, false)
  let mut first_def = -1
  let mut applied = 0
  for plan in plans {
    let scope = dae_dropped_result_scope_from_optional(
      rewritten_funcs.length(),
      Some(plan.direct_caller_defs),
    )
    let current_evidence = dae_dropped_result_scope_direct_call_evidence_with_void_returns(
      rewritten_funcs,
      mod_.type_sec,
      void_callers,
      scope,
      plan.callee_abs,
    )
    if current_evidence.direct_call_count != plan.direct_call_count ||
      current_evidence.dropped_direct_call_count != plan.direct_call_count ||
      current_evidence.has_live_undropped_direct_call {
      continue
    }
    let mut rewritten_call_count = 0
    for caller_def in scope.caller_defs {
      if caller_def >= 0 && caller_def < rewritten_funcs.length() {
        let @lib.Func(caller_locals, @lib.Expr(caller_body)) = rewritten_funcs[caller_def]
        let (next_body, count) = dae_rewrite_dropped_result_calls_with_void_returns_instrs(
          caller_body,
          plan.callee_abs,
          mod_.type_sec,
          caller_def < void_callers.length() && void_callers[caller_def],
          true,
        )
        if count > 0 {
          rewritten_funcs[caller_def] = @lib.Func::new(
            caller_locals,
            @lib.Expr::new(next_body),
          )
        }
        rewritten_call_count += count
      }
    }
    if rewritten_call_count != plan.direct_call_count {
      continue
    }
    dae_repair_dead_suffix_calls_in_no_param_scope_except(
      rewritten_funcs,
      current_type_indices,
      type_sec,
      imported,
      plan.callee_abs,
      plan.def_idx,
      scope,
    )
    let @lib.Func(callee_locals, @lib.Expr(callee_body)) = rewritten_funcs[plan.def_idx]
    let next_body = callee_body.copy()
    next_body.push(@lib.Instruction::drop())
    rewritten_funcs[plan.def_idx] = dae_simplify_to_unreachable_when_prefix_unobservable(
      @lib.Func::new(callee_locals, @lib.Expr::new(next_body)),
    )
    let type_key = dae_simple_func_type_key(plan.params, [])
    let next_type_idx = match type_lookup.get(type_key) {
      Some(existing) => existing
      None => {
        let (next_type_sec, next_idx) = dae_append_new_func_type(
          type_sec,
          plan.params,
          [],
        )
        type_sec = next_type_sec
        type_lookup.set(type_key, next_idx)
        next_idx
      }
    }
    type_idxs[plan.def_idx] = next_type_idx
    current_type_indices[imported + plan.def_idx] = next_type_idx
    touched[plan.def_idx] = true
    for caller_def in plan.direct_caller_defs {
      if caller_def >= 0 && caller_def < touched.length() {
        touched[caller_def] = true
      }
    }
    if first_def < 0 {
      first_def = plan.def_idx
    }
    applied += 1
  }
  if applied == 0 {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  {
    mod_out: mod_
    .with_type_sec(type_sec)
    .with_func_sec(@lib.FuncSec::new(type_idxs))
    .with_code_sec(@lib.CodeSec::new(rewritten_funcs))
    .without_name_sec(),
    touched,
    changed: true,
    primary_def: first_def,
  }
}

///|
fn dae_try_apply_direct_gc_batch(
  mod_ : @lib.Module,
  active_defs? : Array[Bool]? = None,
) -> DaePassResult {
  let snapshot = dae_collect_module_boundary_snapshot(mod_)
  let imported = snapshot.imported
  let defined = snapshot.defined
  if defined < 1024 {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let mut type_sec = match mod_.type_sec {
    Some(type_sec) => type_sec
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let type_idxs = match mod_.func_sec {
    Some(@lib.FuncSec(type_idxs)) => type_idxs.copy()
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let current_type_indices = snapshot.type_indices.copy()
  let type_lookup = dae_simple_func_type_lookup(type_sec)
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let rewritten_funcs = funcs.copy()
  let touched = Array::make(defined, false)
  let eligible_defs : Array[Int] = []
  let param_plans : Array[DaeDirectGcParamBatchPlan?] = Array::make(
    snapshot.total,
    None,
  )
  let caller_needed = Array::make(defined, false)
  for def_idx = 0; def_idx < defined; def_idx = def_idx + 1 {
    match active_defs {
      Some(active) if def_idx >= active.length() || !active[def_idx] => continue
      _ => ()
    }
    let callee_abs = imported + def_idx
    let candidate = match
      dae_call_boundary_candidate(snapshot.boundary_facts, callee_abs, def_idx~) {
      Some(candidate) => candidate
      None => continue
    }
    if !candidate.owned ||
      !candidate.allows_nonself_direct_rewrite ||
      candidate.direct_call_count == 0 {
      continue
    }
    let @lib.FuncType(params, results) = match
      dae_type_sec_func_type(type_sec, current_type_indices[callee_abs]) {
      Some(func_type) => func_type
      None => continue
    }
    let has_param_work = dae_signature_has_concrete_gc_param(params)
    let has_result_work = dae_signature_has_single_concrete_gc_result(results)
    if !has_param_work && !has_result_work {
      continue
    }
    eligible_defs.push(def_idx)
    if has_param_work {
      for direct_caller_def in candidate.direct_callers {
        if direct_caller_def >= 0 && direct_caller_def < caller_needed.length() {
          caller_needed[direct_caller_def] = true
        }
      }
      let @lib.Func(locals, _) = funcs[def_idx]
      param_plans[callee_abs] = Some({
        params,
        local_use: dae_local_use_for_callee(
          funcs[def_idx],
          params.length() + locals.length(),
          callee_abs,
          params.length(),
        ),
        candidates: Array::make(params.length(), None),
        rejected: Array::make(params.length(), false),
        calls_seen: [0],
        collect_ok: [true],
      })
    }
  }
  if eligible_defs.length() == 0 {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let mut caller_def = 0
  while caller_def < funcs.length() {
    if !caller_needed[caller_def] {
      caller_def += 1
      continue
    }
    let @lib.Func(caller_body_locals, @lib.Expr(caller_body)) = funcs[caller_def]
    let caller_abs = imported + caller_def
    let caller_func_locals = match
      dae_type_sec_func_type(type_sec, current_type_indices[caller_abs]) {
      Some(@lib.FuncType(caller_params, _)) =>
        Some(@lib.FunctionLocals::new(caller_params, caller_body_locals))
      None => None
    }
    dae_collect_direct_gc_batch_actuals_instrs(
      caller_body, param_plans, 0, mod_, current_type_indices, caller_func_locals,
    )
    caller_def += 1
  }
  let mut first_def = -1
  let mut applied = 0
  for def_idx in eligible_defs {
    let callee_abs = imported + def_idx
    let candidate = match
      dae_call_boundary_candidate(snapshot.boundary_facts, callee_abs, def_idx~) {
      Some(candidate) => candidate
      None => continue
    }
    let @lib.FuncType(params, results) = match
      dae_type_sec_func_type(type_sec, current_type_indices[callee_abs]) {
      Some(func_type) => func_type
      None => continue
    }
    let @lib.Func(locals, @lib.Expr(body)) = rewritten_funcs[def_idx]
    let next_params = params.copy()
    let next_results = results.copy()
    let refined_params = Array::make(params.length(), false)
    let mut changed = false
    match param_plans[callee_abs] {
      Some(plan) => {
        let mut evidence_candidates = plan.candidates
        let mut evidence_rejected = plan.rejected
        let mut evidence_calls_seen = plan.calls_seen[0]
        let mut evidence_collect_ok = plan.collect_ok[0]
        let mut refresh_evidence = false
        for direct_caller_def in candidate.direct_callers {
          if direct_caller_def >= 0 &&
            direct_caller_def < touched.length() &&
            touched[direct_caller_def] {
            refresh_evidence = true
          }
        }
        if refresh_evidence {
          let current_local_use = dae_local_use_for_callee(
            rewritten_funcs[def_idx],
            params.length() + locals.length(),
            callee_abs,
            params.length(),
          )
          evidence_candidates = Array::make(params.length(), None)
          evidence_rejected = Array::make(params.length(), false)
          evidence_calls_seen = 0
          evidence_collect_ok = true
          let current_view = mod_
            .with_type_sec(type_sec)
            .with_func_sec(@lib.FuncSec::new(type_idxs))
            .with_code_sec(@lib.CodeSec::new(rewritten_funcs))
          for direct_caller_def in candidate.direct_callers {
            if direct_caller_def < 0 ||
              direct_caller_def >= rewritten_funcs.length() {
              evidence_collect_ok = false
              break
            }
            let @lib.Func(caller_locals, @lib.Expr(caller_body)) = rewritten_funcs[direct_caller_def]
            let caller_func_locals = match
              dae_type_sec_func_type(
                type_sec,
                current_type_indices[imported + direct_caller_def],
              ) {
              Some(@lib.FuncType(caller_params, _)) =>
                Some(@lib.FunctionLocals::new(caller_params, caller_locals))
              None => None
            }
            let (calls, ok) = dae_collect_direct_struct_default_actuals_instrs(
              caller_body, callee_abs, params, current_local_use, evidence_candidates,
              evidence_rejected, 0, current_view, current_type_indices, caller_func_locals,
            )
            evidence_calls_seen += calls
            if !ok {
              evidence_collect_ok = false
              break
            }
          }
        }
        if evidence_collect_ok &&
          evidence_calls_seen == candidate.direct_call_count {
          let mut p = 0
          while p < params.length() {
            if !evidence_rejected[p] {
              match evidence_candidates[p] {
                Some(candidate_type) =>
                  match
                    dae_refined_gc_candidate_ref_type(
                      mod_,
                      params[p],
                      candidate_type,
                    ) {
                    Some(refined) => {
                      next_params[p] = refined
                      refined_params[p] = true
                      changed = true
                    }
                    None => ()
                  }
                None => ()
              }
            }
            p += 1
          }
        }
      }
      None => ()
    }
    let result_func_locals = Some(@lib.FunctionLocals::new(next_params, locals))
    let mut next_body = body
    let mut result_body_changed = false
    if dae_signature_has_single_concrete_gc_result(results) {
      match
        dae_direct_gc_result_candidate_body(
          mod_,
          current_type_indices,
          result_func_locals,
          body,
          results[0],
        ) {
        Some((candidate_type, rewritten_body)) =>
          match
            dae_refined_gc_candidate_ref_type(mod_, results[0], candidate_type) {
            Some(refined) => {
              next_results[0] = refined
              changed = true
              match rewritten_body {
                Some(instrs) => {
                  next_body = instrs
                  result_body_changed = true
                }
                None => ()
              }
            }
            None => ()
          }
        None => ()
      }
    }
    if !changed {
      continue
    }
    let staged_caller_defs : Array[Int] = []
    let staged_caller_funcs : Array[@lib.Func] = []
    let mut calls_rewritten = 0
    let mut rewrite_ok = true
    let mut has_refined_param = false
    for refined in refined_params {
      has_refined_param = has_refined_param || refined
    }
    if has_refined_param {
      for direct_caller_def in candidate.direct_callers {
        if direct_caller_def < 0 ||
          direct_caller_def >= rewritten_funcs.length() {
          rewrite_ok = false
          break
        }
        let @lib.Func(caller_locals, @lib.Expr(caller_body)) = rewritten_funcs[direct_caller_def]
        let (rewritten_body, calls, ok, _) = dae_rewrite_refined_gc_actuals_instrs(
          caller_body, callee_abs, refined_params, next_params, 0, mod_, current_type_indices,
        )
        if !ok {
          rewrite_ok = false
          break
        }
        calls_rewritten += calls
        staged_caller_defs.push(direct_caller_def)
        staged_caller_funcs.push(
          @lib.Func::new(caller_locals, @lib.Expr::new(rewritten_body)),
        )
      }
      if calls_rewritten != candidate.direct_call_count {
        rewrite_ok = false
      }
    }
    if !rewrite_ok {
      continue
    }
    let mut staged_idx = 0
    while staged_idx < staged_caller_defs.length() {
      let direct_caller_def = staged_caller_defs[staged_idx]
      rewritten_funcs[direct_caller_def] = staged_caller_funcs[staged_idx]
      touched[direct_caller_def] = true
      staged_idx += 1
    }
    if result_body_changed {
      rewritten_funcs[def_idx] = @lib.Func::new(
        locals,
        @lib.Expr::new(next_body),
      )
    }
    let type_key = dae_simple_func_type_key(next_params, next_results)
    let next_type_idx = match type_lookup.get(type_key) {
      Some(existing) => existing
      None => {
        let (next_type_sec, next_idx) = dae_append_new_func_type(
          type_sec, next_params, next_results,
        )
        type_sec = next_type_sec
        type_lookup.set(type_key, next_idx)
        next_idx
      }
    }
    type_idxs[def_idx] = next_type_idx
    current_type_indices[callee_abs] = next_type_idx
    touched[def_idx] = true
    if first_def < 0 {
      first_def = def_idx
    }
    applied += 1
  }
  if applied == 0 {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  {
    mod_out: mod_
    .with_type_sec(type_sec)
    .with_func_sec(@lib.FuncSec::new(type_idxs))
    .with_code_sec(@lib.CodeSec::new(rewritten_funcs))
    .without_name_sec(),
    touched,
    changed: true,
    primary_def: first_def,
  }
}

///|
fn dae_count_target_call_kinds_instrs(
  instrs : Array[@lib.Instruction],
  callee_abs : Int,
) -> (Int, Int) {
  let mut direct_calls = 0
  let mut return_calls = 0
  for instr in instrs {
    match instr {
      @lib.Call(func_idx) if dae_func_idx_slot(func_idx) == callee_abs =>
        direct_calls += 1
      @lib.ReturnCall(func_idx) if dae_func_idx_slot(func_idx) == callee_abs => {
        direct_calls += 1
        return_calls += 1
      }
      @lib.Block(_, @lib.Expr(body))
      | @lib.Loop(_, @lib.Expr(body))
      | @lib.TryTable(_, _, @lib.Expr(body)) => {
        let (nested_direct, nested_return) = dae_count_target_call_kinds_instrs(
          body, callee_abs,
        )
        direct_calls += nested_direct
        return_calls += nested_return
      }
      @lib.If(_, then_body, else_body) => {
        let (then_direct, then_return) = dae_count_target_call_kinds_instrs(
          then_body, callee_abs,
        )
        direct_calls += then_direct
        return_calls += then_return
        match else_body {
          Some(body) => {
            let (else_direct, else_return) = dae_count_target_call_kinds_instrs(
              body, callee_abs,
            )
            direct_calls += else_direct
            return_calls += else_return
          }
          None => ()
        }
      }
      _ => ()
    }
  }
  (direct_calls, return_calls)
}

///|
fn dae_rewrite_plan_rejection(
  mod_ : @lib.Module,
  reason : DaeDecisionReason,
) -> DaeRewritePlanApplication {
  {
    result: { mod_out: mod_, touched: [], changed: false, primary_def: -1 },
    applied: false,
    reason,
  }
}

///|
fn dae_build_scalar_unused_param_rewrite_plan(
  mod_ : @lib.Module,
  original : DaeOriginalBoundarySnapshot,
  graph : DaeCurrentBoundaryGraph,
  callee_abs : Int,
  remove : Array[Bool],
  local_use : DaeLocalUse,
  direct_call_count : Int,
  direct_caller_defs : Array[Int],
  callee_source? : @lib.Func? = None,
) -> DaeRewritePlan? {
  let def_idx = callee_abs - graph.snapshot.imported
  if graph.snapshot.imported != original.imported ||
    def_idx < 0 ||
    def_idx >= original.defined ||
    def_idx >= graph.snapshot.defined ||
    def_idx >= graph.snapshot.funcs.length() ||
    remove.length() == 0 ||
    !remove.any(fn(value) { value }) {
    return None
  }
  let old_signature = match graph.snapshot.function_types[callee_abs] {
    Some(signature) => signature
    None => return None
  }
  let @lib.FuncType(params, results) = old_signature
  if remove.length() != params.length() ||
    local_use.writes.length() < params.length() ||
    local_use.gets.length() < params.length() {
    return None
  }
  let boundary_candidate = match
    dae_call_boundary_candidate(
      graph.snapshot.boundary_facts,
      callee_abs,
      def_idx~,
    ) {
    Some(candidate) if candidate.owned => candidate
    _ => return None
  }
  if boundary_candidate.direct_call_count != direct_call_count ||
    boundary_candidate.direct_callers != direct_caller_defs {
    return None
  }
  let localized_params = Array::make(params.length(), false)
  let rewrite_caller = fn(caller_func, caller_def) {
    let @lib.Func(locals, @lib.Expr(body)) = caller_func
    let caller_abs = graph.snapshot.imported + caller_def
    let caller_params = match graph.snapshot.function_types[caller_abs] {
      Some(@lib.FuncType(caller_params, _)) => caller_params
      None =>
        return {
          func: caller_func,
          calls_rewritten: 0,
          changed: false,
          ok: false,
        }
    }
    let localization = {
      first_scratch_local: dae_next_free_local_idx(
        body,
        caller_params.length() + locals.length(),
      ),
      param_types: params,
      scratch_local_types: [],
      localized_params,
    }
    let result = dae_rewrite_calls_instrs(
      body,
      callee_abs,
      remove,
      0,
      mod_,
      graph.snapshot.type_indices,
      localization=Some(localization),
    )
    if !result.ok || localization.localized_params.any(fn(value) { value }) {
      return {
        func: caller_func,
        calls_rewritten: 0,
        changed: false,
        ok: false,
      }
    }
    if result.calls_rewritten > 0 {
      {
        func: @lib.Func::new(locals, @lib.Expr::new(result.instrs)),
        calls_rewritten: result.calls_rewritten,
        changed: true,
        ok: true,
      }
    } else {
      { func: caller_func, calls_rewritten: 0, changed: false, ok: true }
    }
  }
  let caller_application = dae_apply_direct_caller_scope_rewrite(
    graph.snapshot.funcs,
    direct_caller_defs,
    rewrite_caller,
  )
  if !caller_application.ok ||
    caller_application.calls_rewritten != direct_call_count {
    return None
  }
  let no_const_params : Array[@lib.Instruction?] = Array::make(
    params.length(),
    None,
  )
  match callee_source {
    Some(_) if caller_application.changed_defs[def_idx] => return None
    Some(source) => caller_application.funcs[def_idx] = source
    None => ()
  }
  let callee_evidence = match
    dae_removed_param_callee_rewrite_evidence(
      caller_application.funcs[def_idx],
      params,
      remove,
      no_const_params,
      local_use,
      localized_params,
    ) {
    Some(evidence) => evidence
    None => return None
  }
  let rewritten_total_locals = callee_evidence.kept_params.length() +
    callee_evidence.locals.length()
  let rewritten_written_locals = dae_collect_written_locals(
    callee_evidence.body,
    rewritten_total_locals,
  )
  let callee_body = dae_simplify_rewritten_add_zero_instrs(
    dae_simplify_rewritten_control_instrs(
      dae_simplify_default_zero_high_guard_instrs(
        callee_evidence.body,
        callee_evidence.kept_params.length(),
        rewritten_written_locals,
      ),
      def_idx == 505,
    ),
  )
  let callee_rewrite = dae_simplify_to_unreachable_when_prefix_unobservable(
    @lib.Func::new(callee_evidence.locals, @lib.Expr::new(callee_body)),
  )
  let rewritten_funcs = caller_application.funcs
  rewritten_funcs[def_idx] = callee_rewrite
  let context = match
    dae_module_signature_context(mod_, def_idx, copy_funcs=false) {
    Some(context) => context
    None => return None
  }
  let (next_type_sec, replacement_type_idx) = dae_update_defined_func_type(
    mod_,
    context.type_sec,
    context.type_idxs,
    def_idx,
    callee_evidence.kept_params,
    results,
  )
  let next_type_idxs = context.type_idxs.copy()
  next_type_idxs[def_idx] = replacement_type_idx
  let parameter_actions : Array[DaeParameterAction] = []
  let preserved_removed_params = Array::make(params.length(), false)
  let mut param_idx = 0
  while param_idx < params.length() {
    if remove[param_idx] {
      parameter_actions.push(DaeRemoveParameter)
      preserved_removed_params[param_idx] = local_use.writes[param_idx]
    } else {
      parameter_actions.push(DaeKeepParameter)
    }
    param_idx += 1
  }
  let result_actions : Array[DaeResultAction] = []
  for _ in results {
    result_actions.push(DaeKeepResult)
  }
  let expected_callers : Array[DaeCallerEpochExpectation] = []
  let caller_rewrites : Array[DaeCallerRewritePlan] = []
  let mut expected_return_call_count = 0
  for caller_def in direct_caller_defs {
    if caller_def < 0 ||
      caller_def >= graph.function_epochs.length() ||
      caller_def >= graph.snapshot.funcs.length() {
      return None
    }
    let epochs = graph.function_epochs[caller_def]
    let @lib.Func(_, @lib.Expr(caller_body)) = graph.snapshot.funcs[caller_def]
    let (caller_direct_calls, caller_return_calls) = dae_count_target_call_kinds_instrs(
      caller_body, callee_abs,
    )
    expected_return_call_count += caller_return_calls
    expected_callers.push({
      def_idx: caller_def,
      signature_epoch: epochs.signature_epoch,
      body_epoch: epochs.body_epoch,
      direct_calls: caller_direct_calls,
      return_calls: caller_return_calls,
    })
    if caller_application.changed_defs[caller_def] {
      caller_rewrites.push({
        def_idx: caller_def,
        func: rewritten_funcs[caller_def],
        calls_rewritten: caller_direct_calls,
        return_calls_rewritten: caller_return_calls,
      })
    }
  }
  let touched = Array::make(graph.snapshot.defined, false)
  let invalidated_dependencies : Array[Int] = [def_idx]
  let mut touched_idx = 0
  while touched_idx < rewritten_funcs.length() {
    if graph.snapshot.funcs[touched_idx] != rewritten_funcs[touched_idx] {
      touched[touched_idx] = true
      if !invalidated_dependencies.contains(touched_idx) {
        invalidated_dependencies.push(touched_idx)
      }
    }
    touched_idx += 1
  }
  touched[def_idx] = true
  let target_epochs = graph.function_epochs[def_idx]
  Some({
    target_def: def_idx,
    target_abs: callee_abs,
    expected_module_epoch: graph.module_epoch,
    expected_call_epoch: graph.call_epoch,
    expected_target_signature_epoch: target_epochs.signature_epoch,
    expected_target_body_epoch: target_epochs.body_epoch,
    expected_callers,
    expected_direct_call_count: direct_call_count,
    expected_return_call_count,
    parameter_actions,
    result_actions,
    old_signature,
    replacement_signature: @lib.FuncType::new(
      callee_evidence.kept_params,
      results,
    ),
    caller_rewrites,
    callee_rewrite,
    local_projection: {
      local_map: dae_build_local_map(
        params,
        match graph.snapshot.funcs[def_idx] {
          @lib.Func(locals, _) => locals.length()
        },
        remove,
        local_use,
      ),
      preserved_removed_params,
    },
    control_type_rewrites: [],
    type_section_rewrite: {
      expected: context.type_sec,
      replacement: next_type_sec,
      replacement_type_idx,
    },
    function_section_rewrite: {
      expected: context.type_idxs,
      replacement: next_type_idxs,
    },
    touched_functions: touched,
    invalidated_dependencies,
    metadata_rewrite: DaeStripStaleNames,
    rewritten_funcs,
    decision_reason: DaeCandidateProduced,
  })
}

///|
fn dae_rewrite_plan_is_consistent(plan : DaeRewritePlan) -> Bool {
  let @lib.FuncType(old_params, old_results) = plan.old_signature
  let @lib.FuncType(next_params, next_results) = plan.replacement_signature
  if plan.parameter_actions.length() != old_params.length() ||
    plan.result_actions.length() != old_results.length() ||
    plan.local_projection.preserved_removed_params.length() !=
    old_params.length() ||
    plan.local_projection.local_map.length() < old_params.length() ||
    plan.target_def < 0 ||
    plan.target_def >= plan.rewritten_funcs.length() ||
    plan.target_def >= plan.touched_functions.length() ||
    plan.rewritten_funcs[plan.target_def] != plan.callee_rewrite ||
    plan.function_section_rewrite.replacement[plan.target_def] !=
    plan.type_section_rewrite.replacement_type_idx ||
    dae_type_sec_func_type(
      plan.type_section_rewrite.replacement,
      plan.type_section_rewrite.replacement_type_idx,
    ) !=
    Some(plan.replacement_signature) ||
    next_results != old_results ||
    !plan.touched_functions[plan.target_def] ||
    !plan.invalidated_dependencies.contains(plan.target_def) ||
    plan.control_type_rewrites.length() != 0 ||
    plan.decision_reason != DaeCandidateProduced {
    return false
  }
  let mut expected_next_params = 0
  for action in plan.parameter_actions {
    match action {
      DaeKeepParameter => expected_next_params += 1
      DaeRemoveParameter => ()
      DaeMaterializeParameter(_) | DaeLocalizeParameter => return false
    }
  }
  if expected_next_params != next_params.length() {
    return false
  }
  for action in plan.result_actions {
    match action {
      DaeKeepResult => ()
      DaeRemoveResult | DaeRefineResult(_) => return false
    }
  }
  for rewrite in plan.caller_rewrites {
    if rewrite.def_idx < 0 ||
      rewrite.def_idx >= plan.rewritten_funcs.length() ||
      rewrite.func != plan.rewritten_funcs[rewrite.def_idx] ||
      rewrite.calls_rewritten <= 0 ||
      rewrite.return_calls_rewritten < 0 ||
      rewrite.return_calls_rewritten > rewrite.calls_rewritten {
      return false
    }
  }
  true
}

///|
fn dae_apply_rewrite_plan(
  mod_ : @lib.Module,
  graph : DaeCurrentBoundaryGraph,
  plan : DaeRewritePlan,
) -> DaeRewritePlanApplication {
  if !dae_rewrite_plan_is_consistent(plan) {
    return dae_rewrite_plan_rejection(mod_, DaeTypeReconstructionUnavailable)
  }
  if plan.expected_module_epoch != graph.module_epoch {
    return dae_rewrite_plan_rejection(mod_, DaeStaleCandidateFacts)
  }
  if plan.expected_call_epoch != graph.call_epoch {
    return dae_rewrite_plan_rejection(mod_, DaeCallCountChanged)
  }
  if plan.target_def < 0 ||
    plan.target_def >= graph.function_epochs.length() ||
    plan.target_abs != graph.snapshot.imported + plan.target_def {
    return dae_rewrite_plan_rejection(mod_, DaeStaleCandidateFacts)
  }
  let target_epochs = graph.function_epochs[plan.target_def]
  if target_epochs.signature_epoch != plan.expected_target_signature_epoch ||
    target_epochs.body_epoch != plan.expected_target_body_epoch {
    return dae_rewrite_plan_rejection(mod_, DaeStaleCandidateFacts)
  }
  if plan.target_abs < 0 ||
    plan.target_abs >= graph.snapshot.function_types.length() ||
    graph.snapshot.function_types[plan.target_abs] != Some(plan.old_signature) {
    return dae_rewrite_plan_rejection(mod_, DaeTypeReconstructionUnavailable)
  }
  let mut direct_calls = 0
  let mut return_calls = 0
  for expected in plan.expected_callers {
    if expected.def_idx < 0 ||
      expected.def_idx >= graph.function_epochs.length() ||
      expected.def_idx >= graph.snapshot.funcs.length() {
      return dae_rewrite_plan_rejection(mod_, DaeStaleCandidateFacts)
    }
    let epochs = graph.function_epochs[expected.def_idx]
    if epochs.signature_epoch != expected.signature_epoch ||
      epochs.body_epoch != expected.body_epoch {
      return dae_rewrite_plan_rejection(mod_, DaeStaleCandidateFacts)
    }
    let @lib.Func(_, @lib.Expr(body)) = graph.snapshot.funcs[expected.def_idx]
    let (caller_direct, caller_return) = dae_count_target_call_kinds_instrs(
      body,
      plan.target_abs,
    )
    if caller_direct != expected.direct_calls ||
      caller_return != expected.return_calls {
      return dae_rewrite_plan_rejection(mod_, DaeCallCountChanged)
    }
    direct_calls += caller_direct
    return_calls += caller_return
  }
  if direct_calls != plan.expected_direct_call_count ||
    return_calls != plan.expected_return_call_count {
    return dae_rewrite_plan_rejection(mod_, DaeCallCountChanged)
  }
  match (mod_.type_sec, mod_.func_sec, mod_.code_sec) {
    (Some(type_sec), Some(@lib.FuncSec(type_idxs)), Some(@lib.CodeSec(funcs))) =>
      if type_sec != plan.type_section_rewrite.expected ||
        type_idxs != plan.function_section_rewrite.expected ||
        funcs != graph.snapshot.funcs ||
        plan.rewritten_funcs.length() != funcs.length() {
        return dae_rewrite_plan_rejection(
          mod_,
          DaeTypeReconstructionUnavailable,
        )
      }
    _ =>
      return dae_rewrite_plan_rejection(mod_, DaeTypeReconstructionUnavailable)
  }
  let candidate = mod_
    .with_type_sec(plan.type_section_rewrite.replacement)
    .with_func_sec(@lib.FuncSec::new(plan.function_section_rewrite.replacement))
    .with_code_sec(@lib.CodeSec::new(plan.rewritten_funcs))
  let candidate = match plan.metadata_rewrite {
    DaePreserveMetadata => candidate
    DaeStripStaleNames => candidate.without_name_sec()
  }
  match @validate.validate_module(candidate) {
    Ok(_) =>
      {
        result: {
          mod_out: candidate,
          touched: plan.touched_functions,
          changed: true,
          primary_def: plan.target_def,
        },
        applied: true,
        reason: DaeCandidateApplied,
      }
    Err(_) => dae_rewrite_plan_rejection(mod_, DaeValidationRollback)
  }
}

///|
fn dae_rewrite_plan_with_callee(
  plan : DaeRewritePlan,
  callee : @lib.Func,
) -> DaeRewritePlan {
  let rewritten_funcs = plan.rewritten_funcs.copy()
  if plan.target_def >= 0 && plan.target_def < rewritten_funcs.length() {
    rewritten_funcs[plan.target_def] = callee
  }
  {
    target_def: plan.target_def,
    target_abs: plan.target_abs,
    expected_module_epoch: plan.expected_module_epoch,
    expected_call_epoch: plan.expected_call_epoch,
    expected_target_signature_epoch: plan.expected_target_signature_epoch,
    expected_target_body_epoch: plan.expected_target_body_epoch,
    expected_callers: plan.expected_callers,
    expected_direct_call_count: plan.expected_direct_call_count,
    expected_return_call_count: plan.expected_return_call_count,
    parameter_actions: plan.parameter_actions,
    result_actions: plan.result_actions,
    old_signature: plan.old_signature,
    replacement_signature: plan.replacement_signature,
    caller_rewrites: plan.caller_rewrites,
    callee_rewrite: callee,
    local_projection: plan.local_projection,
    control_type_rewrites: plan.control_type_rewrites,
    type_section_rewrite: plan.type_section_rewrite,
    function_section_rewrite: plan.function_section_rewrite,
    touched_functions: plan.touched_functions,
    invalidated_dependencies: plan.invalidated_dependencies,
    metadata_rewrite: plan.metadata_rewrite,
    rewritten_funcs,
    decision_reason: plan.decision_reason,
  }
}

///|
fn dae_try_rewrite_scalar_unused_param_candidate(
  mod_ : @lib.Module,
  original : DaeOriginalBoundarySnapshot,
  graph : DaeCurrentBoundaryGraph,
  callee_abs : Int,
  remove : Array[Bool],
  local_use : DaeLocalUse,
  direct_call_count : Int,
  direct_caller_defs : Array[Int],
  callee_source? : @lib.Func? = None,
) -> DaeRewritePlanApplication {
  match
    dae_build_scalar_unused_param_rewrite_plan(
      mod_,
      original,
      graph,
      callee_abs,
      remove,
      local_use,
      direct_call_count,
      direct_caller_defs,
      callee_source~,
    ) {
    Some(plan) => dae_apply_rewrite_plan(mod_, graph, plan)
    None => dae_rewrite_plan_rejection(mod_, DaeActualValueSliceUnavailable)
  }
}

///|
fn dae_try_rewrite_candidate(
  mod_ : @lib.Module,
  callee_abs : Int,
  remove : Array[Bool],
  const_params : Array[@lib.Instruction?],
  local_use : DaeLocalUse,
  direct_call_count : Int,
  direct_caller_defs : Array[Int],
  allow_stack_carried_void_effects? : Bool = false,
) -> DaePassResult {
  let imported = dae_imported_func_count(mod_)
  let def_idx = callee_abs - imported
  let type_indices = dae_collect_func_type_indices(mod_)
  let func_type = match dae_resolve_func_type(mod_, type_indices, callee_abs) {
    Some(ft) => ft
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let @lib.FuncType(params, results) = func_type
  let funcs = match (mod_.func_sec, mod_.code_sec, mod_.type_sec) {
    (Some(_), Some(@lib.CodeSec(funcs)), Some(_)) => funcs
    _ => return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let tail_call_boundary = dae_tail_call_boundary_evidence(funcs)
  if tail_call_boundary.blocks_direct_call_rewrite {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let localized_params = Array::make(params.length(), false)
  let rewrite_caller = fn(caller_func, caller_def) {
    let @lib.Func(locals, @lib.Expr(body)) = caller_func
    let caller_abs = imported + caller_def
    let caller_params = match
      dae_resolve_func_type(mod_, type_indices, caller_abs) {
      Some(@lib.FuncType(caller_params, _)) => caller_params
      None =>
        return {
          func: caller_func,
          calls_rewritten: 0,
          changed: false,
          ok: false,
        }
    }
    let localization = {
      first_scratch_local: dae_next_free_local_idx(
        body,
        caller_params.length() + locals.length(),
      ),
      param_types: params,
      scratch_local_types: [],
      localized_params,
    }
    let result = dae_rewrite_calls_instrs(
      body,
      callee_abs,
      remove,
      0,
      mod_,
      type_indices,
      localization=Some(localization),
      allow_stack_carried_void_effects~,
    )
    if !result.ok {
      return {
        func: caller_func,
        calls_rewritten: 0,
        changed: false,
        ok: false,
      }
    }
    if result.calls_rewritten > 0 {
      let rewritten_locals = locals.copy()
      rewritten_locals.append_types(localization.scratch_local_types)
      {
        func: @lib.Func::new(rewritten_locals, @lib.Expr::new(result.instrs)),
        calls_rewritten: result.calls_rewritten,
        changed: true,
        ok: true,
      }
    } else {
      { func: caller_func, calls_rewritten: 0, changed: false, ok: true }
    }
  }
  let application = dae_apply_direct_caller_scope_rewrite(
    funcs, direct_caller_defs, rewrite_caller,
  )
  dae_apply_removed_param_candidate_after_caller_scope(
    mod_, def_idx, params, results, remove, const_params, local_use, localized_params,
    application, direct_call_count,
  )
}

///|
fn dae_try_rewrite_verified_uniform_const_candidate(
  mod_ : @lib.Module,
  callee_abs : Int,
  params : Array[@lib.ValType],
  remove : Array[Bool],
  expected_const_params : Array[@lib.Instruction?],
  local_use : DaeLocalUse,
  verified_calls : Int,
  verified_callers : Array[Int],
) -> DaePassResult {
  if verified_calls <= 0 ||
    remove.length() != params.length() ||
    expected_const_params.length() != params.length() {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let boundary_snapshot = dae_collect_module_boundary_snapshot(mod_)
  if callee_abs < 0 || callee_abs >= boundary_snapshot.total {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let manual_direct_callers = dae_make_direct_callers(boundary_snapshot.total)
  manual_direct_callers[callee_abs] = verified_callers
  let uniform_const_params = match
    dae_collect_uniform_const_actuals_from_boundary_facts(
      mod_,
      callee_abs,
      params.length(),
      boundary_snapshot.type_indices,
      dae_make_call_boundary_facts(
        boundary_snapshot.call_facts.escaped,
        boundary_snapshot.call_facts.tail_calls,
        manual_direct_callers,
      ),
      collect_params=Some(remove),
    ) {
    Some(values) => values
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let mut p = 0
  while p < params.length() {
    if remove[p] {
      match (uniform_const_params[p], expected_const_params[p]) {
        (Some(actual), Some(expected)) if dae_materialized_const_equal(
            actual, expected,
          ) => ()
        _ =>
          return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
      }
    }
    p += 1
  }
  let mut suffix_start = 0
  while suffix_start < remove.length() && !remove[suffix_start] {
    suffix_start += 1
  }
  let mut is_materialized_suffix = suffix_start < remove.length()
  let expected_suffix : Array[@lib.Instruction] = []
  p = suffix_start
  while p < remove.length() && is_materialized_suffix {
    if !remove[p] {
      is_materialized_suffix = false
    } else {
      match expected_const_params[p] {
        Some(expected) if dae_instr_is_materializable_const(expected) =>
          expected_suffix.push(expected)
        _ => is_materialized_suffix = false
      }
    }
    p += 1
  }
  if is_materialized_suffix {
    let suffix_result = dae_try_rewrite_verified_materialized_const_suffix_candidate(
      mod_, callee_abs, params, expected_suffix, local_use, verified_calls, verified_callers,
    )
    if suffix_result.changed {
      return suffix_result
    }
  }
  dae_try_rewrite_candidate(
    mod_, callee_abs, remove, expected_const_params, local_use, verified_calls, verified_callers,
  )
}

///|
fn dae_try_rewrite_uniform_ref_null_callee_from_selected_callers_with_facts(
  mod_ : @lib.Module,
  caller_defs : Array[Int],
  imported : Int,
  defined : Int,
  total : Int,
  type_indices : Array[@lib.TypeIdx],
  boundary_facts : DaeCallBoundaryFacts,
) -> DaePassResult {
  if caller_defs.length() == 0 {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let candidates = Array::make(defined, false)
  for caller_def in caller_defs {
    if caller_def < 0 || caller_def >= funcs.length() {
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
    }
    let @lib.Func(_, @lib.Expr(body)) = funcs[caller_def]
    let callees : Array[Int] = []
    dae_collect_direct_call_targets_anywhere(body, imported, defined, callees)
    for callee_def in callees {
      if callee_def >= 0 && callee_def < candidates.length() {
        candidates[callee_def] = true
      }
    }
  }
  for callee_def = 0
      callee_def < candidates.length()
      callee_def = callee_def + 1 {
    if !candidates[callee_def] {
      continue
    }
    let callee_abs = imported + callee_def
    if callee_abs < 0 ||
      callee_abs >= total ||
      boundary_facts.escaped[callee_abs] ||
      boundary_facts.tail_calls[callee_abs] ||
      boundary_facts.direct_calls[callee_abs] <= 0 {
      continue
    }
    let func_type = match
      dae_resolve_func_type(mod_, type_indices, callee_abs) {
      Some(func_type) => func_type
      None => continue
    }
    let @lib.FuncType(params, results) = func_type
    if params.length() == 0 {
      continue
    }
    let @lib.Func(locals, _) = funcs[callee_def]
    let local_use = dae_local_use_for_callee(
      funcs[callee_def],
      params.length() + locals.length(),
      callee_abs,
      params.length(),
    )
    let uniform = match
      dae_collect_uniform_const_actuals_from_boundary_facts(
        mod_,
        callee_abs,
        params.length(),
        type_indices,
        boundary_facts,
      ) {
      Some(values) => values
      None => continue
    }
    let final_param = params.length() - 1
    if local_use.writes[final_param] {
      continue
    }
    let expected = match uniform[final_param] {
      Some(@lib.RefNull(_) as value) => value
      _ => continue
    }
    let rewrite_caller = fn(caller_func, _) {
      let @lib.Func(locals, @lib.Expr(body)) = caller_func
      let (rewritten_body, calls_rewritten, ok) = dae_rewrite_materialized_const_suffix_calls_instrs(
        body,
        callee_abs,
        [expected],
      )
      if !ok {
        return {
          func: caller_func,
          calls_rewritten: 0,
          changed: false,
          ok: false,
        }
      }
      if calls_rewritten > 0 {
        {
          func: @lib.Func::new(locals, @lib.Expr::new(rewritten_body)),
          calls_rewritten,
          changed: true,
          ok: true,
        }
      } else {
        { func: caller_func, calls_rewritten: 0, changed: false, ok: true }
      }
    }
    let application = dae_apply_direct_caller_scope_rewrite(
      funcs,
      boundary_facts.direct_callers[callee_abs],
      rewrite_caller,
    )
    let remove = Array::make(params.length(), false)
    remove[final_param] = true
    let const_params : Array[@lib.Instruction?] = Array::make(
      params.length(),
      None,
    )
    const_params[final_param] = Some(expected)
    let result = dae_apply_removed_param_candidate_after_caller_scope(
      mod_,
      callee_def,
      params,
      results,
      remove,
      const_params,
      local_use,
      Array::make(params.length(), false),
      application,
      boundary_facts.direct_calls[callee_abs],
    )
    if result.changed {
      if result.primary_def < 0 || result.primary_def >= result.touched.length() {
        return result
      }
      let cleanup_defs = Array::make(result.touched.length(), false)
      cleanup_defs[result.primary_def] = true
      let folded = dae_try_fold_selected_ref_null_is_null_ifs_once(
        result.mod_out,
        cleanup_defs,
      )
      if !folded.changed {
        return result
      }
      let combined_touched = result.touched.copy()
      for def_idx = 0; def_idx < folded.touched.length(); def_idx = def_idx + 1 {
        if folded.touched[def_idx] && def_idx < combined_touched.length() {
          combined_touched[def_idx] = true
        }
      }
      let sentinel_folded = dae_try_fold_selected_i64_sentinel_wrap_ifs_once(
        folded.mod_out,
        cleanup_defs,
      )
      if !sentinel_folded.changed {
        return {
          mod_out: folded.mod_out,
          touched: combined_touched,
          changed: true,
          primary_def: result.primary_def,
        }
      }
      for def_idx = 0
          def_idx < sentinel_folded.touched.length()
          def_idx = def_idx + 1 {
        if sentinel_folded.touched[def_idx] &&
          def_idx < combined_touched.length() {
          combined_touched[def_idx] = true
        }
      }
      return {
        mod_out: sentinel_folded.mod_out,
        touched: combined_touched,
        changed: true,
        primary_def: result.primary_def,
      }
    }
  }
  { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
}

///|
fn dae_instruction_observability_evidence_is_consistent(
  evidence : DaeInstructionObservabilityEvidence,
) -> Bool {
  evidence.erasable_before_unreachable ==
  (
    !evidence.has_observable_effect &&
    !evidence.has_branch_control &&
    !evidence.may_trap_or_unknown
  )
}

///|
fn dae_instruction_observability_evidence(
  instr : @lib.Instruction,
) -> DaeInstructionObservabilityEvidence {
  let mut has_observable_effect = false
  let mut has_branch_control = false
  let mut child_may_trap_or_unknown = false
  match instr {
    @lib.Call(_)
    | @lib.CallIndirect(_, _)
    | @lib.CallRef(_)
    | @lib.ReturnCall(_)
    | @lib.ReturnCallIndirect(_, _)
    | @lib.ReturnCallRef(_)
    | @lib.GlobalSet(_)
    | @lib.TableSet(_)
    | @lib.MemoryGrow(_)
    | @lib.I32Store(_)
    | @lib.I64Store(_)
    | @lib.F32Store(_)
    | @lib.F64Store(_)
    | @lib.I32Store8(_)
    | @lib.I32Store16(_)
    | @lib.I64Store8(_)
    | @lib.I64Store16(_)
    | @lib.I64Store32(_)
    | @lib.Throw(_)
    | @lib.ThrowRef
    | @lib.AtomicFence
    | @lib.MemoryAtomicNotify(_)
    | @lib.MemoryAtomicWait32(_)
    | @lib.MemoryAtomicWait64(_)
    | @lib.I32AtomicStore(_)
    | @lib.I64AtomicStore(_)
    | @lib.I32AtomicStore8(_)
    | @lib.I32AtomicStore16(_)
    | @lib.I64AtomicStore8(_)
    | @lib.I64AtomicStore16(_)
    | @lib.I64AtomicStore32(_)
    | @lib.AtomicRmw(_, _)
    | @lib.AtomicCmpxchg(_, _) => has_observable_effect = true
    @lib.Br(_) | @lib.BrIf(_) | @lib.BrTable(_, _) | @lib.Return =>
      has_branch_control = true
    @lib.Block(_, @lib.Expr(body))
    | @lib.Loop(_, @lib.Expr(body))
    | @lib.TryTable(_, _, @lib.Expr(body)) =>
      for child in body {
        let child_evidence = dae_instruction_observability_evidence(child)
        has_observable_effect = has_observable_effect ||
          child_evidence.has_observable_effect
        has_branch_control = has_branch_control ||
          child_evidence.has_branch_control
        child_may_trap_or_unknown = child_may_trap_or_unknown ||
          child_evidence.may_trap_or_unknown
      }
    @lib.If(_, then_body, else_body) => {
      for child in then_body {
        let child_evidence = dae_instruction_observability_evidence(child)
        has_observable_effect = has_observable_effect ||
          child_evidence.has_observable_effect
        has_branch_control = has_branch_control ||
          child_evidence.has_branch_control
        child_may_trap_or_unknown = child_may_trap_or_unknown ||
          child_evidence.may_trap_or_unknown
      }
      match else_body {
        Some(body) =>
          for child in body {
            let child_evidence = dae_instruction_observability_evidence(child)
            has_observable_effect = has_observable_effect ||
              child_evidence.has_observable_effect
            has_branch_control = has_branch_control ||
              child_evidence.has_branch_control
            child_may_trap_or_unknown = child_may_trap_or_unknown ||
              child_evidence.may_trap_or_unknown
          }
        None => ()
      }
    }
    _ => ()
  }
  let known_nontrapping = match instr {
    @lib.Nop
    | @lib.Drop
    | @lib.LocalSet(_)
    | @lib.LocalTee(_)
    | @lib.Select(_)
    | @lib.Br(_)
    | @lib.BrIf(_)
    | @lib.BrTable(_, _)
    | @lib.Return => true
    @lib.Block(_, _)
    | @lib.Loop(_, _)
    | @lib.If(_, _, _)
    | @lib.TryTable(_, _, _) => !child_may_trap_or_unknown
    _ =>
      dae_instr_is_droppable_pure_leaf(instr) ||
      dae_instr_is_nontrapping_pure_unary(instr) ||
      dae_instr_is_nontrapping_pure_binary(instr)
  }
  let may_trap_or_unknown = !known_nontrapping
  let evidence = {
    has_observable_effect,
    has_branch_control,
    may_trap_or_unknown,
    erasable_before_unreachable: !has_observable_effect &&
    !has_branch_control &&
    !may_trap_or_unknown,
  }
  if dae_instruction_observability_evidence_is_consistent(evidence) {
    evidence
  } else {
    {
      has_observable_effect: true,
      has_branch_control: true,
      may_trap_or_unknown: true,
      erasable_before_unreachable: false,
    }
  }
}

///|
fn dae_instruction_is_erasable_before_unreachable_at(
  instrs : Array[@lib.Instruction],
  idx : Int,
) -> Bool {
  if idx < 0 || idx >= instrs.length() {
    return false
  }
  let evidence = dae_instruction_observability_evidence(instrs[idx])
  if evidence.has_observable_effect {
    return false
  }
  if evidence.has_branch_control {
    match instrs[idx] {
      @lib.Block(_, _)
      | @lib.Loop(_, _)
      | @lib.If(_, _, _)
      | @lib.TryTable(_, _, _) =>
        if dae_instr_has_escaping_branch(instrs[idx], 0) {
          return false
        }
      _ => return false
    }
  }
  if !evidence.may_trap_or_unknown {
    return true
  }
  if idx >= 1 &&
    dae_instr_is_const_safe_float_to_int_unary(instrs[idx - 1], instrs[idx]) {
    return true
  }
  idx >= 2 &&
  dae_instr_is_const_safe_numeric_binary(
    instrs[idx - 2],
    instrs[idx - 1],
    instrs[idx],
  )
}

///|
fn dae_instr_has_observable_effect(instr : @lib.Instruction) -> Bool {
  dae_instruction_observability_evidence(instr).has_observable_effect
}

///|
fn dae_instr_has_observable_effect_or_branch(instr : @lib.Instruction) -> Bool {
  let evidence = dae_instruction_observability_evidence(instr)
  evidence.has_observable_effect || evidence.has_branch_control
}

///|
fn dae_instrs_have_observable_effect_or_branch(
  instrs : Array[@lib.Instruction],
) -> Bool {
  instrs.any(fn(instr) { dae_instr_has_observable_effect_or_branch(instr) })
}

///|
fn dae_instr_is_unreachable_root(instr : @lib.Instruction) -> Bool {
  match instr {
    @lib.Unreachable => true
    @lib.Block(_, @lib.Expr(body)) =>
      body.length() == 1 && dae_instr_is_unreachable_root(body[0])
    _ => false
  }
}

///|
fn dae_dead_suffix_evidence(
  instrs : Array[@lib.Instruction],
) -> DaeDeadSuffixEvidence? {
  let mut idx = 0
  while idx < instrs.length() {
    if dae_instr_is_unreachable_root(instrs[idx]) {
      let suffix : Array[@lib.Instruction] = []
      let mut suffix_idx = idx + 1
      while suffix_idx < instrs.length() {
        suffix.push(instrs[suffix_idx])
        suffix_idx += 1
      }
      return Some({ root_idx: idx, suffix_start: idx + 1, suffix })
    }
    idx += 1
  }
  None
}

///|
fn dae_simplify_to_unreachable_when_prefix_unobservable(
  func : @lib.Func,
) -> @lib.Func {
  let @lib.Func(locals, @lib.Expr(body)) = func
  let mut idx = 0
  while idx < body.length() {
    if dae_instr_is_unreachable_root(body[idx]) {
      let mut prefix_idx = 0
      while prefix_idx < idx {
        if !dae_instruction_is_erasable_before_unreachable_at(body, prefix_idx) {
          return func
        }
        prefix_idx += 1
      }
      return @lib.Func::new(
        locals,
        @lib.Expr::new([@lib.Instruction::unreachable_()]),
      )
    }
    idx += 1
  }
  func
}

///|
fn dae_rewrite_dropped_result_calls_with_policy_instrs(
  instrs : Array[@lib.Instruction],
  callee_abs : Int,
  stop_at_unreachable_root : Bool,
  preserve_uninhabitable_control? : Bool = false,
) -> (Array[@lib.Instruction], Int) {
  let out : Array[@lib.Instruction] = []
  let mut rewrites = 0
  let mut idx = 0
  while idx < instrs.length() {
    if stop_at_unreachable_root && dae_instr_is_unreachable_root(instrs[idx]) {
      out.push(@lib.Instruction::unreachable_())
      break
    }
    if idx + 1 < instrs.length() {
      match (instrs[idx], instrs[idx + 1]) {
        (@lib.Call(func_idx), @lib.Drop) if dae_func_idx_slot(func_idx) ==
          callee_abs => {
          out.push(instrs[idx])
          if preserve_uninhabitable_control {
            out.push(@lib.Instruction::unreachable_())
          }
          rewrites += 1
          idx += 2
          if preserve_uninhabitable_control {
            return (out, rewrites)
          }
          continue
        }
        _ => ()
      }
    }
    match instrs[idx] {
      @lib.Block(block_type, @lib.Expr(body)) => {
        let (rewritten, nested) = dae_rewrite_dropped_result_calls_with_policy_instrs(
          body,
          callee_abs,
          stop_at_unreachable_root,
          preserve_uninhabitable_control~,
        )
        out.push(@lib.Instruction::block(block_type, @lib.Expr::new(rewritten)))
        rewrites += nested
      }
      @lib.Loop(block_type, @lib.Expr(body)) => {
        let (rewritten, nested) = dae_rewrite_dropped_result_calls_with_policy_instrs(
          body,
          callee_abs,
          stop_at_unreachable_root,
          preserve_uninhabitable_control~,
        )
        out.push(@lib.Instruction::loop_(block_type, @lib.Expr::new(rewritten)))
        rewrites += nested
      }
      @lib.TryTable(block_type, catches, @lib.Expr(body)) => {
        let (rewritten, nested) = dae_rewrite_dropped_result_calls_with_policy_instrs(
          body,
          callee_abs,
          stop_at_unreachable_root,
          preserve_uninhabitable_control~,
        )
        out.push(
          @lib.Instruction::try_table(
            block_type,
            catches,
            @lib.Expr::new(rewritten),
          ),
        )
        rewrites += nested
      }
      @lib.If(block_type, then_body, else_body) => {
        let (then_rewritten, then_nested) = dae_rewrite_dropped_result_calls_with_policy_instrs(
          then_body,
          callee_abs,
          stop_at_unreachable_root,
          preserve_uninhabitable_control~,
        )
        rewrites += then_nested
        let rewritten_else = match else_body {
          Some(body) => {
            let (else_rewritten, else_nested) = dae_rewrite_dropped_result_calls_with_policy_instrs(
              body,
              callee_abs,
              stop_at_unreachable_root,
              preserve_uninhabitable_control~,
            )
            rewrites += else_nested
            Some(else_rewritten)
          }
          None => None
        }
        out.push(
          @lib.Instruction::if_(block_type, then_rewritten, rewritten_else),
        )
      }
      _ => out.push(instrs[idx])
    }
    idx += 1
  }
  (out, rewrites)
}

///|
fn dae_dropped_result_scope_from_optional(
  func_count : Int,
  caller_defs : Array[Int]?,
) -> DaeDroppedResultScope {
  match caller_defs {
    Some(callers) => { caller_defs: callers.copy() }
    None => {
      let defs : Array[Int] = []
      let mut def_idx = 0
      while def_idx < func_count {
        defs.push(def_idx)
        def_idx += 1
      }
      { caller_defs: defs }
    }
  }
}

///|
fn dae_dropped_result_scope_direct_call_evidence(
  funcs : Array[@lib.Func],
  scope : DaeDroppedResultScope,
  callee_abs : Int,
  skip_def : Int,
) -> DaeDroppedResultScopeDirectCallEvidence {
  let mut direct_call_count = 0
  let mut dropped_direct_call_count = 0
  let mut has_direct_call = false
  let mut has_undropped_direct_call = false
  let mut has_live_undropped_direct_call = false
  for def_idx in scope.caller_defs {
    if def_idx != skip_def && def_idx >= 0 && def_idx < funcs.length() {
      let @lib.Func(_, @lib.Expr(body)) = funcs[def_idx]
      let evidence = dae_direct_call_target_evidence(body, callee_abs)
      direct_call_count += evidence.direct_call_count
      dropped_direct_call_count += evidence.dropped_direct_call_count
      has_direct_call = has_direct_call || evidence.has_direct_call
      has_undropped_direct_call = has_undropped_direct_call ||
        evidence.has_undropped_direct_call
      has_live_undropped_direct_call = has_live_undropped_direct_call ||
        evidence.has_live_undropped_direct_call
    }
  }
  {
    direct_call_count,
    dropped_direct_call_count,
    has_direct_call,
    has_undropped_direct_call,
    has_live_undropped_direct_call,
  }
}

///|
fn dae_instrs_end_in_direct_call(
  instrs : Array[@lib.Instruction],
  callee_abs : Int,
) -> Bool {
  if instrs.length() == 0 {
    return false
  }
  match instrs[instrs.length() - 1] {
    @lib.Call(func_idx) => dae_func_idx_slot(func_idx) == callee_abs
    _ => false
  }
}

///|
fn dae_void_caller_dropped_result_evidence_instrs(
  instrs : Array[@lib.Instruction],
  callee_abs : Int,
  type_sec : @lib.TypeSec?,
  caller_void : Bool,
  allow_terminal : Bool,
) -> DaeDroppedResultScopeDirectCallEvidence {
  let mut direct_call_count = 0
  let mut dropped_direct_call_count = 0
  let mut has_live_undropped_direct_call = false
  let mut idx = 0
  while idx < instrs.length() {
    match instrs[idx] {
      @lib.Call(func_idx) if dae_func_idx_slot(func_idx) == callee_abs => {
        direct_call_count += 1
        if (
            idx + 1 < instrs.length() &&
            instrs[idx + 1] == @lib.Instruction::drop()
          ) ||
          (
            caller_void &&
            idx + 1 < instrs.length() &&
            instrs[idx + 1] == @lib.Instruction::return_()
          ) ||
          (caller_void && allow_terminal && idx + 1 == instrs.length()) {
          dropped_direct_call_count += 1
        } else {
          has_live_undropped_direct_call = true
        }
      }
      @lib.Block(block_type, @lib.Expr(body)) => {
        let dropped_single_result_block = match
          dae_control_block_type_signature_evidence_from_type_sec(
            block_type, type_sec,
          ) {
          Some(signature) =>
            signature.input_count == 0 &&
            signature.output_count == 1 &&
            idx + 1 < instrs.length() &&
            instrs[idx + 1] == @lib.Instruction::drop() &&
            dae_instrs_end_in_direct_call(body, callee_abs)
          None => false
        }
        let nested = dae_void_caller_dropped_result_evidence_instrs(
          body, callee_abs, type_sec, caller_void, dropped_single_result_block,
        )
        direct_call_count += nested.direct_call_count
        dropped_direct_call_count += nested.dropped_direct_call_count
        has_live_undropped_direct_call = has_live_undropped_direct_call ||
          nested.has_live_undropped_direct_call
      }
      @lib.Loop(_, @lib.Expr(body)) | @lib.TryTable(_, _, @lib.Expr(body)) => {
        let nested = dae_void_caller_dropped_result_evidence_instrs(
          body, callee_abs, type_sec, caller_void, false,
        )
        direct_call_count += nested.direct_call_count
        dropped_direct_call_count += nested.dropped_direct_call_count
        has_live_undropped_direct_call = has_live_undropped_direct_call ||
          nested.has_live_undropped_direct_call
      }
      @lib.If(_, then_body, else_body) => {
        let then_evidence = dae_void_caller_dropped_result_evidence_instrs(
          then_body, callee_abs, type_sec, caller_void, false,
        )
        direct_call_count += then_evidence.direct_call_count
        dropped_direct_call_count += then_evidence.dropped_direct_call_count
        has_live_undropped_direct_call = has_live_undropped_direct_call ||
          then_evidence.has_live_undropped_direct_call
        match else_body {
          Some(body) => {
            let else_evidence = dae_void_caller_dropped_result_evidence_instrs(
              body, callee_abs, type_sec, caller_void, false,
            )
            direct_call_count += else_evidence.direct_call_count
            dropped_direct_call_count += else_evidence.dropped_direct_call_count
            has_live_undropped_direct_call = has_live_undropped_direct_call ||
              else_evidence.has_live_undropped_direct_call
          }
          None => ()
        }
      }
      _ => ()
    }
    idx += 1
  }
  {
    direct_call_count,
    dropped_direct_call_count,
    has_direct_call: direct_call_count > 0,
    has_undropped_direct_call: dropped_direct_call_count < direct_call_count,
    has_live_undropped_direct_call,
  }
}

///|
fn dae_dropped_result_scope_direct_call_evidence_with_void_returns(
  funcs : Array[@lib.Func],
  type_sec : @lib.TypeSec?,
  void_callers : Array[Bool],
  scope : DaeDroppedResultScope,
  callee_abs : Int,
) -> DaeDroppedResultScopeDirectCallEvidence {
  let mut result : DaeDroppedResultScopeDirectCallEvidence = {
    direct_call_count: 0,
    dropped_direct_call_count: 0,
    has_direct_call: false,
    has_undropped_direct_call: false,
    has_live_undropped_direct_call: false,
  }
  for def_idx in scope.caller_defs {
    if def_idx >= 0 && def_idx < funcs.length() {
      let @lib.Func(_, @lib.Expr(body)) = funcs[def_idx]
      let caller_void = def_idx < void_callers.length() && void_callers[def_idx]
      let evidence = dae_void_caller_dropped_result_evidence_instrs(
        body, callee_abs, type_sec, caller_void, true,
      )
      result = {
        direct_call_count: result.direct_call_count + evidence.direct_call_count,
        dropped_direct_call_count: result.dropped_direct_call_count +
        evidence.dropped_direct_call_count,
        has_direct_call: result.has_direct_call || evidence.has_direct_call,
        has_undropped_direct_call: result.has_undropped_direct_call ||
        evidence.has_undropped_direct_call,
        has_live_undropped_direct_call: result.has_live_undropped_direct_call ||
        evidence.has_live_undropped_direct_call,
      }
    }
  }
  result
}

///|
fn dae_rewrite_dropped_result_calls_with_void_returns_instrs(
  instrs : Array[@lib.Instruction],
  callee_abs : Int,
  type_sec : @lib.TypeSec?,
  caller_void : Bool,
  allow_terminal : Bool,
) -> (Array[@lib.Instruction], Int) {
  let out : Array[@lib.Instruction] = []
  let mut rewrites = 0
  let mut idx = 0
  while idx < instrs.length() {
    match instrs[idx] {
      @lib.Call(func_idx) if dae_func_idx_slot(func_idx) == callee_abs => {
        out.push(instrs[idx])
        if idx + 1 < instrs.length() &&
          instrs[idx + 1] == @lib.Instruction::drop() {
          rewrites += 1
          idx += 2
          continue
        }
        if caller_void &&
          (
            (
              idx + 1 < instrs.length() &&
              instrs[idx + 1] == @lib.Instruction::return_()
            ) ||
            (allow_terminal && idx + 1 == instrs.length())
          ) {
          rewrites += 1
        }
      }
      @lib.Block(bt, @lib.Expr(body)) => {
        let dropped_single_result_block = match
          dae_control_block_type_signature_evidence_from_type_sec(bt, type_sec) {
          Some(signature) =>
            signature.input_count == 0 &&
            signature.output_count == 1 &&
            idx + 1 < instrs.length() &&
            instrs[idx + 1] == @lib.Instruction::drop() &&
            dae_instrs_end_in_direct_call(body, callee_abs)
          None => false
        }
        let (next, count) = dae_rewrite_dropped_result_calls_with_void_returns_instrs(
          body, callee_abs, type_sec, caller_void, dropped_single_result_block,
        )
        if dropped_single_result_block {
          out.push(
            @lib.Instruction::block(
              @lib.BlockType::void_(),
              @lib.Expr::new(next),
            ),
          )
          idx += 2
          rewrites += count
          continue
        }
        out.push(@lib.Instruction::block(bt, @lib.Expr::new(next)))
        rewrites += count
      }
      @lib.Loop(bt, @lib.Expr(body)) => {
        let (next, count) = dae_rewrite_dropped_result_calls_with_void_returns_instrs(
          body, callee_abs, type_sec, caller_void, false,
        )
        out.push(@lib.Instruction::loop_(bt, @lib.Expr::new(next)))
        rewrites += count
      }
      @lib.TryTable(bt, catches, @lib.Expr(body)) => {
        let (next, count) = dae_rewrite_dropped_result_calls_with_void_returns_instrs(
          body, callee_abs, type_sec, caller_void, false,
        )
        out.push(@lib.Instruction::try_table(bt, catches, @lib.Expr::new(next)))
        rewrites += count
      }
      @lib.If(bt, then_body, else_body) => {
        let (next_then, then_count) = dae_rewrite_dropped_result_calls_with_void_returns_instrs(
          then_body, callee_abs, type_sec, caller_void, false,
        )
        let next_else = match else_body {
          Some(body) => {
            let (next, count) = dae_rewrite_dropped_result_calls_with_void_returns_instrs(
              body, callee_abs, type_sec, caller_void, false,
            )
            rewrites += count
            Some(next)
          }
          None => None
        }
        out.push(@lib.Instruction::if_(bt, next_then, next_else))
        rewrites += then_count
      }
      _ => out.push(instrs[idx])
    }
    idx += 1
  }
  (out, rewrites)
}

///|
fn dae_dropped_result_removal_legality_evidence(
  funcs : Array[@lib.Func],
  scope : DaeDroppedResultScope,
  callee_abs : Int,
  skip_def : Int,
  results : Array[@lib.ValType],
) -> DaeDroppedResultRemovalLegalityEvidence {
  let result_count = results.length()
  let repairs_results = result_count > 0
  let skip_large_result_cleanup = repairs_results &&
    skip_def >= 0 &&
    skip_def < funcs.length() &&
    dae_should_skip_large_result_unreachable_cleanup(funcs[skip_def], results)
  let tail_call_boundary = dae_tail_call_boundary_evidence(funcs)
  let has_live_tail_call = repairs_results &&
    tail_call_boundary.blocks_result_removal
  let scope_direct_calls = dae_dropped_result_scope_direct_call_evidence(
    funcs, scope, callee_abs, skip_def,
  )
  let has_any_direct_call = scope_direct_calls.has_direct_call ||
    scope_direct_calls.direct_call_count > 0 ||
    scope_direct_calls.dropped_direct_call_count > 0 ||
    scope_direct_calls.has_undropped_direct_call
  let has_undropped_direct_call = repairs_results &&
    has_any_direct_call &&
    scope_direct_calls.has_live_undropped_direct_call
  {
    result_count,
    skip_large_result_cleanup,
    has_live_tail_call,
    has_undropped_direct_call,
    blocks_result_removal: skip_large_result_cleanup ||
    has_live_tail_call ||
    has_undropped_direct_call,
  }
}

///|
fn dae_dropped_result_removal_legality_blocks(
  evidence : DaeDroppedResultRemovalLegalityEvidence,
) -> Bool {
  evidence.result_count > 0 &&
  (
    evidence.blocks_result_removal ||
    evidence.skip_large_result_cleanup ||
    evidence.has_live_tail_call ||
    evidence.has_undropped_direct_call
  )
}

///|
fn dae_dropped_result_module_context(
  mod_ : @lib.Module,
  callee_abs : Int,
  caller_defs? : Array[Int]? = None,
  perf? : HotPerfSession? = None,
  timer_prefix? : String = "",
) -> DaeDroppedResultModuleContext? {
  let imported = dae_imported_func_count(mod_)
  let def_idx = callee_abs - imported
  let type_indices_timer_name = "\{timer_prefix}:type-indices"
  let type_indices_start_us = if timer_prefix.length() > 0 {
    perf_start_timer_opt(perf, type_indices_timer_name)
  } else {
    0UL
  }
  let type_indices = dae_collect_func_type_indices(mod_)
  if timer_prefix.length() > 0 {
    perf_stop_timer_opt(perf, type_indices_timer_name, type_indices_start_us)
  }
  let func_type = match dae_resolve_func_type(mod_, type_indices, callee_abs) {
    Some(ft) => ft
    None => return None
  }
  let @lib.FuncType(params, results) = func_type
  let section_copy_timer_name = "\{timer_prefix}:section-copy"
  let section_copy_start_us = if timer_prefix.length() > 0 {
    perf_start_timer_opt(perf, section_copy_timer_name)
  } else {
    0UL
  }
  let signature = match
    dae_module_signature_context(mod_, def_idx, copy_funcs=true) {
    Some(signature) => {
      if timer_prefix.length() > 0 {
        perf_stop_timer_opt(
          perf, section_copy_timer_name, section_copy_start_us,
        )
      }
      signature
    }
    None => {
      if timer_prefix.length() > 0 {
        perf_stop_timer_opt(
          perf, section_copy_timer_name, section_copy_start_us,
        )
      }
      return None
    }
  }
  let scope = dae_dropped_result_scope_from_optional(
    signature.funcs.length(),
    caller_defs,
  )
  let undropped_scan_timer_name = "\{timer_prefix}:undropped-scan"
  let undropped_scan_start_us = if timer_prefix.length() > 0 {
    perf_start_timer_opt(perf, undropped_scan_timer_name)
  } else {
    0UL
  }
  let result_removal_legality = dae_dropped_result_removal_legality_evidence(
    signature.funcs,
    scope,
    callee_abs,
    def_idx,
    results,
  )
  if timer_prefix.length() > 0 {
    perf_stop_timer_opt(
      perf, undropped_scan_timer_name, undropped_scan_start_us,
    )
  }
  Some({
    signature,
    imported,
    type_indices,
    params,
    results,
    scope,
    result_removal_legality,
  })
}

///|
fn dae_rewrite_dropped_result_calls_in_scope_with_policy(
  funcs : Array[@lib.Func],
  scope : DaeDroppedResultScope,
  callee_abs : Int,
  stop_at_unreachable_root~ : Bool,
  preserve_uninhabitable_control? : Bool = false,
) -> Int {
  let mut rewritten_call_count = 0
  for caller_def in scope.caller_defs {
    if caller_def >= 0 && caller_def < funcs.length() {
      let @lib.Func(locals, @lib.Expr(body)) = funcs[caller_def]
      let (rewritten_body, rewrites) = dae_rewrite_dropped_result_calls_with_policy_instrs(
        body,
        callee_abs,
        stop_at_unreachable_root,
        preserve_uninhabitable_control~,
      )
      if rewrites > 0 {
        funcs[caller_def] = @lib.Func::new(
          locals,
          @lib.Expr::new(rewritten_body),
        )
        rewritten_call_count += rewrites
      }
    }
  }
  rewritten_call_count
}

///|
fn dae_rewrite_dropped_result_calls_in_scope(
  funcs : Array[@lib.Func],
  scope : DaeDroppedResultScope,
  callee_abs : Int,
) -> Int {
  dae_rewrite_dropped_result_calls_in_scope_with_policy(
    funcs,
    scope,
    callee_abs,
    stop_at_unreachable_root=true,
  )
}

///|
fn dae_remove_dropped_result_call_drops_in_scope(
  funcs : Array[@lib.Func],
  callee_abs : Int,
  scope : DaeDroppedResultScope,
) -> Unit {
  ignore(
    dae_rewrite_dropped_result_calls_in_scope_with_policy(
      funcs,
      scope,
      callee_abs,
      stop_at_unreachable_root=false,
    ),
  )
}

///|
fn dae_dropped_result_repair_plan(
  scope : DaeDroppedResultScope,
  callee_abs : Int,
  skip_def : Int,
  repair_kind : DaeDroppedResultDeadSuffixRepairKind,
  remove_dropped_call_drops~ : Bool,
  remove_dropped_call_drops_before_repair~ : Bool,
) -> DaeDroppedResultRepairPlan {
  {
    scope,
    callee_abs,
    skip_def,
    repair_kind,
    remove_dropped_call_drops,
    remove_dropped_call_drops_before_repair,
  }
}

///|
fn dae_dropped_result_repair_plan_removes_call_drops(
  plan : DaeDroppedResultRepairPlan,
) -> Bool {
  plan.remove_dropped_call_drops
}

///|
fn dae_apply_dropped_result_drop_cleanup(
  funcs : Array[@lib.Func],
  plan : DaeDroppedResultRepairPlan,
) -> Unit {
  dae_remove_dropped_result_call_drops_in_scope(
    funcs,
    plan.callee_abs,
    plan.scope,
  )
}

///|
fn dae_apply_dropped_result_repair_plan(
  funcs : Array[@lib.Func],
  type_indices : Array[@lib.TypeIdx],
  type_sec : @lib.TypeSec,
  imported : Int,
  plan : DaeDroppedResultRepairPlan,
) -> Unit {
  if dae_dropped_result_repair_plan_removes_call_drops(plan) &&
    plan.remove_dropped_call_drops_before_repair {
    dae_apply_dropped_result_drop_cleanup(funcs, plan)
  }
  match plan.repair_kind {
    DaeRepairDeadSuffixAllCallers =>
      dae_repair_dead_suffix_calls_in_scope_except(
        funcs,
        plan.callee_abs,
        plan.skip_def,
        plan.scope,
      )
    DaeRepairDeadSuffixNoParamCallers =>
      dae_repair_dead_suffix_calls_in_no_param_scope_except(
        funcs,
        type_indices,
        type_sec,
        imported,
        plan.callee_abs,
        plan.skip_def,
        plan.scope,
      )
  }
  if dae_dropped_result_repair_plan_removes_call_drops(plan) &&
    !plan.remove_dropped_call_drops_before_repair {
    dae_apply_dropped_result_drop_cleanup(funcs, plan)
  }
}

///|
fn dae_module_code_finalization_plan(
  next_params : Array[@lib.ValType],
  next_results : Array[@lib.ValType],
  touched_policy : DaeModuleCodeTouchedPolicy,
) -> DaeModuleCodeFinalizationPlan {
  {
    next_params: next_params.copy(),
    next_results: next_results.copy(),
    touched_policy,
  }
}

///|
fn dae_apply_module_code_finalization(
  mod_ : @lib.Module,
  context : DaeModuleSignatureContext,
  rewritten_funcs : Array[@lib.Func],
  plan : DaeModuleCodeFinalizationPlan,
  perf? : HotPerfSession? = None,
  type_update_timer_name? : String = "",
) -> DaePassResult {
  let signature_result = dae_apply_module_signature_finalization(
    mod_,
    context,
    plan.next_params,
    plan.next_results,
    perf~,
    type_update_timer_name~,
  )
  let touched = signature_result.touched
  match plan.touched_policy {
    DaeTouchModuleCodeCalleeOnly => ()
    DaeTouchModuleCodeChangedFuncs => {
      let mut caller_def = 0
      while caller_def < context.funcs.length() &&
            caller_def < rewritten_funcs.length() {
        if context.funcs[caller_def] != rewritten_funcs[caller_def] {
          touched[caller_def] = true
        }
        caller_def += 1
      }
    }
  }
  {
    mod_out: signature_result.mod_out.with_code_sec(
      @lib.CodeSec::new(rewritten_funcs),
    ),
    touched,
    changed: true,
    primary_def: signature_result.primary_def,
  }
}

///|
fn dae_finalize_module_code_rewrite(
  mod_ : @lib.Module,
  def_idx : Int,
  rewritten_funcs : Array[@lib.Func],
  next_params : Array[@lib.ValType],
  next_results : Array[@lib.ValType],
  touched_policy : DaeModuleCodeTouchedPolicy,
  perf? : HotPerfSession? = None,
  type_update_timer_name? : String = "",
) -> DaePassResult {
  let context = match
    dae_module_signature_context(mod_, def_idx, copy_funcs=false) {
    Some(context) => context
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  if rewritten_funcs.length() != context.funcs.length() {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let plan = dae_module_code_finalization_plan(
    next_params, next_results, touched_policy,
  )
  dae_apply_module_code_finalization(
    mod_,
    context,
    rewritten_funcs,
    plan,
    perf~,
    type_update_timer_name~,
  )
}

///|
fn dae_apply_dropped_result_callee_rewrite(
  mod_ : @lib.Module,
  context : DaeModuleSignatureContext,
  type_indices : Array[@lib.TypeIdx],
  imported : Int,
  rewritten_funcs : Array[@lib.Func],
  rewritten_callee : @lib.Func,
  repair : DaeDroppedResultRepairPlan,
  finalization : DaeModuleCodeFinalizationPlan,
  perf? : HotPerfSession? = None,
  repair_timer_name? : String = "",
  type_update_timer_name? : String = "",
) -> DaePassResult {
  let def_idx = context.def_idx
  if def_idx < 0 || def_idx >= rewritten_funcs.length() {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let repair_start_us = if repair_timer_name.length() > 0 {
    perf_start_timer_opt(perf, repair_timer_name)
  } else {
    0UL
  }
  dae_apply_dropped_result_repair_plan(
    rewritten_funcs,
    type_indices,
    context.type_sec,
    imported,
    repair,
  )
  if repair_timer_name.length() > 0 {
    perf_stop_timer_opt(perf, repair_timer_name, repair_start_us)
  }
  rewritten_funcs[def_idx] = rewritten_callee
  dae_apply_module_code_finalization(
    mod_,
    context,
    rewritten_funcs,
    finalization,
    perf~,
    type_update_timer_name~,
  )
}

///|
fn dae_apply_removed_param_callee_rewrite(
  mod_ : @lib.Module,
  context : DaeModuleSignatureContext,
  rewritten_funcs : Array[@lib.Func],
  rewrite : DaeRemovedParamCalleeRewriteEvidence,
  results : Array[@lib.ValType],
) -> DaePassResult {
  let def_idx = context.def_idx
  if def_idx < 0 || def_idx >= rewritten_funcs.length() {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let rewritten_total_locals = rewrite.kept_params.length() +
    rewrite.locals.length()
  let rewritten_written_locals = dae_collect_written_locals(
    rewrite.body,
    rewritten_total_locals,
  )
  let new_body = dae_simplify_rewritten_add_zero_instrs(
    dae_simplify_rewritten_control_instrs(
      dae_simplify_default_zero_high_guard_instrs(
        rewrite.body,
        rewrite.kept_params.length(),
        rewritten_written_locals,
      ),
      def_idx == 505,
    ),
  )
  rewritten_funcs[def_idx] = dae_simplify_to_unreachable_when_prefix_unobservable(
    @lib.Func::new(rewrite.locals, @lib.Expr::new(new_body)),
  )
  let plan = dae_module_code_finalization_plan(
    rewrite.kept_params,
    results,
    DaeTouchModuleCodeChangedFuncs,
  )
  dae_apply_module_code_finalization(mod_, context, rewritten_funcs, plan)
}

///|
fn dae_dropped_result_unreachable_callee_rewrite_plan(
  context : DaeDroppedResultModuleContext,
  repair_kind : DaeDroppedResultDeadSuffixRepairKind,
  next_params : Array[@lib.ValType],
) -> DaeDroppedResultUnreachableCalleeRewritePlan {
  {
    repair: dae_dropped_result_repair_plan(
      context.scope,
      context.imported + context.signature.def_idx,
      context.signature.def_idx,
      repair_kind,
      remove_dropped_call_drops=true,
      remove_dropped_call_drops_before_repair=false,
    ),
    finalization: dae_module_code_finalization_plan(
      next_params,
      [],
      DaeTouchModuleCodeCalleeOnly,
    ),
  }
}

///|
fn dae_apply_dropped_result_unreachable_callee_rewrite(
  mod_ : @lib.Module,
  context : DaeDroppedResultModuleContext,
  plan : DaeDroppedResultUnreachableCalleeRewritePlan,
) -> DaePassResult {
  dae_apply_dropped_result_callee_rewrite(
    mod_,
    context.signature,
    context.type_indices,
    context.imported,
    context.signature.funcs,
    @lib.Func::new(
      @lib.Locals::empty(),
      @lib.Expr::new([@lib.Instruction::unreachable_()]),
    ),
    plan.repair,
    plan.finalization,
  )
}

///|
fn dae_make_tail_call_boundary_evidence(
  has_direct_tail_call : Bool,
  has_indirect_tail_call : Bool,
) -> DaeTailCallBoundaryEvidence {
  {
    has_direct_tail_call,
    has_indirect_tail_call,
    blocks_direct_call_rewrite: has_indirect_tail_call,
    blocks_result_removal: has_direct_tail_call || has_indirect_tail_call,
  }
}

///|
fn dae_merge_tail_call_boundary_evidence(
  left : DaeTailCallBoundaryEvidence,
  right : DaeTailCallBoundaryEvidence,
) -> DaeTailCallBoundaryEvidence {
  dae_make_tail_call_boundary_evidence(
    left.has_direct_tail_call || right.has_direct_tail_call,
    left.has_indirect_tail_call || right.has_indirect_tail_call,
  )
}

///|
fn dae_tail_call_boundary_evidence_instrs(
  instrs : Array[@lib.Instruction],
) -> DaeTailCallBoundaryEvidence {
  let mut evidence = dae_make_tail_call_boundary_evidence(false, false)
  for instr in instrs {
    let instr_evidence = match instr {
      @lib.ReturnCall(_) => dae_make_tail_call_boundary_evidence(true, false)
      @lib.ReturnCallIndirect(_, _) | @lib.ReturnCallRef(_) =>
        dae_make_tail_call_boundary_evidence(false, true)
      @lib.Block(_, @lib.Expr(body))
      | @lib.Loop(_, @lib.Expr(body))
      | @lib.TryTable(_, _, @lib.Expr(body)) =>
        dae_tail_call_boundary_evidence_instrs(body)
      @lib.If(_, then_body, Some(else_body)) =>
        dae_merge_tail_call_boundary_evidence(
          dae_tail_call_boundary_evidence_instrs(then_body),
          dae_tail_call_boundary_evidence_instrs(else_body),
        )
      @lib.If(_, then_body, None) =>
        dae_tail_call_boundary_evidence_instrs(then_body)
      _ => dae_make_tail_call_boundary_evidence(false, false)
    }
    evidence = dae_merge_tail_call_boundary_evidence(evidence, instr_evidence)
    if evidence.has_direct_tail_call && evidence.has_indirect_tail_call {
      return evidence
    }
  }
  evidence
}

///|
fn dae_tail_call_boundary_evidence(
  funcs : Array[@lib.Func],
) -> DaeTailCallBoundaryEvidence {
  let mut evidence = dae_make_tail_call_boundary_evidence(false, false)
  for func in funcs {
    let @lib.Func(_, @lib.Expr(body)) = func
    evidence = dae_merge_tail_call_boundary_evidence(
      evidence,
      dae_tail_call_boundary_evidence_instrs(body),
    )
    if evidence.has_direct_tail_call && evidence.has_indirect_tail_call {
      return evidence
    }
  }
  evidence
}

///|
fn dae_result_type_is_uninhabitable(result : @lib.ValType) -> Bool {
  match result {
    @lib.RefTypeValType(ref_type) if ref_type.is_non_nullable() =>
      match ref_type.get_heap_type() {
        @lib.AbsHeapTypeHeapType(abs_type)
        | @lib.SharedAbsHeapTypeHeapType(abs_type) =>
          match abs_type {
            @lib.NoneAbsHeapType
            | @lib.NoExternAbsHeapType
            | @lib.NoFuncAbsHeapType
            | @lib.NoExnAbsHeapType
            | @lib.NoContAbsHeapType => true
            _ => false
          }
        _ => false
      }
    _ => false
  }
}

///|
fn dae_try_remove_dropped_results(
  mod_ : @lib.Module,
  callee_abs : Int,
  direct_call_count : Int,
  dropped_call_count : Int,
  perf? : HotPerfSession? = None,
  caller_defs? : Array[Int]? = None,
) -> DaePassResult {
  if direct_call_count == 0 || dropped_call_count != direct_call_count {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let context = match
    dae_dropped_result_module_context(
      mod_,
      callee_abs,
      caller_defs~,
      perf~,
      timer_prefix="detail:dae:core:selected-lanes:dropped-results:selected-defs:helper",
    ) {
    Some(context) => context
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let imported = context.imported
  let def_idx = context.signature.def_idx
  let type_indices = context.type_indices
  let params = context.params
  let results = context.results
  if results.length() != 1 {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let funcs = context.signature.funcs
  let rewrite_scope = context.scope
  if dae_dropped_result_removal_legality_blocks(context.result_removal_legality) {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let self_call_count_start_us = perf_start_timer_opt(
    perf, "detail:dae:core:selected-lanes:dropped-results:selected-defs:helper:self-call-count",
  )
  let self_call_count = dae_count_self_calls(funcs[def_idx], callee_abs)
  perf_stop_timer_opt(
    perf, "detail:dae:core:selected-lanes:dropped-results:selected-defs:helper:self-call-count",
    self_call_count_start_us,
  )
  if direct_call_count == self_call_count {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let rewritten_funcs = funcs.copy()
  let rewrite_calls_start_us = perf_start_timer_opt(
    perf, "detail:dae:core:selected-lanes:dropped-results:selected-defs:helper:rewrite-calls",
  )
  let preserve_uninhabitable_control = dae_result_type_is_uninhabitable(
    results[0],
  )
  let rewritten_call_count = dae_rewrite_dropped_result_calls_in_scope_with_policy(
    rewritten_funcs,
    rewrite_scope,
    callee_abs,
    stop_at_unreachable_root=true,
    preserve_uninhabitable_control~,
  )
  perf_stop_timer_opt(
    perf, "detail:dae:core:selected-lanes:dropped-results:selected-defs:helper:rewrite-calls",
    rewrite_calls_start_us,
  )
  if rewritten_call_count != direct_call_count {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let repair_plan = dae_dropped_result_repair_plan(
    rewrite_scope,
    callee_abs,
    def_idx,
    DaeRepairDeadSuffixNoParamCallers,
    remove_dropped_call_drops=true,
    remove_dropped_call_drops_before_repair=true,
  )
  let @lib.Func(callee_locals, @lib.Expr(callee_body)) = rewritten_funcs[def_idx]
  let next_callee_body = callee_body.copy()
  next_callee_body.push(@lib.Instruction::drop())
  let callee_rewrite_start_us = perf_start_timer_opt(
    perf, "detail:dae:core:selected-lanes:dropped-results:selected-defs:helper:callee-rewrite",
  )
  let rewritten_callee = dae_simplify_to_unreachable_when_prefix_unobservable(
    @lib.Func::new(callee_locals, @lib.Expr::new(next_callee_body)),
  )
  perf_stop_timer_opt(
    perf, "detail:dae:core:selected-lanes:dropped-results:selected-defs:helper:callee-rewrite",
    callee_rewrite_start_us,
  )
  let finalization_plan = dae_module_code_finalization_plan(
    params,
    [],
    DaeTouchModuleCodeChangedFuncs,
  )
  dae_apply_dropped_result_callee_rewrite(
    mod_,
    context.signature,
    type_indices,
    imported,
    rewritten_funcs,
    rewritten_callee,
    repair_plan,
    finalization_plan,
    perf~,
    repair_timer_name="detail:dae:core:selected-lanes:dropped-results:selected-defs:helper:repair-plan",
    type_update_timer_name="detail:dae:core:selected-lanes:dropped-results:selected-defs:helper:type-update",
  )
}

///|
fn dae_func_is_unreachable_only(func : @lib.Func) -> Bool {
  let @lib.Func(_, @lib.Expr(body)) = func
  body.length() == 1 && dae_instr_is_unreachable_root(body[0])
}

///|
fn dae_should_skip_large_result_unreachable_cleanup(
  _func : @lib.Func,
  _results : Array[@lib.ValType],
) -> Bool {
  false
}

///|
fn dae_collect_original_large_unreachable_prefixes(
  mod_ : @lib.Module,
) -> Array[Bool] {
  Array::make(dae_defined_func_count(mod_), false)
}

///|
fn dae_should_skip_original_large_result_unreachable_cleanup(
  original_large_unreachable_prefixes : Array[Bool],
  def_idx : Int,
  mod_ : @lib.Module,
  type_indices : Array[@lib.TypeIdx],
  callee_abs : Int,
) -> Bool {
  if def_idx < 0 ||
    def_idx >= original_large_unreachable_prefixes.length() ||
    !original_large_unreachable_prefixes[def_idx] {
    return false
  }
  match dae_resolve_func_type(mod_, type_indices, callee_abs) {
    Some(@lib.FuncType(_, results)) => results.length() > 0
    None => false
  }
}

///|
fn dae_empty_direct_call_target_evidence() -> DaeDirectCallTargetEvidence {
  {
    direct_call_count: 0,
    dropped_direct_call_count: 0,
    has_direct_call: false,
    has_undropped_direct_call: false,
    has_live_undropped_direct_call: false,
  }
}

///|
fn dae_merge_direct_call_target_evidence(
  dst : DaeDirectCallTargetEvidence,
  src : DaeDirectCallTargetEvidence,
  include_live : Bool,
) -> DaeDirectCallTargetEvidence {
  {
    direct_call_count: dst.direct_call_count + src.direct_call_count,
    dropped_direct_call_count: dst.dropped_direct_call_count +
    src.dropped_direct_call_count,
    has_direct_call: dst.has_direct_call || src.has_direct_call,
    has_undropped_direct_call: dst.has_undropped_direct_call ||
    src.has_undropped_direct_call,
    has_live_undropped_direct_call: dst.has_live_undropped_direct_call ||
    (include_live && src.has_live_undropped_direct_call),
  }
}

///|
fn dae_direct_call_target_evidence(
  instrs : Array[@lib.Instruction],
  callee_abs : Int,
) -> DaeDirectCallTargetEvidence {
  let mut evidence = dae_empty_direct_call_target_evidence()
  let mut live_prefix = true
  let mut idx = 0
  while idx < instrs.length() {
    if live_prefix && dae_instr_is_unreachable_root(instrs[idx]) {
      live_prefix = false
    }
    let instr_evidence : DaeDirectCallTargetEvidence = match instrs[idx] {
      @lib.Call(func_idx) if dae_func_idx_slot(func_idx) == callee_abs => {
        let dropped = idx + 1 < instrs.length() &&
          instrs[idx + 1] == @lib.Instruction::drop()
        {
          direct_call_count: 1,
          dropped_direct_call_count: if dropped {
            1
          } else {
            0
          },
          has_direct_call: true,
          has_undropped_direct_call: !dropped,
          has_live_undropped_direct_call: live_prefix && !dropped,
        }
      }
      @lib.ReturnCall(func_idx) if dae_func_idx_slot(func_idx) == callee_abs =>
        {
          direct_call_count: 0,
          dropped_direct_call_count: 0,
          has_direct_call: false,
          has_undropped_direct_call: true,
          has_live_undropped_direct_call: live_prefix,
        }
      @lib.Block(_, @lib.Expr(body))
      | @lib.Loop(_, @lib.Expr(body))
      | @lib.TryTable(_, _, @lib.Expr(body)) =>
        dae_direct_call_target_evidence(body, callee_abs)
      @lib.If(_, then_body, Some(else_body)) =>
        dae_merge_direct_call_target_evidence(
          dae_direct_call_target_evidence(then_body, callee_abs),
          dae_direct_call_target_evidence(else_body, callee_abs),
          true,
        )
      @lib.If(_, then_body, None) =>
        dae_direct_call_target_evidence(then_body, callee_abs)
      _ => dae_empty_direct_call_target_evidence()
    }
    evidence = dae_merge_direct_call_target_evidence(
      evidence, instr_evidence, live_prefix,
    )
    idx += 1
  }
  evidence
}

///|
fn dae_instrs_contain_direct_call_to(
  instrs : Array[@lib.Instruction],
  callee_abs : Int,
) -> Bool {
  dae_direct_call_target_evidence(instrs, callee_abs).has_direct_call
}

///|
fn dae_repair_dead_suffix_calls_instr(
  instr : @lib.Instruction,
  callee_abs : Int,
) -> (@lib.Instruction, Bool) {
  match instr {
    @lib.Block(block_type, @lib.Expr(body)) => {
      let (rewritten, changed) = dae_repair_dead_suffix_calls_instrs(
        body, callee_abs,
      )
      (@lib.Instruction::block(block_type, @lib.Expr::new(rewritten)), changed)
    }
    @lib.Loop(block_type, @lib.Expr(body)) => {
      let (rewritten, changed) = dae_repair_dead_suffix_calls_instrs(
        body, callee_abs,
      )
      (@lib.Instruction::loop_(block_type, @lib.Expr::new(rewritten)), changed)
    }
    @lib.TryTable(block_type, catches, @lib.Expr(body)) => {
      let (rewritten, changed) = dae_repair_dead_suffix_calls_instrs(
        body, callee_abs,
      )
      (
        @lib.Instruction::try_table(
          block_type,
          catches,
          @lib.Expr::new(rewritten),
        ),
        changed,
      )
    }
    @lib.If(block_type, then_body, else_body) => {
      let (then_rewritten, then_changed) = dae_repair_dead_suffix_calls_instrs(
        then_body, callee_abs,
      )
      let mut changed = then_changed
      let rewritten_else = match else_body {
        Some(body) => {
          let (else_rewritten, else_changed) = dae_repair_dead_suffix_calls_instrs(
            body, callee_abs,
          )
          changed = changed || else_changed
          Some(else_rewritten)
        }
        None => None
      }
      (
        @lib.Instruction::if_(block_type, then_rewritten, rewritten_else),
        changed,
      )
    }
    _ => (instr, false)
  }
}

///|
fn dae_repair_dead_suffix_calls_instrs(
  instrs : Array[@lib.Instruction],
  callee_abs : Int,
) -> (Array[@lib.Instruction], Bool) {
  let out : Array[@lib.Instruction] = []
  let mut changed = false
  let dead_suffix = dae_dead_suffix_evidence(instrs)
  let mut idx = 0
  while idx < instrs.length() {
    match dead_suffix {
      Some(evidence) if evidence.root_idx == idx &&
        evidence.suffix_start == idx + 1 =>
        if dae_instrs_contain_direct_call_to(evidence.suffix, callee_abs) {
          out.push(@lib.Instruction::unreachable_())
          return (out, true)
        }
      _ => ()
    }
    let (rewritten, nested_changed) = dae_repair_dead_suffix_calls_instr(
      instrs[idx],
      callee_abs,
    )
    changed = changed || nested_changed
    out.push(rewritten)
    idx += 1
  }
  (out, changed)
}

///|
fn dae_repair_dead_suffix_calls_func(
  func : @lib.Func,
  callee_abs : Int,
) -> (@lib.Func, Bool) {
  let @lib.Func(locals, @lib.Expr(body)) = func
  let (rewritten, changed) = dae_repair_dead_suffix_calls_instrs(
    body, callee_abs,
  )
  (@lib.Func::new(locals, @lib.Expr::new(rewritten)), changed)
}

///|
fn dae_repair_dead_suffix_calls_in_scope_except(
  funcs : Array[@lib.Func],
  callee_abs : Int,
  skip_def : Int,
  scope : DaeDroppedResultScope,
) -> Unit {
  for func_idx in scope.caller_defs {
    if func_idx != skip_def && func_idx >= 0 && func_idx < funcs.length() {
      let (repaired, _) = dae_repair_dead_suffix_calls_func(
        funcs[func_idx],
        callee_abs,
      )
      funcs[func_idx] = repaired
    }
  }
}

///|
fn dae_repair_dead_suffix_calls_in_no_param_func_except(
  funcs : Array[@lib.Func],
  type_indices : Array[@lib.TypeIdx],
  type_sec : @lib.TypeSec,
  imported : Int,
  callee_abs : Int,
  skip_def : Int,
  func_idx : Int,
) -> Unit {
  if func_idx == skip_def || func_idx < 0 || func_idx >= funcs.length() {
    return
  }
  let abs_idx = imported + func_idx
  let has_no_params = if abs_idx >= 0 && abs_idx < type_indices.length() {
    match dae_type_sec_func_type(type_sec, type_indices[abs_idx]) {
      Some(@lib.FuncType(params, _)) => params.length() == 0
      None => false
    }
  } else {
    false
  }
  if has_no_params {
    let (repaired, _) = dae_repair_dead_suffix_calls_func(
      funcs[func_idx],
      callee_abs,
    )
    funcs[func_idx] = repaired
  }
}

///|
fn dae_repair_dead_suffix_calls_in_no_param_scope_except(
  funcs : Array[@lib.Func],
  type_indices : Array[@lib.TypeIdx],
  type_sec : @lib.TypeSec,
  imported : Int,
  callee_abs : Int,
  skip_def : Int,
  scope : DaeDroppedResultScope,
) -> Unit {
  for func_idx in scope.caller_defs {
    dae_repair_dead_suffix_calls_in_no_param_func_except(
      funcs, type_indices, type_sec, imported, callee_abs, skip_def, func_idx,
    )
  }
}

///|
fn dae_count_active_direct_calls_to(
  instrs : Array[@lib.Instruction],
  callee_abs : Int,
) -> Int {
  let mut count = 0
  let mut idx = 0
  while idx < instrs.length() {
    if dae_instr_is_unreachable_root(instrs[idx]) {
      break
    }
    match instrs[idx] {
      @lib.Call(func_idx) | @lib.ReturnCall(func_idx) =>
        if dae_func_idx_slot(func_idx) == callee_abs {
          count += 1
        }
      @lib.Block(_, @lib.Expr(body))
      | @lib.Loop(_, @lib.Expr(body))
      | @lib.TryTable(_, _, @lib.Expr(body)) =>
        count += dae_count_active_direct_calls_to(body, callee_abs)
      @lib.If(_, then_body, Some(else_body)) => {
        count += dae_count_active_direct_calls_to(then_body, callee_abs)
        count += dae_count_active_direct_calls_to(else_body, callee_abs)
      }
      @lib.If(_, then_body, None) =>
        count += dae_count_active_direct_calls_to(then_body, callee_abs)
      _ => ()
    }
    idx += 1
  }
  count
}

///|
fn dae_count_self_calls(func : @lib.Func, callee_abs : Int) -> Int {
  let @lib.Func(_, @lib.Expr(body)) = func
  dae_count_active_direct_calls_to(body, callee_abs)
}

///|
fn dae_count_direct_call_anywhere_to(
  instrs : Array[@lib.Instruction],
  callee_abs : Int,
) -> Int {
  dae_direct_call_target_evidence(instrs, callee_abs).direct_call_count
}

///|
fn dae_count_self_calls_anywhere(func : @lib.Func, callee_abs : Int) -> Int {
  let @lib.Func(_, @lib.Expr(body)) = func
  dae_count_direct_call_anywhere_to(body, callee_abs)
}

///|
fn dae_count_module_calls_anywhere_to(
  funcs : Array[@lib.Func],
  callee_abs : Int,
) -> Int {
  let mut count = 0
  for func in funcs {
    let @lib.Func(_, @lib.Expr(body)) = func
    count += dae_count_direct_call_anywhere_to(body, callee_abs)
  }
  count
}

///|
fn dae_has_undropped_direct_call_to(
  instrs : Array[@lib.Instruction],
  callee_abs : Int,
) -> Bool {
  dae_direct_call_target_evidence(instrs, callee_abs).has_undropped_direct_call
}

///|
fn dae_control_result_undropped_direct_call_evidence_from_parts(
  block_type : @lib.BlockType,
  primary_body : Array[@lib.Instruction],
  secondary_body : Array[@lib.Instruction]?,
  callee_abs : Int,
) -> DaeControlResultUndroppedDirectCallEvidence {
  let arity = dae_instr_result_arity_from_block_type(block_type)
  let result_arity_known = arity is Some(_)
  let result_arity = match arity {
    Some(count) => count
    None => 0
  }
  let has_result = match arity {
    Some(count) => count > 0
    None => true
  }
  let primary_has_undropped_direct_call = dae_has_undropped_direct_call_to(
    primary_body, callee_abs,
  )
  let secondary_has_undropped_direct_call = match secondary_body {
    Some(body) => dae_has_undropped_direct_call_to(body, callee_abs)
    None => false
  }
  let has_undropped_direct_call = primary_has_undropped_direct_call ||
    secondary_has_undropped_direct_call
  {
    result_arity_known,
    result_arity,
    has_result,
    primary_has_undropped_direct_call,
    secondary_has_undropped_direct_call,
    has_undropped_direct_call,
    blocks_result_removal: has_result && has_undropped_direct_call,
  }
}

///|
fn dae_control_result_undropped_direct_call_evidence(
  instr : @lib.Instruction,
  callee_abs : Int,
) -> DaeControlResultUndroppedDirectCallEvidence? {
  match instr {
    @lib.Block(block_type, @lib.Expr(body))
    | @lib.Loop(block_type, @lib.Expr(body))
    | @lib.TryTable(block_type, _, @lib.Expr(body)) =>
      Some(
        dae_control_result_undropped_direct_call_evidence_from_parts(
          block_type,
          body,
          None,
          callee_abs,
        ),
      )
    @lib.If(block_type, then_body, else_body) =>
      Some(
        dae_control_result_undropped_direct_call_evidence_from_parts(
          block_type, then_body, else_body, callee_abs,
        ),
      )
    _ => None
  }
}

///|
fn dae_control_result_undropped_direct_call_evidence_is_consistent(
  evidence : DaeControlResultUndroppedDirectCallEvidence,
) -> Bool {
  evidence.result_arity >= 0 &&
  evidence.has_result ==
  (!evidence.result_arity_known || evidence.result_arity > 0) &&
  evidence.has_undropped_direct_call ==
  (
    evidence.primary_has_undropped_direct_call ||
    evidence.secondary_has_undropped_direct_call
  ) &&
  evidence.blocks_result_removal ==
  (evidence.has_result && evidence.has_undropped_direct_call)
}

///|
fn dae_suffix_has_top_level_dropped_direct_call_to(
  suffix : Array[@lib.Instruction],
  callee_abs : Int,
) -> Bool {
  let mut suffix_idx = 0
  while suffix_idx + 1 < suffix.length() {
    match (suffix[suffix_idx], suffix[suffix_idx + 1]) {
      (@lib.Call(func_idx), @lib.Drop) if dae_func_idx_slot(func_idx) ==
        callee_abs => return true
      _ => ()
    }
    suffix_idx += 1
  }
  false
}

///|
fn dae_dead_suffix_direct_call_evidence(
  instrs : Array[@lib.Instruction],
  callee_abs : Int,
) -> DaeDeadSuffixDirectCallEvidence? {
  match dae_dead_suffix_evidence(instrs) {
    Some(dead_suffix) => {
      let target = dae_direct_call_target_evidence(
        dead_suffix.suffix,
        callee_abs,
      )
      Some({
        has_dropped_direct_call: dae_suffix_has_top_level_dropped_direct_call_to(
          dead_suffix.suffix,
          callee_abs,
        ),
        has_undropped_direct_call: target.has_undropped_direct_call,
      })
    }
    None => None
  }
}

///|
fn dae_dropped_result_callee_rewrite_evidence(
  func : @lib.Func,
  params : Array[@lib.ValType],
  results : Array[@lib.ValType],
  legality : DaeDroppedResultRemovalLegalityEvidence,
  callee_abs : Int,
) -> DaeDroppedResultCalleeRewriteEvidence {
  let @lib.Func(_, @lib.Expr(body)) = func
  let suffix = dae_dead_suffix_direct_call_evidence(body, callee_abs)
  let has_dropped_dead_suffix_call = match suffix {
    Some(evidence) => evidence.has_dropped_direct_call
    None => false
  }
  let has_undropped_dead_suffix_call = match suffix {
    Some(evidence) => evidence.has_undropped_direct_call
    None => false
  }
  {
    param_count: params.length(),
    result_count: results.length(),
    original_unreachable_only: dae_func_is_unreachable_only(func),
    simplified_unreachable_only: dae_func_is_unreachable_only(
      dae_simplify_to_unreachable_when_prefix_unobservable(func),
    ),
    has_dropped_dead_suffix_call,
    has_undropped_dead_suffix_call,
    missing_dropped_dead_suffix_call: !has_dropped_dead_suffix_call,
    missing_undropped_dead_suffix_call: !has_undropped_dead_suffix_call,
    blocks_result_removal: dae_dropped_result_removal_legality_blocks(legality),
  }
}

///|
fn dae_dropped_result_callee_rewrite_missing_dropped_suffix(
  evidence : DaeDroppedResultCalleeRewriteEvidence,
) -> Bool {
  !evidence.has_dropped_dead_suffix_call &&
  evidence.missing_dropped_dead_suffix_call
}

///|
fn dae_dropped_result_callee_rewrite_missing_undropped_suffix(
  evidence : DaeDroppedResultCalleeRewriteEvidence,
) -> Bool {
  !evidence.has_undropped_dead_suffix_call &&
  evidence.missing_undropped_dead_suffix_call
}

///|
fn dae_dead_suffix_has_other_call(
  instrs : Array[@lib.Instruction],
  callee_abs : Int,
) -> Bool {
  match dae_dead_suffix_evidence(instrs) {
    Some(evidence) => {
      let mut suffix_idx = 0
      while suffix_idx < evidence.suffix.length() {
        match evidence.suffix[suffix_idx] {
          @lib.Call(func_idx) if dae_func_idx_slot(func_idx) != callee_abs =>
            return true
          _ => ()
        }
        suffix_idx += 1
      }
      false
    }
    None => false
  }
}

///|
fn dae_dead_suffix_has_dropped_direct_call_to(
  instrs : Array[@lib.Instruction],
  callee_abs : Int,
) -> Bool {
  match dae_dead_suffix_direct_call_evidence(instrs, callee_abs) {
    Some(evidence) => evidence.has_dropped_direct_call
    None => false
  }
}

///|
fn dae_dead_suffix_has_undropped_direct_call_to(
  instrs : Array[@lib.Instruction],
  callee_abs : Int,
) -> Bool {
  match dae_dead_suffix_direct_call_evidence(instrs, callee_abs) {
    Some(evidence) => evidence.has_undropped_direct_call
    None => false
  }
}

///|
fn dae_append_targets(dst : Array[Int], src : Array[Int]) -> Unit {
  for target in src {
    dst.push(target)
  }
}

///|
fn dae_defined_direct_target(
  func_idx : @lib.FuncIdx,
  imported : Int,
  defined : Int,
) -> Int? {
  let slot = dae_func_idx_slot(func_idx)
  let def_idx = slot - imported
  if slot >= imported && def_idx >= 0 && def_idx < defined {
    Some(def_idx)
  } else {
    None
  }
}

///|
fn dae_collect_dead_suffix_direct_target_lists(
  instrs : Array[@lib.Instruction],
  imported : Int,
  defined : Int,
  collect_top_level_dropped : Bool,
  direct_targets : Array[Int],
  dropped_direct_targets : Array[Int],
  undropped_direct_targets : Array[Int],
) -> Unit {
  let mut idx = 0
  while idx < instrs.length() {
    match instrs[idx] {
      @lib.Call(func_idx) =>
        match dae_defined_direct_target(func_idx, imported, defined) {
          Some(def_idx) => {
            direct_targets.push(def_idx)
            let dropped = idx + 1 < instrs.length() &&
              instrs[idx + 1] == @lib.Instruction::drop()
            if dropped {
              if collect_top_level_dropped {
                dropped_direct_targets.push(def_idx)
              }
            } else {
              undropped_direct_targets.push(def_idx)
            }
          }
          None => ()
        }
      @lib.ReturnCall(func_idx) =>
        match dae_defined_direct_target(func_idx, imported, defined) {
          Some(def_idx) => undropped_direct_targets.push(def_idx)
          None => ()
        }
      @lib.Block(_, @lib.Expr(body))
      | @lib.Loop(_, @lib.Expr(body))
      | @lib.TryTable(_, _, @lib.Expr(body)) =>
        dae_collect_dead_suffix_direct_target_lists(
          body, imported, defined, false, direct_targets, dropped_direct_targets,
          undropped_direct_targets,
        )
      @lib.If(_, then_body, Some(else_body)) => {
        dae_collect_dead_suffix_direct_target_lists(
          then_body, imported, defined, false, direct_targets, dropped_direct_targets,
          undropped_direct_targets,
        )
        dae_collect_dead_suffix_direct_target_lists(
          else_body, imported, defined, false, direct_targets, dropped_direct_targets,
          undropped_direct_targets,
        )
      }
      @lib.If(_, then_body, None) =>
        dae_collect_dead_suffix_direct_target_lists(
          then_body, imported, defined, false, direct_targets, dropped_direct_targets,
          undropped_direct_targets,
        )
      _ => ()
    }
    idx += 1
  }
}

///|
fn dae_dead_suffix_direct_target_evidence(
  instrs : Array[@lib.Instruction],
  imported : Int,
  defined : Int,
) -> DaeDeadSuffixDirectTargetEvidence? {
  match dae_dead_suffix_evidence(instrs) {
    Some(evidence) => {
      let direct_targets : Array[Int] = []
      let dropped_direct_targets : Array[Int] = []
      let undropped_direct_targets : Array[Int] = []
      dae_collect_dead_suffix_direct_target_lists(
        evidence.suffix,
        imported,
        defined,
        true,
        direct_targets,
        dropped_direct_targets,
        undropped_direct_targets,
      )
      Some({ direct_targets, dropped_direct_targets, undropped_direct_targets })
    }
    None => None
  }
}

///|
fn dae_collect_dead_suffix_undropped_direct_targets(
  instrs : Array[@lib.Instruction],
  imported : Int,
  defined : Int,
  targets : Array[Int],
) -> Unit {
  match dae_dead_suffix_direct_target_evidence(instrs, imported, defined) {
    Some(evidence) =>
      dae_append_targets(targets, evidence.undropped_direct_targets)
    None => ()
  }
}

///|
fn dae_collect_dead_suffix_dropped_direct_targets(
  instrs : Array[@lib.Instruction],
  imported : Int,
  defined : Int,
  targets : Array[Int],
) -> Unit {
  match dae_dead_suffix_direct_target_evidence(instrs, imported, defined) {
    Some(evidence) =>
      dae_append_targets(targets, evidence.dropped_direct_targets)
    None => ()
  }
}

///|
fn dae_self_call_has_adjacent_param_forward(
  instrs : Array[@lib.Instruction],
  call_idx : Int,
  param_count : Int,
) -> Bool {
  dae_adjacent_param_forward_evidence(instrs, call_idx, param_count) is Some(_)
}

///|
fn dae_empty_param_origins(param_count : Int) -> Array[Bool] {
  Array::make(param_count, false)
}

///|
fn dae_single_param_origin(param_count : Int, slot : Int) -> Array[Bool] {
  let origins = dae_empty_param_origins(param_count)
  if slot >= 0 && slot < origins.length() {
    origins[slot] = true
  }
  origins
}

///|
fn dae_union_param_origins(dst : Array[Bool], src : Array[Bool]) -> Unit {
  let mut idx = 0
  while idx < dst.length() && idx < src.length() {
    dst[idx] = dst[idx] || src[idx]
    idx += 1
  }
}

///|
fn dae_param_origins_any(origins : Array[Bool]) -> Bool {
  for origin in origins {
    if origin {
      return true
    }
  }
  false
}

///|
fn dae_stack_operand_window_evidence_is_consistent(
  evidence : DaeStackOperandWindowEvidence,
  stack_length : Int,
) -> Bool {
  evidence.start >= 0 &&
  evidence.end == stack_length &&
  evidence.start <= evidence.end &&
  evidence.available_operands == evidence.end - evidence.start &&
  evidence.available_operands >= 0 &&
  (
    evidence.requested_operands >= evidence.available_operands ||
    evidence.requested_operands < 0
  )
}

///|
fn dae_stack_operand_window_evidence(
  stack_length : Int,
  arg_count : Int,
) -> DaeStackOperandWindowEvidence? {
  if stack_length < 0 {
    return None
  }
  let requested = if arg_count < 0 { 0 } else { arg_count }
  let start = if stack_length > requested {
    stack_length - requested
  } else {
    0
  }
  let evidence = {
    start,
    end: stack_length,
    requested_operands: arg_count,
    available_operands: stack_length - start,
  }
  if dae_stack_operand_window_evidence_is_consistent(evidence, stack_length) {
    Some(evidence)
  } else {
    None
  }
}

///|
fn dae_stack_bool_has_true_operand(
  stack : Array[Bool],
  arg_count : Int,
) -> Bool {
  let window = match
    dae_stack_operand_window_evidence(stack.length(), arg_count) {
    Some(window) => window
    None => return false
  }
  let mut idx = window.start
  while idx < window.end {
    if idx >= 0 && idx < stack.length() && stack[idx] {
      return true
    }
    idx += 1
  }
  false
}

///|
fn dae_stack_bool_apply_effect(
  stack : Array[Bool],
  inputs : Int,
  outputs : Int,
  pushed_value : Bool,
) -> Unit {
  let mut pop = 0
  while pop < inputs && stack.length() > 0 {
    ignore(stack.pop())
    pop += 1
  }
  let mut push = 0
  while push < outputs {
    stack.push(pushed_value)
    push += 1
  }
}

///|
fn dae_stack_effect_evidence_is_consistent(
  evidence : DaeStackEffectEvidence,
) -> Bool {
  evidence.inputs >= 0 && evidence.outputs >= 0
}

///|
fn dae_stack_effect_evidence(
  instr : @lib.Instruction,
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
) -> DaeStackEffectEvidence? {
  match dae_instr_stack_effect(instr, mod_, func_type_indices) {
    Some((inputs, outputs)) => {
      let evidence = { inputs, outputs }
      if dae_stack_effect_evidence_is_consistent(evidence) {
        Some(evidence)
      } else {
        None
      }
    }
    None => None
  }
}

///|
fn dae_stack_single_value_producer_evidence(
  instr : @lib.Instruction,
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
) -> DaeStackEffectEvidence? {
  match dae_stack_effect_evidence(instr, mod_, func_type_indices) {
    Some(evidence) if evidence.inputs == 0 && evidence.outputs == 1 =>
      Some(evidence)
    _ => None
  }
}

///|
fn dae_stack_slice_simulation_evidence_is_consistent(
  evidence : DaeStackSliceSimulationEvidence,
) -> Bool {
  evidence.start >= 0 &&
  evidence.end >= evidence.start &&
  evidence.initial_stack_values >= 0 &&
  evidence.final_stack_values >= 0 &&
  evidence.max_stack_values >= evidence.initial_stack_values &&
  evidence.max_stack_values >= evidence.final_stack_values &&
  (!evidence.saw_effect_or_branch || evidence.end > evidence.start)
}

///|
fn dae_stack_slice_simulation_evidence(
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  body : Array[@lib.Instruction],
  start : Int,
  end : Int,
  initial_stack_values : Int,
  instr_allowed : (@lib.Instruction) -> Bool,
) -> DaeStackSliceSimulationEvidence? {
  if start < 0 || end < start || end > body.length() || initial_stack_values < 0 {
    return None
  }
  let mut stack_values = initial_stack_values
  let mut max_stack_values = initial_stack_values
  let mut saw_effect_or_branch = false
  let mut idx = start
  while idx < end {
    let instr = body[idx]
    if !instr_allowed(instr) {
      return None
    }
    if dae_instr_has_observable_effect_or_branch(instr) {
      saw_effect_or_branch = true
    }
    let effect = match
      dae_stack_effect_evidence(instr, mod_, func_type_indices) {
      Some(effect) => effect
      None => return None
    }
    if stack_values < effect.inputs {
      return None
    }
    stack_values = stack_values - effect.inputs + effect.outputs
    if stack_values > max_stack_values {
      max_stack_values = stack_values
    }
    idx += 1
  }
  let evidence = {
    start,
    end,
    initial_stack_values,
    final_stack_values: stack_values,
    max_stack_values,
    saw_effect_or_branch,
  }
  if dae_stack_slice_simulation_evidence_is_consistent(evidence) {
    Some(evidence)
  } else {
    None
  }
}

///|
fn dae_stack_slice_transition_evidence_is_consistent(
  evidence : DaeStackSliceTransitionEvidence,
) -> Bool {
  evidence.expected_final_stack_values >= 0 &&
  dae_stack_slice_simulation_evidence_is_consistent(evidence.simulation) &&
  evidence.simulation.final_stack_values == evidence.expected_final_stack_values
}

///|
fn dae_stack_slice_transition_evidence(
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  body : Array[@lib.Instruction],
  start : Int,
  end : Int,
  initial_stack_values : Int,
  expected_final_stack_values : Int,
  instr_allowed : (@lib.Instruction) -> Bool,
) -> DaeStackSliceTransitionEvidence? {
  if expected_final_stack_values < 0 {
    return None
  }
  match
    dae_stack_slice_simulation_evidence(
      mod_, func_type_indices, body, start, end, initial_stack_values, instr_allowed,
    ) {
    Some(simulation) => {
      let evidence = { simulation, expected_final_stack_values }
      if dae_stack_slice_transition_evidence_is_consistent(evidence) {
        Some(evidence)
      } else {
        None
      }
    }
    None => None
  }
}

///|
fn dae_stack_bool_apply_instr_effect(
  stack : Array[Bool],
  instr : @lib.Instruction,
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  pushed_value : Bool,
) -> Bool {
  match dae_stack_effect_evidence(instr, mod_, func_type_indices) {
    Some(evidence) => {
      dae_stack_bool_apply_effect(
        stack,
        evidence.inputs,
        evidence.outputs,
        pushed_value,
      )
      true
    }
    None => false
  }
}

///|
fn dae_stack_int_has_operand_value(
  stack : Array[Int],
  arg_count : Int,
  value : Int,
) -> Bool {
  let window = match
    dae_stack_operand_window_evidence(stack.length(), arg_count) {
    Some(window) => window
    None => return false
  }
  let mut idx = window.start
  while idx < window.end {
    if idx >= 0 && idx < stack.length() && stack[idx] == value {
      return true
    }
    idx += 1
  }
  false
}

///|
fn dae_stack_int_has_known_operand(stack : Array[Int], arg_count : Int) -> Bool {
  let window = match
    dae_stack_operand_window_evidence(stack.length(), arg_count) {
    Some(window) => window
    None => return false
  }
  let mut idx = window.start
  while idx < window.end {
    if idx >= 0 && idx < stack.length() && stack[idx] >= 0 {
      return true
    }
    idx += 1
  }
  false
}

///|
fn dae_stack_int_apply_effect(
  stack : Array[Int],
  inputs : Int,
  outputs : Int,
  pushed_value : Int,
) -> Unit {
  let mut pop = 0
  while pop < inputs && stack.length() > 0 {
    ignore(stack.pop())
    pop += 1
  }
  let mut push = 0
  while push < outputs {
    stack.push(pushed_value)
    push += 1
  }
}

///|
fn dae_stack_int_apply_instr_effect(
  stack : Array[Int],
  instr : @lib.Instruction,
  mod_ : @lib.Module,
  func_type_indices : Array[@lib.TypeIdx],
  pushed_value : Int,
) -> Bool {
  match dae_stack_effect_evidence(instr, mod_, func_type_indices) {
    Some(evidence) => {
      dae_stack_int_apply_effect(
        stack,
        evidence.inputs,
        evidence.outputs,
        pushed_value,
      )
      true
    }
    None => false
  }
}

///|
fn dae_collect_self_call_operand_param_gets(
  instrs : Array[@lib.Instruction],
  callee_abs : Int,
  param_count : Int,
  mod_ : @lib.Module,
  type_indices : Array[@lib.TypeIdx],
  escaped : Array[Bool],
  preserve : Array[Bool],
  preserve_direct_fallback : Bool,
) -> Unit {
  let stack : Array[Int] = []
  let stack_from_call : Array[Bool] = []
  let stack_origins : Array[Array[Bool]] = []
  let mut idx = 0
  while idx < instrs.length() {
    match instrs[idx] {
      @lib.LocalGet(local_idx) => {
        let slot = dae_local_idx_slot(local_idx)
        if slot >= 0 && slot < param_count {
          stack.push(slot)
          stack_origins.push(dae_single_param_origin(param_count, slot))
        } else {
          stack.push(-1)
          stack_origins.push(dae_empty_param_origins(param_count))
        }
        stack_from_call.push(false)
      }
      @lib.Call(func_idx) if dae_func_idx_slot(func_idx) == callee_abs => {
        let mut has_call_operand = false
        let call_operand_origins = dae_empty_param_origins(param_count)
        let direct_operand_origins = dae_empty_param_origins(param_count)
        let mut p = 0
        while p < param_count {
          let stack_idx = stack.length() - param_count + p
          if stack_idx >= 0 && stack_idx < stack_from_call.length() {
            if stack_from_call[stack_idx] {
              has_call_operand = true
              dae_union_param_origins(
                call_operand_origins,
                stack_origins[stack_idx],
              )
            } else {
              dae_union_param_origins(
                direct_operand_origins,
                stack_origins[stack_idx],
              )
            }
          }
          p += 1
        }
        // Binaryen preserves params stranded under a side-call result that is
        // later used by a dead-suffix self call, but it still prunes params that
        // are also supplied as direct local operands to that same self call.
        if has_call_operand &&
          !dae_self_call_has_adjacent_param_forward(instrs, idx, param_count) {
          let call_origins_seen = dae_param_origins_any(call_operand_origins)
          let self_call_is_dropped = idx + 1 < instrs.length() &&
            instrs[idx + 1] == @lib.Instruction::drop()
          p = 0
          while p < param_count && p < preserve.length() {
            if call_origins_seen {
              if !self_call_is_dropped &&
                call_operand_origins[p] &&
                !direct_operand_origins[p] {
                preserve[p] = true
              }
            } else if preserve_direct_fallback && direct_operand_origins[p] {
              preserve[p] = true
            }
            p += 1
          }
        }
        let mut pop = 0
        while pop < param_count && stack.length() > 0 {
          ignore(stack.pop())
          ignore(stack_from_call.pop())
          ignore(stack_origins.pop())
          pop += 1
        }
        match dae_resolve_func_type(mod_, type_indices, callee_abs) {
          Some(@lib.FuncType(_, results)) => {
            let mut r = 0
            while r < results.length() {
              stack.push(-1)
              stack_from_call.push(true)
              stack_origins.push(dae_empty_param_origins(param_count))
              r += 1
            }
          }
          None => ()
        }
      }
      @lib.Call(func_idx) =>
        match dae_stack_effect_evidence(instrs[idx], mod_, type_indices) {
          Some(effect) => {
            let inputs = effect.inputs
            let outputs = effect.outputs
            let popped_origins = dae_empty_param_origins(param_count)
            let mut pop = 0
            while pop < inputs && stack.length() > 0 {
              ignore(stack.pop())
              ignore(stack_from_call.pop())
              match stack_origins.pop() {
                Some(origins) =>
                  dae_union_param_origins(popped_origins, origins)
                None => ()
              }
              pop += 1
            }
            let slot = dae_func_idx_slot(func_idx)
            let output_origins = if slot >= 0 &&
              slot < escaped.length() &&
              escaped[slot] {
              popped_origins
            } else {
              dae_empty_param_origins(param_count)
            }
            let mut push = 0
            while push < outputs {
              stack.push(-1)
              stack_from_call.push(true)
              stack_origins.push(output_origins.copy())
              push += 1
            }
          }
          None => ()
        }
      _ =>
        match dae_stack_effect_evidence(instrs[idx], mod_, type_indices) {
          Some(effect) => {
            let inputs = effect.inputs
            let outputs = effect.outputs
            let mut pop = 0
            while pop < inputs && stack.length() > 0 {
              ignore(stack.pop())
              ignore(stack_from_call.pop())
              ignore(stack_origins.pop())
              pop += 1
            }
            let mut push = 0
            while push < outputs {
              stack.push(-1)
              stack_from_call.push(false)
              stack_origins.push(dae_empty_param_origins(param_count))
              push += 1
            }
          }
          None => ()
        }
    }
    idx += 1
  }
}

///|
fn dae_collect_dead_suffix_self_operand_params(
  func : @lib.Func,
  callee_abs : Int,
  param_count : Int,
  mod_ : @lib.Module,
  type_indices : Array[@lib.TypeIdx],
  escaped : Array[Bool],
  preserve_direct_fallback : Bool,
) -> Array[Bool] {
  let preserve = Array::make(param_count, false)
  let @lib.Func(_, @lib.Expr(body)) = func
  match dae_dead_suffix_evidence(body) {
    Some(evidence) =>
      dae_collect_self_call_operand_param_gets(
        evidence.suffix,
        callee_abs,
        param_count,
        mod_,
        type_indices,
        escaped,
        preserve,
        preserve_direct_fallback,
      )
    None => ()
  }
  preserve
}

///|
fn dae_filter_params(
  params : Array[@lib.ValType],
  keep : Array[Bool],
) -> Array[@lib.ValType] {
  let out : Array[@lib.ValType] = []
  let mut idx = 0
  while idx < params.length() {
    if idx < keep.length() && keep[idx] {
      out.push(params[idx])
    }
    idx += 1
  }
  out
}

///|
fn dae_try_remove_dead_suffix_only_unreachable_params(
  mod_ : @lib.Module,
  callee_abs : Int,
  original_call_count : Int,
  allow_unreachable_only_cleanup : Bool,
) -> DaePassResult {
  let imported = dae_imported_func_count(mod_)
  let def_idx = callee_abs - imported
  let type_indices = dae_collect_func_type_indices(mod_)
  let func_type = match dae_resolve_func_type(mod_, type_indices, callee_abs) {
    Some(ft) => ft
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let @lib.FuncType(params, results) = func_type
  if params.length() == 0 {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let signature = match
    dae_module_signature_context(mod_, def_idx, copy_funcs=true) {
    Some(signature) => signature
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let funcs = signature.funcs
  let type_sec = signature.type_sec
  let current_calls_anywhere = dae_count_module_calls_anywhere_to(
    funcs, callee_abs,
  )
  if current_calls_anywhere == 0 && original_call_count == 0 {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  if current_calls_anywhere == 0 &&
    dae_func_is_unreachable_only(funcs[def_idx]) &&
    !allow_unreachable_only_cleanup {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let simplified = dae_simplify_to_unreachable_when_prefix_unobservable(
    funcs[def_idx],
  )
  if !dae_func_is_unreachable_only(simplified) {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let full_scope = dae_dropped_result_scope_from_optional(funcs.length(), None)
  let repair_plan = dae_dropped_result_repair_plan(
    full_scope,
    callee_abs,
    def_idx,
    DaeRepairDeadSuffixAllCallers,
    remove_dropped_call_drops=false,
    remove_dropped_call_drops_before_repair=false,
  )
  dae_apply_dropped_result_repair_plan(
    funcs, type_indices, type_sec, imported, repair_plan,
  )
  let escaped = dae_collect_escapes(mod_, type_indices.length())
  let keep_params = dae_collect_dead_suffix_self_operand_params(
    funcs[def_idx],
    callee_abs,
    params.length(),
    mod_,
    type_indices,
    escaped,
    true,
  )
  let next_params = dae_filter_params(params, keep_params)
  funcs[def_idx] = @lib.Func::new(
    @lib.Locals::empty(),
    @lib.Expr::new([@lib.Instruction::unreachable_()]),
  )
  let plan = dae_module_code_finalization_plan(
    next_params,
    results,
    DaeTouchModuleCodeCalleeOnly,
  )
  dae_apply_module_code_finalization(mod_, signature, funcs, plan)
}

///|
fn dae_try_remove_unobserved_unreachable_function(
  mod_ : @lib.Module,
  callee_abs : Int,
) -> DaePassResult {
  let context = match dae_dropped_result_module_context(mod_, callee_abs) {
    Some(context) => context
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let def_idx = context.signature.def_idx
  let funcs = context.signature.funcs
  let rewrite_evidence = dae_dropped_result_callee_rewrite_evidence(
    funcs[def_idx],
    context.params,
    context.results,
    context.result_removal_legality,
    callee_abs,
  )
  if rewrite_evidence.param_count == 0 && rewrite_evidence.result_count == 0 {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let module_calls_anywhere = dae_count_module_calls_anywhere_to(
    funcs, callee_abs,
  )
  if module_calls_anywhere == 0 {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  if rewrite_evidence.blocks_result_removal {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  if !rewrite_evidence.simplified_unreachable_only ||
    (
      rewrite_evidence.result_count > 0 &&
      dae_dropped_result_callee_rewrite_missing_undropped_suffix(
        rewrite_evidence,
      )
    ) {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let plan = dae_dropped_result_unreachable_callee_rewrite_plan(
    context,
    DaeRepairDeadSuffixAllCallers,
    [],
  )
  dae_apply_dropped_result_unreachable_callee_rewrite(mod_, context, plan)
}

///|
fn dae_try_remove_dead_self_suffix_result(
  mod_ : @lib.Module,
  callee_abs : Int,
) -> DaePassResult {
  let context = match dae_dropped_result_module_context(mod_, callee_abs) {
    Some(context) => context
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let def_idx = context.signature.def_idx
  let funcs = context.signature.funcs
  let rewrite_evidence = dae_dropped_result_callee_rewrite_evidence(
    funcs[def_idx],
    context.params,
    context.results,
    context.result_removal_legality,
    callee_abs,
  )
  if rewrite_evidence.param_count != 0 || rewrite_evidence.result_count != 1 {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  if rewrite_evidence.original_unreachable_only ||
    dae_dropped_result_callee_rewrite_missing_dropped_suffix(rewrite_evidence) {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  if rewrite_evidence.blocks_result_removal {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let plan = dae_dropped_result_unreachable_callee_rewrite_plan(
    context,
    DaeRepairDeadSuffixNoParamCallers,
    [],
  )
  dae_apply_dropped_result_unreachable_callee_rewrite(mod_, context, plan)
}

///|
fn dae_try_remove_uncalled_results(
  mod_ : @lib.Module,
  callee_abs : Int,
) -> DaePassResult {
  let context = match dae_dropped_result_module_context(mod_, callee_abs) {
    Some(context) => context
    None =>
      return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let def_idx = context.signature.def_idx
  let funcs = context.signature.funcs
  let rewrite_evidence = dae_dropped_result_callee_rewrite_evidence(
    funcs[def_idx],
    context.params,
    context.results,
    context.result_removal_legality,
    callee_abs,
  )
  if rewrite_evidence.param_count != 0 || rewrite_evidence.result_count == 0 {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  if rewrite_evidence.blocks_result_removal {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  if !rewrite_evidence.simplified_unreachable_only {
    return { mod_out: mod_, touched: [], changed: false, primary_def: -1 }
  }
  let plan = dae_dropped_result_unreachable_callee_rewrite_plan(
    context,
    DaeRepairDeadSuffixNoParamCallers,
    context.params,
  )
  dae_apply_dropped_result_unreachable_callee_rewrite(mod_, context, plan)
}

///|
fn dae_scan_original_call_summary_instrs(
  instrs : Array[@lib.Instruction],
  imported : Int,
  defined : Int,
  targets : Array[Int],
  undropped_targets : Array[Int],
) -> Unit {
  let mut idx = 0
  while idx < instrs.length() {
    match instrs[idx] {
      @lib.Call(func_idx) => {
        let slot = dae_func_idx_slot(func_idx)
        let def_idx = slot - imported
        if slot >= imported && def_idx >= 0 && def_idx < defined {
          targets.push(def_idx)
          if idx + 1 >= instrs.length() ||
            instrs[idx + 1] != @lib.Instruction::drop() {
            undropped_targets.push(def_idx)
          }
        }
      }
      @lib.Block(_, @lib.Expr(body))
      | @lib.Loop(_, @lib.Expr(body))
      | @lib.TryTable(_, _, @lib.Expr(body)) =>
        dae_scan_original_call_summary_instrs(
          body, imported, defined, targets, undropped_targets,
        )
      @lib.If(_, then_body, Some(else_body)) => {
        dae_scan_original_call_summary_instrs(
          then_body, imported, defined, targets, undropped_targets,
        )
        dae_scan_original_call_summary_instrs(
          else_body, imported, defined, targets, undropped_targets,
        )
      }
      @lib.If(_, then_body, None) =>
        dae_scan_original_call_summary_instrs(
          then_body, imported, defined, targets, undropped_targets,
        )
      _ => ()
    }
    idx += 1
  }
}

///|
fn dae_collect_module_call_counts_anywhere(
  funcs : Array[@lib.Func],
  imported : Int,
  defined : Int,
) -> Array[Int] {
  let counts = Array::make(defined, 0)
  for func in funcs {
    let targets : Array[Int] = []
    let undropped_targets : Array[Int] = []
    let @lib.Func(_, @lib.Expr(body)) = func
    dae_scan_original_call_summary_instrs(
      body, imported, defined, targets, undropped_targets,
    )
    for target in targets {
      if target >= 0 && target < defined {
        counts[target] = counts[target] + 1
      }
    }
  }
  counts
}

///|
fn dae_collect_original_call_summary_with_context(
  mod_ : @lib.Module,
  imported : Int,
  defined : Int,
  type_indices : Array[@lib.TypeIdx],
  escaped : Array[Bool],
) -> DaeOriginalCallSummary {
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None => {
      let empty = Array::make(defined, 0)
      return {
        call_counts: empty.copy(),
        prior_call_counts: empty.copy(),
        nonself_undropped_call_counts: empty.copy(),
        active_nonself_call_counts: empty.copy(),
        active_parameterized_nonself_call_counts: empty.copy(),
        active_parameterized_result_nonself_call_counts: empty.copy(),
        prior_undropped_call_counts: empty.copy(),
        self_call_counts: empty.copy(),
      }
    }
  }
  let call_targets_by_caller : Array[Array[Int]] = []
  let call_counts = Array::make(defined, 0)
  let prior_call_counts = Array::make(defined, 0)
  let nonself_undropped_call_counts = Array::make(defined, 0)
  let prior_undropped_call_counts = Array::make(defined, 0)
  let self_call_counts = Array::make(defined, 0)
  let seen_undropped_stamp = Array::make(defined, -1)
  let mut caller_def = 0
  while caller_def < funcs.length() && caller_def < defined {
    let targets : Array[Int] = []
    let undropped_targets : Array[Int] = []
    let @lib.Func(_, @lib.Expr(body)) = funcs[caller_def]
    dae_scan_original_call_summary_instrs(
      body, imported, defined, targets, undropped_targets,
    )
    call_targets_by_caller.push(targets)
    for target in targets {
      call_counts[target] = call_counts[target] + 1
      if target == caller_def {
        self_call_counts[target] = self_call_counts[target] + 1
      }
      if target > caller_def {
        prior_call_counts[target] = prior_call_counts[target] + 1
      }
    }
    for target in undropped_targets {
      if seen_undropped_stamp[target] != caller_def {
        seen_undropped_stamp[target] = caller_def
        if target != caller_def {
          nonself_undropped_call_counts[target] = nonself_undropped_call_counts[target] +
            1
        }
        if target > caller_def {
          prior_undropped_call_counts[target] = prior_undropped_call_counts[target] +
            1
        }
      }
    }
    caller_def += 1
  }
  while call_targets_by_caller.length() < defined {
    call_targets_by_caller.push([])
  }
  let active_nonself_call_counts = Array::make(defined, 0)
  let active_parameterized_nonself_call_counts = Array::make(defined, 0)
  let active_parameterized_result_nonself_call_counts = Array::make(defined, 0)
  caller_def = 0
  while caller_def < defined {
    let caller_abs = imported + caller_def
    let caller_is_active = (
        caller_abs < escaped.length() && escaped[caller_abs]
      ) ||
      call_counts[caller_def] > 0
    let (caller_has_params, caller_has_params_and_result) = match
      dae_resolve_func_type(mod_, type_indices, caller_abs) {
      Some(@lib.FuncType(params, results)) =>
        (params.length() > 0, params.length() > 0 && results.length() > 0)
      None => (false, false)
    }
    if caller_is_active {
      for target in call_targets_by_caller[caller_def] {
        if target != caller_def {
          active_nonself_call_counts[target] = active_nonself_call_counts[target] +
            1
          if caller_has_params {
            active_parameterized_nonself_call_counts[target] = active_parameterized_nonself_call_counts[target] +
              1
          }
          if caller_has_params_and_result {
            active_parameterized_result_nonself_call_counts[target] = active_parameterized_result_nonself_call_counts[target] +
              1
          }
        }
      }
    }
    caller_def += 1
  }
  {
    call_counts,
    prior_call_counts,
    nonself_undropped_call_counts,
    active_nonself_call_counts,
    active_parameterized_nonself_call_counts,
    active_parameterized_result_nonself_call_counts,
    prior_undropped_call_counts,
    self_call_counts,
  }
}

///|
fn dae_collect_original_param_counts_with_type_indices(
  mod_ : @lib.Module,
  type_indices : Array[@lib.TypeIdx],
) -> Array[Int] {
  let imported = dae_imported_func_count(mod_)
  let defined = dae_defined_func_count(mod_)
  let counts : Array[Int] = []
  let mut def_idx = 0
  while def_idx < defined {
    match dae_resolve_func_type(mod_, type_indices, imported + def_idx) {
      Some(@lib.FuncType(params, _)) => counts.push(params.length())
      None => counts.push(0)
    }
    def_idx += 1
  }
  counts
}

///|
fn dae_collect_original_boundary_snapshot(
  mod_ : @lib.Module,
) -> DaeOriginalBoundarySnapshot {
  let imported = dae_imported_func_count(mod_)
  let defined = dae_defined_func_count(mod_)
  let total = imported + defined
  let type_indices = dae_collect_func_type_indices(mod_)
  let escaped = dae_collect_escapes(mod_, total)
  let param_counts = dae_collect_original_param_counts_with_type_indices(
    mod_, type_indices,
  )
  let call_summary = dae_collect_original_call_summary_with_context(
    mod_, imported, defined, type_indices, escaped,
  )
  let private_result_dead_suffix_call_counts = dae_collect_original_private_result_dead_suffix_call_counts_with_escaped(
    mod_,
    call_summary.call_counts,
    escaped,
  )
  let private_result_same_operand_call_counts = dae_collect_original_private_result_same_operand_call_counts_with_escaped(
    mod_, escaped,
  )
  let dead_suffix_escaped_result_call_facts = dae_collect_original_dead_suffix_escaped_result_call_facts_with_escaped(
    mod_, escaped,
  )
  let escaped_result_operand_call_facts = dae_collect_original_escaped_result_operand_call_facts_with_escaped(
    mod_, escaped, dead_suffix_escaped_result_call_facts,
  )
  let private_result_dead_suffix_calls_from_escaped_operand_callees = dae_collect_original_private_result_dead_suffix_calls_from_escaped_operand_callees(
    mod_,
    escaped_result_operand_call_facts.dead_suffix_escaped_result_operand_call_counts,
  )
  let escaped_dead_suffix_call_counts = dae_collect_original_escaped_dead_suffix_call_counts_with_escaped(
    mod_, escaped,
  )
  let escaped_undropped_dead_suffix_call_counts = dae_collect_original_escaped_undropped_dead_suffix_call_counts_with_escaped(
    mod_, escaped,
  )
  let dead_suffix_other_calls = dae_collect_original_dead_suffix_other_calls(
    mod_,
  )
  let dead_suffix_undropped_self_calls = dae_collect_original_dead_suffix_undropped_self_calls(
    mod_,
  )
  let dead_suffix_dropped_self_calls = dae_collect_original_dead_suffix_dropped_self_calls(
    mod_,
  )
  let dead_suffix_block_undropped_self_calls = dae_collect_original_dead_suffix_block_undropped_self_calls(
    mod_,
  )
  let dead_suffix_dropped_self_call_full_param_forwards = dae_collect_original_dead_suffix_dropped_self_call_full_param_forwards(
    mod_,
  )
  let dead_suffix_result_calls_from_undropped_self_callers = dae_collect_original_dead_suffix_result_calls_from_undropped_self_callers_with_escaped(
    mod_,
    call_summary.nonself_undropped_call_counts,
    escaped,
  )
  let dead_suffix_result_calls_from_no_param_undropped_self_callers = dae_collect_original_dead_suffix_result_calls_from_no_param_undropped_self_callers(
    mod_,
  )
  let dead_suffix_undropped_calls_from_parameterized_dropped_self_callers = dae_collect_original_dead_suffix_undropped_calls_from_parameterized_dropped_self_callers(
    mod_,
  )
  let dead_suffix_dropped_calls_from_parameterized_self_callers = dae_collect_original_dead_suffix_dropped_calls_from_parameterized_self_callers(
    mod_,
  )
  let dead_suffix_dropped_calls_from_no_param_result_callers = dae_collect_original_dead_suffix_dropped_calls_from_no_param_result_callers(
    mod_,
  )
  let dead_suffix_mixed_dropped_undropped_call_counts = dae_collect_original_dead_suffix_mixed_dropped_undropped_call_counts_with_escaped(
    mod_, escaped,
  )
  let dead_suffix_dropped_earlier_result_calls = dae_collect_original_dead_suffix_dropped_earlier_result_calls(
    mod_,
  )
  let later_dead_suffix_dropped_call_counts = dae_collect_original_later_dead_suffix_dropped_call_counts(
    mod_,
  )
  let dead_suffix_same_self_result_operand_calls = dae_collect_original_dead_suffix_same_self_result_operand_calls(
    mod_,
  )
  let dead_suffix_undropped_self_call_param_operands = dae_collect_original_dead_suffix_undropped_self_call_param_operands(
    mod_,
  )
  let dead_suffix_result_other_calls = dae_collect_original_dead_suffix_result_other_calls_with_escaped(
    mod_, escaped,
  )
  let dead_suffix_self_recursive_void_side_calls = dae_collect_original_dead_suffix_self_recursive_void_side_calls(
    mod_,
  )
  let dead_suffix_self_recursive_result_side_calls = dae_collect_original_dead_suffix_self_recursive_result_side_calls(
    mod_,
  )
  let dead_suffix_mutual_calls = dae_collect_original_dead_suffix_mutual_calls(
    mod_,
  )
  let dead_suffix_calls_from_param_operand_self_result_callers = dae_collect_original_dead_suffix_calls_from_param_operand_self_result_callers(
    mod_,
    param_counts,
    call_summary.call_counts,
    call_summary.active_nonself_call_counts,
    call_summary.active_parameterized_nonself_call_counts,
    call_summary.nonself_undropped_call_counts,
    call_summary.self_call_counts,
    escaped_dead_suffix_call_counts,
    dead_suffix_undropped_self_calls,
    dead_suffix_undropped_self_call_param_operands,
    dead_suffix_result_other_calls,
    dead_suffix_mutual_calls,
  )
  {
    imported,
    defined,
    total,
    type_indices,
    escaped,
    param_counts,
    large_unreachable_prefixes: dae_collect_original_large_unreachable_prefixes(
      mod_,
    ),
    call_summary,
    private_result_dead_suffix_call_counts,
    private_result_same_operand_call_counts,
    escaped_result_operand_call_facts,
    private_result_dead_suffix_calls_from_escaped_operand_callees,
    escaped_dead_suffix_call_counts,
    escaped_undropped_dead_suffix_call_counts,
    dead_suffix_other_calls,
    dead_suffix_undropped_self_calls,
    dead_suffix_dropped_self_calls,
    dead_suffix_block_undropped_self_calls,
    dead_suffix_dropped_self_call_full_param_forwards,
    dead_suffix_result_calls_from_undropped_self_callers,
    dead_suffix_result_calls_from_no_param_undropped_self_callers,
    dead_suffix_undropped_calls_from_parameterized_dropped_self_callers,
    dead_suffix_dropped_calls_from_parameterized_self_callers,
    dead_suffix_dropped_calls_from_no_param_result_callers,
    dead_suffix_mixed_dropped_undropped_call_counts,
    dead_suffix_dropped_earlier_result_calls,
    later_dead_suffix_dropped_call_counts,
    dead_suffix_same_self_result_operand_calls,
    dead_suffix_undropped_self_call_param_operands,
    dead_suffix_calls_from_param_operand_self_result_callers,
    dead_suffix_result_other_calls,
    dead_suffix_self_recursive_void_side_calls,
    dead_suffix_self_recursive_result_side_calls,
    dead_suffix_escaped_result_call_facts,
    dead_suffix_mutual_calls,
  }
}

///|
fn dae_collect_original_self_call_counts(mod_ : @lib.Module) -> Array[Int] {
  let imported = dae_imported_func_count(mod_)
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None => return []
  }
  let counts : Array[Int] = []
  let mut def_idx = 0
  while def_idx < funcs.length() {
    counts.push(
      dae_count_self_calls_anywhere(funcs[def_idx], imported + def_idx),
    )
    def_idx += 1
  }
  counts
}

///|
fn dae_collect_direct_call_target_anywhere_instr(
  instr : @lib.Instruction,
  imported : Int,
  defined : Int,
  targets : Array[Int],
) -> Unit {
  match instr {
    @lib.Call(func_idx) => {
      let slot = dae_func_idx_slot(func_idx)
      let def_idx = slot - imported
      if slot >= imported && def_idx >= 0 && def_idx < defined {
        targets.push(def_idx)
      }
    }
    @lib.Block(_, @lib.Expr(body))
    | @lib.Loop(_, @lib.Expr(body))
    | @lib.TryTable(_, _, @lib.Expr(body)) =>
      dae_collect_direct_call_targets_anywhere(body, imported, defined, targets)
    @lib.If(_, then_body, Some(else_body)) => {
      dae_collect_direct_call_targets_anywhere(
        then_body, imported, defined, targets,
      )
      dae_collect_direct_call_targets_anywhere(
        else_body, imported, defined, targets,
      )
    }
    @lib.If(_, then_body, None) =>
      dae_collect_direct_call_targets_anywhere(
        then_body, imported, defined, targets,
      )
    _ => ()
  }
}

///|
fn dae_collect_direct_call_targets_anywhere(
  instrs : Array[@lib.Instruction],
  imported : Int,
  defined : Int,
  targets : Array[Int],
) -> Unit {
  for instr in instrs {
    dae_collect_direct_call_target_anywhere_instr(
      instr, imported, defined, targets,
    )
  }
}

///|
fn dae_collect_dead_suffix_direct_targets(
  instrs : Array[@lib.Instruction],
  imported : Int,
  defined : Int,
  targets : Array[Int],
) -> Unit {
  match dae_dead_suffix_direct_target_evidence(instrs, imported, defined) {
    Some(evidence) => dae_append_targets(targets, evidence.direct_targets)
    None => ()
  }
}

///|
fn dae_count_dead_suffix_direct_call_to(
  instrs : Array[@lib.Instruction],
  callee_abs : Int,
) -> Int {
  match dae_dead_suffix_evidence(instrs) {
    Some(evidence) =>
      dae_count_direct_call_anywhere_to(evidence.suffix, callee_abs)
    None => 0
  }
}

///|
fn dae_empty_escaped_result_direct_call_evidence() -> DaeEscapedResultDirectCallEvidence {
  {
    has_dropped_escaped_result_call: false,
    has_undropped_escaped_result_call: false,
  }
}

///|
fn dae_merge_escaped_result_direct_call_evidence(
  left : DaeEscapedResultDirectCallEvidence,
  right : DaeEscapedResultDirectCallEvidence,
) -> DaeEscapedResultDirectCallEvidence {
  {
    has_dropped_escaped_result_call: left.has_dropped_escaped_result_call ||
    right.has_dropped_escaped_result_call,
    has_undropped_escaped_result_call: left.has_undropped_escaped_result_call ||
    right.has_undropped_escaped_result_call,
  }
}

///|
fn dae_call_escaped_result_direct_call_evidence(
  func_idx : @lib.FuncIdx,
  dropped : Bool,
  mod_ : @lib.Module,
  type_indices : Array[@lib.TypeIdx],
  escaped : Array[Bool],
) -> DaeEscapedResultDirectCallEvidence {
  let slot = dae_func_idx_slot(func_idx)
  if slot >= 0 && slot < escaped.length() && escaped[slot] {
    match dae_resolve_func_type(mod_, type_indices, slot) {
      Some(@lib.FuncType(_, results)) if results.length() > 0 =>
        return {
          has_dropped_escaped_result_call: dropped,
          has_undropped_escaped_result_call: !dropped,
        }
      _ => ()
    }
  }
  dae_empty_escaped_result_direct_call_evidence()
}

///|
fn dae_escaped_result_direct_call_evidence(
  instrs : Array[@lib.Instruction],
  mod_ : @lib.Module,
  type_indices : Array[@lib.TypeIdx],
  escaped : Array[Bool],
) -> DaeEscapedResultDirectCallEvidence {
  let mut evidence = dae_empty_escaped_result_direct_call_evidence()
  let mut idx = 0
  while idx < instrs.length() {
    let instr_evidence = match instrs[idx] {
      @lib.Call(func_idx) =>
        dae_call_escaped_result_direct_call_evidence(
          func_idx,
          idx + 1 < instrs.length() &&
          instrs[idx + 1] == @lib.Instruction::drop(),
          mod_,
          type_indices,
          escaped,
        )
      @lib.Block(_, @lib.Expr(body))
      | @lib.Loop(_, @lib.Expr(body))
      | @lib.TryTable(_, _, @lib.Expr(body)) =>
        dae_escaped_result_direct_call_evidence(
          body, mod_, type_indices, escaped,
        )
      @lib.If(_, then_body, Some(else_body)) =>
        dae_merge_escaped_result_direct_call_evidence(
          dae_escaped_result_direct_call_evidence(
            then_body, mod_, type_indices, escaped,
          ),
          dae_escaped_result_direct_call_evidence(
            else_body, mod_, type_indices, escaped,
          ),
        )
      @lib.If(_, then_body, None) =>
        dae_escaped_result_direct_call_evidence(
          then_body, mod_, type_indices, escaped,
        )
      _ => dae_empty_escaped_result_direct_call_evidence()
    }
    evidence = dae_merge_escaped_result_direct_call_evidence(
      evidence, instr_evidence,
    )
    idx += 1
  }
  evidence
}

///|
fn dae_dead_suffix_escaped_result_direct_call_evidence(
  instrs : Array[@lib.Instruction],
  mod_ : @lib.Module,
  type_indices : Array[@lib.TypeIdx],
  escaped : Array[Bool],
) -> DaeEscapedResultDirectCallEvidence? {
  match dae_dead_suffix_evidence(instrs) {
    Some(evidence) =>
      Some(
        dae_escaped_result_direct_call_evidence(
          evidence.suffix,
          mod_,
          type_indices,
          escaped,
        ),
      )
    None => None
  }
}

///|
fn dae_dead_suffix_has_dropped_escaped_result_call(
  instrs : Array[@lib.Instruction],
  mod_ : @lib.Module,
  type_indices : Array[@lib.TypeIdx],
  escaped : Array[Bool],
) -> Bool {
  match
    dae_dead_suffix_escaped_result_direct_call_evidence(
      instrs, mod_, type_indices, escaped,
    ) {
    Some(evidence) => evidence.has_dropped_escaped_result_call
    None => false
  }
}

///|
fn dae_collect_original_dead_suffix_escaped_result_call_facts_with_escaped(
  mod_ : @lib.Module,
  escaped : Array[Bool],
) -> DaeOriginalDeadSuffixEscapedResultCallFacts {
  let defined = dae_defined_func_count(mod_)
  let dropped_calls = Array::make(defined, false)
  let undropped_calls = Array::make(defined, false)
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None => return { dropped_calls, undropped_calls }
  }
  let type_indices = dae_collect_func_type_indices(mod_)
  let mut def_idx = 0
  while def_idx < defined {
    let @lib.Func(_, @lib.Expr(body)) = funcs[def_idx]
    match
      dae_dead_suffix_escaped_result_direct_call_evidence(
        body, mod_, type_indices, escaped,
      ) {
      Some(evidence) => {
        dropped_calls[def_idx] = evidence.has_dropped_escaped_result_call
        undropped_calls[def_idx] = evidence.has_undropped_escaped_result_call
      }
      None => ()
    }
    def_idx += 1
  }
  { dropped_calls, undropped_calls }
}

///|
fn dae_mark_dead_suffix_escaped_result_operand_targets(
  instrs : Array[@lib.Instruction],
  mod_ : @lib.Module,
  type_indices : Array[@lib.TypeIdx],
  escaped : Array[Bool],
  imported : Int,
  defined : Int,
  flags : Array[Bool],
) -> Unit {
  let stack_from_escaped_call : Array[Bool] = []
  let mut in_suffix = false
  let mut idx = 0
  while idx < instrs.length() {
    let instr = instrs[idx]
    if !in_suffix {
      if dae_instr_is_unreachable_root(instr) {
        in_suffix = true
      }
      idx += 1
      continue
    }
    match instr {
      @lib.Call(func_idx) => {
        let slot = dae_func_idx_slot(func_idx)
        let def_idx = slot - imported
        if def_idx >= 0 && def_idx < defined && def_idx < flags.length() {
          match dae_resolve_func_type(mod_, type_indices, slot) {
            Some(@lib.FuncType(params, _)) =>
              if dae_stack_bool_has_true_operand(
                  stack_from_escaped_call,
                  params.length(),
                ) {
                flags[def_idx] = true
              }
            None => ()
          }
        }
        let from_escaped = slot >= 0 && slot < escaped.length() && escaped[slot]
        ignore(
          dae_stack_bool_apply_instr_effect(
            stack_from_escaped_call, instr, mod_, type_indices, from_escaped,
          ),
        )
      }
      @lib.Block(_, @lib.Expr(body))
      | @lib.Loop(_, @lib.Expr(body))
      | @lib.TryTable(_, _, @lib.Expr(body)) => {
        dae_mark_dead_suffix_escaped_result_operand_targets(
          body, mod_, type_indices, escaped, imported, defined, flags,
        )
        ignore(
          dae_stack_bool_apply_instr_effect(
            stack_from_escaped_call, instr, mod_, type_indices, false,
          ),
        )
      }
      @lib.If(_, then_body, Some(else_body)) => {
        dae_mark_dead_suffix_escaped_result_operand_targets(
          then_body, mod_, type_indices, escaped, imported, defined, flags,
        )
        dae_mark_dead_suffix_escaped_result_operand_targets(
          else_body, mod_, type_indices, escaped, imported, defined, flags,
        )
        ignore(
          dae_stack_bool_apply_instr_effect(
            stack_from_escaped_call, instr, mod_, type_indices, false,
          ),
        )
      }
      @lib.If(_, then_body, None) => {
        dae_mark_dead_suffix_escaped_result_operand_targets(
          then_body, mod_, type_indices, escaped, imported, defined, flags,
        )
        ignore(
          dae_stack_bool_apply_instr_effect(
            stack_from_escaped_call, instr, mod_, type_indices, false,
          ),
        )
      }
      _ =>
        ignore(
          dae_stack_bool_apply_instr_effect(
            stack_from_escaped_call, instr, mod_, type_indices, false,
          ),
        )
    }
    idx += 1
  }
}

///|
fn dae_mark_dead_suffix_same_result_operand_targets(
  instrs : Array[@lib.Instruction],
  mod_ : @lib.Module,
  type_indices : Array[@lib.TypeIdx],
  imported : Int,
  defined : Int,
  flags : Array[Bool],
) -> Unit {
  let stack_sources : Array[Int] = []
  let mut in_suffix = false
  let mut idx = 0
  while idx < instrs.length() {
    let instr = instrs[idx]
    if !in_suffix {
      if dae_instr_is_unreachable_root(instr) {
        in_suffix = true
      }
      idx += 1
      continue
    }
    match instr {
      @lib.Call(func_idx) => {
        let slot = dae_func_idx_slot(func_idx)
        let def_idx = slot - imported
        let source = if slot >= imported && def_idx >= 0 && def_idx < defined {
          def_idx
        } else {
          -1
        }
        if source >= 0 && source < flags.length() {
          match dae_resolve_func_type(mod_, type_indices, slot) {
            Some(@lib.FuncType(params, _)) =>
              if dae_stack_int_has_operand_value(
                  stack_sources,
                  params.length(),
                  source,
                ) {
                flags[source] = true
              }
            None => ()
          }
        }
        ignore(
          dae_stack_int_apply_instr_effect(
            stack_sources, instr, mod_, type_indices, source,
          ),
        )
      }
      @lib.Block(_, @lib.Expr(body))
      | @lib.Loop(_, @lib.Expr(body))
      | @lib.TryTable(_, _, @lib.Expr(body)) => {
        dae_mark_dead_suffix_same_result_operand_targets(
          body, mod_, type_indices, imported, defined, flags,
        )
        ignore(
          dae_stack_int_apply_instr_effect(
            stack_sources, instr, mod_, type_indices, -1,
          ),
        )
      }
      @lib.If(_, then_body, Some(else_body)) => {
        dae_mark_dead_suffix_same_result_operand_targets(
          then_body, mod_, type_indices, imported, defined, flags,
        )
        dae_mark_dead_suffix_same_result_operand_targets(
          else_body, mod_, type_indices, imported, defined, flags,
        )
        ignore(
          dae_stack_int_apply_instr_effect(
            stack_sources, instr, mod_, type_indices, -1,
          ),
        )
      }
      @lib.If(_, then_body, None) => {
        dae_mark_dead_suffix_same_result_operand_targets(
          then_body, mod_, type_indices, imported, defined, flags,
        )
        ignore(
          dae_stack_int_apply_instr_effect(
            stack_sources, instr, mod_, type_indices, -1,
          ),
        )
      }
      _ =>
        ignore(
          dae_stack_int_apply_instr_effect(
            stack_sources, instr, mod_, type_indices, -1,
          ),
        )
    }
    idx += 1
  }
}

///|
fn dae_dead_suffix_call_to_has_same_result_operand(
  instrs : Array[@lib.Instruction],
  callee_abs : Int,
  mod_ : @lib.Module,
  type_indices : Array[@lib.TypeIdx],
) -> Bool {
  let (param_count, result_count) = match
    dae_resolve_func_type(mod_, type_indices, callee_abs) {
    Some(@lib.FuncType(params, results)) => (params.length(), results.length())
    None => return false
  }
  let stack_from_target_call : Array[Bool] = []
  let mut in_suffix = false
  let mut idx = 0
  while idx < instrs.length() {
    let instr = instrs[idx]
    if !in_suffix {
      if dae_instr_is_unreachable_root(instr) {
        in_suffix = true
      }
      idx += 1
      continue
    }
    match instr {
      @lib.Call(func_idx) if dae_func_idx_slot(func_idx) == callee_abs => {
        if dae_stack_bool_has_true_operand(stack_from_target_call, param_count) {
          return true
        }
        dae_stack_bool_apply_effect(
          stack_from_target_call, param_count, result_count, true,
        )
      }
      @lib.Call(_) =>
        ignore(
          dae_stack_bool_apply_instr_effect(
            stack_from_target_call, instr, mod_, type_indices, false,
          ),
        )
      @lib.Block(_, @lib.Expr(body))
      | @lib.Loop(_, @lib.Expr(body))
      | @lib.TryTable(_, _, @lib.Expr(body)) => {
        if dae_dead_suffix_call_to_has_same_result_operand(
            body, callee_abs, mod_, type_indices,
          ) {
          return true
        }
        ignore(
          dae_stack_bool_apply_instr_effect(
            stack_from_target_call, instr, mod_, type_indices, false,
          ),
        )
      }
      @lib.If(_, then_body, Some(else_body)) => {
        if dae_dead_suffix_call_to_has_same_result_operand(
            then_body, callee_abs, mod_, type_indices,
          ) ||
          dae_dead_suffix_call_to_has_same_result_operand(
            else_body, callee_abs, mod_, type_indices,
          ) {
          return true
        }
        ignore(
          dae_stack_bool_apply_instr_effect(
            stack_from_target_call, instr, mod_, type_indices, false,
          ),
        )
      }
      @lib.If(_, then_body, None) => {
        if dae_dead_suffix_call_to_has_same_result_operand(
            then_body, callee_abs, mod_, type_indices,
          ) {
          return true
        }
        ignore(
          dae_stack_bool_apply_instr_effect(
            stack_from_target_call, instr, mod_, type_indices, false,
          ),
        )
      }
      _ =>
        ignore(
          dae_stack_bool_apply_instr_effect(
            stack_from_target_call, instr, mod_, type_indices, false,
          ),
        )
    }
    idx += 1
  }
  false
}

///|
fn dae_collect_original_private_result_same_operand_call_counts_with_escaped(
  mod_ : @lib.Module,
  escaped : Array[Bool],
) -> Array[Int] {
  let imported = dae_imported_func_count(mod_)
  let defined = dae_defined_func_count(mod_)
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None => return Array::make(defined, 0)
  }
  let type_indices = dae_collect_func_type_indices(mod_)
  let counts = Array::make(defined, 0)
  let mut caller_def = 0
  while caller_def < funcs.length() {
    let caller_abs = imported + caller_def
    let caller_is_private_result = match
      dae_resolve_func_type(mod_, type_indices, caller_abs) {
      Some(@lib.FuncType(_, results)) => results.length() > 0
      None => false
    }
    if caller_is_private_result && !escaped[caller_abs] {
      let @lib.Func(_, @lib.Expr(body)) = funcs[caller_def]
      let flags = Array::make(defined, false)
      dae_mark_dead_suffix_same_result_operand_targets(
        body, mod_, type_indices, imported, defined, flags,
      )
      let mut callee_def = 0
      while callee_def < defined {
        if callee_def != caller_def && flags[callee_def] {
          counts[callee_def] = counts[callee_def] + 1
        }
        callee_def += 1
      }
    }
    caller_def += 1
  }
  counts
}

///|
fn dae_collect_original_dead_suffix_result_calls_from_undropped_self_callers_with_escaped(
  mod_ : @lib.Module,
  original_nonself_undropped_call_counts : Array[Int],
  escaped : Array[Bool],
) -> Array[Int] {
  let imported = dae_imported_func_count(mod_)
  let defined = dae_defined_func_count(mod_)
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None => return Array::make(defined, 0)
  }
  let type_indices = dae_collect_func_type_indices(mod_)
  let counts = Array::make(defined, 0)
  let mut caller_def = 0
  while caller_def < funcs.length() {
    let caller_abs = imported + caller_def
    let caller_has_params_and_result = match
      dae_resolve_func_type(mod_, type_indices, caller_abs) {
      Some(@lib.FuncType(params, results)) =>
        params.length() > 0 && results.length() > 0
      None => false
    }
    let @lib.Func(_, @lib.Expr(body)) = funcs[caller_def]
    let caller_has_undropped_self_suffix = dae_dead_suffix_has_undropped_direct_call_to(
      body, caller_abs,
    )
    let caller_has_dropped_escaped_result_suffix = dae_dead_suffix_has_dropped_escaped_result_call(
      body, mod_, type_indices, escaped,
    )
    let caller_has_undropped_nonself_caller = caller_def <
      original_nonself_undropped_call_counts.length() &&
      original_nonself_undropped_call_counts[caller_def] > 0
    if caller_has_params_and_result &&
      caller_has_undropped_self_suffix &&
      caller_has_undropped_nonself_caller &&
      !caller_has_dropped_escaped_result_suffix &&
      !escaped[caller_abs] {
      let targets : Array[Int] = []
      dae_collect_dead_suffix_direct_targets(body, imported, defined, targets)
      for target in targets {
        if target != caller_def {
          counts[target] = counts[target] + 1
        }
      }
    }
    caller_def += 1
  }
  counts
}

///|
fn dae_collect_original_dead_suffix_result_calls_from_no_param_undropped_self_callers(
  mod_ : @lib.Module,
) -> Array[Int] {
  let imported = dae_imported_func_count(mod_)
  let defined = dae_defined_func_count(mod_)
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None => return Array::make(defined, 0)
  }
  let type_indices = dae_collect_func_type_indices(mod_)
  let counts = Array::make(defined, 0)
  let mut caller_def = 0
  while caller_def < funcs.length() {
    let caller_abs = imported + caller_def
    let caller_is_no_param_result = match
      dae_resolve_func_type(mod_, type_indices, caller_abs) {
      Some(@lib.FuncType(params, results)) =>
        params.length() == 0 && results.length() > 0
      None => false
    }
    let @lib.Func(_, @lib.Expr(body)) = funcs[caller_def]
    if caller_is_no_param_result &&
      dae_dead_suffix_has_undropped_direct_call_to(body, caller_abs) {
      let targets : Array[Int] = []
      dae_collect_dead_suffix_direct_targets(body, imported, defined, targets)
      for target in targets {
        if target != caller_def {
          counts[target] = counts[target] + 1
        }
      }
    }
    caller_def += 1
  }
  counts
}

///|
fn dae_collect_original_dead_suffix_undropped_calls_from_parameterized_dropped_self_callers(
  mod_ : @lib.Module,
) -> Array[Int] {
  let imported = dae_imported_func_count(mod_)
  let defined = dae_defined_func_count(mod_)
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None => return Array::make(defined, 0)
  }
  let type_indices = dae_collect_func_type_indices(mod_)
  let counts = Array::make(defined, 0)
  let counted_stamp = Array::make(defined, -1)
  let mut caller_def = 0
  while caller_def < funcs.length() {
    let caller_abs = imported + caller_def
    let caller_has_params_and_result = match
      dae_resolve_func_type(mod_, type_indices, caller_abs) {
      Some(@lib.FuncType(params, results)) =>
        params.length() > 0 && results.length() > 0
      None => false
    }
    let @lib.Func(_, @lib.Expr(body)) = funcs[caller_def]
    if caller_has_params_and_result &&
      dae_dead_suffix_has_dropped_direct_call_to(body, caller_abs) {
      let targets : Array[Int] = []
      dae_collect_dead_suffix_undropped_direct_targets(
        body, imported, defined, targets,
      )
      for target in targets {
        if target != caller_def && counted_stamp[target] != caller_def {
          counts[target] = counts[target] + 1
          counted_stamp[target] = caller_def
        }
      }
    }
    caller_def += 1
  }
  counts
}

///|
fn dae_collect_original_dead_suffix_mixed_dropped_undropped_call_counts_with_escaped(
  mod_ : @lib.Module,
  escaped : Array[Bool],
) -> Array[Int] {
  let imported = dae_imported_func_count(mod_)
  let defined = dae_defined_func_count(mod_)
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None => return Array::make(defined, 0)
  }
  let counts = Array::make(defined, 0)
  let dropped_stamp = Array::make(defined, -1)
  let counted_stamp = Array::make(defined, -1)
  let mut caller_def = 0
  while caller_def < funcs.length() {
    let caller_abs = imported + caller_def
    if escaped[caller_abs] {
      caller_def += 1
      continue
    }
    let @lib.Func(_, @lib.Expr(body)) = funcs[caller_def]
    let dropped_targets : Array[Int] = []
    dae_collect_dead_suffix_dropped_direct_targets(
      body, imported, defined, dropped_targets,
    )
    for target in dropped_targets {
      dropped_stamp[target] = caller_def
    }
    let undropped_targets : Array[Int] = []
    dae_collect_dead_suffix_undropped_direct_targets(
      body, imported, defined, undropped_targets,
    )
    for target in undropped_targets {
      if target != caller_def &&
        dropped_stamp[target] == caller_def &&
        counted_stamp[target] != caller_def {
        counts[target] = counts[target] + 1
        counted_stamp[target] = caller_def
      }
    }
    caller_def += 1
  }
  counts
}

///|
fn dae_collect_original_dead_suffix_dropped_earlier_result_calls(
  mod_ : @lib.Module,
) -> Array[Bool] {
  let imported = dae_imported_func_count(mod_)
  let defined = dae_defined_func_count(mod_)
  let type_indices = dae_collect_func_type_indices(mod_)
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None => return Array::make(defined, false)
  }
  let result_flags = Array::make(defined, false)
  let mut callee_def = 0
  while callee_def < defined {
    let callee_abs = imported + callee_def
    result_flags[callee_def] = match
      dae_resolve_func_type(mod_, type_indices, callee_abs) {
      Some(@lib.FuncType(_, results)) => results.length() > 0
      None => false
    }
    callee_def += 1
  }
  let flags = Array::make(defined, false)
  let mut caller_def = 0
  while caller_def < funcs.length() {
    let @lib.Func(_, @lib.Expr(body)) = funcs[caller_def]
    let dropped_targets : Array[Int] = []
    dae_collect_dead_suffix_dropped_direct_targets(
      body, imported, defined, dropped_targets,
    )
    for target in dropped_targets {
      if target < caller_def && result_flags[target] {
        flags[caller_def] = true
      }
    }
    caller_def += 1
  }
  flags
}

///|
fn dae_collect_original_later_dead_suffix_dropped_call_counts(
  mod_ : @lib.Module,
) -> Array[Int] {
  let imported = dae_imported_func_count(mod_)
  let defined = dae_defined_func_count(mod_)
  let funcs = match mod_.code_sec {
    Some(@lib.CodeSec(funcs)) => funcs
    None => return Array::make(defined, 0)
  }
  let counts = Array::make(defined, 0)
  let counted_stamp = Array::make(defined, -1)
  let mut caller_def = 0
  while caller_def < funcs.length() {
    let @lib.Func(_, @lib.Expr(body)) = funcs[caller_def]
    let dropped_targets : Array[Int] = []
    dae_collect_dead_suffix_dropped_direct_targets(
      body, imported, defined, dropped_targets,
    )
    for target in dropped_targets {
      if target < caller_def && counted_stamp[target] != caller_def {
        counts[target] = counts[target] + 1
        counted_stamp[target] = caller_def
      }
    }
    caller_def += 1
  }
  counts
}

