                @lib.Instruction::ref_cast_desc_eq_type(
                  nullable_described_ref_type,
                ),
              ]),
            ),
          ]),
        ),
      ]),
    )
  let optimized = optimize_instructions_test_run_module(module_)
  match optimized.code_sec {
    Some(
      @lib.CodeSec([@lib.Func(_, @lib.Expr([@lib.Block(_, @lib.Expr(body))]))])
    ) => {
      @debug.assert_eq(body.length(), 8)
      match body[0] {
        @lib.LocalGet(@lib.LocalIdx(0U)) => ()
        other => fail("expected cast operand local.get 0, got \{other}")
      }
      match body[1] {
        @lib.LocalGet(@lib.LocalIdx(0U)) => ()
        other =>
          fail("expected br_on_non_null tested local.get 0, got \{other}")
      }
      match body[2] {
        @lib.BrOnNonNull(@lib.LabelIdx(0U)) => ()
        other =>
          fail(
            "expected effectful-fallthrough br_on_non_null retargeted to outer label, got \{other}",
          )
      }
      match body[3] {
        @lib.I32Const(@lib.I32(1)) => ()
        other =>
          fail(
            "expected effectful br_on_non_null fallthrough i32.const, got \{other}",
          )
      }
      match body[4] {
        @lib.GlobalSet(@lib.GlobalIdx(0U)) => ()
        other =>
          fail(
            "expected effectful br_on_non_null fallthrough global.set, got \{other}",
          )
      }
      match body[5] {
        @lib.LocalGet(@lib.LocalIdx(1U)) => ()
        other =>
          fail(
            "expected effectful br_on_non_null fallthrough local.get 1, got \{other}",
          )
      }
      match body[6] {
        @lib.RefGetDesc(type_idx) => @debug.assert_eq(type_idx, described_type)
        other =>
          fail("expected flattened br_on_non_null ref.get_desc, got \{other}")
      }
      match body[7] {
        @lib.RefCastDescEq(nullable, exact, target) => {
          assert_true(nullable)
          assert_false(exact)
          @debug.assert_eq(target, described_heap)
        }
        other =>
          fail(
            "expected descriptor cast after flattened br_on_non_null, got \{other}",
          )
      }
    }
    other =>
      fail(
        "expected optimized effectful-fallthrough br_on_non_null block body, got \{other}",
      )
  }
}

///|
test "optimize-instructions lowers escaping br_on_non_null block ref.get_desc child like Binaryen" {
  // OI-J descriptor-operand escaping-label breadth: Binaryen version_130
  // default and IIT flatten this `br_on_non_null` descriptor child to the outer
  // block as `local.get 0; local.get 0; br_on_non_null 0; local.get 1;
  // ref.get_desc; ref.cast_desc_eq`. This remains a narrow local-only shape and
  // is not a general br_on_* localizer.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let described_heap = @lib.HeapType::new(described_type)
  let nullable_described_ref_type = @lib.RefType::new(true, described_heap)
  let nullable_described_val_type = @lib.ValType::ref_type(
    nullable_described_ref_type,
  )
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func(
              [nullable_described_val_type, nullable_described_val_type],
              [nullable_described_val_type],
            ),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([@lib.TypeIdx::new(2U)]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(nullable_described_val_type),
              @lib.Expr::new([
                @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
                @lib.Instruction::block(
                  @lib.BlockType::val_type(nullable_described_val_type),
                  @lib.Expr::new([
                    @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
                    @lib.Instruction::br_on_non_null(@lib.LabelIdx::new(1U)),
                    @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
                  ]),
                ),
                @lib.Instruction::ref_as_non_null(),
                @lib.Instruction::ref_get_desc(described_type),
                @lib.Instruction::ref_cast_desc_eq_type(
                  nullable_described_ref_type,
                ),
              ]),
            ),
          ]),
        ),
      ]),
    )
  let optimized = optimize_instructions_test_run_module(module_)
  match optimized.code_sec {
    Some(
      @lib.CodeSec([@lib.Func(_, @lib.Expr([@lib.Block(_, @lib.Expr(body))]))])
    ) => {
      @debug.assert_eq(body.length(), 6)
      match body[0] {
        @lib.LocalGet(@lib.LocalIdx(0U)) => ()
        other => fail("expected cast operand local.get 0, got \{other}")
      }
      match body[1] {
        @lib.LocalGet(@lib.LocalIdx(0U)) => ()
        other =>
          fail(
            "expected escaping br_on_non_null input local.get 0, got \{other}",
          )
      }
      match body[2] {
        @lib.BrOnNonNull(@lib.LabelIdx(0U)) => ()
        other =>
          fail(
            "expected br_on_non_null retargeted to outer label, got \{other}",
          )
      }
      match body[3] {
        @lib.LocalGet(@lib.LocalIdx(1U)) => ()
        other =>
          fail("expected br_on_non_null fallthrough local.get 1, got \{other}")
      }
      match body[4] {
        @lib.RefGetDesc(type_idx) => @debug.assert_eq(type_idx, described_type)
        other =>
          fail("expected flattened br_on_non_null ref.get_desc, got \{other}")
      }
      match body[5] {
        @lib.RefCastDescEq(nullable, exact, target) => {
          assert_true(nullable)
          assert_false(exact)
          @debug.assert_eq(target, described_heap)
        }
        other =>
          fail(
            "expected descriptor cast after flattened br_on_non_null, got \{other}",
          )
      }
    }
    other =>
      fail(
        "expected one optimized outer br_on_non_null block body, got \{other}",
      )
  }
}

///|
test "optimize-instructions localizes escaping-branch ref.get_desc descriptor operands under traps-never-happen" {
  // OI-J TNH escaping-label companion: Binaryen version_130 skips the
  // descriptor cast under --traps-never-happen but still evaluates the
  // escaping-label `ref.get_desc` operand into a descriptor scratch local before
  // returning the original reference operand. This is narrower than broad
  // escaping-label localization and does not cover ref.test_desc.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let described_heap = @lib.HeapType::new(described_type)
  let nullable_described_ref_type = @lib.RefType::new(true, described_heap)
  let nullable_described_val_type = @lib.ValType::ref_type(
    nullable_described_ref_type,
  )
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func(
              [nullable_described_val_type, nullable_described_val_type],
              [nullable_described_val_type],
            ),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([@lib.TypeIdx::new(2U)]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(nullable_described_val_type),
              @lib.Expr::new([
                @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
                @lib.Instruction::block(
                  @lib.BlockType::val_type(nullable_described_val_type),
                  @lib.Expr::new([
                    @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
                    @lib.Instruction::br(@lib.LabelIdx::new(1U)),
                    @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
                  ]),
                ),
                @lib.Instruction::ref_as_non_null(),
                @lib.Instruction::ref_get_desc(described_type),
                @lib.Instruction::ref_cast_desc_eq_type(
                  nullable_described_ref_type,
                ),
              ]),
            ),
          ]),
        ),
      ]),
    )
  let func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(0U))
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    traps_never_happen=true,
    module_ctx=Some(@ir.hot_module_context_from_module(module_)),
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) =>
      fail(
        "expected escaping ref.get_desc TNH localization success, got \{err}",
      )
  }
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_get(func, root).op {
    @ir.HotOp::Block => ()
    other => fail("expected TNH localization block, got \{other}")
  }
  let localized_block = if @ir.hot_child_count(func, root) == 1 {
    @ir.hot_child_get(func, root, 0)
  } else {
    root
  }
  match @ir.hot_node_get(func, localized_block).op {
    @ir.HotOp::Block => ()
    other => fail("expected nested TNH localization block, got \{other}")
  }
  @debug.assert_eq(@ir.hot_child_count(func, localized_block), 2)
  let localized_descriptor = @ir.hot_child_get(func, localized_block, 0)
  match @ir.hot_node_get(func, localized_descriptor).op {
    @ir.HotOp::LocalSet => ()
    other => fail("expected descriptor scratch local.set, got \{other}")
  }
  let stored_descriptor = @ir.hot_child_get(func, localized_descriptor, 0)
  match @ir.hot_node_exact_instr(func, stored_descriptor) {
    Some(@lib.Instruction::RefGetDesc(_)) => ()
    other => fail("expected localized ref.get_desc, got \{other}")
  }
  let get_desc_child = @ir.hot_child_get(func, stored_descriptor, 0)
  match @ir.hot_node_get(func, get_desc_child).op {
    @ir.HotOp::Block => ()
    other => fail("expected escaping block as ref.get_desc child, got \{other}")
  }
  let result = @ir.hot_child_get(func, localized_block, 1)
  let result_node = @ir.hot_node_get(func, result)
  match result_node.op {
    @ir.HotOp::LocalGet => ()
    other => fail("expected original local.get result, got \{other}")
  }
  @debug.assert_eq(result_node.imm0, 0)
}

///|
test "optimize-instructions fail-closed on escaping-branch block ref.get_desc child null checks" {
  // OI-J descriptor-operand trapOnNull boundary: Binaryen version_130 can
  // rewrite an escaping-branch block-produced child to a branch/unreachable
  // shape, but Starshine does not yet have the label-aware localizer needed to
  // do that safely. Keep this branch-control shape fail-closed instead of
  // moving `ref.as_non_null` into `ref.cast_desc_eq`, which previously could
  // exactify the cast and produce invalid descriptor-operand typing.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let described_heap = @lib.HeapType::new(described_type)
  let nullable_described_ref_type = @lib.RefType::new(true, described_heap)
  let nullable_described_val_type = @lib.ValType::ref_type(
    nullable_described_ref_type,
  )
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func(
              [nullable_described_val_type, nullable_described_val_type],
              [nullable_described_val_type],
            ),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([@lib.TypeIdx::new(2U)]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(nullable_described_val_type),
              @lib.Expr::new([
                @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
                @lib.Instruction::block(
                  @lib.BlockType::val_type(nullable_described_val_type),
                  @lib.Expr::new([
                    @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
                    @lib.Instruction::br(@lib.LabelIdx::new(1U)),
                    @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
                  ]),
                ),
                @lib.Instruction::ref_as_non_null(),
                @lib.Instruction::ref_get_desc(described_type),
                @lib.Instruction::ref_cast_desc_eq_type(
                  nullable_described_ref_type,
                ),
              ]),
            ),
          ]),
        ),
      ]),
    )
  let func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(0U))
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    module_ctx=Some(@ir.hot_module_context_from_module(module_)),
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) =>
      fail(
        "expected escaping-branch descriptor child to remain valid and fail closed, got \{err}",
      )
  }
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_get(func, root).op {
    @ir.HotOp::Block => ()
    other => fail("expected outer block to remain, got \{other}")
  }
  let body = @ir.hot_region_body_ref(func, root)
  @debug.assert_eq(@ir.hot_region_root_count(func, body), 1)
  let cast = @ir.hot_region_get(func, body, 0)
  match @ir.hot_node_exact_instr(func, cast) {
    Some(@lib.Instruction::RefCastDescEq(_, exact, _)) =>
      assert_false(
        exact,
        msg="escaping branch descriptor cast must not exactify",
      )
    other => fail("expected descriptor cast to fail closed, got \{other}")
  }
  @debug.assert_eq(@ir.hot_child_count(func, cast), 2)
  let descriptor_operand = @ir.hot_child_get(func, cast, 1)
  match @ir.hot_node_exact_instr(func, descriptor_operand) {
    Some(@lib.Instruction::RefGetDesc(_)) => ()
    other => fail("expected ref.get_desc descriptor operand, got \{other}")
  }
  let get_desc_child = @ir.hot_child_get(func, descriptor_operand, 0)
  match @ir.hot_node_get(func, get_desc_child).op {
    @ir.HotOp::Block => ()
    other =>
      fail(
        "expected escaping block descriptor child to remain fail-closed, got \{other}",
      )
  }
}

///|
test "optimize-instructions localizes effectful-condition if ref.get_desc descriptor operands under traps-never-happen" {
  // OI-J TNH companion for the effectful-condition if case above: Binaryen
  // skips the descriptor cast but preserves the effectful condition by
  // evaluating `ref.get_desc(if ...)` into a descriptor scratch local before
  // returning the original reference operand. Escaping labels remain open.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let described_heap = @lib.HeapType::new(described_type)
  let nullable_described_ref_type = @lib.RefType::new(true, described_heap)
  let nullable_described_val_type = @lib.ValType::ref_type(
    nullable_described_ref_type,
  )
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func(
              [
                nullable_described_val_type,
                nullable_described_val_type,
                @lib.ValType::i32(),
              ],
              [nullable_described_val_type],
            ),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([@lib.TypeIdx::new(2U)]))
    .with_global_sec(
      @lib.GlobalSec::new([
        @lib.Global::new(
          @lib.GlobalType::new(@lib.ValType::i32(), true),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::block(
              @lib.BlockType::val_type(@lib.ValType::i32()),
              @lib.Expr::new([
                @lib.Instruction::local_get(@lib.LocalIdx::new(2U)),
                @lib.Instruction::global_set(@lib.GlobalIdx::new(0U)),
                @lib.Instruction::i32_const(@lib.I32(1)),
              ]),
            ),
            @lib.Instruction::if_(
              @lib.BlockType::val_type(nullable_described_val_type),
              [@lib.Instruction::local_get(@lib.LocalIdx::new(0U))],
              Some([@lib.Instruction::local_get(@lib.LocalIdx::new(1U))]),
            ),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_get_desc(described_type),
            @lib.Instruction::ref_cast_desc_eq_type(nullable_described_ref_type),
          ]),
        ),
      ]),
    )
  let func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(0U))
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    traps_never_happen=true,
    module_ctx=Some(@ir.hot_module_context_from_module(module_)),
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) =>
      fail(
        "expected effectful-condition if descriptor TNH ref.get_desc localization, got \{err}",
      )
  }
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_get(func, root).op {
    @ir.HotOp::Block => ()
    other => fail("expected ref.get_desc localization block, got \{other}")
  }
  @debug.assert_eq(@ir.hot_child_count(func, root), 2)
  let localized_descriptor = @ir.hot_child_get(func, root, 0)
  match @ir.hot_node_get(func, localized_descriptor).op {
    @ir.HotOp::LocalSet => ()
    other => fail("expected descriptor scratch local.set, got \{other}")
  }
  let stored_descriptor = @ir.hot_child_get(func, localized_descriptor, 0)
  match @ir.hot_node_exact_instr(func, stored_descriptor) {
    Some(@lib.Instruction::RefGetDesc(_)) => ()
    other =>
      fail("expected localized ref.get_desc descriptor operand, got \{other}")
  }
  @debug.assert_eq(@ir.hot_child_count(func, stored_descriptor), 1)
  let child = @ir.hot_child_get(func, stored_descriptor, 0)
  match @ir.hot_node_get(func, child).op {
    @ir.HotOp::If => ()
    other =>
      fail(
        "expected localized ref.get_desc child null check to move into if, got \{other}",
      )
  }
  let result = @ir.hot_child_get(func, root, 1)
  let result_node = @ir.hot_node_get(func, result)
  match result_node.op {
    @ir.HotOp::LocalGet => ()
    other => fail("expected original local.get result, got \{other}")
  }
  @debug.assert_eq(result_node.imm0, 0)
}

///|
test "optimize-instructions moves if-produced ref.get_desc child null checks into descriptor casts" {
  // OI-J descriptor-operand trapOnNull breadth: Binaryen version_130 default
  // and IIT modes preserve the descriptor equality cast, but simplify a pure
  // if-produced nullable child from `ref.get_desc(ref.as_non_null(if ...))` to
  // `ref.get_desc(if ...)`, leaving the descriptor cast to carry the null trap.
  // This broadens the local/block/select child slices without claiming
  // effectful control, escaping labels, or ref.test_desc support.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let described_heap = @lib.HeapType::new(described_type)
  let nullable_described_ref_type = @lib.RefType::new(true, described_heap)
  let nullable_described_val_type = @lib.ValType::ref_type(
    nullable_described_ref_type,
  )
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func(
              [
                nullable_described_val_type,
                nullable_described_val_type,
                @lib.ValType::i32(),
              ],
              [nullable_described_val_type],
            ),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([@lib.TypeIdx::new(2U)]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(2U)),
            @lib.Instruction::if_(
              @lib.BlockType::val_type(nullable_described_val_type),
              [@lib.Instruction::local_get(@lib.LocalIdx::new(0U))],
              Some([@lib.Instruction::local_get(@lib.LocalIdx::new(1U))]),
            ),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_get_desc(described_type),
            @lib.Instruction::ref_cast_desc_eq_type(nullable_described_ref_type),
          ]),
        ),
      ]),
    )
  let func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(0U))
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    module_ctx=Some(@ir.hot_module_context_from_module(module_)),
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) =>
      fail(
        "expected if-produced descriptor ref.get_desc null-check simplification, got \{err}",
      )
  }
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_exact_instr(func, root) {
    Some(@lib.Instruction::RefCastDescEq(_, _, _)) => ()
    other => fail("expected descriptor cast to remain, got \{other}")
  }
  @debug.assert_eq(@ir.hot_child_count(func, root), 2)
  let descriptor_operand = @ir.hot_child_get(func, root, 1)
  match @ir.hot_node_exact_instr(func, descriptor_operand) {
    Some(@lib.Instruction::RefGetDesc(_)) => ()
    other => fail("expected ref.get_desc descriptor operand, got \{other}")
  }
  @debug.assert_eq(@ir.hot_child_count(func, descriptor_operand), 1)
  let child = @ir.hot_child_get(func, descriptor_operand, 0)
  match @ir.hot_node_get(func, child).op {
    @ir.HotOp::If => ()
    other =>
      fail(
        "expected if child after descriptor null check moved into cast, got \{other}",
      )
  }
}

