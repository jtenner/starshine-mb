    _ => fail("expected positive lhs zero-rhs i64.gt_s to canonicalize")
  }
  @debug.assert_eq(
    @ir.hot_node_exact_instr(i64_pos_gt_func, i64_pos_gt_root),
    Some(@lib.Instruction::i64_gt_u()),
