///|
test "optimize-instructions lowers non-null same-heap ref.cast to ref.as_non_null" {
  let eq_heap = @lib.HeapType::abs(@lib.AbsHeapType::eq())
  let array_heap = @lib.HeapType::abs(@lib.AbsHeapType::array())
  let maybe_type = @lib.TypeIdx::new(0U)
  let same_heap_type = @lib.TypeIdx::new(1U)
  let array_type = @lib.TypeIdx::new(2U)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::eqref_null()]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [
              @lib.ValType::ref_type(@lib.RefType::new(false, eq_heap)),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [
              @lib.ValType::ref_type(@lib.RefType::new(false, array_heap)),
            ]),
          ),
        ),
      ]),
    )
    .with_import_sec(
      @lib.ImportSec::new([
        @lib.Import::new(
          @lib.Name::from_string("m"),
          @lib.Name::from_string("maybe"),
          @lib.ExternType::func(maybe_type),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([same_heap_type, array_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::ref_cast(false, eq_heap),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::ref_cast(false, array_heap),
          ]),
        ),
      ]),
    ),
  )
  let same_heap_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  let array_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_false(same_heap_pretty.contains("ref.cast"), msg=same_heap_pretty)
  assert_true(
    same_heap_pretty.contains("ref.as_non_null"),
    msg=same_heap_pretty,
  )
  assert_true(same_heap_pretty.contains("call (Func 0)"), msg=same_heap_pretty)
  assert_true(array_pretty.contains("ref.cast"), msg=array_pretty)
  assert_true(array_pretty.contains("call (Func 0)"), msg=array_pretty)
}

///|
test "optimize-instructions folds ref.as_non_null on known null and non-null refs" {
  let source =
    #|(module
    #|  (func $callee)
    #|  (elem declare func $callee)
    #|  (func (export "null") (result eqref)
    #|    ref.null eq
    #|    ref.as_non_null)
    #|  (func (export "i31") (result eqref)
    #|    i32.const 7
    #|    ref.i31
    #|    ref.as_non_null)
    #|  (func (export "func") (result funcref)
    #|    ref.func $callee
    #|    ref.as_non_null)
    #|)
  let optimized = match
    pass_test_run_pipeline(source, ["optimize-instructions"]) {
    Ok(mod_) => mod_
    Err(err) => fail("expected ref.as_non_null optimize success, got \{err}")
  }
  let null_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  let i31_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  let func_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(3U))
  assert_true(null_pretty.contains("unreachable"), msg=null_pretty)
  assert_false(null_pretty.contains("ref.as_non_null"), msg=null_pretty)
  assert_true(i31_pretty.contains("ref.i31"), msg=i31_pretty)
  assert_false(i31_pretty.contains("ref.as_non_null"), msg=i31_pretty)
  assert_true(func_pretty.contains("ref.func"), msg=func_pretty)
  assert_false(func_pretty.contains("ref.as_non_null"), msg=func_pretty)
}

///|
test "optimize-instructions directizes call_ref from local.tee ref.func target facts" {
  // OI-H call_ref target fact slice: Binaryen version_130
  // `visitCallRef` calls `getFallthrough(curr->target)`, so a `local.tee` target
  // whose value is a direct `ref.func` still directizes to `call` while keeping
  // the target-side tee/drop effects. This locks target fallthrough as a
  // reusable fact, not a one-off call_ref scanner. Keep this HOT-only because
  // Starshine's current public validation/parser surface rejects the typed
  // function-reference local spelling used by the Binaryen probe.
  let sig_type = @lib.TypeIdx::new(0U)
  let nullable_sig_ref = @lib.RefType::new(true, @lib.HeapType::new(sig_type))
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::i32()], [@lib.ValType::i32()]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([sig_type, sig_type]))
    .with_elem_sec(
      @lib.ElemSec::new([
        @lib.Elem::new(
          @lib.ElemMode::declarative(),
          @lib.ElemKind::funcs([@lib.FuncIdx::new(0U)]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::local_get(@lib.LocalIdx::new(0U))]),
        ),
        @lib.Func::new(
          @lib.Locals::single(1U, @lib.ValType::ref_type(nullable_sig_ref)),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_func(@lib.FuncIdx::new(0U)),
            @lib.Instruction::local_tee(@lib.LocalIdx::new(1U)),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::call_ref(sig_type),
          ]),
        ),
      ]),
    )
  let func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(1U))
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::final_module_only(),
    false,
    fn(_) { () },
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) => fail("expected call_ref target fact success, got \{err}")
  }
  let root = @ir.hot_root_get(func, 0)
  let root_node = @ir.hot_node_get(func, root)
  match root_node.op {
    @ir.HotOp::Call => @debug.assert_eq(root_node.imm0, 0)
    other =>
      fail(
        "expected fallthrough-target call_ref to become direct call, got \{other}",
      )
  }
  @debug.assert_eq(root_node.child_count, 1)
  let interposed_arg = @ir.hot_child_get(func, root, 0)
  match @ir.hot_node_get(func, interposed_arg).op {
    @ir.HotOp::Block => ()
    other => fail("expected target/drop block on last operand, got \{other}")
  }
  let body = @ir.hot_region_body_ref(func, interposed_arg)
  @debug.assert_eq(@ir.hot_region_root_count(func, body), 3)
  match @ir.hot_node_get(func, @ir.hot_region_get(func, body, 1)).op {
    @ir.HotOp::Drop => ()
    other => fail("expected target drop before reloaded operand, got \{other}")
  }
}

///|
test "optimize-instructions directizes call_ref after non-null target skip fact" {
  // OI-H call_ref target fact slice: Binaryen version_130 first runs
  // `skipNonNullCast(curr->target, curr)`, so a statically non-null target such
  // as `ref.as_non_null(ref.func)` should be classified as the direct target
  // rather than the fallthrough/drop target path. This keeps the target
  // skip-cast decision in a fact before broader descriptor-producer work.
  let sig_type = @lib.TypeIdx::new(0U)
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::i32()]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([sig_type, sig_type]))
    .with_elem_sec(
      @lib.ElemSec::new([
        @lib.Elem::new(
          @lib.ElemMode::declarative(),
          @lib.ElemKind::funcs([@lib.FuncIdx::new(0U)]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(7))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::ref_func(@lib.FuncIdx::new(0U)),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::call_ref(sig_type),
          ]),
        ),
      ]),
    )
  let func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(1U))
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::final_module_only(),
    false,
    fn(_) { () },
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) =>
      fail("expected call_ref non-null target fact success, got \{err}")
  }
  let root = @ir.hot_root_get(func, 0)
  let root_node = @ir.hot_node_get(func, root)
  match root_node.op {
    @ir.HotOp::Call => @debug.assert_eq(root_node.imm0, 0)
    other =>
      fail(
        "expected skipped non-null call_ref target to direct call, got \{other}",
      )
  }
  @debug.assert_eq(root_node.child_count, 0)
}

///|
test "optimize-instructions directizes call_ref through same-heap ref.cast fallthrough facts" {
  // OI-H call_ref target fact slice: Binaryen version_130 asks
  // `Properties::getFallthrough(curr->target)` for an underlying `ref.func`, but
  // only directizes when the call_ref target's static heap matches the
  // fallthrough `ref.func` heap. A same-heap `ref.cast` around a local.tee
  // target should therefore directize while preserving the cast/drop side
  // effect, and the proof belongs in target/fallthrough facts rather than a
  // visitor-local wrapper scanner. Keep this HOT-only because Starshine's
  // current public parser/validation surface rejects some typed function
  // reference local spellings used by Binaryen-compatible probes.
  let sig_type = @lib.TypeIdx::new(0U)
  let nullable_sig_ref = @lib.RefType::new(true, @lib.HeapType::new(sig_type))
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::i32()]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([sig_type, sig_type]))
    .with_elem_sec(
      @lib.ElemSec::new([
        @lib.Elem::new(
          @lib.ElemMode::declarative(),
          @lib.ElemKind::funcs([@lib.FuncIdx::new(0U)]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(7))]),
        ),
        @lib.Func::new(
          @lib.Locals::single(1U, @lib.ValType::ref_type(nullable_sig_ref)),
          @lib.Expr::new([
            @lib.Instruction::ref_func(@lib.FuncIdx::new(0U)),
            @lib.Instruction::local_tee(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_cast_type(nullable_sig_ref),
            @lib.Instruction::call_ref(sig_type),
          ]),
        ),
      ]),
    )
  let func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(1U))
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::final_module_only(),
    false,
    fn(_) { () },
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) =>
      fail(
        "expected same-heap ref.cast call_ref target fact success, got \{err}",
      )
  }
  let root = @ir.hot_root_get(func, 0)
  let root_node = @ir.hot_node_get(func, root)
  match root_node.op {
    @ir.HotOp::Block => ()
    other =>
      fail(
        "expected same-heap ref.cast call_ref to become block+call, got \{other}",
      )
  }
  let body = @ir.hot_region_body_ref(func, root)
  @debug.assert_eq(@ir.hot_region_root_count(func, body), 2)
  match @ir.hot_node_get(func, @ir.hot_region_get(func, body, 0)).op {
    @ir.HotOp::Drop => ()
    other => fail("expected cast target drop before direct call, got \{other}")
  }
  let call_id = @ir.hot_region_get(func, body, 1)
  let call_node = @ir.hot_node_get(func, call_id)
  match call_node.op {
    @ir.HotOp::Call => @debug.assert_eq(call_node.imm0, 0)
    other =>
      fail("expected fallthrough target to become direct call, got \{other}")
  }
}

///|
test "optimize-instructions interposes fallthrough call_ref target at last operand fact" {
  // OI-H call_ref operand-order fact slice: Binaryen version_130 localizes only
  // the last call_ref operand when a fallthrough target directizes, then runs the
  // target/drop before reloading that last operand. Earlier operands remain
  // direct call operands. This keeps the fact source-backed by
  // `OptimizeInstructions::visitCallRef` instead of broad all-argument
  // localization.
  let sig_type = @lib.TypeIdx::new(0U)
  let nullable_sig_ref = @lib.RefType::new(true, @lib.HeapType::new(sig_type))
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::i32(), @lib.ValType::i64()], [
              @lib.ValType::i32(),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([sig_type, sig_type]))
    .with_elem_sec(
      @lib.ElemSec::new([
        @lib.Elem::new(
          @lib.ElemMode::declarative(),
          @lib.ElemKind::funcs([@lib.FuncIdx::new(0U)]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::local_get(@lib.LocalIdx::new(0U))]),
        ),
        @lib.Func::new(
          @lib.Locals::single(1U, @lib.ValType::ref_type(nullable_sig_ref)),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
            @lib.Instruction::ref_func(@lib.FuncIdx::new(0U)),
            @lib.Instruction::local_tee(@lib.LocalIdx::new(2U)),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::call_ref(sig_type),
          ]),
        ),
      ]),
    )
  let func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(1U))
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::final_module_only(),
    false,
    fn(_) { () },
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) => fail("expected call_ref last-operand fact success, got \{err}")
  }
  let root = @ir.hot_root_get(func, 0)
  let root_node = @ir.hot_node_get(func, root)
  match root_node.op {
    @ir.HotOp::Call => @debug.assert_eq(root_node.imm0, 0)
    other =>
      fail("expected fallthrough-target call_ref to direct call, got \{other}")
  }
  @debug.assert_eq(root_node.child_count, 2)
  let first_arg = @ir.hot_child_get(func, root, 0)
  let first_arg_node = @ir.hot_node_get(func, first_arg)
  match first_arg_node.op {
    @ir.HotOp::LocalGet => @debug.assert_eq(first_arg_node.imm0, 0)
    other =>
      fail(
        "expected first direct-call arg to remain original local.get, got \{other}",
      )
  }
  let interposed_arg = @ir.hot_child_get(func, root, 1)
  match @ir.hot_node_get(func, interposed_arg).op {
    @ir.HotOp::Block => ()
    other => fail("expected last arg to carry target/drop block, got \{other}")
  }
  let body = @ir.hot_region_body_ref(func, interposed_arg)
  @debug.assert_eq(@ir.hot_region_root_count(func, body), 3)
  match @ir.hot_node_get(func, @ir.hot_region_get(func, body, 0)).op {
    @ir.HotOp::LocalSet => ()
    other =>
      fail("expected last operand local.set before target drop, got \{other}")
  }
  match @ir.hot_node_get(func, @ir.hot_region_get(func, body, 1)).op {
    @ir.HotOp::Drop => ()
    other =>
      fail("expected target drop after last operand local.set, got \{other}")
  }
  match @ir.hot_node_get(func, @ir.hot_region_get(func, body, 2)).op {
    @ir.HotOp::LocalGet => ()
    other =>
      fail("expected last operand reload after target drop, got \{other}")
  }
}

///|
test "optimize-instructions preserves effectful prefix while folding known-null ref.eq" {
  let source =
    #|(module
    #|  (import "m" "effect" (func $effect (result i32)))
    #|  (func (export "both-null") (result i32)
    #|    call $effect
    #|    drop
    #|    ref.null eq
    #|    ref.null eq
    #|    ref.eq)
    #|  (func (export "left-null") (result i32)
    #|    call $effect
    #|    drop
    #|    ref.null eq
    #|    i32.const 1
    #|    ref.i31
    #|    ref.eq)
    #|  (func (export "right-null") (result i32)
    #|    call $effect
    #|    drop
    #|    i32.const 1
    #|    ref.i31
    #|    ref.null eq
    #|    ref.eq)
    #|)
  let optimized = match
    pass_test_run_pipeline(source, ["optimize-instructions"]) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected effectful known-null ref.eq optimize success, got \{err}")
  }
  let both_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  let left_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  let right_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(3U))
  assert_false(both_pretty.contains("ref.eq"), msg=both_pretty)
  assert_false(left_pretty.contains("ref.eq"), msg=left_pretty)
  assert_false(right_pretty.contains("ref.eq"), msg=right_pretty)
  assert_true(both_pretty.contains("call (Func 0)"), msg=both_pretty)
  assert_true(left_pretty.contains("call (Func 0)"), msg=left_pretty)
  assert_true(right_pretty.contains("call (Func 0)"), msg=right_pretty)
  assert_true(both_pretty.contains("drop"), msg=both_pretty)
  assert_true(left_pretty.contains("drop"), msg=left_pretty)
  assert_true(right_pretty.contains("drop"), msg=right_pretty)
  assert_true(both_pretty.contains("I32(1)"), msg=both_pretty)
  assert_true(left_pretty.contains("I32(0)"), msg=left_pretty)
  assert_true(right_pretty.contains("I32(0)"), msg=right_pretty)
}

///|
test "optimize-instructions preserves effectful prefix while folding known-null ref.as_non_null" {
  let source =
    #|(module
    #|  (import "m" "effect" (func $effect (result i32)))
    #|  (func (export "f") (result eqref)
    #|    call $effect
    #|    drop
    #|    ref.null eq
    #|    ref.as_non_null)
    #|)
  let optimized = match
    pass_test_run_pipeline(source, ["optimize-instructions"]) {
    Ok(mod_) => mod_
    Err(err) =>
      fail(
        "expected effectful known-null ref.as_non_null optimize success, got \{err}",
      )
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_false(pretty.contains("ref.as_non_null"), msg=pretty)
