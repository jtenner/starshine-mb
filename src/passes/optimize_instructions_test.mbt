}

///|
test "optimize-instructions expands memory64 tiny memory.copy preserving i64 addresses" {
  let func_type = @lib.RecType::new(
    @lib.SubType::comp_type(
      @lib.CompType::func([@lib.ValType::i64(), @lib.ValType::i64()], []),
    ),
  )
  let input = @lib.Module::new()
    .with_type_sec(@lib.TypeSec::new([func_type]))
    .with_func_sec(@lib.FuncSec::new([@lib.TypeIdx::new(0U)]))
    .with_mem_sec(
      @lib.MemSec::new([@lib.MemType::new(@lib.Limits::i64(1UL, None))]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
            @lib.Instruction::i64_const(@lib.I64(1L)),
            @lib.Instruction::memory_copy(
              @lib.MemIdx::new(0U),
              @lib.MemIdx::new(0U),
            ),
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
            @lib.Instruction::i64_const(@lib.I64(8L)),
            @lib.Instruction::memory_copy(
              @lib.MemIdx::new(0U),
              @lib.MemIdx::new(0U),
            ),
          ]),
        ),
      ]),
    )
  match @validate.validate_module(input) {
    Ok(_) => ()
    Err(err) => fail("expected valid memory64 input, got \{err}")
  }
  let optimized = match
    run_hot_pipeline(input, HotPipelineOptions::new(), ["optimize-instructions"]) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected memory64 memory.copy optimize success, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("memory.copy"), msg=pretty)
  optimize_instructions_assert_strings_in_order(pretty, [
    "(local.get (Local 0))", "(local.get (Local 1))", "i32.load8u", "i32.store8",
    "(local.get (Local 0))", "(local.get (Local 1))", "i64.load", "i64.store",
  ])
}

///|
test "optimize-instructions keeps nonconstant larger tiny memory.fill for Binaryen parity" {
  // Binaryen v130 `optimizeMemoryFill` only lowers nonconstant fill values for
  // size 1. Larger tiny fills require a constant byte value; Starshine should
  // not synthesize repeated-byte multiply trees for size 2/4/8 without a
  // measured Starshine win.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func (param $dst i32) (param $val i32)
        #|    local.get $dst
        #|    local.get $val
        #|    i32.const 1
        #|    memory.fill
        #|    local.get $dst
        #|    local.get $val
        #|    i32.const 2
        #|    memory.fill
        #|    local.get $dst
        #|    local.get $val
        #|    i32.const 4
        #|    memory.fill
        #|    local.get $dst
        #|    local.get $val
        #|    i32.const 8
        #|    memory.fill))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected nonconstant memory.fill parity success, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  @debug.assert_eq(
    optimize_instructions_test_count_substring(pretty, "memory.fill"),
    3,
    msg=pretty,
  )
  assert_true(pretty.contains("i32.store8"), msg=pretty)
  assert_false(pretty.contains("i32.store16"), msg=pretty)
  assert_false(pretty.contains("i32.mul"), msg=pretty)
  assert_false(pretty.contains("i64.mul"), msg=pretty)
}

///|
test "optimize-instructions keeps memory64 nonconstant larger tiny memory.fill" {
  let func_type = @lib.RecType::new(
