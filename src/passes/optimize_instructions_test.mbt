  let or_func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32) (result (ref i31)) (select (ref.i31 (i32.or (local.get 0) (i32.const 7))) (ref.i31 (i32.or (local.get 0) (i32.const 7))) (local.get 1))))",
