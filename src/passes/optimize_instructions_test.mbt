  assert_false(pretty.contains("i64.store"), msg=pretty)
}

///|
test "optimize-instructions keeps memory64 memory.copy outside exact tiny lowering boundary" {
  let func_type = @lib.RecType::new(
    @lib.SubType::comp_type(
      @lib.CompType::func(
        [@lib.ValType::i64(), @lib.ValType::i64(), @lib.ValType::i64()],
        [],
      ),
    ),
  )
  let input = @lib.Module::new()
    .with_type_sec(@lib.TypeSec::new([func_type]))
    .with_func_sec(@lib.FuncSec::new([@lib.TypeIdx::new(0U)]))
    .with_mem_sec(
      @lib.MemSec::new([@lib.MemType::new(@lib.Limits::i64(1UL, None))]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
            @lib.Instruction::i64_const(@lib.I64(2147483648L)),
            @lib.Instruction::memory_copy(
              @lib.MemIdx::new(0U),
              @lib.MemIdx::new(0U),
            ),
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(2U)),
            @lib.Instruction::memory_copy(
              @lib.MemIdx::new(0U),
              @lib.MemIdx::new(0U),
            ),
          ]),
        ),
      ]),
    )
  match @validate.validate_module(input) {
    Ok(_) => ()
    Err(err) => fail("expected valid memory64 boundary input, got \{err}")
  }
  let optimized = match
    run_hot_pipeline(input, HotPipelineOptions::new(), ["optimize-instructions"]) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected memory64 memory.copy boundary success, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  // Intentional fail-closed memory64 boundary: exact tiny lowering only accepts
  // constant sizes representable as local Int values and never proves dynamic
  // memory64 lengths, so oversized and nonconstant lengths remain bulk copies.
  @debug.assert_eq(
    optimize_instructions_test_count_substring(pretty, "memory.copy"),
    2,
    msg=pretty,
  )
  assert_false(pretty.contains("i32.load8u"), msg=pretty)
  assert_false(pretty.contains("i64.load"), msg=pretty)
}

///|
test "optimize-instructions keeps memory.copy outside exact tiny lowering boundary" {
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func (param $dst i32) (param $src i32) (param $size i32)
        #|    local.get $dst
        #|    local.get $src
        #|    i32.const 0
        #|    memory.copy
        #|    local.get $dst
        #|    local.get $src
        #|    i32.const 3
        #|    memory.copy
        #|    local.get $dst
        #|    local.get $src
        #|    i32.const 32
        #|    memory.copy
        #|    local.get $dst
        #|    local.get $src
        #|    local.get $size
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected memory.copy boundary optimize success, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  // Intentional fail-closed boundary: without trap-relaxed mode support, a
  // zero-size memory.copy is kept; Binaryen also keeps size-3 copy spelling
  // (`.tmp/oi-g-memory-copy-size3-boundary-probe.wat`) rather than widening to
  // multiple narrow stores, and larger/nonconstant copies are kept too.
  @debug.assert_eq(
    optimize_instructions_test_count_substring(pretty, "memory.copy"),
    4,
    msg=pretty,
  )
  assert_false(pretty.contains("i32.load8u"), msg=pretty)
  assert_false(pretty.contains("i32.store8"), msg=pretty)
  assert_false(pretty.contains("i32.load16u"), msg=pretty)
  assert_false(pretty.contains("i32.store16"), msg=pretty)
  assert_false(pretty.contains("i64.load"), msg=pretty)
  assert_false(pretty.contains("i64.store"), msg=pretty)
  assert_false(pretty.contains("v128.load"), msg=pretty)
  assert_false(pretty.contains("v128.store"), msg=pretty)
}

///|
test "optimize-instructions drops zero-size stack bulk-memory under trap-relaxed facts" {
  // OI-G stack-operand fact slice: Binaryen version_130 drops zero-size
  // `memory.copy` / `memory.fill` under `--traps-never-happen` even when the
  // destination, source, and value operands are stack-carried calls, preserving
  // the call effects as drops. This is the trap-relaxed zero-size counterpart to
  // the tiny stack bulk-memory raw-gate fact.
  let trace : Array[String] = []
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (import "env" "dst" (func $dst (result i32)))
        #|  (import "env" "src" (func $src (result i32)))
        #|  (import "env" "val" (func $val (result i32)))
        #|  (memory 1)
        #|  (func
        #|    call $dst
        #|    call $src
        #|    i32.const 0
        #|    memory.copy
        #|    call $dst
        #|    call $val
        #|    i32.const 0
        #|    memory.fill))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(
        traps_never_happen=true,
        trace=Some(fn(line) { trace.push(line) }),
      ),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected zero-size stack bulk-memory TNH success, got \{err}")
  }
  assert_false(
    trace.any(fn(line) {
      line.contains(
        "pass[optimize-instructions]:skip-raw reason=stack-carried-effect-optimize-instructions-noop",
      )
    }),
    msg=trace.to_string(),
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(3U))
  assert_false(pretty.contains("memory.copy"), msg=pretty)
  assert_false(pretty.contains("memory.fill"), msg=pretty)
  optimize_instructions_assert_strings_in_order(pretty, [
    "call (Func 0)", "drop", "call (Func 1)", "drop", "call (Func 0)", "drop", "call (Func 2)",
    "drop",
  ])
}

///|
test "optimize-instructions keeps zero-size bulk-memory with effectful operands" {
  // Boundary-only OI-G classification: Binaryen `version_130`
  // `--optimize-instructions` keeps zero-size memory.copy/fill even when the
  // destination, source, and fill value operands are calls
  // (`.tmp/oi-g-zero-bulk-effect-probe.wat`). Starshine likewise keeps the
  // original bulk-memory operations rather than dropping evaluated operands.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func $dst (result i32) (i32.const 0))
        #|  (func $src (result i32) (i32.const 4))
        #|  (func $val (result i32) (i32.const 255))
        #|  (func
        #|    call $dst
        #|    call $src
        #|    i32.const 0
        #|    memory.copy
        #|    call $dst
        #|    call $val
        #|    i32.const 0
        #|    memory.fill))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected zero-size bulk-memory boundary success, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(3U))
  assert_true(pretty.contains("memory.copy"), msg=pretty)
  assert_true(pretty.contains("memory.fill"), msg=pretty)
  optimize_instructions_assert_strings_in_order(pretty, [
    "call (Func 0)", "call (Func 1)", "memory.copy", "call (Func 0)", "call (Func 2)",
    "memory.fill",
  ])
  assert_false(pretty.contains("i32.load8u"), msg=pretty)
  assert_false(pretty.contains("i32.store8"), msg=pretty)
}

///|
test "optimize-instructions drops same-address memory.copy under trap-relaxed facts" {
  // OI-G trap-relaxed bulk fact slice: Binaryen version_130 drops
  // `memory.copy(x, x, size)` under `--traps-never-happen` or
  // `--ignore-implicit-traps`, even when size is dynamic, because the only
  // remaining observable behavior is evaluating and dropping the three operands.
  // This locks a fact-driven same-input/dynamic-size path before widening to
  // Binaryen's full fallthrough/effect equality helper.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func (param $addr i32) (param $size i32)
        #|    local.get $addr
        #|    local.get $addr
        #|    local.get $size
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(traps_never_happen=true),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected same-address memory.copy trap-relaxed success, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("memory.copy"), msg=pretty)
  assert_false(pretty.contains("i32.load8u"), msg=pretty)
  assert_false(pretty.contains("i32.store8"), msg=pretty)
  optimize_instructions_assert_strings_in_order(pretty, [
    "local.get (Local 0)", "drop", "local.get (Local 0)", "drop", "local.get (Local 1)",
    "drop",
  ])
}

///|
test "optimize-instructions drops localtee same-address memory.copy under trap-relaxed facts" {
  // OI-G same-input fact breadth: Binaryen version_130 treats adjacent
  // `local.tee` + matching `local.get` operands as equal for
  // `areConsecutiveInputsEqual` under `--traps-never-happen`, replacing
  // `memory.copy(local.tee x, local.get x, size)` with operand drops. This is a
  // source-backed widening beyond the initial same-local-get subset without
  // claiming broader fallthrough/control equality yet.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func (export "f") (param $addr i32) (param $size i32) (local $tmp i32)
        #|    local.get $addr
        #|    local.tee $tmp
        #|    local.get $tmp
        #|    local.get $size
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(traps_never_happen=true),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected localtee same-address memory.copy TNH success, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("memory.copy"), msg=pretty)
  assert_true(pretty.contains("local.tee"), msg=pretty)
  optimize_instructions_assert_strings_in_order(pretty, [
    "local.tee", "drop", "local.get (Local 2)", "drop", "local.get (Local 1)", "drop",
  ])
}

///|
test "optimize-instructions drops block-fallthrough same-address memory.copy under trap-relaxed facts" {
  // OI-G same-input fact breadth: Binaryen version_130
  // `areConsecutiveInputsEqual` compares the fallthrough value of the left
  // operand to the right operand. A block whose fallthrough value is the same
  // local as the adjacent source operand is therefore a same-address copy under
  // `--traps-never-happen`; the block's prefix effects must be preserved by the
  // dropped destination operand.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func $side)
        #|  (func (export "f") (param $addr i32) (param $size i32)
        #|    (block (result i32)
        #|      call $side
        #|      local.get $addr)
        #|    local.get $addr
        #|    local.get $size
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(traps_never_happen=true),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail(
        "expected block-fallthrough same-address memory.copy TNH success, got \{err}",
      )
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_false(pretty.contains("memory.copy"), msg=pretty)
  optimize_instructions_assert_strings_in_order(pretty, [
    "call (Func 0)", "local.get (Local 0)", "drop", "local.get (Local 0)", "drop",
    "local.get (Local 1)", "drop",
  ])
}

///|
test "optimize-instructions drops right block-fallthrough same-address memory.copy under trap-relaxed facts" {
  // OI-G same-input fact breadth: Binaryen version_130
  // `areConsecutiveInputsEqual` also peels the fallthrough value of the right
  // operand while accumulating non-fallthrough prefix effects. This focused
  // subset accepts a right block only when the prefix is pure, proving the same
  // local address without claiming full Binaryen br_if/effect-interference
  // parity yet.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func (export "f") (param $addr i32) (param $size i32)
        #|    local.get $addr
        #|    (block (result i32)
        #|      i32.const 9
        #|      drop
        #|      local.get $addr)
        #|    local.get $size
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(traps_never_happen=true),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail(
        "expected right block-fallthrough same-address memory.copy TNH success, got \{err}",
      )
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("memory.copy"), msg=pretty)
  optimize_instructions_assert_strings_in_order(pretty, [
    "local.get (Local 0)", "drop", "i32.const I32(9)", "drop", "local.get (Local 0)",
    "drop", "local.get (Local 1)", "drop",
  ])
}

///|
test "optimize-instructions drops right block unrelated-state same-address memory.copy under trap-relaxed facts" {
  // OI-G same-input interference fact breadth: Binaryen version_130
  // `areConsecutiveInputsEqual` accumulates right-block prefix effects, then only
  // rejects them if they are ordered before the fallthrough value. An unrelated
  // global.set before a local.get address cannot affect the local address, so the
  // trap-relaxed same-address `memory.copy` is removed while preserving the
  // global write inside the dropped source operand.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (global $g (mut i32) (i32.const 0))
        #|  (func (export "f") (param $addr i32) (param $size i32)
        #|    local.get $addr
        #|    (block (result i32)
        #|      i32.const 1
        #|      global.set $g
        #|      local.get $addr)
        #|    local.get $size
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(traps_never_happen=true),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail(
        "expected unrelated-state right block same-address memory.copy TNH success, got \{err}",
      )
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("memory.copy"), msg=pretty)
  assert_true(pretty.contains("global.set"), msg=pretty)
  optimize_instructions_assert_strings_in_order(pretty, [
    "local.get (Local 0)", "drop", "i32.const I32(1)", "global.set", "local.get (Local 0)",
    "drop", "local.get (Local 1)", "drop",
  ])
}

///|
test "optimize-instructions drops right block unrelated local.set same-address memory.copy" {
  // OI-G same-input local-interference fact breadth: Binaryen version_130
  // `areConsecutiveInputsEqual` only rejects prefix effects that are ordered
  // before the right fallthrough value. A right block prefix writing a different
  // local from the fallthrough `local.get` cannot change the address, so the
  // trap-relaxed same-address `memory.copy` is removed while preserving the
  // unrelated write inside the dropped source operand.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func (export "f") (param $addr i32) (param $size i32) (local $tmp i32)
        #|    local.get $addr
        #|    (block (result i32)
        #|      i32.const 7
        #|      local.set $tmp
        #|      local.get $addr)
        #|    local.get $size
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(traps_never_happen=true),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail(
        "expected unrelated right local.set memory.copy TNH success, got \{err}",
      )
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("memory.copy"), msg=pretty)
  assert_true(pretty.contains("local.set (Local 2)"), msg=pretty)
  optimize_instructions_assert_strings_in_order(pretty, [
    "local.get (Local 0)", "drop", "i32.const I32(7)", "local.set (Local 2)", "local.get (Local 0)",
    "drop", "local.get (Local 1)", "drop",
  ])
}

///|
test "optimize-instructions drops raw right localtee memory.copy" {
  // OI-G raw stack-root fact: Binaryen version_130 peels the right operand
  // with `Properties::getImmediateFallthrough(...AllowTeeBrIf)` and drops this
  // same-address copy under TNH while preserving the right `local.tee` write as
  // part of the dropped source operand. This locks the flat raw counterpart to
  // the HOT right-localtee consecutive-input equality fact.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func (export "f") (param $addr i32) (param $size i32) (local $tmp i32)
        #|    (memory.copy
        #|      (local.get $addr)
        #|      (local.tee $tmp (local.get $addr))
        #|      (local.get $size))))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(traps_never_happen=true),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected raw right localtee memory.copy TNH success, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("memory.copy"), msg=pretty)
  assert_true(pretty.contains("local.tee"), msg=pretty)
  optimize_instructions_assert_strings_in_order(pretty, [
    "local.get (Local 0)", "drop", "local.get (Local 0)", "local.tee (Local 2)",
    "drop", "local.get (Local 1)", "drop",
  ])
}

///|
test "optimize-instructions drops left localtee payload same-address memory.copy" {
  // OI-G same-input left-tee fact breadth: Binaryen version_130 descends through
  // a non-matching left `local.tee` to compare its payload with the adjacent
  // right operand, while treating the tee write as an intervening effect. When
  // that write targets a different local than the right `local.get`, the
  // trap-relaxed same-address `memory.copy` can be removed.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func (export "f") (param $addr i32) (param $size i32) (local $tmp i32)
        #|    local.get $addr
        #|    local.tee $tmp
        #|    local.get $addr
        #|    local.get $size
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(traps_never_happen=true),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected left localtee payload memory.copy TNH success, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("memory.copy"), msg=pretty)
  // Starshine's HOT dropped-operand cleanup canonicalizes `drop(local.tee tmp x)`
  // to `local.set tmp x`, a smaller effect-preserving spelling than Binaryen's
  // raw text while preserving the same source-backed same-address fold.
  assert_true(pretty.contains("local.set (Local 2)"), msg=pretty)
  optimize_instructions_assert_strings_in_order(pretty, [
    "local.get (Local 0)", "local.set (Local 2)", "local.get (Local 0)", "drop",
    "local.get (Local 1)", "drop",
  ])
}

///|
test "optimize-instructions drops select-tree same-address memory.copy" {
  // OI-G ExpressionAnalyzer equality breadth: Binaryen v130 treats matching
  // branchless `select` address trees as equal for `areConsecutiveInputsEqual`.
  // Under TNH, the same-address copy collapses to operand drops while preserving
  // both selects and the dynamic size operand.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func (export "f") (param $a i32) (param $b i32) (param $cond i32) (param $size i32)
        #|    local.get $a
        #|    local.get $b
        #|    local.get $cond
        #|    select
        #|    local.get $a
        #|    local.get $b
        #|    local.get $cond
        #|    select
        #|    local.get $size
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(traps_never_happen=true),
    ) {
    Ok(mod_) => mod_
    Err(err) => fail("expected select-tree memory.copy TNH success, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("memory.copy"), msg=pretty)
  optimize_instructions_assert_strings_in_order(pretty, [
    "local.get (Local 0)", "local.get (Local 1)", "local.get (Local 2)", "select",
    "drop", "local.get (Local 0)", "local.get (Local 1)", "local.get (Local 2)",
    "select", "drop", "local.get (Local 3)", "drop",
  ])
}

///|
test "optimize-instructions drops right block unrelated global.set global-address memory.copy" {
  // OI-G same-input global-interference fact breadth: Binaryen version_130
  // `areConsecutiveInputsEqual` also treats `global.get` fallthrough values as
  // equal when intervening effects are not ordered before that specific global
  // read. A right-block prefix writing an unrelated global cannot change the
  // copied address, so the trap-relaxed same-address `memory.copy` is removed
  // while preserving the unrelated write inside the dropped source operand.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (global $addr (mut i32) (i32.const 16))
        #|  (global $tmp (mut i32) (i32.const 0))
        #|  (func (export "f") (param $size i32)
        #|    global.get $addr
        #|    (block (result i32)
        #|      i32.const 1
        #|      global.set $tmp
        #|      global.get $addr)
        #|    local.get $size
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(traps_never_happen=true),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail(
        "expected unrelated right global.set memory.copy TNH success, got \{err}",
      )
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("memory.copy"), msg=pretty)
  assert_true(pretty.contains("global.set"), msg=pretty)
  optimize_instructions_assert_strings_in_order(pretty, [
    "global.get (Global 0)", "drop", "i32.const I32(1)", "global.set (Global 1)",
    "global.get (Global 0)", "drop", "local.get (Local 0)", "drop",
  ])
}

///|
test "optimize-instructions drops load-read same-address memory.copy" {
  // OI-G same-input equality fact breadth: Binaryen version_130
  // `areConsecutiveInputsEqual` delegates to `ExpressionAnalyzer::equal`, which
  // treats repeated loads with the same access and address expression as equal
  // when no intervening effects can change the memory read. Under
  // `--traps-never-happen`, same-address memory.copy then collapses to operand
  // drops while preserving both load reads.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func (export "f") (param $addr i32) (param $size i32)
        #|    (memory.copy
        #|      (i32.load (local.get $addr))
        #|      (i32.load (local.get $addr))
        #|      (local.get $size))))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(traps_never_happen=true),
    ) {
    Ok(mod_) => mod_
    Err(err) => fail("expected load-read memory.copy TNH success, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("memory.copy"), msg=pretty)
  optimize_instructions_assert_strings_in_order(pretty, [
    "local.get (Local 0)", "i32.load", "drop", "local.get (Local 0)", "i32.load",
    "drop", "local.get (Local 1)", "drop",
  ])
}

///|
test "optimize-instructions drops load-read memory.size-address same-address memory.copy" {
  // OI-G same-input equality fact breadth: Binaryen version_130
  // `ExpressionAnalyzer::equal` compares repeated load address expressions that
  // contain deterministic state-read leaves, such as `memory.size`, and the
  // enclosing equality fact separately rejects intervening effects that can
  // change either the address read or loaded memory. Under TNH, matching loads
  // from `memory.size` addresses are equal enough for same-address copy removal.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func (export "f") (param $size i32)
        #|    memory.size
        #|    i32.load
        #|    memory.size
        #|    i32.load
        #|    local.get $size
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(traps_never_happen=true),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
