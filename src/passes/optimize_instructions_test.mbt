///|
test "optimize-instructions skips nullable ref.is_null casts under traps-never-happen" {
  // Binaryen v130 `visitRefIsNull` calls `skipCast(curr->value)` only in
  // traps-never-happen mode after direct non-null folds. A nullable cast from
  // anyref to eqref must therefore be preserved by default but erased under TNH,
  // leaving the null predicate on the original value.
  let eq_heap = @lib.HeapType::abs(@lib.AbsHeapType::eq())
  let func_type = @lib.TypeIdx::new(0U)
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::anyref()], [@lib.ValType::i32()]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([func_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_cast(true, eq_heap),
            @lib.Instruction::ref_is_null(),
          ]),
        ),
      ]),
    )
  let default_optimized = optimize_instructions_test_run_module(module_)
  match default_optimized.code_sec {
    Some(@lib.CodeSec([@lib.Func(_, @lib.Expr(default_body))])) => {
      assert_true(
        default_body.any(fn(instr) {
          match instr {
            @lib.Instruction::RefCast(true, false, target) => target == eq_heap
            _ => false
          }
        }),
        msg="\{default_body}",
      )
      assert_true(
        default_body.any(fn(instr) { instr == @lib.Instruction::ref_is_null() }),
        msg="\{default_body}",
      )
    }
    _ => fail("expected one default optimized function")
  }
  let tnh_optimized = match
    run_hot_pipeline(
      module_,
      HotPipelineOptions::new(traps_never_happen=true),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) => fail("expected TNH ref.is_null cast skip success, got \{err}")
  }
  match tnh_optimized.code_sec {
    Some(@lib.CodeSec([@lib.Func(_, @lib.Expr(tnh_body))])) => {
      assert_false(
        tnh_body.any(fn(instr) {
          match instr {
            @lib.Instruction::RefCast(true, false, target) => target == eq_heap
            _ => false
          }
        }),
        msg="\{tnh_body}",
      )
      assert_true(
        tnh_body.any(fn(instr) { instr == @lib.Instruction::ref_is_null() }),
        msg="\{tnh_body}",
      )
    }
    _ => fail("expected one TNH optimized function")
  }
}

///|
test "optimize-instructions skips ref.eq operand casts under traps-never-happen" {
  // Binaryen v130 `visitRefEq` checks impossible heap pairs before calling
  // `skipCast(curr->left/right, (ref null eq))`. A cast whose input already
  // has a nullable-eq subtype is therefore preserved by default but erased
  // under TNH even when `ref.eq` itself remains live.
  let i31_heap = @lib.HeapType::abs(@lib.AbsHeapType::i31())
  let eq_heap = @lib.HeapType::abs(@lib.AbsHeapType::eq())
  let eq_ref = @lib.ValType::ref_null(eq_heap)
  let func_type = @lib.TypeIdx::new(0U)
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([eq_ref, eq_ref], [@lib.ValType::i32()]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([func_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_cast(true, i31_heap),
            @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
            @lib.Instruction::ref_eq(),
          ]),
        ),
      ]),
    )
  let default_optimized = optimize_instructions_test_run_module(module_)
  match default_optimized.code_sec {
    Some(@lib.CodeSec([@lib.Func(_, @lib.Expr(default_body))])) => {
      assert_true(
        default_body.any(fn(instr) {
          match instr {
            @lib.Instruction::RefCast(true, false, target) => target == i31_heap
            _ => false
          }
        }),
        msg="\{default_body}",
      )
      assert_true(
        default_body.any(fn(instr) { instr == @lib.Instruction::ref_eq() }),
        msg="\{default_body}",
      )
    }
    _ => fail("expected one default optimized ref.eq function")
  }
  let tnh_optimized = match
    run_hot_pipeline(
      module_,
      HotPipelineOptions::new(traps_never_happen=true),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) => fail("expected TNH ref.eq cast skip success, got \{err}")
  }
  match tnh_optimized.code_sec {
    Some(@lib.CodeSec([@lib.Func(_, @lib.Expr(tnh_body))])) => {
      assert_false(
        tnh_body.any(fn(instr) {
          match instr {
            @lib.Instruction::RefCast(true, false, target) => target == i31_heap
            _ => false
          }
        }),
        msg="\{tnh_body}",
      )
      assert_true(
        tnh_body.any(fn(instr) { instr == @lib.Instruction::ref_eq() }),
        msg="\{tnh_body}",
      )
    }
    _ => fail("expected one TNH optimized ref.eq function")
  }
}

///|
test "optimize-instructions folds reference checks on non-null local refs" {
  let source =
    #|(module
    #|  (func (export "is-null") (param (ref eq)) (result i32)
    #|    local.get 0
    #|    ref.is_null)
    #|  (func (export "as-non-null") (param (ref eq)) (result (ref eq))
    #|    local.get 0
    #|    ref.as_non_null)
    #|  (func (export "eq-null") (param (ref eq)) (result i32)
    #|    local.get 0
    #|    ref.null eq
    #|    ref.eq)
    #|)
  let optimized = match
    pass_test_run_pipeline(source, ["optimize-instructions"]) {
    Ok(mod_) => mod_
    Err(err) => fail("expected non-null local ref optimize success, got \{err}")
  }
  let is_null_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  let as_non_null_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  let eq_null_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_false(is_null_pretty.contains("ref.is_null"), msg=is_null_pretty)
  assert_true(is_null_pretty.contains("I32(0)"), msg=is_null_pretty)
  assert_false(
    as_non_null_pretty.contains("ref.as_non_null"),
    msg=as_non_null_pretty,
  )
  assert_true(as_non_null_pretty.contains("local.get"), msg=as_non_null_pretty)
  assert_false(eq_null_pretty.contains("ref.eq"), msg=eq_null_pretty)
  assert_true(eq_null_pretty.contains("I32(0)"), msg=eq_null_pretty)
}

