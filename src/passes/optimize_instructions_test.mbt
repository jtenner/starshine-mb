///|
test "optimize-instructions folds i64.extend_i32_u unsigned maxBits compares" {
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (func (param $x i32) (result i32)
        #|    local.get $x
        #|    i64.extend_i32_u
        #|    i64.const -1
        #|    i64.lt_s)
        #|  (func (param $x i32) (result i32)
        #|    local.get $x
        #|    i64.extend_i32_u
        #|    i64.const 42
        #|    i64.ge_s)
        #|  (func (param $x i32) (result i32)
        #|    local.get $x
        #|    i32.const 255
        #|    i32.and
        #|    i64.extend_i32_u
        #|    i64.const 300
        #|    i64.gt_s))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected i64.extend_i32_u maxBits optimize success, got \{err}")
  }
  let folded_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_true(folded_pretty.contains("i32.const I32(0)"), msg=folded_pretty)
  assert_false(folded_pretty.contains("i64.lt_s"), msg=folded_pretty)
  let spelling_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_true(spelling_pretty.contains("i64.ge_u"), msg=spelling_pretty)
  assert_false(spelling_pretty.contains("i64.ge_s"), msg=spelling_pretty)
  let narrowed_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_true(narrowed_pretty.contains("i32.const I32(0)"), msg=narrowed_pretty)
  assert_false(narrowed_pretty.contains("i64.gt_s"), msg=narrowed_pretty)
}

///|
test "optimize-instructions rewrites unsigned maxBits signed compare spelling" {
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func (param $x i32) (result i32)
        #|    local.get $x
        #|    i32.const 255
        #|    i32.and
        #|    i32.const 128
        #|    i32.lt_s)
        #|  (func (param $x i64) (result i32)
        #|    local.get $x
        #|    i64.const 8
        #|    i64.shr_u
        #|    i64.const 42
        #|    i64.ge_s)
        #|  (func (param $p i32) (result i32)
        #|    local.get $p
        #|    i32.load8_u
        #|    i32.const 128
        #|    i32.lt_s))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected unsigned maxBits spelling optimize success, got \{err}")
  }
  let i32_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_true(i32_pretty.contains("i32.lt_u"), msg=i32_pretty)
  assert_false(i32_pretty.contains("i32.lt_s"), msg=i32_pretty)
  let i64_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_true(i64_pretty.contains("i64.ge_u"), msg=i64_pretty)
  assert_false(i64_pretty.contains("i64.ge_s"), msg=i64_pretty)
  let load_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_true(load_pretty.contains("i32.lt_u"), msg=load_pretty)
  assert_false(load_pretty.contains("i32.lt_s"), msg=load_pretty)
}

///|
test "optimize-instructions rewrites unsigned maxBits signed div rem shift spellings" {
  // Red-first OI-D fact slice: Binaryen v130 lowers signed div/rem/shr to the
  // unsigned spelling when `makeUnsignedBinaryOp` succeeds, the right constant
  // is nonnegative, and `Bits::getMaxBits(left) <= signBit - 1`. Starshine's
  // local unsigned-max fact should own the equivalent local-HOT proof for
  // bounded `and`, `shr_u`, zero-extend producers, and nested bounded bitwise
  // producers instead of requiring both operands to be direct constants.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (func (param $x i32) (result i32)
        #|    local.get $x
        #|    i32.const 255
        #|    i32.and
        #|    i32.const 3
        #|    i32.div_s)
        #|  (func (param $x i32) (result i32)
        #|    local.get $x
        #|    i32.const 1
        #|    i32.shr_u
        #|    i32.const 3
        #|    i32.rem_s)
        #|  (func (param $x i64) (result i64)
        #|    local.get $x
        #|    i64.const 255
        #|    i64.and
        #|    i64.const 1
        #|    i64.shr_s)
        #|  (func (param $x i32) (result i32)
        #|    local.get $x
        #|    i32.const 1023
        #|    i32.and
        #|    i32.const -2
        #|    i32.and
        #|    i32.const 3
        #|    i32.div_s)
        #|  (func (param $x i32) (result i32)
        #|    local.get $x
        #|    i32.const 1023
        #|    i32.and
        #|    i32.const 1
        #|    i32.or
        #|    i32.const 3
        #|    i32.rem_s)
        #|  (func (param $x i64) (result i64)
        #|    local.get $x
        #|    i64.const 1023
        #|    i64.and
        #|    i64.const 1
        #|    i64.xor
        #|    i64.const 1
        #|    i64.shr_s))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail(
        "expected unsigned maxBits signed arithmetic optimize success, got \{err}",
      )
  }
  let div_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_true(div_pretty.contains("i32.div_u"), msg=div_pretty)
  assert_false(div_pretty.contains("i32.div_s"), msg=div_pretty)
  let rem_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_true(rem_pretty.contains("i32.rem_u"), msg=rem_pretty)
  assert_false(rem_pretty.contains("i32.rem_s"), msg=rem_pretty)
  let shr_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_true(shr_pretty.contains("i64.shr_u"), msg=shr_pretty)
  assert_false(shr_pretty.contains("i64.shr_s"), msg=shr_pretty)
  let neg_mask_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(3U))
  assert_true(neg_mask_pretty.contains("i32.div_u"), msg=neg_mask_pretty)
  assert_false(neg_mask_pretty.contains("i32.div_s"), msg=neg_mask_pretty)
  let or_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(4U))
  assert_true(or_pretty.contains("i32.rem_u"), msg=or_pretty)
  assert_false(or_pretty.contains("i32.rem_s"), msg=or_pretty)
  let xor_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(5U))
  assert_true(xor_pretty.contains("i64.shr_u"), msg=xor_pretty)
  assert_false(xor_pretty.contains("i64.shr_s"), msg=xor_pretty)
}

///|
test "optimize-instructions rewrites eqz wrap_i64 with unsigned maxBits" {
  // Red-first OI-D fact slice: Binaryen v130 rewrites
  // `i32.eqz(i32.wrap_i64(x))` to `i64.eqz(x)` when `Bits::getMaxBits(x) <= 32`.
  // Keep the proof in the shared unsigned-max fact so bounded i64 producers,
  // including bitwise masks, feed both spelling and eqz-wrap consumers.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (func (param $x i64) (result i32)
        #|    local.get $x
        #|    i64.const 4294967295
        #|    i64.and
        #|    i32.wrap_i64
        #|    i32.eqz))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) => fail("expected eqz wrap_i64 optimize success, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_true(pretty.contains("i64.eqz"), msg=pretty)
  assert_false(pretty.contains("i32.wrap_i64"), msg=pretty)
  assert_false(pretty.contains("i32.eqz"), msg=pretty)
}

///|
test "optimize-instructions removes extend wrap_i64 with unsigned maxBits" {
  // Red-first OI-D fact slice: Binaryen v130 rewrites
  // `i64.extend_i32_u(i32.wrap_i64(x))` to `x` when `Bits::getMaxBits(x) <= 32`
  // and `i64.extend_i32_s(i32.wrap_i64(x))` to `x` when `Bits::getMaxBits(x) <= 31`.
  // Keep this as another consumer of the shared unsigned-max fact, not a new wrapper scanner.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (func (param $x i64) (result i64)
        #|    local.get $x
        #|    i64.const 4294967295
        #|    i64.and
        #|    i32.wrap_i64
        #|    i64.extend_i32_u)
        #|  (func (param $x i64) (result i64)
        #|    local.get $x
        #|    i64.const 2147483647
        #|    i64.and
        #|    i32.wrap_i64
        #|    i64.extend_i32_s))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) => fail("expected extend wrap_i64 optimize success, got \{err}")
  }
  for idx = 0U; idx < 2U; idx = idx + 1U {
    let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(idx))
    assert_true(pretty.contains("i64.and"), msg=pretty)
    assert_false(pretty.contains("i32.wrap_i64"), msg=pretty)
    assert_false(pretty.contains("i64.extend_i32"), msg=pretty)
  }
}

///|
test "optimize-instructions rewrites signed extend wrap_i64 to extend32 fallback" {
  // Red-first OI-D fact slice: Binaryen v130 first removes
  // `i64.extend_i32_s(i32.wrap_i64(x))` completely when `Bits::getMaxBits(x) <= 31`,
  // then falls back to `i64.extend32_s(x)` for the signed 32-bit low-lane case.
  // Keep that fallback as an explicit fact sibling of the unsigned-max removal,
  // not a wrapper-specific scanner.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (func (param $x i64) (result i64)
        #|    local.get $x
        #|    i32.wrap_i64
        #|    i64.extend_i32_s)
        #|  (func (param $x i64) (result i64)
        #|    local.get $x
        #|    i64.const 4294967295
        #|    i64.and
        #|    i32.wrap_i64
        #|    i64.extend_i32_s))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected signed extend wrap_i64 optimize success, got \{err}")
  }
  for idx = 0U; idx < 2U; idx = idx + 1U {
    let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(idx))
    assert_true(pretty.contains("i64.extend32s"), msg=pretty)
    assert_false(pretty.contains("i32.wrap_i64"), msg=pretty)
    assert_false(pretty.contains("i64.extend_i32"), msg=pretty)
  }
}

///|
test "optimize-instructions folds unsigned maxBits signed compares" {
  let pure_source =
    #|(module
    #|  (func $test (param $x i32) (result i32)
    #|    local.get $x
    #|    i32.const 255
    #|    i32.and
    #|    i32.const 300
    #|    i32.gt_s))
    #|
  let pure_func = optimize_instructions_test_run_hot(pure_source)
  let pure_root = @ir.hot_root_get(pure_func, 0)
  match @ir.hot_node_get(pure_func, pure_root).op {
    @ir.HotOp::Const => ()
    _ => fail("expected pure unsigned maxBits signed compare to fold to const")
  }
  @debug.assert_eq(
    @ir.hot_const_get(pure_func, @ir.hot_node_get(pure_func, pure_root).imm0),
    @ir.HotConstPayload::i32_const(@lib.I32(0)),
  )

  let effect_source =
    #|(module
    #|  (memory 1)
    #|  (func $test (param $ptr i32) (result i32)
    #|    local.get $ptr
    #|    i32.load8_u
    #|    i32.const 300
    #|    i32.le_s))
    #|
  let effect_func = optimize_instructions_test_run_hot(effect_source)
  let effect_root = @ir.hot_root_get(effect_func, 0)
  match @ir.hot_node_get(effect_func, effect_root).op {
    @ir.HotOp::Block => ()
    _ => fail("expected effectful load maxBits signed compare to preserve load")
  }
  let body = @ir.hot_region_body_ref(effect_func, effect_root)
  @debug.assert_eq(@ir.hot_region_root_count(effect_func, body), 2)
  let dropped = @ir.hot_region_get(effect_func, body, 0)
  match @ir.hot_node_get(effect_func, dropped).op {
    @ir.HotOp::Drop => ()
    _ => fail("expected folded load signed compare to keep load under drop")
  }
  @debug.assert_eq(
    @ir.hot_node_exact_instr(
      effect_func,
      @ir.hot_child_get(effect_func, dropped, 0),
    ),
    Some(
      @lib.Instruction::i32_load8u(
        @lib.MemArg::new(@lib.U32(0), None, @lib.U64(0)),
      ),
    ),
  )
  let result = @ir.hot_region_get(effect_func, body, 1)
  match @ir.hot_node_get(effect_func, result).op {
    @ir.HotOp::Const => ()
    _ => fail("expected folded load signed compare result const")
  }
  @debug.assert_eq(
    @ir.hot_const_get(effect_func, @ir.hot_node_get(effect_func, result).imm0),
    @ir.HotConstPayload::i32_const(@lib.I32(1)),
  )
}

///|
test "optimize-instructions preserves i64 masked unsigned compare effects" {
  let source =
    #|(module
    #|  (func $test (result i32)
    #|    call $effect
    #|    i64.const 255
    #|    i64.and
    #|    i64.const 256
    #|    i64.eq)
    #|  (func $effect (result i64) i64.const 7))
    #|
  let func = optimize_instructions_test_run_hot(source)
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_get(func, root).op {
    @ir.HotOp::Block => ()
    _ =>
      fail("expected effectful i64 masked compare to become drop+const block")
  }
  let body = @ir.hot_region_body_ref(func, root)
  @debug.assert_eq(@ir.hot_region_root_count(func, body), 2)
  let dropped = @ir.hot_region_get(func, body, 0)
  match @ir.hot_node_get(func, dropped).op {
    @ir.HotOp::Drop => ()
    _ =>
      fail(
        "expected first folded i64 masked compare root to preserve lhs with drop",
      )
  }
  @debug.assert_eq(@ir.hot_child_count(func, dropped), 1)
  let masked = @ir.hot_child_get(func, dropped, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(func, masked),
    Some(@lib.Instruction::i64_and()),
  )
  let result = @ir.hot_region_get(func, body, 1)
  match @ir.hot_node_get(func, result).op {
    @ir.HotOp::Const => ()
    _ => fail("expected second folded i64 masked compare root to be const")
  }
  @debug.assert_eq(
    @ir.hot_const_get(func, @ir.hot_node_get(func, result).imm0),
    @ir.HotConstPayload::i32_const(@lib.I32(0)),
  )
}

///|
