        [
          _,
          _,
          @lib.Func(
            _,
            @lib.Expr(
              [
                @lib.LocalGet(arg0),
                @lib.LocalGet(arg1),
                @lib.LocalGet(arg2),
                @lib.Call(ref_func),
                @lib.Drop,
                @lib.LocalGet(arg3),
                @lib.LocalGet(arg4),
                @lib.Call(desc_func),
                @lib.Drop,
                @lib.Unreachable,
              ]
