  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_true(pretty.contains("memory.copy"), msg=pretty)
  optimize_instructions_assert_strings_in_order(pretty, [
    "local.get (Local 0)", "i32.const I32(4)", "i32.add", "local.get (Local 0)",
    "i32.const I32(8)", "i32.add", "local.get (Local 1)", "memory.copy",
  ])
}

///|
test "optimize-instructions keeps right-prefix write pure binary memory.copy" {
  // Boundary guard for source-backed `orderedBefore(effects(right))` parity:
  // if the code between the left and right fallthroughs writes a local read by
  // the right expression tree, the repeated binary shape is not enough to prove
  // equal runtime addresses, so the trap-relaxed bulk copy must remain.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func (export "f") (param $addr i32) (param $size i32)
        #|    (memory.copy
        #|      (i32.add (local.get $addr) (i32.const 4))
        #|      (block (result i32)
        #|        i32.const 99
        #|        local.set $addr
        #|        (i32.add (local.get $addr) (i32.const 4)))
        #|      (local.get $size))))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(traps_never_happen=true),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail(
        "expected right-prefix write pure binary memory.copy boundary success, got \{err}",
      )
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_true(pretty.contains("memory.copy"), msg=pretty)
  assert_true(pretty.contains("local.set"), msg=pretty)
  optimize_instructions_assert_strings_in_order(pretty, [
    "local.get (Local 0)", "i32.const I32(4)", "i32.add", "i32.const I32(99)", "local.set (Local 0)",
    "local.get (Local 0)", "i32.const I32(4)", "i32.add", "local.get (Local 1)",
    "memory.copy",
  ])
}

///|
test "optimize-instructions keeps different-const memory.copy outside equality fact" {
  // Boundary guard for the constant equality fact: different constants are not
  // equal under Binaryen's `ExpressionAnalyzer::equal`, so a dynamic-size
  // trap-relaxed `memory.copy` must remain a bulk copy rather than being
  // rewritten to operand drops.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func (export "f") (param $size i32)
        #|    i32.const 16
        #|    i32.const 32
        #|    local.get $size
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(traps_never_happen=true),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected different-const memory.copy boundary success, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_true(pretty.contains("memory.copy"), msg=pretty)
  optimize_instructions_assert_strings_in_order(pretty, [
    "i32.const I32(16)", "i32.const I32(32)", "local.get (Local 0)", "memory.copy",
  ])
}

///|
test "optimize-instructions keeps interfering right global.set global-address memory.copy" {
  // Boundary guard for the OI-G right-prefix global-interference fact:
  // Binaryen v130's `orderedBefore(effects(right))` rejects a right block whose
  // prefix writes the global later read by the fallthrough address. The
  // addresses are not provably equal after the write, so Starshine must keep the
  // `memory.copy`.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (global $addr (mut i32) (i32.const 16))
        #|  (func (export "f") (param $size i32)
        #|    global.get $addr
        #|    (block (result i32)
        #|      i32.const 1
        #|      global.set $addr
        #|      global.get $addr)
        #|    local.get $size
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(traps_never_happen=true),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail(
        "expected interfering right global.set memory.copy success, got \{err}",
      )
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_true(pretty.contains("memory.copy"), msg=pretty)
  optimize_instructions_assert_strings_in_order(pretty, [
    "global.get (Global 0)", "i32.const I32(1)", "global.set (Global 0)", "global.get (Global 0)",
    "local.get (Local 0)", "memory.copy",
  ])
}

///|
test "optimize-instructions keeps interfering right local.set same-address memory.copy" {
  // Boundary guard for the OI-G right-prefix interference fact: Binaryen v130's
  // `orderedBefore(effects(right))` rejects a right block whose prefix writes the
  // local later read by the fallthrough address. The addresses are not provably
  // equal after the write, so Starshine must keep the `memory.copy`.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func (export "f") (param $addr i32) (param $size i32)
        #|    local.get $addr
        #|    (block (result i32)
        #|      i32.const 7
        #|      local.set $addr
        #|      local.get $addr)
        #|    local.get $size
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(traps_never_happen=true),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail(
