  assert_true(pretty.contains("unreachable"), msg=pretty)
  assert_false(pretty.contains("ref.as_non_null"), msg=pretty)
  assert_false(pretty.contains("ref.cast"), msg=pretty)
}

///|
test "optimize-instructions rewrites ref.eq null comparisons through ref.is_null" {
  let source =
    #|(module
    #|  (func (export "right") (param eqref) (result i32)
    #|    local.get 0
    #|    ref.null eq
    #|    ref.eq)
    #|  (func (export "left") (param eqref) (result i32)
    #|    ref.null eq
    #|    local.get 0
    #|    ref.eq)
    #|  (func (export "null-null") (result i32)
    #|    ref.null eq
    #|    ref.null eq
    #|    ref.eq)
    #|)
  let optimized = match
    pass_test_run_pipeline(source, ["optimize-instructions"]) {
    Ok(mod_) => mod_
    Err(err) => fail("expected ref.eq optimize success, got \{err}")
  }
  let right_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  let left_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  let null_null_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_false(right_pretty.contains("ref.eq"), msg=right_pretty)
  // pretty_print currently spells the lowered RefIsNull instruction as
  // `ref.null`; lock the OI rewrite by proving `ref.eq` is gone while the
  // operand-preserving unary reference check remains.
  assert_true(right_pretty.contains("local.get"), msg=right_pretty)
  assert_true(right_pretty.contains("ref.null"), msg=right_pretty)
  assert_false(left_pretty.contains("ref.eq"), msg=left_pretty)
  assert_true(left_pretty.contains("local.get"), msg=left_pretty)
  assert_true(left_pretty.contains("ref.null"), msg=left_pretty)
  assert_false(null_null_pretty.contains("ref.eq"), msg=null_null_pretty)
  assert_false(null_null_pretty.contains("ref.is_null"), msg=null_null_pretty)
  assert_true(null_null_pretty.contains("I32(1)"), msg=null_null_pretty)
}

///|
test "optimize-instructions directizes ref.func call_ref targets" {
  let callee_type_idx = @lib.TypeIdx::new(0U)
  let callee_type = @lib.RecType::new(
    @lib.SubType::comp_type(
      @lib.CompType::func([@lib.ValType::i32()], [@lib.ValType::i32()]),
    ),
  )
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(@lib.TypeSec::new([callee_type]))
    .with_func_sec(
      @lib.FuncSec::new([callee_type_idx, callee_type_idx, callee_type_idx]),
    )
    .with_elem_sec(
      @lib.ElemSec::new([
        @lib.Elem::new(
          @lib.ElemMode::declarative(),
          @lib.ElemKind::funcs([@lib.FuncIdx::new(0U)]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::local_get(@lib.LocalIdx::new(0U))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_func(@lib.FuncIdx::new(0U)),
            @lib.Instruction::call_ref(callee_type_idx),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_func(@lib.FuncIdx::new(0U)),
            @lib.Instruction::return_call_ref(callee_type_idx),
          ]),
        ),
      ]),
    ),
  )
  let caller = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  let tail = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_true(caller.contains("call (Func 0)"), msg=caller)
  assert_false(caller.contains("call_ref"), msg=caller)
  assert_false(caller.contains("ref.func"), msg=caller)
  assert_true(tail.contains("return_call (Func 0)"), msg=tail)
  assert_false(tail.contains("return_call_ref"), msg=tail)
  assert_false(tail.contains("ref.func"), msg=tail)
}

///|
test "optimize-instructions replaces known-null call_ref targets with unreachable preserving args" {
  // OI-H call_ref null-trap fact slice: Binaryen version_130 runs
  // `trapOnNull(curr, curr->target)` before target directization, so a direct
  // `ref.null` target becomes `unreachable` while source-order argument effects
  // remain observable. Keep this as a call_ref-target null-trap fact rather than
  // a direct ref.null scanner inside the target-directization cascade.
  let target_type_idx = @lib.TypeIdx::new(0U)
  let arg_type_idx = @lib.TypeIdx::new(1U)
  let caller_type_idx = @lib.TypeIdx::new(2U)
  let target_type = @lib.RecType::new(
    @lib.SubType::comp_type(
      @lib.CompType::func([@lib.ValType::i32()], [@lib.ValType::i32()]),
    ),
  )
  let arg_type = @lib.RecType::new(
    @lib.SubType::comp_type(@lib.CompType::func([], [@lib.ValType::i32()])),
  )
  let caller_type = @lib.RecType::new(
    @lib.SubType::comp_type(@lib.CompType::func([], [@lib.ValType::i32()])),
  )
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(@lib.TypeSec::new([target_type, arg_type, caller_type]))
    .with_func_sec(
      @lib.FuncSec::new([arg_type_idx, caller_type_idx, caller_type_idx]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(7))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::ref_null(@lib.HeapType::new(target_type_idx)),
            @lib.Instruction::call_ref(target_type_idx),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::ref_null(@lib.HeapType::new(target_type_idx)),
            @lib.Instruction::return_call_ref(target_type_idx),
          ]),
        ),
      ]),
    ),
  )
  let caller = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  let tail = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_true(caller.contains("call (Func 0)"), msg=caller)
  assert_true(caller.contains("unreachable"), msg=caller)
  assert_false(caller.contains("call_ref"), msg=caller)
  assert_false(caller.contains("ref.null"), msg=caller)
  assert_true(tail.contains("call (Func 0)"), msg=tail)
  assert_true(tail.contains("unreachable"), msg=tail)
  assert_false(tail.contains("return_call_ref"), msg=tail)
  assert_false(tail.contains("ref.null"), msg=tail)
}

///|
test "optimize-instructions replaces pure fallthrough-null call_ref targets with unreachable preserving args" {
  // OI-H call_ref null-trap fact slice: Binaryen version_130 `trapOnNull`
  // uses `getFallthrough(curr->target)` before it replaces the call with
  // `getDroppedChildrenAndAppend(..., unreachable)`, so a pure block target
  // whose tail is `ref.null` traps like a direct null target. Keep this as a
  // fallthrough-null target fact with pure-target evidence; target-side effects
  // and control/EH localization remain separate reopening criteria.
  let target_type_idx = @lib.TypeIdx::new(0U)
  let arg_type_idx = @lib.TypeIdx::new(1U)
  let caller_type_idx = @lib.TypeIdx::new(2U)
  let target_ref = @lib.ValType::ref_type(
    @lib.RefType::new(true, @lib.HeapType::new(target_type_idx)),
  )
  let target_type = @lib.RecType::new(
    @lib.SubType::comp_type(
      @lib.CompType::func([@lib.ValType::i32()], [@lib.ValType::i32()]),
    ),
  )
  let arg_type = @lib.RecType::new(
    @lib.SubType::comp_type(@lib.CompType::func([], [@lib.ValType::i32()])),
  )
  let caller_type = @lib.RecType::new(
    @lib.SubType::comp_type(@lib.CompType::func([], [@lib.ValType::i32()])),
  )
  let pure_null_target = fn() {
    @lib.Instruction::block(
      @lib.BlockType::val_type(target_ref),
      @lib.Expr::new([
        @lib.Instruction::ref_null(@lib.HeapType::new(target_type_idx)),
      ]),
    )
  }
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(@lib.TypeSec::new([target_type, arg_type, caller_type]))
    .with_func_sec(
      @lib.FuncSec::new([arg_type_idx, caller_type_idx, caller_type_idx]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(7))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            pure_null_target(),
            @lib.Instruction::call_ref(target_type_idx),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            pure_null_target(),
            @lib.Instruction::return_call_ref(target_type_idx),
          ]),
        ),
      ]),
    ),
  )
  let caller = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  let tail = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_true(caller.contains("call (Func 0)"), msg=caller)
  assert_true(caller.contains("unreachable"), msg=caller)
  assert_false(caller.contains("call_ref"), msg=caller)
  assert_false(caller.contains("ref.null"), msg=caller)
  assert_true(tail.contains("call (Func 0)"), msg=tail)
  assert_true(tail.contains("unreachable"), msg=tail)
  assert_false(tail.contains("return_call_ref"), msg=tail)
  assert_false(tail.contains("ref.null"), msg=tail)
}

///|
test "optimize-instructions replaces effectful fallthrough-null call_ref targets preserving target effects" {
  // OI-H call_ref null-trap target-effect slice: Binaryen version_130
  // `trapOnNull` uses `getFallthrough(curr->target)` and then
  // `getDroppedChildrenAndAppend`, which preserves source-order argument
  // effects and then drops an effectful block target before the replacement
  // `unreachable`. This covers the narrow no-branch block-target fact; broader
  // control/EH target localization remains a documented boundary.
  let target_type_idx = @lib.TypeIdx::new(0U)
  let arg_type_idx = @lib.TypeIdx::new(1U)
  let effect_type_idx = @lib.TypeIdx::new(2U)
  let caller_type_idx = @lib.TypeIdx::new(3U)
  let target_ref = @lib.ValType::ref_type(
    @lib.RefType::new(true, @lib.HeapType::new(target_type_idx)),
  )
  let target_type = @lib.RecType::new(
    @lib.SubType::comp_type(
      @lib.CompType::func([@lib.ValType::i32()], [@lib.ValType::i32()]),
    ),
  )
  let arg_type = @lib.RecType::new(
    @lib.SubType::comp_type(@lib.CompType::func([], [@lib.ValType::i32()])),
  )
  let effect_type = @lib.RecType::new(
    @lib.SubType::comp_type(@lib.CompType::func([], [])),
  )
  let caller_type = @lib.RecType::new(
    @lib.SubType::comp_type(@lib.CompType::func([], [@lib.ValType::i32()])),
  )
  let effectful_null_target = fn() {
    @lib.Instruction::block(
      @lib.BlockType::val_type(target_ref),
      @lib.Expr::new([
        @lib.Instruction::call(@lib.FuncIdx::new(1U)),
        @lib.Instruction::ref_null(@lib.HeapType::new(target_type_idx)),
      ]),
    )
  }
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([target_type, arg_type, effect_type, caller_type]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        arg_type_idx, effect_type_idx, caller_type_idx, caller_type_idx,
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(7))]),
        ),
        @lib.Func::new(@lib.Locals::empty(), @lib.Expr::new([])),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            effectful_null_target(),
            @lib.Instruction::call_ref(target_type_idx),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            effectful_null_target(),
            @lib.Instruction::return_call_ref(target_type_idx),
          ]),
        ),
      ]),
    ),
  )
  let caller = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  let tail = optimized.pretty_print_func(@lib.FuncIdx::new(3U))
  assert_true(caller.contains("call (Func 0)"), msg=caller)
  assert_true(caller.contains("call (Func 1)"), msg=caller)
  assert_true(caller.contains("unreachable"), msg=caller)
  assert_false(caller.contains("call_ref"), msg=caller)
  assert_true(tail.contains("call (Func 0)"), msg=tail)
  assert_true(tail.contains("call (Func 1)"), msg=tail)
  assert_true(tail.contains("unreachable"), msg=tail)
  assert_false(tail.contains("return_call_ref"), msg=tail)
}

///|
test "optimize-instructions directizes one-sided if fallthrough call_ref targets" {
  // OI-H call_ref fallthrough target fact slice: Binaryen version_130
  // `Properties::getImmediateFallthrough` looks through an `if` only when one
  // side is unreachable, then `visitCallRef` preserves the whole target in a
  // dropped evaluation before emitting a direct call. Keep this as an if-target
  // fallthrough fact, not a broad select/control localizer: two live arms,
  // branch/EH control, target-side locals, and multivalue operands remain open.
  let target_type_idx = @lib.TypeIdx::new(0U)
  let caller_type_idx = @lib.TypeIdx::new(1U)
  let target_type = @lib.RecType::new(
    @lib.SubType::comp_type(@lib.CompType::func([], [@lib.ValType::i32()])),
  )
  let caller_type = @lib.RecType::new(
    @lib.SubType::comp_type(
      @lib.CompType::func([@lib.ValType::i32()], [@lib.ValType::i32()]),
    ),
  )
  let typed_func_ref = @lib.ValType::ref_type(
    @lib.RefType::new(false, @lib.HeapType::new(target_type_idx)),
  )
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(@lib.TypeSec::new([target_type, caller_type]))
    .with_func_sec(
      @lib.FuncSec::new([target_type_idx, caller_type_idx, caller_type_idx]),
    )
    .with_elem_sec(
      @lib.ElemSec::new([
        @lib.Elem::new(
          @lib.ElemMode::declarative(),
          @lib.ElemKind::funcs([@lib.FuncIdx::new(0U)]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(7))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::if_(
              @lib.BlockType::val_type(typed_func_ref),
              [@lib.Instruction::unreachable_()],
              Some([@lib.Instruction::ref_func(@lib.FuncIdx::new(0U))]),
            ),
            @lib.Instruction::call_ref(target_type_idx),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::if_(
              @lib.BlockType::val_type(typed_func_ref),
              [@lib.Instruction::unreachable_()],
              Some([@lib.Instruction::ref_func(@lib.FuncIdx::new(0U))]),
            ),
            @lib.Instruction::return_call_ref(target_type_idx),
          ]),
        ),
      ]),
    ),
  )
  let caller = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  let tail = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_true(caller.contains("drop"), msg=caller)
  assert_true(caller.contains("if"), msg=caller)
  assert_true(caller.contains("call (Func 0)"), msg=caller)
  assert_false(caller.contains("call_ref"), msg=caller)
  assert_true(tail.contains("drop"), msg=tail)
  assert_true(tail.contains("if"), msg=tail)
  assert_true(tail.contains("return_call (Func 0)"), msg=tail)
  assert_false(tail.contains("return_call_ref"), msg=tail)
}

///|
test "optimize-instructions directizes loop fallthrough call_ref targets" {
  // OI-H call_ref fallthrough target fact slice: Binaryen version_130
  // `Properties::getImmediateFallthrough` descends through loop bodies before
  // `visitCallRef` checks whether the final fallthrough is a `ref.func`, then
  // keeps the original loop target as a dropped evaluation before the direct
  // call. This locks loop fallthrough as an explicit fact next to the block/if
  // target facts; branch/EH loop exits and multivalue operands remain open.
  let target_type_idx = @lib.TypeIdx::new(0U)
  let caller_type_idx = @lib.TypeIdx::new(1U)
  let target_type = @lib.RecType::new(
    @lib.SubType::comp_type(@lib.CompType::func([], [@lib.ValType::i32()])),
  )
  let caller_type = @lib.RecType::new(
    @lib.SubType::comp_type(@lib.CompType::func([], [@lib.ValType::i32()])),
  )
  let typed_func_ref = @lib.ValType::ref_type(
    @lib.RefType::new(false, @lib.HeapType::new(target_type_idx)),
  )
  let loop_target = fn() {
    @lib.Instruction::loop_(
      @lib.BlockType::val_type(typed_func_ref),
      @lib.Expr::new([@lib.Instruction::ref_func(@lib.FuncIdx::new(0U))]),
    )
  }
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(@lib.TypeSec::new([target_type, caller_type]))
    .with_func_sec(
      @lib.FuncSec::new([target_type_idx, caller_type_idx, caller_type_idx]),
    )
    .with_elem_sec(
      @lib.ElemSec::new([
        @lib.Elem::new(
          @lib.ElemMode::declarative(),
          @lib.ElemKind::funcs([@lib.FuncIdx::new(0U)]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(7))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            loop_target(),
            @lib.Instruction::call_ref(target_type_idx),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            loop_target(),
            @lib.Instruction::return_call_ref(target_type_idx),
          ]),
        ),
      ]),
    ),
  )
  let caller = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  let tail = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_true(caller.contains("drop"), msg=caller)
  assert_true(caller.contains("loop"), msg=caller)
  assert_true(caller.contains("call (Func 0)"), msg=caller)
  assert_false(caller.contains("call_ref"), msg=caller)
  assert_true(tail.contains("drop"), msg=tail)
  assert_true(tail.contains("loop"), msg=tail)
  assert_true(tail.contains("return_call (Func 0)"), msg=tail)
  assert_false(tail.contains("return_call_ref"), msg=tail)
}

///|
test "optimize-instructions directizes multi-root loop fallthrough call_ref targets" {
  // OI-H call_ref loop fallthrough target fact slice: Binaryen version_130
  // `Properties::getImmediateFallthrough` descends through a loop to its body,
  // and ordinary loop-body sequencing then exposes the final `ref.func` tail.
  // The directization must still preserve the entire multi-root loop target as
  // a dropped evaluation before the direct call / return_call. Branching loop
  // exits, EH, and multivalue operands remain separate source-backed facts.
  let target_type_idx = @lib.TypeIdx::new(0U)
  let caller_type_idx = @lib.TypeIdx::new(1U)
  let target_type = @lib.RecType::new(
    @lib.SubType::comp_type(@lib.CompType::func([], [@lib.ValType::i32()])),
  )
  let caller_type = @lib.RecType::new(
    @lib.SubType::comp_type(@lib.CompType::func([], [@lib.ValType::i32()])),
  )
  let typed_func_ref = @lib.ValType::ref_type(
    @lib.RefType::new(false, @lib.HeapType::new(target_type_idx)),
  )
  let multi_root_loop_target = fn(seed : Int) {
    @lib.Instruction::loop_(
      @lib.BlockType::val_type(typed_func_ref),
      @lib.Expr::new([
        @lib.Instruction::i32_const(@lib.I32(seed)),
        @lib.Instruction::drop(),
        @lib.Instruction::ref_func(@lib.FuncIdx::new(0U)),
      ]),
    )
  }
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(@lib.TypeSec::new([target_type, caller_type]))
    .with_func_sec(
      @lib.FuncSec::new([target_type_idx, caller_type_idx, caller_type_idx]),
    )
    .with_elem_sec(
      @lib.ElemSec::new([
        @lib.Elem::new(
          @lib.ElemMode::declarative(),
          @lib.ElemKind::funcs([@lib.FuncIdx::new(0U)]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(7))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            multi_root_loop_target(42),
            @lib.Instruction::call_ref(target_type_idx),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            multi_root_loop_target(99),
            @lib.Instruction::return_call_ref(target_type_idx),
          ]),
        ),
      ]),
    ),
  )
  let caller = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  let tail = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_true(caller.contains("drop"), msg=caller)
  assert_true(caller.contains("loop"), msg=caller)
  assert_true(caller.contains("call (Func 0)"), msg=caller)
  assert_false(caller.contains("call_ref"), msg=caller)
  assert_true(tail.contains("drop"), msg=tail)
  assert_true(tail.contains("loop"), msg=tail)
  assert_true(tail.contains("return_call (Func 0)"), msg=tail)
  assert_false(tail.contains("return_call_ref"), msg=tail)
}

///|
test "optimize-instructions directizes br_on_null fallthrough call_ref targets" {
  // OI-H call_ref br_on fallthrough target fact slice: Binaryen version_130
  // `Properties::getImmediateFallthrough` descends through `BrOn::ref`, so a
  // target-side `br_on_null` with a direct `ref.func` input still directizes
  // while preserving the whole branch target as the dropped pre-call
  // evaluation. This is a BrOn fallthrough-target fact, not a general
  // ChildLocalizer/control/EH or branch-retargeting claim.
  let target_type_idx = @lib.TypeIdx::new(0U)
  let caller_type_idx = @lib.TypeIdx::new(1U)
  let target_type = @lib.RecType::new(
    @lib.SubType::comp_type(@lib.CompType::func([], [@lib.ValType::i32()])),
  )
  let caller_type = @lib.RecType::new(
    @lib.SubType::comp_type(@lib.CompType::func([], [@lib.ValType::i32()])),
  )
  let module_ = @lib.Module::new()
    .with_type_sec(@lib.TypeSec::new([target_type, caller_type]))
    .with_func_sec(
      @lib.FuncSec::new([target_type_idx, caller_type_idx, caller_type_idx]),
    )
    .with_elem_sec(
      @lib.ElemSec::new([
        @lib.Elem::new(
          @lib.ElemMode::declarative(),
          @lib.ElemKind::funcs([@lib.FuncIdx::new(0U)]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(7))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::ref_func(@lib.FuncIdx::new(0U)),
            @lib.Instruction::call_ref(target_type_idx),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::ref_func(@lib.FuncIdx::new(0U)),
            @lib.Instruction::return_call_ref(target_type_idx),
          ]),
        ),
      ]),
    )
  let rewrite_target_to_br_on_null = fn(func : @ir.HotFunc, root : Int) {
    let ref_func = @ir.hot_child_get(func, root, 0)
    let branch_target = @ir.hot_control_node_label(
      func,
      @ir.hot_build_block(func, @lib.BlockType::void_(), []),
    )
    let br_on_null = @ir.hot_build_node(
      func,
      @ir.HotOp::br_on_null(),
      @ir.hot_node_type(func, ref_func),
      imm0=branch_target,
      children=[ref_func],
    )
    @ir.hot_child_set(func, root, 0, br_on_null)
  }
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::final_module_only(),
    false,
    fn(_) { () },
  )
  let call_ref_func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(1U))
  let call_ref = @ir.hot_root_get(call_ref_func, 0)
  rewrite_target_to_br_on_null(call_ref_func, call_ref)
  match hot_pass_run(ctx, call_ref_func) {
    Ok(_) => ()
    Err(err) =>
      fail("expected br_on_null call_ref target fact success, got \{err}")
  }
  match @ir.hot_node_get(call_ref_func, @ir.hot_root_get(call_ref_func, 0)).op {
    @ir.HotOp::Block => ()
    other =>
      fail(
        "expected br_on_null call_ref target to become block+call, got \{other}",
      )
  }
  let call_ref_body = @ir.hot_region_body_ref(
    call_ref_func,
    @ir.hot_root_get(call_ref_func, 0),
  )
  @debug.assert_eq(@ir.hot_region_root_count(call_ref_func, call_ref_body), 2)
  match
    @ir.hot_node_get(
      call_ref_func,
      @ir.hot_region_get(call_ref_func, call_ref_body, 1),
    ).op {
    @ir.HotOp::Call => ()
    other =>
      fail("expected direct call after dropped br_on_null target, got \{other}")
  }

  let return_call_ref_func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(2U))
  let return_call_ref = @ir.hot_root_get(return_call_ref_func, 0)
  rewrite_target_to_br_on_null(return_call_ref_func, return_call_ref)
  match hot_pass_run(ctx, return_call_ref_func) {
    Ok(_) => ()
    Err(err) =>
      fail(
        "expected br_on_null return_call_ref target fact success, got \{err}",
      )
  }
  match
    @ir.hot_node_get(
      return_call_ref_func,
      @ir.hot_root_get(return_call_ref_func, 0),
    ).op {
    @ir.HotOp::Block => ()
    other =>
      fail(
        "expected br_on_null return_call_ref target to become block+return_call, got \{other}",
      )
  }
  let return_body = @ir.hot_region_body_ref(
    return_call_ref_func,
    @ir.hot_root_get(return_call_ref_func, 0),
  )
  @debug.assert_eq(
    @ir.hot_region_root_count(return_call_ref_func, return_body),
    2,
  )
  match
    @ir.hot_node_get(
      return_call_ref_func,
      @ir.hot_region_get(return_call_ref_func, return_body, 1),
    ).op {
    @ir.HotOp::ReturnCall => ()
    other =>
      fail("expected return_call after dropped br_on_null target, got \{other}")
  }
}

///|
test "optimize-instructions directizes br_on_non_null and cast fallthrough call_ref targets" {
  // Structure-only OI-H BrOn fallthrough-target coverage: the preceding slice
  // implemented the Binaryen v130 `Properties::getImmediateFallthrough`
  // `BrOn::ref` fact for every represented `br_on_*` opcode. This regression
  // guard locks the non-null/cast/fail siblings without widening beyond the
  // existing target-drop semantics or claiming ChildLocalizer/control/EH repair.
  let target_type_idx = @lib.TypeIdx::new(0U)
  let caller_type_idx = @lib.TypeIdx::new(1U)
  let target_heap = @lib.HeapType::new(target_type_idx)
  let typed_func_ref = @lib.ValType::ref_type(
    @lib.RefType::new(false, target_heap),
  )
  let target_type = @lib.RecType::new(
    @lib.SubType::comp_type(@lib.CompType::func([], [@lib.ValType::i32()])),
  )
  let caller_type = @lib.RecType::new(
    @lib.SubType::comp_type(@lib.CompType::func([], [@lib.ValType::i32()])),
  )
  let module_ = @lib.Module::new()
    .with_type_sec(@lib.TypeSec::new([target_type, caller_type]))
    .with_func_sec(@lib.FuncSec::new([target_type_idx, caller_type_idx]))
    .with_elem_sec(
      @lib.ElemSec::new([
        @lib.Elem::new(
          @lib.ElemMode::declarative(),
          @lib.ElemKind::funcs([@lib.FuncIdx::new(0U)]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(7))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::ref_func(@lib.FuncIdx::new(0U)),
            @lib.Instruction::call_ref(target_type_idx),
          ]),
        ),
      ]),
    )
  let rewrite_target_to_br_on = fn(func : @ir.HotFunc, root : Int, kind : Int) {
    let ref_func = @ir.hot_child_get(func, root, 0)
    let branch_target = @ir.hot_control_node_label(
      func,
      @ir.hot_build_block(func, @lib.BlockType::val_type(typed_func_ref), []),
    )
    let hot_op = if kind == 0 {
      @ir.HotOp::br_on_non_null()
    } else if kind == 1 {
      @ir.HotOp::br_on_cast()
    } else {
      @ir.HotOp::br_on_cast_fail()
    }
    let payload_id = if kind == 1 {
      @ir.hot_alloc_instr_payload(
        func,
        @ir.HotInstrPayload::new(
          @lib.Instruction::br_on_cast(
            @lib.LabelIdx::new(0U),
            false,
            target_heap,
            false,
            target_heap,
          ),
        ),
      )
    } else if kind == 2 {
      @ir.hot_alloc_instr_payload(
        func,
        @ir.HotInstrPayload::new(
          @lib.Instruction::br_on_cast_fail(
            @lib.LabelIdx::new(0U),
            false,
            target_heap,
            false,
            target_heap,
          ),
        ),
      )
    } else {
      0
    }
    let branch = @ir.hot_build_node(
      func,
      hot_op,
      @ir.hot_node_type(func, ref_func),
      imm0=branch_target,
      imm1=payload_id,
      children=[ref_func],
    )
    @ir.hot_child_set(func, root, 0, branch)
  }
  let assert_directized = fn(kind : Int, name : String) raise {
    let func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(1U))
    let root = @ir.hot_root_get(func, 0)
    rewrite_target_to_br_on(func, root, kind)
    let ctx = HotPassContext::new(
      optimize_instructions_descriptor(),
      @ir.HotAnalysisCache::new(),
      HotPipelineVerifyPolicy::final_module_only(),
      false,
      fn(_) { () },
    )
    match hot_pass_run(ctx, func) {
      Ok(_) => ()
      Err(err) =>
        fail("expected \{name} call_ref target fact success, got \{err}")
    }
    let result_root = @ir.hot_root_get(func, 0)
    match @ir.hot_node_get(func, result_root).op {
      @ir.HotOp::Block => ()
      other =>
        fail("expected \{name} target to become block+call, got \{other}")
    }
    let body = @ir.hot_region_body_ref(func, result_root)
    @debug.assert_eq(@ir.hot_region_root_count(func, body), 2)
    match @ir.hot_node_get(func, @ir.hot_region_get(func, body, 1)).op {
      @ir.HotOp::Call => ()
      other =>
        fail("expected direct call after dropped \{name} target, got \{other}")
    }
  }
  assert_directized(0, "br_on_non_null")
  assert_directized(1, "br_on_cast")
  assert_directized(2, "br_on_cast_fail")
}

///|
test "optimize-instructions lowers select ref.func call_ref targets to direct if calls" {
  let target_type_idx = @lib.TypeIdx::new(0U)
  let caller_type_idx = @lib.TypeIdx::new(1U)
  let target_type = @lib.RecType::new(
    @lib.SubType::comp_type(@lib.CompType::func([], [@lib.ValType::i32()])),
  )
  let caller_type = @lib.RecType::new(
    @lib.SubType::comp_type(
      @lib.CompType::func([@lib.ValType::i32()], [@lib.ValType::i32()]),
    ),
  )
  let typed_func_ref = @lib.ValType::ref_type(
    @lib.RefType::new(false, @lib.HeapType::new(target_type_idx)),
  )
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(@lib.TypeSec::new([target_type, caller_type]))
    .with_func_sec(
      @lib.FuncSec::new([
        target_type_idx, target_type_idx, caller_type_idx, caller_type_idx,
      ]),
    )
    .with_elem_sec(
      @lib.ElemSec::new([
        @lib.Elem::new(
          @lib.ElemMode::declarative(),
          @lib.ElemKind::funcs([@lib.FuncIdx::new(0U), @lib.FuncIdx::new(1U)]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(10))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(20))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::ref_func(@lib.FuncIdx::new(0U)),
            @lib.Instruction::ref_func(@lib.FuncIdx::new(1U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::select(types=Some([typed_func_ref])),
            @lib.Instruction::call_ref(target_type_idx),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::ref_func(@lib.FuncIdx::new(0U)),
            @lib.Instruction::ref_func(@lib.FuncIdx::new(1U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::select(types=Some([typed_func_ref])),
            @lib.Instruction::return_call_ref(target_type_idx),
          ]),
        ),
      ]),
    ),
  )
  let caller = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  let tail = optimized.pretty_print_func(@lib.FuncIdx::new(3U))
  assert_true(caller.contains("if"), msg=caller)
  assert_true(caller.contains("call (Func 0)"), msg=caller)
  assert_true(caller.contains("call (Func 1)"), msg=caller)
  assert_false(caller.contains("call_ref"), msg=caller)
  assert_false(caller.contains("select"), msg=caller)
  assert_false(caller.contains("ref.func"), msg=caller)
  assert_true(tail.contains("if"), msg=tail)
  assert_true(tail.contains("return_call (Func 0)"), msg=tail)
  assert_true(tail.contains("return_call (Func 1)"), msg=tail)
  assert_false(tail.contains("return_call_ref"), msg=tail)
  assert_false(tail.contains("select"), msg=tail)
  assert_false(tail.contains("ref.func"), msg=tail)
}

///|
test "optimize-instructions collapses same-target select call_ref facts to one direct call" {
  // OI-H call_ref select-target fact slice: Binaryen version_130's
  // `CallUtils::convertToDirectCalls` can collapse a select whose known arms are
  // the same `ref.func` to one direct call. Keep same-target select as its own
  // fact instead of broadening the two-arm-if directization path or adding a
  // visitor-local condition scanner; effectful conditions remain a separate
  // ChildLocalizer/order-sensitive widening.
  let target_type_idx = @lib.TypeIdx::new(0U)
  let caller_type_idx = @lib.TypeIdx::new(1U)
  let target_type = @lib.RecType::new(
    @lib.SubType::comp_type(
      @lib.CompType::func([@lib.ValType::i32()], [@lib.ValType::i32()]),
    ),
  )
  let caller_type = @lib.RecType::new(
    @lib.SubType::comp_type(
      @lib.CompType::func([@lib.ValType::i32()], [@lib.ValType::i32()]),
    ),
  )
  let typed_func_ref = @lib.ValType::ref_type(
    @lib.RefType::new(false, @lib.HeapType::new(target_type_idx)),
  )
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(@lib.TypeSec::new([target_type, caller_type]))
    .with_func_sec(@lib.FuncSec::new([target_type_idx, caller_type_idx]))
    .with_elem_sec(
      @lib.ElemSec::new([
        @lib.Elem::new(
          @lib.ElemMode::declarative(),
          @lib.ElemKind::funcs([@lib.FuncIdx::new(0U)]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::local_get(@lib.LocalIdx::new(0U))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_func(@lib.FuncIdx::new(0U)),
            @lib.Instruction::ref_func(@lib.FuncIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::select(types=Some([typed_func_ref])),
            @lib.Instruction::call_ref(target_type_idx),
          ]),
        ),
      ]),
    ),
  )
  let caller = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_true(caller.contains("call (Func 0)"), msg=caller)
  assert_false(caller.contains("if"), msg=caller)
  assert_false(caller.contains("drop"), msg=caller)
  assert_false(caller.contains("local.set"), msg=caller)
  assert_false(caller.contains("call_ref"), msg=caller)
  assert_false(caller.contains("select"), msg=caller)
  assert_false(caller.contains("ref.func"), msg=caller)
}

///|
test "optimize-instructions preserves same-target select call_ref effectful condition facts" {
  // OI-H call_ref same-target select condition fact: Binaryen version_130
  // `CallUtils::convertToDirectCalls` collapses identical select target arms to a
  // single direct call while preserving the select condition in the original
  // target-evaluation slot. Keep the condition as a fact with an explicit i32
  // guard instead of a visitor-local side-effect scanner; nested select arms,
  // control/EH, and multivalue operands remain separate localization work.
  let effect_type_idx = @lib.TypeIdx::new(0U)
  let target_type_idx = @lib.TypeIdx::new(1U)
  let caller_type_idx = @lib.TypeIdx::new(2U)
  let effect_type = @lib.RecType::new(
    @lib.SubType::comp_type(@lib.CompType::func([], [@lib.ValType::i32()])),
  )
  let target_type = @lib.RecType::new(
    @lib.SubType::comp_type(
      @lib.CompType::func([@lib.ValType::i32()], [@lib.ValType::i32()]),
    ),
  )
  let caller_type = @lib.RecType::new(
    @lib.SubType::comp_type(
      @lib.CompType::func([@lib.ValType::i32()], [@lib.ValType::i32()]),
    ),
  )
  let typed_func_ref = @lib.ValType::ref_type(
    @lib.RefType::new(false, @lib.HeapType::new(target_type_idx)),
  )
  let module_ = @lib.Module::new()
    .with_type_sec(@lib.TypeSec::new([effect_type, target_type, caller_type]))
    .with_import_sec(
      @lib.ImportSec::new([
        @lib.Import::new(
          @lib.Name::from_string("m"),
          @lib.Name::from_string("effect"),
          @lib.ExternType::func(effect_type_idx),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([target_type_idx, caller_type_idx]))
    .with_elem_sec(
      @lib.ElemSec::new([
        @lib.Elem::new(
          @lib.ElemMode::declarative(),
          @lib.ElemKind::funcs([@lib.FuncIdx::new(1U)]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::local_get(@lib.LocalIdx::new(0U))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_func(@lib.FuncIdx::new(1U)),
            @lib.Instruction::ref_func(@lib.FuncIdx::new(1U)),
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::select(types=Some([typed_func_ref])),
            @lib.Instruction::call_ref(target_type_idx),
          ]),
        ),
      ]),
    )
  let func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(2U))
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::final_module_only(),
    false,
    fn(_) { () },
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) =>
      fail("expected effectful select call_ref fact success, got \{err}")
  }
  let root = @ir.hot_root_get(func, 0)
  let root_node = @ir.hot_node_get(func, root)
  match root_node.op {
    @ir.HotOp::Call => @debug.assert_eq(root_node.imm0, 1)
    other =>
      fail("expected same-target select call_ref to direct call, got \{other}")
  }
  @debug.assert_eq(root_node.child_count, 1)
  let interposed_arg = @ir.hot_child_get(func, root, 0)
  match @ir.hot_node_get(func, interposed_arg).op {
    @ir.HotOp::Block => ()
    other =>
      fail("expected condition-preserving last-operand block, got \{other}")
  }
  let body = @ir.hot_region_body_ref(func, interposed_arg)
  @debug.assert_eq(@ir.hot_region_root_count(func, body), 3)
  let target_drop = @ir.hot_region_get(func, body, 1)
  match @ir.hot_node_get(func, target_drop).op {
    @ir.HotOp::Drop => ()
    other =>
      fail(
        "expected effectful target-evaluation drop before reloaded operand, got \{other}",
      )
  }
  let target_residue = @ir.hot_child_get(func, target_drop, 0)
  match @ir.hot_node_get(func, target_residue).op {
    @ir.HotOp::Block => ()
    other => fail("expected dropped select-target residue block, got \{other}")
  }
  let target_residue_body = @ir.hot_region_body_ref(func, target_residue)
  @debug.assert_eq(@ir.hot_region_root_count(func, target_residue_body), 2)
  match
    @ir.hot_node_get(func, @ir.hot_region_get(func, target_residue_body, 1)).op {
    @ir.HotOp::RefFunc => ()
    other => fail("expected same-target ref.func residue, got \{other}")
  }
}

///|
test "optimize-instructions directizes select call_ref targets through arm wrapper facts" {
  // OI-H call_ref select-arm fact slice: Binaryen version_130 visits child
  // wrappers before `CallUtils::convertToDirectCalls`, so no-op non-null checks
  // around `ref.func` arms expose direct arms to the select classifier. This
  // locks wrapper arm classification as a fact instead of broadening the mixed
  // known/unknown select family; same-heap cast arms are covered separately.
  let target_type_idx = @lib.TypeIdx::new(0U)
  let caller_type_idx = @lib.TypeIdx::new(1U)
  let target_type = @lib.RecType::new(
    @lib.SubType::comp_type(@lib.CompType::func([], [@lib.ValType::i32()])),
  )
  let caller_type = @lib.RecType::new(
    @lib.SubType::comp_type(
      @lib.CompType::func([@lib.ValType::i32()], [@lib.ValType::i32()]),
    ),
  )
  let typed_func_ref = @lib.ValType::ref_type(
    @lib.RefType::new(false, @lib.HeapType::new(target_type_idx)),
  )
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(@lib.TypeSec::new([target_type, caller_type]))
    .with_func_sec(
      @lib.FuncSec::new([target_type_idx, target_type_idx, caller_type_idx]),
    )
    .with_elem_sec(
      @lib.ElemSec::new([
        @lib.Elem::new(
          @lib.ElemMode::declarative(),
          @lib.ElemKind::funcs([@lib.FuncIdx::new(0U), @lib.FuncIdx::new(1U)]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(10))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(20))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::ref_func(@lib.FuncIdx::new(0U)),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_func(@lib.FuncIdx::new(1U)),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::select(types=Some([typed_func_ref])),
            @lib.Instruction::call_ref(target_type_idx),
          ]),
        ),
      ]),
    ),
  )
  let nonnull_arms = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_true(nonnull_arms.contains("if"), msg=nonnull_arms)
  assert_true(nonnull_arms.contains("call (Func 0)"), msg=nonnull_arms)
  assert_true(nonnull_arms.contains("call (Func 1)"), msg=nonnull_arms)
  assert_false(nonnull_arms.contains("call_ref"), msg=nonnull_arms)
  assert_false(nonnull_arms.contains("select"), msg=nonnull_arms)
  assert_false(nonnull_arms.contains("ref.as_non_null"), msg=nonnull_arms)
}

///|
test "optimize-instructions directizes select call_ref targets through cast arm facts" {
  // OI-H call_ref select-arm fact slice: Binaryen version_130 child visits can
  // erase known-success same-heap `ref.cast` wrappers around direct `ref.func`
  // arms before `CallUtils::convertToDirectCalls`. Keep this to pure arm-local
  // casts and do not admit effectful fallthrough arms or nested selects without
  // a separate ChildLocalizer/control fact.
  let target_type_idx = @lib.TypeIdx::new(0U)
  let caller_type_idx = @lib.TypeIdx::new(1U)
  let target_heap = @lib.HeapType::new(target_type_idx)
  let nullable_target_ref = @lib.RefType::new(true, target_heap)
  let select_type = @lib.ValType::ref_type(nullable_target_ref)
  let target_type = @lib.RecType::new(
    @lib.SubType::comp_type(@lib.CompType::func([], [@lib.ValType::i32()])),
  )
  let caller_type = @lib.RecType::new(
    @lib.SubType::comp_type(
      @lib.CompType::func([@lib.ValType::i32()], [@lib.ValType::i32()]),
    ),
  )
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(@lib.TypeSec::new([target_type, caller_type]))
    .with_func_sec(
      @lib.FuncSec::new([target_type_idx, target_type_idx, caller_type_idx]),
    )
    .with_elem_sec(
      @lib.ElemSec::new([
        @lib.Elem::new(
          @lib.ElemMode::declarative(),
          @lib.ElemKind::funcs([@lib.FuncIdx::new(0U), @lib.FuncIdx::new(1U)]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(10))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(20))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::ref_func(@lib.FuncIdx::new(0U)),
            @lib.Instruction::ref_cast_type(nullable_target_ref),
            @lib.Instruction::ref_func(@lib.FuncIdx::new(1U)),
            @lib.Instruction::ref_cast_type(nullable_target_ref),
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::select(types=Some([select_type])),
            @lib.Instruction::call_ref(target_type_idx),
          ]),
        ),
      ]),
    ),
  )
  let cast_arms = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_true(cast_arms.contains("if"), msg=cast_arms)
  assert_true(cast_arms.contains("call (Func 0)"), msg=cast_arms)
  assert_true(cast_arms.contains("call (Func 1)"), msg=cast_arms)
  assert_false(cast_arms.contains("call_ref"), msg=cast_arms)
  assert_false(cast_arms.contains("select"), msg=cast_arms)
  assert_false(cast_arms.contains("ref.cast"), msg=cast_arms)
}

///|
test "optimize-instructions localizes argument select call_ref targets before direct calls" {
  let target_type_idx = @lib.TypeIdx::new(0U)
  let caller_type_idx = @lib.TypeIdx::new(1U)
  let target_type = @lib.RecType::new(
    @lib.SubType::comp_type(
      @lib.CompType::func([@lib.ValType::i32()], [@lib.ValType::i32()]),
    ),
  )
  let caller_type = @lib.RecType::new(
    @lib.SubType::comp_type(
      @lib.CompType::func([@lib.ValType::i32(), @lib.ValType::i32()], [
        @lib.ValType::i32(),
      ]),
    ),
  )
  let typed_func_ref = @lib.ValType::ref_type(
    @lib.RefType::new(false, @lib.HeapType::new(target_type_idx)),
  )
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(@lib.TypeSec::new([target_type, caller_type]))
    .with_func_sec(
      @lib.FuncSec::new([
        target_type_idx, target_type_idx, caller_type_idx, caller_type_idx,
      ]),
    )
    .with_elem_sec(
      @lib.ElemSec::new([
        @lib.Elem::new(
          @lib.ElemMode::declarative(),
          @lib.ElemKind::funcs([@lib.FuncIdx::new(0U), @lib.FuncIdx::new(1U)]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::local_get(@lib.LocalIdx::new(0U))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::i32_add(),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_func(@lib.FuncIdx::new(0U)),
            @lib.Instruction::ref_func(@lib.FuncIdx::new(1U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
            @lib.Instruction::select(types=Some([typed_func_ref])),
            @lib.Instruction::call_ref(target_type_idx),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_func(@lib.FuncIdx::new(0U)),
            @lib.Instruction::ref_func(@lib.FuncIdx::new(1U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
            @lib.Instruction::select(types=Some([typed_func_ref])),
            @lib.Instruction::return_call_ref(target_type_idx),
          ]),
        ),
      ]),
    ),
  )
  let caller = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  let tail = optimized.pretty_print_func(@lib.FuncIdx::new(3U))
  assert_true(caller.contains("local.set"), msg=caller)
  assert_true(caller.contains("local.get"), msg=caller)
  assert_true(caller.contains("if"), msg=caller)
  assert_true(caller.contains("call (Func 0)"), msg=caller)
  assert_true(caller.contains("call (Func 1)"), msg=caller)
  assert_false(caller.contains("call_ref"), msg=caller)
  assert_false(caller.contains("select"), msg=caller)
  assert_false(caller.contains("ref.func"), msg=caller)
  assert_true(tail.contains("local.set"), msg=tail)
  assert_true(tail.contains("local.get"), msg=tail)
  assert_true(tail.contains("if"), msg=tail)
  assert_true(tail.contains("return_call (Func 0)"), msg=tail)
  assert_true(tail.contains("return_call (Func 1)"), msg=tail)
  assert_false(tail.contains("return_call_ref"), msg=tail)
  assert_false(tail.contains("select"), msg=tail)
  assert_false(tail.contains("ref.func"), msg=tail)
}

///|
test "optimize-instructions intentionally keeps multi-result argument select call_ref boundary" {
  // Boundary-only OI-H classification: Binaryen `version_130`
  // localizes a multi-result argument producer through tuple scratch plus scalar
  // temps before lowering select-of-`ref.func` call_ref / return_call_ref to a
  // direct-call if (`.tmp/oi-h-multivalue-arg-select-probe.wat` and
  // `.tmp/oi-h-multivalue-arg-select-return-probe.wat`). Starshine's current
  // call_ref localizer only proves scalar single-result call arguments, so this
  // public fixture keeps call_ref forms instead of hiding the broader
  // multivalue localization gap as parity.
  let target_type_idx = @lib.TypeIdx::new(0U)
  let pair_type_idx = @lib.TypeIdx::new(1U)
  let caller_type_idx = @lib.TypeIdx::new(2U)
  let target_type = @lib.RecType::new(
    @lib.SubType::comp_type(
      @lib.CompType::func([@lib.ValType::i32(), @lib.ValType::i32()], [
        @lib.ValType::i32(),
      ]),
    ),
  )
  let pair_type = @lib.RecType::new(
    @lib.SubType::comp_type(
      @lib.CompType::func([], [@lib.ValType::i32(), @lib.ValType::i32()]),
    ),
  )
  let caller_type = @lib.RecType::new(
    @lib.SubType::comp_type(
      @lib.CompType::func([@lib.ValType::i32()], [@lib.ValType::i32()]),
    ),
  )
  let typed_func_ref = @lib.ValType::ref_type(
    @lib.RefType::new(false, @lib.HeapType::new(target_type_idx)),
  )
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(@lib.TypeSec::new([target_type, pair_type, caller_type]))
    .with_func_sec(
      @lib.FuncSec::new([
        target_type_idx, target_type_idx, pair_type_idx, caller_type_idx, caller_type_idx,
      ]),
    )
    .with_elem_sec(
      @lib.ElemSec::new([
        @lib.Elem::new(
          @lib.ElemMode::declarative(),
          @lib.ElemKind::funcs([@lib.FuncIdx::new(0U), @lib.FuncIdx::new(1U)]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::local_get(@lib.LocalIdx::new(0U))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::local_get(@lib.LocalIdx::new(1U))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::i32_const(@lib.I32(2)),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(2U)),
            @lib.Instruction::ref_func(@lib.FuncIdx::new(0U)),
            @lib.Instruction::ref_func(@lib.FuncIdx::new(1U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::select(types=Some([typed_func_ref])),
            @lib.Instruction::call_ref(target_type_idx),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(2U)),
            @lib.Instruction::ref_func(@lib.FuncIdx::new(0U)),
            @lib.Instruction::ref_func(@lib.FuncIdx::new(1U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::select(types=Some([typed_func_ref])),
            @lib.Instruction::return_call_ref(target_type_idx),
          ]),
        ),
      ]),
    ),
  )
  let caller = optimized.pretty_print_func(@lib.FuncIdx::new(3U))
  assert_true(caller.contains("call_ref"), msg=caller)
  assert_true(caller.contains("select"), msg=caller)
  assert_true(caller.contains("ref.func"), msg=caller)
  assert_true(caller.contains("call (Func 2)"), msg=caller)
  assert_false(caller.contains("call (Func 0)"), msg=caller)
  assert_false(caller.contains("call (Func 1)"), msg=caller)
  let tail = optimized.pretty_print_func(@lib.FuncIdx::new(4U))
  assert_true(tail.contains("return_call_ref"), msg=tail)
  assert_true(tail.contains("select"), msg=tail)
  assert_true(tail.contains("ref.func"), msg=tail)
  assert_true(tail.contains("call (Func 2)"), msg=tail)
  assert_false(tail.contains("return_call (Func 0)"), msg=tail)
  assert_false(tail.contains("return_call (Func 1)"), msg=tail)
}

///|
test "optimize-instructions intentionally keeps select call_ref when an arm is not direct ref.func" {
  let target_type_idx = @lib.TypeIdx::new(0U)
  let caller_type_idx = @lib.TypeIdx::new(1U)
  let target_type = @lib.RecType::new(
    @lib.SubType::comp_type(
      @lib.CompType::func([@lib.ValType::i32()], [@lib.ValType::i32()]),
    ),
  )
  let caller_type = @lib.RecType::new(
    @lib.SubType::comp_type(
      @lib.CompType::func([@lib.ValType::i32(), @lib.ValType::i32()], [
        @lib.ValType::i32(),
      ]),
    ),
  )
  let nullable_func_ref = @lib.RefType::new(
    true,
    @lib.HeapType::new(target_type_idx),
  )
  let typed_func_ref = @lib.ValType::ref_type(nullable_func_ref)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(@lib.TypeSec::new([target_type, caller_type]))
    .with_func_sec(
      @lib.FuncSec::new([target_type_idx, target_type_idx, caller_type_idx]),
    )
    .with_table_sec(
      @lib.TableSec::new([
        @lib.Table::new(
          @lib.TableType::new(nullable_func_ref, @lib.Limits::i32(1U, Some(1U))),
          None,
        ),
      ]),
    )
    .with_elem_sec(
      @lib.ElemSec::new([
        @lib.Elem::new(
          @lib.ElemMode::active(
            @lib.TableIdx::new(0U),
            @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
          ),
          @lib.ElemKind::typed_exprs(nullable_func_ref, [
            @lib.Expr::new([@lib.Instruction::ref_func(@lib.FuncIdx::new(1U))]),
          ]),
        ),
        @lib.Elem::new(
          @lib.ElemMode::declarative(),
          @lib.ElemKind::funcs([@lib.FuncIdx::new(0U), @lib.FuncIdx::new(1U)]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::local_get(@lib.LocalIdx::new(0U))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::i32_add(),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_func(@lib.FuncIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::table_get(@lib.TableIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
            @lib.Instruction::select(types=Some([typed_func_ref])),
            @lib.Instruction::call_ref(target_type_idx),
          ]),
        ),
      ]),
    ),
  )
  let caller = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_true(caller.contains("call_ref"), msg=caller)
  assert_true(caller.contains("select"), msg=caller)
  assert_true(caller.contains("table.get"), msg=caller)
  assert_true(caller.contains("ref.func"), msg=caller)
}

///|
test "optimize-instructions localizes argument fallthrough call_ref targets" {
  let target_type_idx = @lib.TypeIdx::new(0U)
  let arg_effect_type_idx = @lib.TypeIdx::new(1U)
  let target_effect_type_idx = @lib.TypeIdx::new(2U)
  let caller_type_idx = @lib.TypeIdx::new(3U)
  let target_type = @lib.RecType::new(
    @lib.SubType::comp_type(
      @lib.CompType::func([@lib.ValType::i32()], [@lib.ValType::i32()]),
    ),
  )
  let arg_effect_type = @lib.RecType::new(
    @lib.SubType::comp_type(@lib.CompType::func([], [@lib.ValType::i32()])),
  )
  let target_effect_type = @lib.RecType::new(
    @lib.SubType::comp_type(@lib.CompType::func([], [])),
  )
  let caller_type = @lib.RecType::new(
    @lib.SubType::comp_type(@lib.CompType::func([], [@lib.ValType::i32()])),
  )
  let typed_func_ref = @lib.ValType::ref_type(
    @lib.RefType::new(false, @lib.HeapType::new(target_type_idx)),
  )
  let effectful_target = fn() {
    @lib.Instruction::block(
      @lib.BlockType::val_type(typed_func_ref),
      @lib.Expr::new([
        @lib.Instruction::call(@lib.FuncIdx::new(2U)),
        @lib.Instruction::ref_func(@lib.FuncIdx::new(0U)),
      ]),
    )
  }
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        target_type, arg_effect_type, target_effect_type, caller_type,
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        target_type_idx, arg_effect_type_idx, target_effect_type_idx, caller_type_idx,
        caller_type_idx,
      ]),
    )
    .with_elem_sec(
      @lib.ElemSec::new([
        @lib.Elem::new(
          @lib.ElemMode::declarative(),
          @lib.ElemKind::funcs([@lib.FuncIdx::new(0U)]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::local_get(@lib.LocalIdx::new(0U))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(7))]),
        ),
        @lib.Func::new(@lib.Locals::empty(), @lib.Expr::new([])),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(1U)),
            effectful_target(),
            @lib.Instruction::call_ref(target_type_idx),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(1U)),
            effectful_target(),
            @lib.Instruction::return_call_ref(target_type_idx),
          ]),
        ),
      ]),
    ),
  )
  let caller = optimized.pretty_print_func(@lib.FuncIdx::new(3U))
  let tail = optimized.pretty_print_func(@lib.FuncIdx::new(4U))
  assert_true(caller.contains("local.set"), msg=caller)
  assert_true(caller.contains("call (Func 0)"), msg=caller)
  assert_true(caller.contains("call (Func 1)"), msg=caller)
  assert_true(caller.contains("call (Func 2)"), msg=caller)
  assert_false(caller.contains("call_ref"), msg=caller)
  assert_true(caller.contains("ref.func"), msg=caller)
  assert_true(tail.contains("local.set"), msg=tail)
  assert_true(tail.contains("return_call (Func 0)"), msg=tail)
  assert_true(tail.contains("call (Func 1)"), msg=tail)
  assert_true(tail.contains("call (Func 2)"), msg=tail)
  assert_false(tail.contains("return_call_ref"), msg=tail)
  assert_true(tail.contains("ref.func"), msg=tail)
}

///|
test "optimize-instructions directizes fallthrough ref.func call_ref targets and preserves target effects" {
  let target_type_idx = @lib.TypeIdx::new(0U)
  let side_type_idx = @lib.TypeIdx::new(1U)
  let caller_type_idx = @lib.TypeIdx::new(2U)
  let target_type = @lib.RecType::new(
    @lib.SubType::comp_type(@lib.CompType::func([], [@lib.ValType::i32()])),
  )
  let side_type = @lib.RecType::new(
    @lib.SubType::comp_type(@lib.CompType::func([@lib.ValType::i32()], [])),
  )
  let caller_type = @lib.RecType::new(
    @lib.SubType::comp_type(
      @lib.CompType::func([@lib.ValType::i32()], [@lib.ValType::i32()]),
    ),
  )
  let typed_func_ref = @lib.ValType::ref_type(
    @lib.RefType::new(false, @lib.HeapType::new(target_type_idx)),
  )
  let effectful_target = fn() {
    @lib.Instruction::block(
      @lib.BlockType::val_type(typed_func_ref),
      @lib.Expr::new([
        @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
        @lib.Instruction::call(@lib.FuncIdx::new(1U)),
        @lib.Instruction::ref_func(@lib.FuncIdx::new(0U)),
      ]),
    )
  }
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(@lib.TypeSec::new([target_type, side_type, caller_type]))
    .with_func_sec(
      @lib.FuncSec::new([
        target_type_idx, side_type_idx, caller_type_idx, caller_type_idx,
      ]),
    )
    .with_elem_sec(
      @lib.ElemSec::new([
        @lib.Elem::new(
          @lib.ElemMode::declarative(),
          @lib.ElemKind::funcs([@lib.FuncIdx::new(0U)]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(42))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::drop(),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            effectful_target(),
            @lib.Instruction::call_ref(target_type_idx),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            effectful_target(),
            @lib.Instruction::return_call_ref(target_type_idx),
          ]),
        ),
      ]),
    ),
  )
  let caller = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  let tail = optimized.pretty_print_func(@lib.FuncIdx::new(3U))
  assert_true(caller.contains("call (Func 1)"), msg=caller)
  assert_true(caller.contains("call (Func 0)"), msg=caller)
  assert_false(caller.contains("call_ref"), msg=caller)
  assert_true(caller.contains("ref.func"), msg=caller)
  assert_true(tail.contains("call (Func 1)"), msg=tail)
  assert_true(tail.contains("return_call (Func 0)"), msg=tail)
  assert_false(tail.contains("return_call_ref"), msg=tail)
  assert_true(tail.contains("ref.func"), msg=tail)
}

///|
test "optimize-instructions lowers table.get call_ref targets to indirect calls" {
  let callee_type_idx = @lib.TypeIdx::new(0U)
  let callee_type = @lib.RecType::new(
    @lib.SubType::comp_type(
      @lib.CompType::func([@lib.ValType::i32()], [@lib.ValType::i32()]),
    ),
  )
  let typed_func_ref = @lib.RefType::new(
    true,
    @lib.HeapType::new(callee_type_idx),
  )
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(@lib.TypeSec::new([callee_type]))
    .with_func_sec(
      @lib.FuncSec::new([callee_type_idx, callee_type_idx, callee_type_idx]),
    )
    .with_table_sec(
      @lib.TableSec::new([
        @lib.Table::new(
          @lib.TableType::new(typed_func_ref, @lib.Limits::i32(1U, Some(1U))),
          None,
        ),
      ]),
    )
    .with_elem_sec(
      @lib.ElemSec::new([
        @lib.Elem::new(
          @lib.ElemMode::active(
            @lib.TableIdx::new(0U),
            @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
          ),
          @lib.ElemKind::typed_exprs(typed_func_ref, [
            @lib.Expr::new([@lib.Instruction::ref_func(@lib.FuncIdx::new(0U))]),
          ]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::local_get(@lib.LocalIdx::new(0U))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::table_get(@lib.TableIdx::new(0U)),
            @lib.Instruction::call_ref(callee_type_idx),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::table_get(@lib.TableIdx::new(0U)),
            @lib.Instruction::return_call_ref(callee_type_idx),
          ]),
        ),
      ]),
    ),
  )
  let caller = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  let tail = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_true(caller.contains("call_indirect (Type 0) (Table 0)"), msg=caller)
  assert_false(caller.contains("call_ref"), msg=caller)
  assert_false(caller.contains("table.get"), msg=caller)
  assert_true(
    tail.contains("return_call_indirect (Type 0) (Table 0)"),
    msg=tail,
  )
  assert_false(tail.contains("return_call_ref"), msg=tail)
  assert_false(tail.contains("table.get"), msg=tail)
}

///|
test "optimize-instructions lowers ref.as_non_null table.get call_ref targets" {
  // OI-H call_ref target skip fact slice: Binaryen version_130 runs
  // `skipNonNullCast(curr->target, curr)` before table-target directization.
  // Because the call_ref target is the final child, removing a top-level
  // `ref.as_non_null` does not cross later sibling effects; the subsequent
  // table-target fact can lower to call_indirect while preserving the null trap
  // through call_indirect. This keeps nullable-child skipping source-backed and
  // limited to the call_ref target slot rather than adding a broad cast scanner.
  let callee_type_idx = @lib.TypeIdx::new(0U)
  let callee_type = @lib.RecType::new(
    @lib.SubType::comp_type(
      @lib.CompType::func([@lib.ValType::i32()], [@lib.ValType::i32()]),
    ),
  )
  let typed_func_ref = @lib.RefType::new(
    true,
    @lib.HeapType::new(callee_type_idx),
  )
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(@lib.TypeSec::new([callee_type]))
    .with_func_sec(
      @lib.FuncSec::new([callee_type_idx, callee_type_idx, callee_type_idx]),
    )
    .with_table_sec(
      @lib.TableSec::new([
        @lib.Table::new(
          @lib.TableType::new(typed_func_ref, @lib.Limits::i32(1U, Some(1U))),
          None,
        ),
      ]),
    )
    .with_elem_sec(
      @lib.ElemSec::new([
        @lib.Elem::new(
          @lib.ElemMode::active(
            @lib.TableIdx::new(0U),
            @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
          ),
          @lib.ElemKind::typed_exprs(typed_func_ref, [
            @lib.Expr::new([@lib.Instruction::ref_func(@lib.FuncIdx::new(0U))]),
          ]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::local_get(@lib.LocalIdx::new(0U))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::table_get(@lib.TableIdx::new(0U)),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::call_ref(callee_type_idx),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::table_get(@lib.TableIdx::new(0U)),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::return_call_ref(callee_type_idx),
          ]),
        ),
      ]),
    ),
  )
  let caller = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  let tail = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_true(caller.contains("call_indirect (Type 0) (Table 0)"), msg=caller)
  assert_false(caller.contains("call_ref"), msg=caller)
  assert_false(caller.contains("ref.as_non_null"), msg=caller)
  assert_false(caller.contains("table.get"), msg=caller)
  assert_true(
    tail.contains("return_call_indirect (Type 0) (Table 0)"),
    msg=tail,
  )
  assert_false(tail.contains("return_call_ref"), msg=tail)
  assert_false(tail.contains("ref.as_non_null"), msg=tail)
  assert_false(tail.contains("table.get"), msg=tail)
}

///|
test "optimize-instructions directizes call-indexed table.get call_ref targets" {
  let callee_type_idx = @lib.TypeIdx::new(0U)
  let index_type_idx = @lib.TypeIdx::new(1U)
  let callee_type = @lib.RecType::new(
    @lib.SubType::comp_type(
      @lib.CompType::func([@lib.ValType::i32()], [@lib.ValType::i32()]),
    ),
  )
  let index_type = @lib.RecType::new(
    @lib.SubType::comp_type(@lib.CompType::func([], [@lib.ValType::i32()])),
  )
  let typed_func_ref = @lib.RefType::new(
    true,
    @lib.HeapType::new(callee_type_idx),
  )
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(@lib.TypeSec::new([callee_type, index_type]))
    .with_import_sec(
      @lib.ImportSec::new([
        @lib.Import::new(
          @lib.Name::from_string("m"),
          @lib.Name::from_string("index"),
          @lib.ExternType::func(index_type_idx),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([callee_type_idx, callee_type_idx, callee_type_idx]),
    )
    .with_table_sec(
      @lib.TableSec::new([
        @lib.Table::new(
          @lib.TableType::new(typed_func_ref, @lib.Limits::i32(1U, Some(1U))),
          None,
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::local_get(@lib.LocalIdx::new(0U))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::table_get(@lib.TableIdx::new(0U)),
            @lib.Instruction::call_ref(callee_type_idx),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::table_get(@lib.TableIdx::new(0U)),
            @lib.Instruction::return_call_ref(callee_type_idx),
          ]),
        ),
      ]),
    ),
  )
  let caller = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  let tail = optimized.pretty_print_func(@lib.FuncIdx::new(3U))
  assert_true(caller.contains("call_indirect (Type 0) (Table 0)"), msg=caller)
  assert_true(caller.contains("call (Func 0)"), msg=caller)
  assert_false(caller.contains("call_ref"), msg=caller)
  assert_false(caller.contains("table.get"), msg=caller)
  assert_true(
    tail.contains("return_call_indirect (Type 0) (Table 0)"),
    msg=tail,
  )
  assert_true(tail.contains("call (Func 0)"), msg=tail)
  assert_false(tail.contains("return_call_ref"), msg=tail)
  assert_false(tail.contains("table.get"), msg=tail)
}

///|
test "optimize-instructions rewrites OI-L struct aggregate atomics and preserves array boundary" {
  // OI-L source-backed Binaryen version_130 subset: direct
  // --optimize-instructions lowers unshared struct aggregate RMW/cmpxchg, folds
  // identity struct RMW and same-value cmpxchg to struct.atomic.get plus dropped
  // operands, and leaves sampled array RMW/cmpxchg unchanged.
  let src =
    #|(module
    #|  (type $S (struct (field (mut i32))))
    #|  (type $A (array (mut i32)))
    #|  (global $gv i32 (i32.const 9))
    #|  (func (param $s (ref $S)) (param $v i32) (result i32)
    #|    (struct.atomic.rmw.add 0 0
    #|      (local.get $s)
    #|      (local.get $v)))
    #|  (func (param $s (ref $S)) (param $v i32) (result i32)
    #|    (struct.atomic.rmw.xchg 0 0
    #|      (local.get $s)
    #|      (local.get $v)))
    #|  (func (param $s (ref $S)) (param $v i32) (result i32)
    #|    (struct.atomic.rmw.sub 0 0
    #|      (local.get $s)
    #|      (local.get $v)))
    #|  (func (param $s (ref $S)) (param $v i32) (result i32)
    #|    (struct.atomic.rmw.and 0 0
    #|      (local.get $s)
    #|      (local.get $v)))
    #|  (func (param $s (ref $S)) (param $v i32) (result i32)
    #|    (struct.atomic.rmw.or 0 0
    #|      (local.get $s)
    #|      (local.get $v)))
    #|  (func (param $s (ref $S)) (param $v i32) (result i32)
    #|    (struct.atomic.rmw.xor 0 0
    #|      (local.get $s)
    #|      (local.get $v)))
    #|  (func (param $s (ref $S)) (result i32)
    #|    (struct.atomic.rmw.add 0 0
    #|      (local.get $s)
    #|      (i32.const 0)))
    #|  (func (param $s (ref $S)) (result i32)
    #|    (struct.atomic.rmw.or 0 0
    #|      (local.get $s)
    #|      (i32.const 0)))
    #|  (func (param $s (ref $S)) (result i32)
    #|    (struct.atomic.rmw.and 0 0
    #|      (local.get $s)
    #|      (i32.const -1)))
    #|  (func (param $s (ref $S)) (result i32)
    #|    (struct.atomic.rmw.cmpxchg 0 0
    #|      (local.get $s)
    #|      (i32.const 7)
    #|      (i32.const 7)))
    #|  (func (param $s (ref $S)) (param $e i32) (result i32)
    #|    (struct.atomic.rmw.cmpxchg 0 0
    #|      (local.get $s)
    #|      (local.get $e)
    #|      (local.get $e)))
    #|  (func (param $s (ref $S)) (result i32)
    #|    (struct.atomic.rmw.cmpxchg 0 0
    #|      (local.get $s)
    #|      (global.get $gv)
    #|      (global.get $gv)))
    #|  (func (param $s (ref $S)) (param $e i32) (param $r i32) (result i32)
    #|    (struct.atomic.rmw.cmpxchg 0 0
    #|      (local.get $s)
    #|      (local.get $e)
    #|      (local.get $r)))
    #|  (func (param $a (ref $A)) (param $i i32) (param $v i32) (result i32)
    #|    (array.atomic.rmw.add 1
    #|      (local.get $a)
    #|      (local.get $i)
    #|      (local.get $v))))
    #|
  let optimized = match pass_test_run_pipeline(src, ["optimize-instructions"]) {
    Ok(mod_) => mod_
    Err(err) => fail("expected OI-L optimize-instructions success, got \{err}")
  }

  let lowered_add = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(lowered_add.contains("struct.atomic.rmw.add"), msg=lowered_add)
  assert_true(lowered_add.contains("struct.get"), msg=lowered_add)
  assert_true(lowered_add.contains("struct.set"), msg=lowered_add)
  assert_true(lowered_add.contains("i32.add"), msg=lowered_add)

  let lowered_xchg = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_false(
    lowered_xchg.contains("struct.atomic.rmw.xchg"),
    msg=lowered_xchg,
  )
  assert_true(lowered_xchg.contains("struct.get"), msg=lowered_xchg)
  assert_true(lowered_xchg.contains("struct.set"), msg=lowered_xchg)

  let lowered_sub = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_false(lowered_sub.contains("struct.atomic.rmw.sub"), msg=lowered_sub)
  assert_true(lowered_sub.contains("struct.get"), msg=lowered_sub)
  assert_true(lowered_sub.contains("struct.set"), msg=lowered_sub)
  assert_true(lowered_sub.contains("i32.sub"), msg=lowered_sub)

  let lowered_and = optimized.pretty_print_func(@lib.FuncIdx::new(3U))
  assert_false(lowered_and.contains("struct.atomic.rmw.and"), msg=lowered_and)
  assert_true(lowered_and.contains("struct.get"), msg=lowered_and)
  assert_true(lowered_and.contains("struct.set"), msg=lowered_and)
  assert_true(lowered_and.contains("i32.and"), msg=lowered_and)

  let lowered_or = optimized.pretty_print_func(@lib.FuncIdx::new(4U))
  assert_false(lowered_or.contains("struct.atomic.rmw.or"), msg=lowered_or)
  assert_true(lowered_or.contains("struct.get"), msg=lowered_or)
  assert_true(lowered_or.contains("struct.set"), msg=lowered_or)
  assert_true(lowered_or.contains("i32.or"), msg=lowered_or)

  let lowered_xor = optimized.pretty_print_func(@lib.FuncIdx::new(5U))
  assert_false(lowered_xor.contains("struct.atomic.rmw.xor"), msg=lowered_xor)
  assert_true(lowered_xor.contains("struct.get"), msg=lowered_xor)
  assert_true(lowered_xor.contains("struct.set"), msg=lowered_xor)
  assert_true(lowered_xor.contains("i32.xor"), msg=lowered_xor)

  for idx = 6; idx <= 11; idx = idx + 1 {
    let pretty = optimized.pretty_print_func(
      @lib.FuncIdx::new(idx.reinterpret_as_uint()),
    )
    assert_false(pretty.contains("struct.atomic.rmw"), msg=pretty)
    assert_true(pretty.contains("struct.atomic.get"), msg=pretty)
    assert_true(pretty.contains("drop"), msg=pretty)
  }

  let lowered_cmpxchg = optimized.pretty_print_func(@lib.FuncIdx::new(12U))
  assert_false(
    lowered_cmpxchg.contains("struct.atomic.rmw.cmpxchg"),
    msg=lowered_cmpxchg,
  )
  assert_true(lowered_cmpxchg.contains("struct.get"), msg=lowered_cmpxchg)
  assert_true(lowered_cmpxchg.contains("struct.set"), msg=lowered_cmpxchg)
  assert_true(lowered_cmpxchg.contains("select"), msg=lowered_cmpxchg)

  let array_boundary = optimized.pretty_print_func(@lib.FuncIdx::new(13U))
  assert_true(
    array_boundary.contains("array.atomic.rmw.add"),
    msg=array_boundary,
  )

  // Binaryen-shaped native probes use global receivers. They must rewrite too;
  // decoding must not leave a trailing unreachable sentinel that collapses the body.
  let global_receiver_src =
    #|(module
    #|  (type $S (struct (field (mut i32))))
    #|  (global $g (ref $S) (struct.new $S (i32.const 7)))
    #|  (func (result i32)
    #|    (struct.atomic.rmw.add 0 0
    #|      (global.get $g)
    #|      (i32.const 1))))
    #|
  let global_receiver = match
    pass_test_run_pipeline(global_receiver_src, ["optimize-instructions"]) {
    Ok(mod_) => mod_.pretty_print_func(@lib.FuncIdx::new(0U))
    Err(err) => fail("expected global receiver fail-closed success, got \{err}")
  }
  assert_false(
    global_receiver.contains("struct.atomic.rmw.add"),
    msg=global_receiver,
  )
  assert_true(global_receiver.contains("struct.get"), msg=global_receiver)
  assert_true(global_receiver.contains("struct.set"), msg=global_receiver)
  assert_true(global_receiver.contains("global.get"), msg=global_receiver)
  assert_false(global_receiver.contains("unreachable"), msg=global_receiver)
}

///|
test "optimize-instructions folds atomic load constant offsets" {
  // OI-G grouped shared-atomic residuals showed Binaryen folding constant
  // atomic load offsets into constant addresses while preserving the atomic
  // operation. RMW/cmpxchg offset policy stays separate because Binaryen keeps
  // the sampled atomic.rmw/cmpxchg offset spelling.
  let func_type = @lib.RecType::new(
    @lib.SubType::comp_type(@lib.CompType::func([], [@lib.ValType::i64()])),
  )
  let input = @lib.Module::new()
    .with_type_sec(@lib.TypeSec::new([func_type]))
    .with_func_sec(@lib.FuncSec::new([@lib.TypeIdx::new(0U)]))
    .with_mem_sec(
      @lib.MemSec::new([
        @lib.MemType::new(@lib.Limits::i32(1U, Some(1U)), shared=true),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(3008)),
            @lib.Instruction::i64_atomic_load(
              @lib.MemArg::new(@lib.U32(3), None, @lib.U64(8UL)),
            ),
          ]),
        ),
      ]),
    )
  let optimized = match
    run_hot_pipeline(input, HotPipelineOptions::new(), ["optimize-instructions"]) {
    Ok(mod_) => mod_
    Err(err) => fail("expected atomic load offset optimize success, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("i64.atomic.load offset=8"), msg=pretty)
  optimize_instructions_assert_strings_in_order(pretty, [
    "I32(3016)", "i64.atomic.load",
  ])
}

///|
test "optimize-instructions folds atomic store constant offsets" {
  // Binaryen folds atomic store constant memarg offsets just like scalar stores
  // and atomic loads, but leaves sampled atomic RMW/cmpxchg offsets unchanged.
  let func_type = @lib.RecType::new(
    @lib.SubType::comp_type(@lib.CompType::func([], [])),
  )
  let input = @lib.Module::new()
    .with_type_sec(@lib.TypeSec::new([func_type]))
    .with_func_sec(@lib.FuncSec::new([@lib.TypeIdx::new(0U)]))
    .with_mem_sec(
      @lib.MemSec::new([
        @lib.MemType::new(@lib.Limits::i32(1U, Some(1U)), shared=true),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(3008)),
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::i32_atomic_store(
              @lib.MemArg::new(@lib.U32(2), None, @lib.U64(8UL)),
            ),
          ]),
        ),
      ]),
    )
  let optimized = match
    run_hot_pipeline(input, HotPipelineOptions::new(), ["optimize-instructions"]) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected atomic store offset optimize success, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("i32.atomic.store offset=8"), msg=pretty)
  optimize_instructions_assert_strings_in_order(pretty, [
    "I32(3016)", "I32(1)", "i32.atomic.store",
  ])
}

///|
test "optimize-instructions expands one-byte memory.copy to load8/store8" {
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func (param $dst i32) (param $src i32)
        #|    local.get $dst
        #|    local.get $src
        #|    i32.const 1
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) => fail("expected memory.copy optimize success, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("memory.copy"), msg=pretty)
  assert_true(pretty.contains("i32.load8u"), msg=pretty)
  assert_true(pretty.contains("i32.store8"), msg=pretty)
}

///|
test "optimize-instructions expands stack-carried effectful tiny memory.copy" {
  let trace : Array[String] = []
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (import "env" "dst" (func $dst (result i32)))
        #|  (import "env" "src" (func $src (result i32)))
        #|  (memory 1)
        #|  (func
        #|    call $dst
        #|    call $src
        #|    i32.const 1
        #|    memory.copy
        #|    call $dst
        #|    call $src
        #|    i32.const 8
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(trace=Some(fn(line) { trace.push(line) })),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected effectful memory.copy optimize success, got \{err}")
  }
  assert_false(
    trace.any(fn(line) {
      line.contains(
        "pass[optimize-instructions]:skip-raw reason=stack-carried-effect-optimize-instructions-noop",
      )
    }),
    msg=trace.to_string(),
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  // Binaryen version_130 lowers these size-1/8 copies to load/store despite the
  // call operands; the store address child is emitted before the nested load,
  // preserving the original dst-call then src-call evaluation order.
  assert_false(pretty.contains("memory.copy"), msg=pretty)
  optimize_instructions_assert_strings_in_order(pretty, [
    "call (Func 0)", "call (Func 1)", "i32.load8u", "i32.store8", "call (Func 0)",
    "call (Func 1)", "i64.load", "i64.store",
  ])
}

///|
test "optimize-instructions expands stack-carried effectful v128 memory.copy" {
  // Coverage/status OI-G classification: Binaryen `version_130`
  // `--optimize-instructions` lowers the exact flat call-backed size-16
  // `memory.copy` shape to one `v128.load` plus one `v128.store`
  // (`.tmp/oi-g-stack-call-memory-copy-16-probe.wat`). Starshine's raw-gate
  // escape already admits this size-16 shape; this test locks the v128 lane and
  // call-order evidence without claiming broader stack-carried localization.
  let trace : Array[String] = []
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (import "env" "dst" (func $dst (result i32)))
        #|  (import "env" "src" (func $src (result i32)))
        #|  (memory 1)
        #|  (func
        #|    call $dst
        #|    call $src
        #|    i32.const 16
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(trace=Some(fn(line) { trace.push(line) })),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected effectful v128 memory.copy optimize success, got \{err}")
  }
  assert_false(
    trace.any(fn(line) {
      line.contains(
        "pass[optimize-instructions]:skip-raw reason=stack-carried-effect-optimize-instructions-noop",
      )
    }),
    msg="expected size-16 stack memory.copy raw escape, trace=\{trace}",
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_false(pretty.contains("memory.copy"), msg=pretty)
  optimize_instructions_assert_strings_in_order(pretty, [
    "call (Func 0)", "call (Func 1)", "v128.load", "v128.store",
  ])
}

///|
test "optimize-instructions keeps size-16 memory.copy at shrink level one" {
  // OI-G tiny memory.copy fact: Binaryen version_130 `optimizeMemoryCopy`
  // lowers the 16-byte SIMD lane only when `shrinkLevel == 0`. At shrink level
  // one, the pass keeps `memory.copy` instead of introducing `v128.load` /
  // `v128.store` (`.tmp/oi-g-copy16-shrink-probe.wat`).
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func (param $dst i32) (param $src i32)
        #|    local.get $dst
        #|    local.get $src
        #|    i32.const 16
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(shrink_level=1),
    ) {
    Ok(mod_) => mod_
    Err(err) => fail("expected shrink-level memory.copy success, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_true(pretty.contains("memory.copy"), msg=pretty)
  assert_false(pretty.contains("v128.load"), msg=pretty)
  assert_false(pretty.contains("v128.store"), msg=pretty)
}

///|
test "optimize-instructions expands stack-carried parameterized tiny memory.copy" {
  let trace : Array[String] = []
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func $dst (param i32) (result i32) local.get 0)
        #|  (func $src (param i32) (result i32) local.get 0)
        #|  (func (param $d i32) (param $s i32)
        #|    local.get $d
        #|    call $dst
        #|    local.get $s
        #|    call $src
        #|    i32.const 1
        #|    memory.copy
        #|    local.get $d
        #|    call $dst
        #|    local.get $s
        #|    call $src
        #|    i32.const 8
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(trace=Some(fn(line) { trace.push(line) })),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected parameterized memory.copy optimize success, got \{err}")
  }
  assert_false(
    trace.any(fn(line) {
      line.contains(
        "pass[optimize-instructions]:skip-raw reason=stack-carried-effect-optimize-instructions-noop",
      )
    }),
    msg="expected parameterized stack memory.copy raw escape, trace=\{trace}",
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  // Binaryen version_130 lowers the same parameterized-call shape
  // (`.tmp/oi-g-parameterized-memory-copy-probe.wat`), so this is a narrow raw
  // gate escape rather than a broad stack-carried/localizing claim.
  assert_false(pretty.contains("memory.copy"), msg=pretty)
  optimize_instructions_assert_strings_in_order(pretty, [
    "(local.get (Local 0))", "call (Func 0)", "(local.get (Local 1))", "call (Func 1)",
    "i32.load8u", "i32.store8", "(local.get (Local 0))", "call (Func 0)", "(local.get (Local 1))",
    "call (Func 1)", "i64.load", "i64.store",
  ])
}

///|
test "optimize-instructions expands stack-carried mixed parameterized tiny memory.copy" {
  let trace : Array[String] = []
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func $dst1 (param i32) (result i32) local.get 0)
        #|  (func $src0 (result i32) i32.const 16)
        #|  (func $dst0 (result i32) i32.const 32)
        #|  (func $src1 (param i32) (result i32) local.get 0)
        #|  (func (param $d i32) (param $s i32)
        #|    local.get $d
        #|    call $dst1
        #|    call $src0
        #|    i32.const 1
        #|    memory.copy
        #|    call $dst0
        #|    local.get $s
        #|    call $src1
        #|    i32.const 8
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(trace=Some(fn(line) { trace.push(line) })),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail(
        "expected mixed parameterized memory.copy optimize success, got \{err}",
      )
  }
  assert_false(
    trace.any(fn(line) {
      line.contains(
        "pass[optimize-instructions]:skip-raw reason=stack-carried-effect-optimize-instructions-noop",
      )
    }),
    msg="expected mixed parameterized stack memory.copy raw escape, trace=\{trace}",
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(4U))
  // Binaryen version_130 lowers the mixed one-arg/no-arg direct-call address
  // shape (`.tmp/oi-g-mixed-parameterized-memory-copy-probe.wat`). This remains
  // a narrow raw-gate escape for pure local/constant unary-call arguments, not a
  // broad stack-carried/localizing claim.
  assert_false(pretty.contains("memory.copy"), msg=pretty)
  optimize_instructions_assert_strings_in_order(pretty, [
    "(local.get (Local 0))", "call (Func 0)", "call (Func 1)", "i32.load8u", "i32.store8",
    "call (Func 2)", "(local.get (Local 1))", "call (Func 3)", "i64.load", "i64.store",
  ])
}

