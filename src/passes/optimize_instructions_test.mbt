///|
test "optimize-instructions folds select with identical pure local-local binary arms" {
  // Red-first OI-F parity slice: Binaryen `version_130`
  // `--optimize-instructions` folds direct identical local/local binary select
  // arms when both arms use the same instruction over the same ordered locals
  // and the condition is side-effect-free
  // (`.tmp/oi-select-identical-local-local-arms-probe.wat`,
  // `.tmp/oi-select-identical-i64-local-local-arms-probe.wat`,
  // `.tmp/oi-select-identical-i64-mul-local-local-arms-probe.wat`,
  // `.tmp/oi-select-identical-i32-mul-local-local-arms-probe.wat`,
  // `.tmp/oi-select-identical-i32-sub-local-local-arms-probe.wat`,
  // `.tmp/oi-select-identical-i64-sub-local-local-arms-probe.wat`,
  // `.tmp/oi-select-identical-i32-bitwise-local-local-arms-probe.wat`,
  // `.tmp/oi-select-identical-i64-bitwise-local-local-arms-probe.wat`,
  // `.tmp/oi-select-identical-shift-rot-local-local-arms-probe.wat`,
  // `.tmp/oi-select-identical-compare-local-local-arms-probe.wat`,
  // `.tmp/oi-select-identical-float-compare-local-local-arms-probe.wat`,
  // `.tmp/oi-select-identical-float-binary-local-local-arms-probe.wat`).
  // This
  // deliberately stays at same-instruction/same-ordered-local binary shells,
  // not commuted operands or arbitrary structural expression equality.
  let func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32 i32) (result i32) (select (i32.add (local.get 0) (local.get 1)) (i32.add (local.get 0) (local.get 1)) (local.get 2))))",
  )
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_exact_instr(func, root) {
    Some(instr) if instr == @lib.Instruction::i32_add() => ()
    _ => fail("expected identical pure i32.add local-local select arms to fold")
  }

  let i32_mul_func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32 i32) (result i32) (select (i32.mul (local.get 0) (local.get 1)) (i32.mul (local.get 0) (local.get 1)) (local.get 2))))",
  )
  let i32_mul_root = @ir.hot_root_get(i32_mul_func, 0)
  match @ir.hot_node_exact_instr(i32_mul_func, i32_mul_root) {
    Some(instr) if instr == @lib.Instruction::i32_mul() => ()
    _ => fail("expected identical pure i32.mul local-local select arms to fold")
  }

  let i32_sub_func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32 i32) (result i32) (select (i32.sub (local.get 0) (local.get 1)) (i32.sub (local.get 0) (local.get 1)) (local.get 2))))",
  )
  let i32_sub_root = @ir.hot_root_get(i32_sub_func, 0)
  match @ir.hot_node_exact_instr(i32_sub_func, i32_sub_root) {
    Some(instr) if instr == @lib.Instruction::i32_sub() => ()
    _ => fail("expected identical pure i32.sub local-local select arms to fold")
  }

  let i32_and_func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32 i32) (result i32) (select (i32.and (local.get 0) (local.get 1)) (i32.and (local.get 0) (local.get 1)) (local.get 2))))",
  )
  let i32_and_root = @ir.hot_root_get(i32_and_func, 0)
  match @ir.hot_node_exact_instr(i32_and_func, i32_and_root) {
