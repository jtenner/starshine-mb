      @debug.assert_eq(arg5, @lib.LocalIdx::new(5U))
      @debug.assert_eq(arg6, @lib.LocalIdx::new(6U))
      @debug.assert_eq(desc_func, @lib.FuncIdx::new(1U))
    }
    _ =>
      fail(
        "expected two ref args; call ref; drop; five desc args; call desc; drop; unreachable",
      )
  }
}

