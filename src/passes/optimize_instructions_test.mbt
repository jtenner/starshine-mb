            @lib.Instruction::i32_const(@lib.I32(128)),
            @lib.Instruction::array_new_fixed(array_i8_type, @lib.U32(2U)),
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::array_get_s(array_i8_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(255)),
            @lib.Instruction::i32_const(@lib.I32(128)),
            @lib.Instruction::array_new_fixed(array_i8_type, @lib.U32(2U)),
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::array_get_u(array_i8_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(65535)),
            @lib.Instruction::i32_const(@lib.I32(32768)),
            @lib.Instruction::array_new_fixed(array_i16_type, @lib.U32(2U)),
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::array_get_s(array_i16_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(65535)),
            @lib.Instruction::i32_const(@lib.I32(32768)),
            @lib.Instruction::array_new_fixed(array_i16_type, @lib.U32(2U)),
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::array_get_u(array_i16_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::array_new_fixed(array_i8_type, @lib.U32(2U)),
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::array_get_s(array_i8_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::array_new_fixed(array_i16_type, @lib.U32(2U)),
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::array_get_u(array_i16_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(255)),
            @lib.Instruction::i32_const(@lib.I32(128)),
            @lib.Instruction::array_new_fixed(array_i8_type, @lib.U32(2U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::array_get_s(array_i8_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(255)),
            @lib.Instruction::i32_const(@lib.I32(128)),
            @lib.Instruction::array_new_fixed(array_i8_type, @lib.U32(2U)),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_get_s(array_i8_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::array_new_fixed(array_i8_type, @lib.U32(2U)),
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::array_get_u(array_i8_type),
          ]),
        ),
      ]),
    ),
  )
  let s8_const = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  let u8_const = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  let s16_const = optimized.pretty_print_func(@lib.FuncIdx::new(3U))
  let u16_const = optimized.pretty_print_func(@lib.FuncIdx::new(4U))
  let s8_nonconst = optimized.pretty_print_func(@lib.FuncIdx::new(5U))
  let u16_nonconst = optimized.pretty_print_func(@lib.FuncIdx::new(6U))
  let dynidx = optimized.pretty_print_func(@lib.FuncIdx::new(7U))
  let oob = optimized.pretty_print_func(@lib.FuncIdx::new(8U))
  let effectful_sibling = optimized.pretty_print_func(@lib.FuncIdx::new(9U))
  assert_false(s8_const.contains("array.get"), msg=s8_const)
  assert_false(s8_const.contains("array.new_fixed"), msg=s8_const)
  assert_true(s8_const.contains("I32(-1)"), msg=s8_const)
  assert_false(u8_const.contains("array.get"), msg=u8_const)
  assert_true(u8_const.contains("I32(255)"), msg=u8_const)
  assert_false(s16_const.contains("array.get"), msg=s16_const)
  assert_true(s16_const.contains("I32(-32768)"), msg=s16_const)
  assert_false(u16_const.contains("array.get"), msg=u16_const)
  assert_true(u16_const.contains("I32(32768)"), msg=u16_const)
  assert_false(s8_nonconst.contains("array.get"), msg=s8_nonconst)
  assert_false(s8_nonconst.contains("array.new_fixed"), msg=s8_nonconst)
  assert_true(s8_nonconst.contains("i32.extend8s"), msg=s8_nonconst)
  assert_false(u16_nonconst.contains("array.get"), msg=u16_nonconst)
  assert_false(u16_nonconst.contains("array.new_fixed"), msg=u16_nonconst)
  assert_true(u16_nonconst.contains("i32.and"), msg=u16_nonconst)
  assert_true(u16_nonconst.contains("I32(65535)"), msg=u16_nonconst)
  assert_true(dynidx.contains("array.get_s"), msg=dynidx)
  assert_true(dynidx.contains("array.new_fixed"), msg=dynidx)
  assert_false(oob.contains("array.get"), msg=oob)
  assert_false(oob.contains("array.new_fixed"), msg=oob)
  assert_true(oob.contains("unreachable"), msg=oob)
  // Boundary-only half of this OI-K slice: Binaryen can preserve the effectful
  // sibling with a drop before forwarding, but Starshine keeps the stack form
  // until a safe localizing lowering preserves element-evaluation effects.
  assert_true(effectful_sibling.contains("array.get_u"), msg=effectful_sibling)
  assert_true(
    effectful_sibling.contains("array.new_fixed"),
    msg=effectful_sibling,
  )
  assert_true(
    effectful_sibling.contains("call (Func 0)"),
    msg=effectful_sibling,
  )
}

///|
test "optimize-instructions removes array.set to fresh pure arrays with constant indexes" {
  let array_type = @lib.TypeIdx::new(0U)
  let effect_type = @lib.TypeIdx::new(1U)
  let void_type = @lib.TypeIdx::new(2U)
  let indexed_void_type = @lib.TypeIdx::new(3U)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::array(
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::var_(),
              ),
            ),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::i32()]),
          ),
        ),
        @lib.RecType::new(@lib.SubType::comp_type(@lib.CompType::func([], []))),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::i32()], []),
          ),
        ),
      ]),
    )
    .with_import_sec(
      @lib.ImportSec::new([
        @lib.Import::new(
          @lib.Name::from_string("m"),
          @lib.Name::from_string("effect"),
          @lib.ExternType::func(effect_type),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        void_type, void_type, void_type, void_type, void_type, void_type, indexed_void_type,
        void_type, void_type,
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_new_fixed(array_type, @lib.U32(2U)),
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::i32_const(@lib.I32(9)),
            @lib.Instruction::array_set(array_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_new_fixed(array_type, @lib.U32(2U)),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::i32_const(@lib.I32(9)),
            @lib.Instruction::array_set(array_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_new_default(array_type),
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::i32_const(@lib.I32(9)),
            @lib.Instruction::array_set(array_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_new_default(array_type),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::array_set(array_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_new_fixed(array_type, @lib.U32(2U)),
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::array_set(array_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_new_fixed(array_type, @lib.U32(2U)),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::array_set(array_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_new_fixed(array_type, @lib.U32(2U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(9)),
            @lib.Instruction::array_set(array_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_new_fixed(array_type, @lib.U32(2U)),
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::i32_const(@lib.I32(9)),
            @lib.Instruction::array_set(array_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_new_fixed(array_type, @lib.U32(2U)),
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::array_set(array_type),
          ]),
        ),
      ]),
    ),
  )
  let fixed_inbounds = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  let fixed_oob = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  let default_inbounds = optimized.pretty_print_func(@lib.FuncIdx::new(3U))
  let default_oob = optimized.pretty_print_func(@lib.FuncIdx::new(4U))
  let effect_inbounds = optimized.pretty_print_func(@lib.FuncIdx::new(5U))
  let effect_oob = optimized.pretty_print_func(@lib.FuncIdx::new(6U))
  let dynamic_index = optimized.pretty_print_func(@lib.FuncIdx::new(7U))
  let effectful_sibling = optimized.pretty_print_func(@lib.FuncIdx::new(8U))
  let effectful_sibling_and_value = optimized.pretty_print_func(
    @lib.FuncIdx::new(9U),
  )
  assert_false(fixed_inbounds.contains("array.set"), msg=fixed_inbounds)
  assert_false(fixed_inbounds.contains("array.new_fixed"), msg=fixed_inbounds)
  assert_false(fixed_oob.contains("array.set"), msg=fixed_oob)
  assert_false(fixed_oob.contains("array.new_fixed"), msg=fixed_oob)
  assert_true(fixed_oob.contains("unreachable"), msg=fixed_oob)
  assert_false(default_inbounds.contains("array.set"), msg=default_inbounds)
  assert_false(
    default_inbounds.contains("array.new_default"),
    msg=default_inbounds,
  )
  assert_false(default_oob.contains("array.set"), msg=default_oob)
  assert_false(default_oob.contains("array.new_default"), msg=default_oob)
  optimize_instructions_assert_strings_in_order(default_oob, [
    "call (Func 0)", "drop", "unreachable",
  ])
  assert_false(effect_inbounds.contains("array.set"), msg=effect_inbounds)
  assert_false(effect_inbounds.contains("array.new_fixed"), msg=effect_inbounds)
  optimize_instructions_assert_strings_in_order(effect_inbounds, [
    "call (Func 0)", "drop",
  ])
  assert_false(effect_oob.contains("array.set"), msg=effect_oob)
  assert_false(effect_oob.contains("array.new_fixed"), msg=effect_oob)
  optimize_instructions_assert_strings_in_order(effect_oob, [
    "call (Func 0)", "drop", "unreachable",
  ])
  assert_true(dynamic_index.contains("array.set"), msg=dynamic_index)
  assert_true(dynamic_index.contains("array.new_fixed"), msg=dynamic_index)
  assert_false(effectful_sibling.contains("array.set"), msg=effectful_sibling)
  assert_false(
    effectful_sibling.contains("array.new_fixed"),
    msg=effectful_sibling,
  )
  optimize_instructions_assert_strings_in_order(effectful_sibling, [
    "call (Func 0)", "drop",
  ])
  assert_false(
    effectful_sibling_and_value.contains("array.set"),
    msg=effectful_sibling_and_value,
  )
  assert_false(
    effectful_sibling_and_value.contains("array.new_fixed"),
    msg=effectful_sibling_and_value,
  )
  @debug.assert_eq(
    optimize_instructions_test_count_substring(
      effectful_sibling_and_value, "call",
    ),
    2,
  )
  optimize_instructions_assert_strings_in_order(effectful_sibling_and_value, [
    "call (Func 0)", "drop", "call (Func 0)", "drop",
  ])
}

///|
test "optimize-instructions localizes array.set to fresh array.new repeated-value arrays with constant indexes" {
  let array_type = @lib.TypeIdx::new(0U)
  let effect_type = @lib.TypeIdx::new(1U)
  let void_type = @lib.TypeIdx::new(2U)
  let indexed_void_type = @lib.TypeIdx::new(3U)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::array(
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::var_(),
              ),
            ),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::i32()]),
          ),
        ),
        @lib.RecType::new(@lib.SubType::comp_type(@lib.CompType::func([], []))),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::i32()], []),
          ),
        ),
      ]),
    )
    .with_import_sec(
      @lib.ImportSec::new([
        @lib.Import::new(
          @lib.Name::from_string("m"),
          @lib.Name::from_string("effect"),
          @lib.ExternType::func(effect_type),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        void_type, void_type, void_type, void_type, void_type, void_type, void_type,
        void_type, indexed_void_type, void_type, void_type, indexed_void_type, void_type,
        void_type,
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        // set_new_inbounds_pure: array.set(array.new(7, 2), 1, 9) -> nop.
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_new(array_type),
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::i32_const(@lib.I32(9)),
            @lib.Instruction::array_set(array_type),
          ]),
        ),
        // set_new_oob_pure: array.set(array.new(7, 2), 2, 9) -> unreachable.
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_new(array_type),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::i32_const(@lib.I32(9)),
            @lib.Instruction::array_set(array_type),
          ]),
        ),
        // set_new_effect_setval: effectful set value is localized and dropped.
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_new(array_type),
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::array_set(array_type),
          ]),
        ),
        // set_new_effect_repeated: effectful repeated value is localized.
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_new(array_type),
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::i32_const(@lib.I32(9)),
            @lib.Instruction::array_set(array_type),
          ]),
        ),
        // set_new_effect_both: repeated-value effect stays before set-value effect.
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_new(array_type),
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::array_set(array_type),
          ]),
        ),
        // set_new_oob_effect_repeated: preserve repeated effect before trap.
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_new(array_type),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::i32_const(@lib.I32(9)),
            @lib.Instruction::array_set(array_type),
          ]),
        ),
        // set_new_oob_effect_setval: preserve set-value effect before trap.
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_new(array_type),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::array_set(array_type),
          ]),
        ),
        // set_new_oob_effect_both: preserve repeated then set-value effects.
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_new(array_type),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::array_set(array_type),
          ]),
        ),
        // set_new_dynamic_len: dynamic length may trap on allocation (boundary).
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::array_new(array_type),
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::i32_const(@lib.I32(9)),
            @lib.Instruction::array_set(array_type),
          ]),
        ),
        // set_new_negative_len: negative length traps on allocation (boundary).
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::i32_const(@lib.I32(-1)),
            @lib.Instruction::array_new(array_type),
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::i32_const(@lib.I32(9)),
            @lib.Instruction::array_set(array_type),
          ]),
        ),
        // set_new_huge_len: huge length traps on allocation (boundary).
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::i32_const(@lib.I32(2147483647)),
            @lib.Instruction::array_new(array_type),
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::i32_const(@lib.I32(9)),
            @lib.Instruction::array_set(array_type),
          ]),
        ),
        // set_new_dynamic_index: dynamic index may be in- or out-of-bounds.
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_new(array_type),
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(9)),
            @lib.Instruction::array_set(array_type),
          ]),
        ),
        // set_new_control_repeated: control-shaped repeated operand stays intact.
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(@lib.ValType::i32()),
              @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(7))]),
            ),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_new(array_type),
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::i32_const(@lib.I32(9)),
            @lib.Instruction::array_set(array_type),
          ]),
        ),
        // set_new_control_setval: control-shaped set value stays intact.
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_new(array_type),
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::block(
              @lib.BlockType::val_type(@lib.ValType::i32()),
              @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(9))]),
            ),
            @lib.Instruction::array_set(array_type),
          ]),
        ),
      ]),
    ),
  )
  let new_inbounds = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  let new_oob = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  let effect_setval = optimized.pretty_print_func(@lib.FuncIdx::new(3U))
  let effect_repeated = optimized.pretty_print_func(@lib.FuncIdx::new(4U))
  let effect_both = optimized.pretty_print_func(@lib.FuncIdx::new(5U))
  let oob_effect_repeated = optimized.pretty_print_func(@lib.FuncIdx::new(6U))
  let oob_effect_setval = optimized.pretty_print_func(@lib.FuncIdx::new(7U))
  let oob_effect_both = optimized.pretty_print_func(@lib.FuncIdx::new(8U))
  let dynamic_len = optimized.pretty_print_func(@lib.FuncIdx::new(9U))
  let negative_len = optimized.pretty_print_func(@lib.FuncIdx::new(10U))
  let huge_len = optimized.pretty_print_func(@lib.FuncIdx::new(11U))
  let dynamic_index = optimized.pretty_print_func(@lib.FuncIdx::new(12U))
  let control_repeated = optimized.pretty_print_func(@lib.FuncIdx::new(13U))
  let control_setval = optimized.pretty_print_func(@lib.FuncIdx::new(14U))
  assert_false(new_inbounds.contains("array.set"), msg=new_inbounds)
  assert_false(new_inbounds.contains("array.new"), msg=new_inbounds)
  assert_false(new_inbounds.contains("unreachable"), msg=new_inbounds)
  assert_false(new_oob.contains("array.set"), msg=new_oob)
  assert_false(new_oob.contains("array.new"), msg=new_oob)
  assert_true(new_oob.contains("unreachable"), msg=new_oob)
  assert_false(effect_setval.contains("array.set"), msg=effect_setval)
  assert_false(effect_setval.contains("array.new"), msg=effect_setval)
  optimize_instructions_assert_strings_in_order(effect_setval, [
    "call (Func 0)", "drop",
  ])
  assert_false(effect_repeated.contains("array.set"), msg=effect_repeated)
  assert_false(effect_repeated.contains("array.new"), msg=effect_repeated)
  @debug.assert_eq(
    optimize_instructions_test_count_substring(effect_repeated, "call"),
    1,
  )
  optimize_instructions_assert_strings_in_order(effect_repeated, [
    "call (Func 0)", "drop",
  ])
  assert_false(effect_both.contains("array.set"), msg=effect_both)
  assert_false(effect_both.contains("array.new"), msg=effect_both)
  @debug.assert_eq(
    optimize_instructions_test_count_substring(effect_both, "call"),
    2,
  )
  optimize_instructions_assert_strings_in_order(effect_both, [
    "call (Func 0)", "drop", "call (Func 0)", "drop",
  ])
  assert_false(
    oob_effect_repeated.contains("array.set"),
    msg=oob_effect_repeated,
  )
  assert_false(
    oob_effect_repeated.contains("array.new"),
    msg=oob_effect_repeated,
  )
  optimize_instructions_assert_strings_in_order(oob_effect_repeated, [
    "call (Func 0)", "drop", "unreachable",
  ])
  assert_false(oob_effect_setval.contains("array.set"), msg=oob_effect_setval)
  assert_false(oob_effect_setval.contains("array.new"), msg=oob_effect_setval)
  optimize_instructions_assert_strings_in_order(oob_effect_setval, [
    "call (Func 0)", "drop", "unreachable",
  ])
  assert_false(oob_effect_both.contains("array.set"), msg=oob_effect_both)
  assert_false(oob_effect_both.contains("array.new"), msg=oob_effect_both)
  @debug.assert_eq(
    optimize_instructions_test_count_substring(oob_effect_both, "call"),
    2,
  )
  optimize_instructions_assert_strings_in_order(oob_effect_both, [
    "call (Func 0)", "drop", "call (Func 0)", "drop", "unreachable",
  ])
  // Boundary-only half: dynamic, negative, and huge lengths may trap on allocation.
  assert_true(dynamic_len.contains("array.set"), msg=dynamic_len)
  assert_true(dynamic_len.contains("array.new"), msg=dynamic_len)
  assert_true(negative_len.contains("array.set"), msg=negative_len)
  assert_true(negative_len.contains("array.new"), msg=negative_len)
  assert_true(huge_len.contains("array.set"), msg=huge_len)
  assert_true(huge_len.contains("array.new"), msg=huge_len)
  // Boundary-only half: dynamic index and control-shaped operands stay intact.
  assert_true(dynamic_index.contains("array.set"), msg=dynamic_index)
  assert_true(dynamic_index.contains("array.new"), msg=dynamic_index)
  assert_true(control_repeated.contains("array.set"), msg=control_repeated)
  assert_true(control_repeated.contains("array.new"), msg=control_repeated)
  assert_true(control_setval.contains("array.set"), msg=control_setval)
  assert_true(control_setval.contains("array.new"), msg=control_setval)
}

///|
test "optimize-instructions keeps multi-use array.new producer boundary for array.set" {
  let array_type = @lib.TypeIdx::new(0U)
  let void_type = @lib.TypeIdx::new(1U)
  let array_ref = @lib.ValType::ref_type(
    @lib.RefType::new(true, @lib.HeapType::new(array_type)),
  )
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::array(
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::var_(),
              ),
            ),
          ),
        ),
        @lib.RecType::new(@lib.SubType::comp_type(@lib.CompType::func([], []))),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([void_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::new([@lib.LocalRun::new(1U, array_ref)]),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_new(array_type),
            @lib.Instruction::local_tee(@lib.LocalIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::i32_const(@lib.I32(9)),
            @lib.Instruction::array_set(array_type),
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::drop(),
          ]),
        ),
      ]),
    ),
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_true(pretty.contains("array.set"), msg=pretty)
  assert_true(pretty.contains("array.new"), msg=pretty)
  assert_true(pretty.contains("local.tee"), msg=pretty)
}

///|
test "optimize-instructions keeps multi-result array.new set operands boundary" {
  let array_type = @lib.TypeIdx::new(0U)
  let multi_type = @lib.TypeIdx::new(1U)
  let void_type = @lib.TypeIdx::new(2U)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::array(
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::var_(),
              ),
            ),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::i32(), @lib.ValType::i32()]),
          ),
        ),
        @lib.RecType::new(@lib.SubType::comp_type(@lib.CompType::func([], []))),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([void_type, void_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::type_idx(multi_type),
              @lib.Expr::new([
                @lib.Instruction::i32_const(@lib.I32(7)),
                @lib.Instruction::i32_const(@lib.I32(2)),
              ]),
            ),
            @lib.Instruction::array_new(array_type),
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::i32_const(@lib.I32(9)),
            @lib.Instruction::array_set(array_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_new(array_type),
            @lib.Instruction::block(
              @lib.BlockType::type_idx(multi_type),
              @lib.Expr::new([
                @lib.Instruction::i32_const(@lib.I32(1)),
                @lib.Instruction::i32_const(@lib.I32(9)),
              ]),
            ),
            @lib.Instruction::array_set(array_type),
          ]),
        ),
      ]),
    ),
  )
  let multi_repeated = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  let multi_set_value = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_true(multi_repeated.contains("array.set"), msg=multi_repeated)
  assert_true(multi_repeated.contains("array.new"), msg=multi_repeated)
  assert_true(multi_set_value.contains("array.set"), msg=multi_set_value)
  assert_true(multi_set_value.contains("array.new"), msg=multi_set_value)
}

///|
test "optimize-instructions keeps array.fill and array.copy on fresh arrays as a Binaryen OI parity boundary" {
  // Boundary-only OI-K classification: Binaryen `version_130`
  // `--optimize-instructions` (both direct and O4z-style `-O`) does NOT fold
  // `array.fill` or `array.copy` on fresh one-use pure arrays, even for pure
  // in-bounds or out-of-bounds shapes (probe `.tmp/oi-k-array-fill-probe.wat`
  // and `.tmp/oi-k-array-copy-probe.wat`). Starshine keeping these unchanged
  // is therefore correct OI parity, not a gap. This test locks that boundary so
  // any future OI folding of these bulk array ops forces a fresh Binaryen
  // parity / Starshine-win review.
  let array_type = @lib.TypeIdx::new(0U)
  let void_type = @lib.TypeIdx::new(1U)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::array(
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::var_(),
              ),
            ),
          ),
        ),
        @lib.RecType::new(@lib.SubType::comp_type(@lib.CompType::func([], []))),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([void_type, void_type, void_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        // array.fill over a fresh one-use array.new_fixed (pure, in-bounds).
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_new_fixed(array_type, @lib.U32(2U)),
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::i32_const(@lib.I32(9)),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_fill(array_type),
          ]),
        ),
        // array.fill over a fresh one-use array.new_default (pure, in-bounds).
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_new_default(array_type),
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::i32_const(@lib.I32(9)),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_fill(array_type),
          ]),
        ),
        // array.copy between two fresh one-use array.new_default (pure, in-bounds).
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_new_default(array_type),
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_new_default(array_type),
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_copy(array_type, array_type),
          ]),
        ),
      ]),
    ),
  )
  let fill_fixed = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  let fill_default = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  let copy_fresh = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_true(fill_fixed.contains("array.fill"), msg=fill_fixed)
  assert_true(fill_default.contains("array.fill"), msg=fill_default)
  assert_true(copy_fresh.contains("array.copy"), msg=copy_fresh)
}

///|
test "optimize-instructions folds array.get of constant-size array.new repeated values" {
  let array_i32_type = @lib.TypeIdx::new(0U)
  let array_i8_type = @lib.TypeIdx::new(1U)
  let array_i16_type = @lib.TypeIdx::new(2U)
  let result_type = @lib.TypeIdx::new(3U)
  let param_result_type = @lib.TypeIdx::new(4U)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::array(
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
            ),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::array(
              @lib.FieldType::new(
                @lib.StorageType::pack_type(@lib.PackType::i8()),
                @lib.Mut::const_(),
              ),
            ),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::array(
              @lib.FieldType::new(
                @lib.StorageType::pack_type(@lib.PackType::i16()),
                @lib.Mut::const_(),
              ),
            ),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::i32()]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::i32()], [@lib.ValType::i32()]),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        result_type, result_type, param_result_type, result_type, result_type, result_type,
        result_type, param_result_type, param_result_type, result_type, result_type,
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(99))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::i32_const(@lib.I32(3)),
            @lib.Instruction::array_new(array_i32_type),
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::array_get(array_i32_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(3)),
            @lib.Instruction::array_new(array_i32_type),
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::array_get(array_i32_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(3)),
            @lib.Instruction::array_new(array_i32_type),
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::array_get(array_i32_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::i32_const(@lib.I32(3)),
            @lib.Instruction::array_new(array_i32_type),
            @lib.Instruction::i32_const(@lib.I32(3)),
            @lib.Instruction::array_get(array_i32_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(3)),
            @lib.Instruction::array_new(array_i32_type),
            @lib.Instruction::i32_const(@lib.I32(3)),
            @lib.Instruction::array_get(array_i32_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(255)),
            @lib.Instruction::i32_const(@lib.I32(3)),
            @lib.Instruction::array_new(array_i8_type),
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::array_get_s(array_i8_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(3)),
            @lib.Instruction::array_new(array_i16_type),
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::array_get_u(array_i16_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::i32_const(@lib.I32(3)),
            @lib.Instruction::array_new(array_i32_type),
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::array_get(array_i32_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::i32_const(@lib.I32(-1)),
            @lib.Instruction::array_new(array_i32_type),
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::array_get(array_i32_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::i32_const(@lib.I32(2147483647)),
            @lib.Instruction::array_new(array_i32_type),
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::array_get(array_i32_type),
          ]),
        ),
      ]),
    ),
  )
  let const_value = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  let local_value = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  let effect_value = optimized.pretty_print_func(@lib.FuncIdx::new(3U))
  let pure_oob = optimized.pretty_print_func(@lib.FuncIdx::new(4U))
  let effect_oob = optimized.pretty_print_func(@lib.FuncIdx::new(5U))
  let s8 = optimized.pretty_print_func(@lib.FuncIdx::new(6U))
  let u16_local = optimized.pretty_print_func(@lib.FuncIdx::new(7U))
  let dynamic_index = optimized.pretty_print_func(@lib.FuncIdx::new(8U))
  let negative_len = optimized.pretty_print_func(@lib.FuncIdx::new(9U))
  let huge_len = optimized.pretty_print_func(@lib.FuncIdx::new(10U))
  for pretty in [const_value, local_value, effect_value, s8, u16_local] {
    assert_false(pretty.contains("array.get"), msg=pretty)
    assert_false(pretty.contains("array.new"), msg=pretty)
  }
  assert_true(const_value.contains("I32(7)"), msg=const_value)
  assert_true(local_value.contains("local.get (Local 0)"), msg=local_value)
  @debug.assert_eq(
    optimize_instructions_test_count_substring(effect_value, "call"),
    1,
  )
  assert_false(pure_oob.contains("array.get"), msg=pure_oob)
  assert_false(pure_oob.contains("array.new"), msg=pure_oob)
  assert_true(pure_oob.contains("unreachable"), msg=pure_oob)
  assert_true(s8.contains("I32(-1)"), msg=s8)
  assert_true(u16_local.contains("i32.and"), msg=u16_local)
  assert_true(u16_local.contains("I32(65535)"), msg=u16_local)
  assert_true(dynamic_index.contains("array.get"), msg=dynamic_index)
  assert_true(dynamic_index.contains("array.new"), msg=dynamic_index)
  assert_false(effect_oob.contains("array.get"), msg=effect_oob)
  assert_false(effect_oob.contains("array.new"), msg=effect_oob)
  @debug.assert_eq(
    optimize_instructions_test_count_substring(effect_oob, "call"),
    1,
  )
  optimize_instructions_assert_strings_in_order(effect_oob, [
    "call (Func 0)", "drop", "unreachable",
  ])
  // Boundary-only half of this OI-K slice: trap-preserving length limits mirror
  // the array.new len slice and keep negative/huge allocation traps intact.
  assert_true(negative_len.contains("array.get"), msg=negative_len)
  assert_true(negative_len.contains("array.new"), msg=negative_len)
  assert_true(huge_len.contains("array.get"), msg=huge_len)
  assert_true(huge_len.contains("array.new"), msg=huge_len)
}

///|
test "optimize-instructions folds array.get of constant-size array.new_default defaults" {
  let array_i32_type = @lib.TypeIdx::new(0U)
  let array_i8_type = @lib.TypeIdx::new(1U)
  let array_i16_type = @lib.TypeIdx::new(2U)
  let result_type = @lib.TypeIdx::new(3U)
  let indexed_type = @lib.TypeIdx::new(4U)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::array(
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
            ),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::array(
              @lib.FieldType::new(
                @lib.StorageType::pack_type(@lib.PackType::i8()),
                @lib.Mut::const_(),
              ),
            ),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::array(
              @lib.FieldType::new(
                @lib.StorageType::pack_type(@lib.PackType::i16()),
                @lib.Mut::const_(),
              ),
            ),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::i32()]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::i32()], [@lib.ValType::i32()]),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        result_type, result_type, result_type, result_type, result_type, indexed_type,
        result_type, result_type,
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(3)),
            @lib.Instruction::array_new_default(array_i32_type),
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::array_get(array_i32_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_new_default(array_i8_type),
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::array_get_s(array_i8_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_new_default(array_i8_type),
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::array_get_u(array_i8_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_new_default(array_i16_type),
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::array_get_s(array_i16_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(3)),
            @lib.Instruction::array_new_default(array_i32_type),
            @lib.Instruction::i32_const(@lib.I32(3)),
            @lib.Instruction::array_get(array_i32_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::array_new_default(array_i32_type),
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::array_get(array_i32_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(-1)),
            @lib.Instruction::array_new_default(array_i32_type),
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::array_get(array_i32_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(50000000)),
            @lib.Instruction::array_new_default(array_i32_type),
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::array_get(array_i32_type),
          ]),
        ),
      ]),
    ),
  )
  let plain = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  let s8 = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  let u8 = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  let s16 = optimized.pretty_print_func(@lib.FuncIdx::new(3U))
  let oob = optimized.pretty_print_func(@lib.FuncIdx::new(4U))
  let dynamic_len = optimized.pretty_print_func(@lib.FuncIdx::new(5U))
  let negative_len = optimized.pretty_print_func(@lib.FuncIdx::new(6U))
  let huge_len = optimized.pretty_print_func(@lib.FuncIdx::new(7U))
  for pretty in [plain, s8, u8, s16] {
    assert_false(pretty.contains("array.get"), msg=pretty)
    assert_false(pretty.contains("array.new_default"), msg=pretty)
    assert_true(pretty.contains("I32(0)"), msg=pretty)
  }
  assert_false(oob.contains("array.get"), msg=oob)
  assert_false(oob.contains("array.new_default"), msg=oob)
  assert_true(oob.contains("unreachable"), msg=oob)
  // Boundary-only half of this OI-K slice: without a constant length, Starshine
  // cannot prove that a constant index is in-bounds or out-of-bounds.
  assert_true(dynamic_len.contains("array.get"), msg=dynamic_len)
  assert_true(dynamic_len.contains("array.new_default"), msg=dynamic_len)
  // Correctness boundary: Binaryen version_130 keeps negative and huge
  // allocation lengths to preserve the allocation-size trap before the get.
  assert_true(negative_len.contains("array.get"), msg=negative_len)
  assert_true(negative_len.contains("array.new_default"), msg=negative_len)
  assert_true(huge_len.contains("array.get"), msg=huge_len)
  assert_true(huge_len.contains("array.new_default"), msg=huge_len)
}

///|
test "optimize-instructions preserves later effectful struct.new sibling when forwarding first field" {
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (type $s (struct (field i32) (field i32)))
        #|  (import "env" "effect" (func $effect (result i32)))
        #|  (func (export "get0") (result i32)
        #|    i32.const 7
        #|    call $effect
        #|    struct.new $s
        #|    struct.get $s 0))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail(
        "expected effectful struct.get(struct.new) localization success, got \{err}",
      )
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_false(pretty.contains("struct.get"), msg=pretty)
  assert_false(pretty.contains("struct.new"), msg=pretty)
  optimize_instructions_assert_strings_in_order(pretty, [
    "I32(7)", "local.set", "call (Func 0)", "drop", "local.get",
  ])
}

///|
test "optimize-instructions preserves earlier effectful struct.new sibling before forwarding second field" {
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (type $s (struct (field i32) (field i32)))
        #|  (import "env" "effect" (func $effect (result i32)))
        #|  (func (export "get1") (result i32)
        #|    call $effect
        #|    i32.const 8
        #|    struct.new $s
        #|    struct.get $s 1))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail(
        "expected earlier-effect struct.get(struct.new) localization success, got \{err}",
      )
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_false(pretty.contains("struct.get"), msg=pretty)
  assert_false(pretty.contains("struct.new"), msg=pretty)
  optimize_instructions_assert_strings_in_order(pretty, [
    "call (Func 0)", "drop", "I32(8)",
  ])
}

///|
test "optimize-instructions localizes effectful selected struct.new field before later effectful sibling" {
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (type $s (struct (field i32) (field i32)))
        #|  (import "env" "a" (func $a (result i32)))
        #|  (import "env" "b" (func $b (result i32)))
        #|  (func (export "get0") (result i32)
        #|    call $a
        #|    call $b
        #|    struct.new $s
        #|    struct.get $s 0))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail(
        "expected selected-effect struct.get(struct.new) localization success, got \{err}",
      )
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_false(pretty.contains("struct.get"), msg=pretty)
  assert_false(pretty.contains("struct.new"), msg=pretty)
  @debug.assert_eq(
    optimize_instructions_test_count_substring(pretty, "call"),
    2,
  )
  optimize_instructions_assert_strings_in_order(pretty, [
    "call (Func 0)", "local.set", "call (Func 1)", "drop", "local.get",
  ])
}

///|
test "optimize-instructions keeps multi-use and multi-result struct.new boundaries" {
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (type $s (struct (field i32) (field i32)))
        #|  (func $pair (result i32 i32)
        #|    i32.const 1
        #|    i32.const 2)
        #|  (func (export "multi_use") (result i32)
        #|    (local $obj (ref null $s))
        #|    i32.const 7
        #|    i32.const 8
        #|    struct.new $s
        #|    local.tee $obj
        #|    struct.get $s 0
        #|    local.get $obj
        #|    drop)
        #|  (func (export "multi_result") (result i32)
        #|    call $pair
        #|    struct.new $s
        #|    struct.get $s 0))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) => fail("expected struct.get boundary success, got \{err}")
  }
  let multi_use = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  let multi_result = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_true(multi_use.contains("struct.get"), msg=multi_use)
  assert_true(multi_use.contains("struct.new"), msg=multi_use)
  assert_true(multi_result.contains("struct.get"), msg=multi_result)
  assert_true(multi_result.contains("struct.new"), msg=multi_result)
}

///|
test "optimize-instructions folds constant memory access offset into i32 address" {
  let load_func = optimize_instructions_test_run_hot(
    "(module (memory 1) (func (result i32) i32.const 8 i32.load offset=4))",
  )
  let load = @ir.hot_root_get(load_func, 0)
  let load_addr = @ir.hot_child_get(load_func, load, 0)
  @debug.assert_eq(
    @ir.hot_const_get(load_func, @ir.hot_node_get(load_func, load_addr).imm0),
    @ir.HotConstPayload::i32_const(@lib.I32(12)),
  )
  @debug.assert_eq(
    @ir.hot_node_exact_instr(load_func, load),
    Some(
      @lib.Instruction::i32_load(
        @lib.MemArg::new(@lib.U32(2), None, @lib.U64(0)),
      ),
    ),
  )

  let store_func = optimize_instructions_test_run_hot(
    "(module (memory 1) (func i32.const 16 i32.const 99 i32.store offset=12))",
  )
  let store = @ir.hot_root_get(store_func, 0)
  let store_addr = @ir.hot_child_get(store_func, store, 0)
  @debug.assert_eq(
    @ir.hot_const_get(store_func, @ir.hot_node_get(store_func, store_addr).imm0),
    @ir.HotConstPayload::i32_const(@lib.I32(28)),
  )
  @debug.assert_eq(
    @ir.hot_node_exact_instr(store_func, store),
    Some(
      @lib.Instruction::i32_store(
        @lib.MemArg::new(@lib.U32(2), None, @lib.U64(0)),
      ),
    ),
  )
}

///|
test "optimize-instructions folds constant memory64 access offset into i64 address" {
  let func_type = @lib.RecType::new(
    @lib.SubType::comp_type(@lib.CompType::func([], [@lib.ValType::i32()])),
  )
  let input = @lib.Module::new()
    .with_type_sec(@lib.TypeSec::new([func_type]))
    .with_func_sec(@lib.FuncSec::new([@lib.TypeIdx::new(0U)]))
    .with_mem_sec(
      @lib.MemSec::new([@lib.MemType::new(@lib.Limits::i64(1UL, None))]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i64_const(@lib.I64(8L)),
            @lib.Instruction::i32_load(
              @lib.MemArg::new(@lib.U32(2), None, @lib.U64(4)),
            ),
          ]),
        ),
      ]),
    )
  match @validate.validate_module(input) {
    Ok(_) => ()
    Err(err) =>
      fail("expected valid memory64 constant-offset input, got \{err}")
  }
  let optimized = match
    run_hot_pipeline(input, HotPipelineOptions::new(), ["optimize-instructions"]) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected memory64 constant-offset optimize success, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_true(pretty.contains("i64.const I64(12)"), msg=pretty)
  assert_true(pretty.contains("i32.load"), msg=pretty)
  assert_false(pretty.contains("offset=U64(4)"), msg=pretty)
}

///|
test "optimize-instructions intentionally keeps nonconstant pointer-add memory offsets outside OI ownership" {
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func (param $p i32) (result i32)
        #|    local.get $p
        #|    i32.const 4
        #|    i32.add
        #|    i32.load offset=8)
        #|  (func (param $p i32) (param $v i32)
        #|    local.get $p
        #|    i32.const 4
        #|    i32.add
        #|    local.get $v
        #|    i32.store offset=8))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) => fail("expected pointer-add offset boundary success, got \{err}")
  }
  let load_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  let store_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  // Intentional fail-closed OI-G boundary: Binaryen `version_130`
  // `optimize-instructions` folds only constant address children with static
  // offsets. Pointer-add address arithmetic is left to other passes rather than
  // claimed as OI-owned load/store canonicalization.
  assert_true(load_pretty.contains("i32.add"), msg=load_pretty)
  assert_true(load_pretty.contains("offset=U64(8)"), msg=load_pretty)
  assert_false(load_pretty.contains("offset=U64(12)"), msg=load_pretty)
  assert_true(store_pretty.contains("i32.add"), msg=store_pretty)
  assert_true(store_pretty.contains("offset=U64(8)"), msg=store_pretty)
  assert_false(store_pretty.contains("offset=U64(12)"), msg=store_pretty)
}

