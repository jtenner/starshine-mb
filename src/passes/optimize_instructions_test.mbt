///|
test "optimize-instructions rewrites array.new default init through facts" {
  // OI-K/OI-L aggregate constructor fact: Binaryen version_130 `visitArrayNew`
  // checks the initializer through `getFallthrough`; defaultable array element
  // initializers become `array.new_default` while the original initializer is
  // still dropped/evaluated before allocation via `getDroppedChildrenAndAppend`.
  let array_type = @lib.TypeIdx::new(0U)
  let effect_type = @lib.TypeIdx::new(1U)
  let result_type = @lib.TypeIdx::new(2U)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::array(
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
            ),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::i32()]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [
              @lib.ValType::ref_null(@lib.HeapType::new(array_type)),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([effect_type, result_type, result_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::i32_const(@lib.I32(3)),
            @lib.Instruction::array_new(array_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(@lib.ValType::i32()),
              @lib.Expr::new([
                @lib.Instruction::call(@lib.FuncIdx::new(0U)),
                @lib.Instruction::drop(),
                @lib.Instruction::i32_const(@lib.I32(0)),
              ]),
            ),
            @lib.Instruction::i32_const(@lib.I32(3)),
            @lib.Instruction::array_new(array_type),
          ]),
        ),
      ]),
    ),
  )
  let direct = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_true(direct.contains("array.new_default"), msg=direct)
  assert_true(direct.contains("drop"), msg=direct)
  assert_true(direct.contains("I32(3)"), msg=direct)
  let effectful = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_true(effectful.contains("array.new_default"), msg=effectful)
  assert_true(effectful.contains("call (Func 0)"), msg=effectful)
  assert_true(effectful.contains("drop"), msg=effectful)
  assert_true(effectful.contains("I32(3)"), msg=effectful)
}

///|
test "optimize-instructions rewrites array.new default init through control fallthrough facts" {
  // OI-K/OI-L aggregate constructor fact: Binaryen version_130
  // `Properties::getFallthrough` also looks through loop bodies and `if` nodes
  // where exactly one arm cannot fall through. `visitArrayNew` still drops the
  // original initializer before `array.new_default`, preserving the loop/if
  // effects and traps before allocation.
  let array_type = @lib.TypeIdx::new(0U)
  let loop_result_type = @lib.TypeIdx::new(1U)
  let if_result_type = @lib.TypeIdx::new(2U)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::array(
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
            ),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [
              @lib.ValType::ref_null(@lib.HeapType::new(array_type)),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::i32()], [
              @lib.ValType::ref_null(@lib.HeapType::new(array_type)),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([loop_result_type, if_result_type, if_result_type]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::loop_(
              @lib.BlockType::val_type(@lib.ValType::i32()),
              @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
            ),
            @lib.Instruction::i32_const(@lib.I32(3)),
            @lib.Instruction::array_new(array_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::if_(
              @lib.BlockType::val_type(@lib.ValType::i32()),
              [@lib.Instruction::unreachable_()],
              Some([@lib.Instruction::i32_const(@lib.I32(0))]),
            ),
            @lib.Instruction::i32_const(@lib.I32(4)),
            @lib.Instruction::array_new(array_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::if_(
              @lib.BlockType::val_type(@lib.ValType::i32()),
              [@lib.Instruction::i32_const(@lib.I32(0))],
              Some([@lib.Instruction::unreachable_()]),
            ),
            @lib.Instruction::i32_const(@lib.I32(5)),
            @lib.Instruction::array_new(array_type),
          ]),
        ),
      ]),
    ),
  )
  let loop_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_true(loop_pretty.contains("array.new_default"), msg=loop_pretty)
  assert_true(loop_pretty.contains("loop"), msg=loop_pretty)
  assert_true(loop_pretty.contains("drop"), msg=loop_pretty)
  assert_true(loop_pretty.contains("I32(3)"), msg=loop_pretty)
  let then_unreachable = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_true(
    then_unreachable.contains("array.new_default"),
    msg=then_unreachable,
  )
  assert_true(then_unreachable.contains("if"), msg=then_unreachable)
  assert_true(then_unreachable.contains("unreachable"), msg=then_unreachable)
  assert_true(then_unreachable.contains("drop"), msg=then_unreachable)
  assert_true(then_unreachable.contains("I32(4)"), msg=then_unreachable)
  let else_unreachable = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_true(
    else_unreachable.contains("array.new_default"),
    msg=else_unreachable,
  )
  assert_true(else_unreachable.contains("if"), msg=else_unreachable)
  assert_true(else_unreachable.contains("unreachable"), msg=else_unreachable)
  assert_true(else_unreachable.contains("drop"), msg=else_unreachable)
  assert_true(else_unreachable.contains("I32(5)"), msg=else_unreachable)
}

///|
test "optimize-instructions folds array.len of pure array.new_fixed length" {
  let array_type = @lib.TypeIdx::new(0U)
  let effect_type = @lib.TypeIdx::new(1U)
  let result_type = @lib.TypeIdx::new(2U)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::array(
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
            ),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::i32()]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::i32()]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([effect_type, result_type, result_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(99))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::i32_const(@lib.I32(8)),
            @lib.Instruction::array_new_fixed(array_type, @lib.U32(2U)),
            @lib.Instruction::array_len(),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(8)),
            @lib.Instruction::array_new_fixed(array_type, @lib.U32(2U)),
            @lib.Instruction::array_len(),
          ]),
        ),
      ]),
    ),
  )
  let pure = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  let effectful = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_false(pure.contains("array.len"), msg=pure)
  assert_false(pure.contains("array.new_fixed"), msg=pure)
  assert_true(pure.contains("I32(2)"), msg=pure)
  // Boundary-only half of this OI-K slice: Binaryen currently leaves the
  // effectful element form intact, and Starshine must not drop element effects.
  assert_true(effectful.contains("array.len"), msg=effectful)
  assert_true(effectful.contains("array.new_fixed"), msg=effectful)
  assert_true(effectful.contains("call (Func 0)"), msg=effectful)
}

///|
test "optimize-instructions folds array.len of constant-size array.new_default" {
  let array_type = @lib.TypeIdx::new(0U)
  let result_type = @lib.TypeIdx::new(1U)
  let param_result_type = @lib.TypeIdx::new(2U)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::array(
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
            ),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::i32()]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::i32()], [@lib.ValType::i32()]),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        result_type, param_result_type, result_type, result_type,
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(3)),
            @lib.Instruction::array_new_default(array_type),
            @lib.Instruction::array_len(),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::array_new_default(array_type),
            @lib.Instruction::array_len(),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(-1)),
            @lib.Instruction::array_new_default(array_type),
            @lib.Instruction::array_len(),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(2147483647)),
            @lib.Instruction::array_new_default(array_type),
            @lib.Instruction::array_len(),
          ]),
        ),
      ]),
    ),
  )
  let constant_len = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  let dynamic_len = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  let negative_len = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  let huge_len = optimized.pretty_print_func(@lib.FuncIdx::new(3U))
  assert_false(constant_len.contains("array.len"), msg=constant_len)
  assert_false(constant_len.contains("array.new_default"), msg=constant_len)
  assert_true(constant_len.contains("I32(3)"), msg=constant_len)
  // Boundary-only half of this OI-K slice: Binaryen's O4z-style oracle keeps
  // dynamic-length default arrays because removing allocation could drop the
  // allocation-size trap.
  assert_true(dynamic_len.contains("array.len"), msg=dynamic_len)
  assert_true(dynamic_len.contains("array.new_default"), msg=dynamic_len)
  // Boundary-only half of this OI-K slice: Binaryen also keeps negative
  // i32.const lengths because the huge unsigned allocation should still trap.
  assert_true(negative_len.contains("array.len"), msg=negative_len)
  assert_true(negative_len.contains("array.new_default"), msg=negative_len)
  // Boundary-only half of this OI-K slice: Binaryen keeps huge non-negative
  // lengths past the O4z-observed allocation limit for the same trap reason.
  assert_true(huge_len.contains("array.len"), msg=huge_len)
  assert_true(huge_len.contains("array.new_default"), msg=huge_len)
}

///|
test "optimize-instructions folds array.len of constant-size array.new and localizes repeated effects" {
  let array_type = @lib.TypeIdx::new(0U)
  let result_type = @lib.TypeIdx::new(1U)
  let param_result_type = @lib.TypeIdx::new(2U)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::array(
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
            ),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::i32()]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::i32()], [@lib.ValType::i32()]),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        result_type, result_type, param_result_type, result_type, result_type, result_type,
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(9))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::i32_const(@lib.I32(3)),
            @lib.Instruction::array_new(array_type),
            @lib.Instruction::array_len(),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(3)),
            @lib.Instruction::array_new(array_type),
            @lib.Instruction::array_len(),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(3)),
            @lib.Instruction::array_new(array_type),
            @lib.Instruction::array_len(),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::i32_const(@lib.I32(-1)),
            @lib.Instruction::array_new(array_type),
            @lib.Instruction::array_len(),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::i32_const(@lib.I32(2147483647)),
            @lib.Instruction::array_new(array_type),
            @lib.Instruction::array_len(),
          ]),
        ),
      ]),
    ),
  )
  let constant_value = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  let local_value = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  let effectful_value = optimized.pretty_print_func(@lib.FuncIdx::new(3U))
  let negative_len = optimized.pretty_print_func(@lib.FuncIdx::new(4U))
  let huge_len = optimized.pretty_print_func(@lib.FuncIdx::new(5U))
  assert_false(constant_value.contains("array.len"), msg=constant_value)
  assert_false(constant_value.contains("array.new"), msg=constant_value)
  assert_true(constant_value.contains("I32(3)"), msg=constant_value)
  // Boundary-only half of this OI-K slice: Binaryen's O4z-style oracle keeps
  // nonconstant repeated values, even pure local.get values, so Starshine keeps
  // them until a broader source-backed proof justifies dropping value evaluation.
  assert_true(local_value.contains("array.len"), msg=local_value)
  assert_true(local_value.contains("array.new"), msg=local_value)
  assert_false(effectful_value.contains("array.len"), msg=effectful_value)
  assert_false(effectful_value.contains("array.new"), msg=effectful_value)
  @debug.assert_eq(
    optimize_instructions_test_count_substring(effectful_value, "call"),
    1,
  )
  optimize_instructions_assert_strings_in_order(effectful_value, [
    "call (Func 0)", "drop", "I32(3)",
  ])
  // Boundary-only half of this OI-K slice: trap-preserving length limits mirror
  // the array.new_default length slice.
  assert_true(negative_len.contains("array.len"), msg=negative_len)
  assert_true(negative_len.contains("array.new"), msg=negative_len)
  assert_true(huge_len.contains("array.len"), msg=huge_len)
  assert_true(huge_len.contains("array.new"), msg=huge_len)
}

///|
test "optimize-instructions folds array.get of pure array.new_fixed elements" {
  let array_type = @lib.TypeIdx::new(0U)
  let effect_type = @lib.TypeIdx::new(1U)
  let result_type = @lib.TypeIdx::new(2U)
  let indexed_type = @lib.TypeIdx::new(3U)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::array(
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
            ),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::i32()]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::i32()]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::i32()], [@lib.ValType::i32()]),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        effect_type, result_type, result_type, indexed_type, result_type, result_type,
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(99))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::i32_const(@lib.I32(8)),
            @lib.Instruction::array_new_fixed(array_type, @lib.U32(2U)),
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::array_get(array_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::i32_const(@lib.I32(8)),
            @lib.Instruction::array_new_fixed(array_type, @lib.U32(2U)),
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::array_get(array_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::i32_const(@lib.I32(8)),
            @lib.Instruction::array_new_fixed(array_type, @lib.U32(2U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::array_get(array_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::i32_const(@lib.I32(8)),
            @lib.Instruction::array_new_fixed(array_type, @lib.U32(2U)),
            @lib.Instruction::i32_const(@lib.I32(2)),
            @lib.Instruction::array_get(array_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(8)),
            @lib.Instruction::array_new_fixed(array_type, @lib.U32(2U)),
            @lib.Instruction::i32_const(@lib.I32(1)),
            @lib.Instruction::array_get(array_type),
          ]),
        ),
      ]),
    ),
  )
  let get0 = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  let get1 = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  let dynidx = optimized.pretty_print_func(@lib.FuncIdx::new(3U))
  let oob = optimized.pretty_print_func(@lib.FuncIdx::new(4U))
  let effectful_sibling = optimized.pretty_print_func(@lib.FuncIdx::new(5U))
  assert_false(get0.contains("array.get"), msg=get0)
  assert_false(get0.contains("array.new_fixed"), msg=get0)
  assert_true(get0.contains("I32(7)"), msg=get0)
  assert_false(get1.contains("array.get"), msg=get1)
  assert_false(get1.contains("array.new_fixed"), msg=get1)
  assert_true(get1.contains("I32(8)"), msg=get1)
  assert_true(dynidx.contains("array.get"), msg=dynidx)
  assert_true(dynidx.contains("array.new_fixed"), msg=dynidx)
  assert_false(oob.contains("array.get"), msg=oob)
  assert_false(oob.contains("array.new_fixed"), msg=oob)
  assert_true(oob.contains("unreachable"), msg=oob)
  // OI-K effect-localization slice: Binaryen removes the fresh allocation,
  // forwards the selected element, and preserves the earlier non-selected call
  // as a dropped effect in element evaluation order.
  assert_false(effectful_sibling.contains("array.get"), msg=effectful_sibling)
  assert_false(
    effectful_sibling.contains("array.new_fixed"),
    msg=effectful_sibling,
  )
  optimize_instructions_assert_strings_in_order(effectful_sibling, [
    "call (Func 0)", "drop", "I32(8)",
  ])
}

///|
test "optimize-instructions localizes selected array.get new_fixed element before later effectful sibling" {
  let array_type = @lib.TypeIdx::new(0U)
  let effect_type = @lib.TypeIdx::new(1U)
  let result_type = @lib.TypeIdx::new(2U)
