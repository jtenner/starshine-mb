    .with_func_sec(@lib.FuncSec::new([@lib.TypeIdx::new(2U)]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::struct_new_default(descriptor_type),
            @lib.Instruction::struct_new_default_desc(described_type),
            @lib.Instruction::struct_new_default(descriptor_type),
            @lib.Instruction::ref_cast_desc_eq_type(described_ref_type),
          ]),
        ),
      ]),
    ),
    @lib.FuncIdx::new(0U),
  )
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) =>
      fail("expected non-null descriptor exactness narrowing, got \{err}")
  }
  let root = @ir.hot_root_get(func, 0)
  @debug.assert_eq(@ir.hot_child_count(func, root), 2)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(func, root),
    Some(
      @lib.Instruction::ref_cast_desc_eq_type(
        @lib.RefType::new(false, described_heap, exact=true),
      ),
    ),
  )
  match @ir.hot_type_results(func, @ir.hot_node_type(func, root)) {
    [@lib.ValType::RefTypeValType(ref_type)] => {
      @debug.assert_eq(ref_type.is_non_nullable(), true)
      @debug.assert_eq(ref_type.is_exact(), true)
      @debug.assert_eq(ref_type.get_heap_type(), described_heap)
    }
    other => fail("expected exact non-null ref.cast_desc_eq type, got \{other}")
  }
}

///|
test "optimize-instructions exactifies nullable descriptor casts with exact descriptor operands" {
  // OI-J descriptor exactness breadth: Binaryen version_130 rewrites a nullable
  // descriptor equality cast fed by an inexact nullable reference plus an exact
  // descriptor object for the same heap to `ref.cast_desc_eq (ref null (exact
  // $target))`. The descriptor equality check remains; only the result type's
  // exactness is strengthened. This does not claim ref.test_desc, TNH/IIT, or
  // subtype descriptor breadth beyond exact same-target descriptor operands.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let described_heap = @lib.HeapType::new(described_type)
  let nullable_described_ref_type = @lib.RefType::new(true, described_heap)
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func(
              [@lib.ValType::ref_type(nullable_described_ref_type)],
              [@lib.ValType::ref_type(nullable_described_ref_type)],
            ),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([@lib.TypeIdx::new(2U)]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::struct_new_default(descriptor_type),
            @lib.Instruction::ref_cast_desc_eq_type(nullable_described_ref_type),
          ]),
        ),
      ]),
    )
  let func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(0U))
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    module_ctx=Some(@ir.hot_module_context_from_module(module_)),
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) => fail("expected nullable descriptor exactification, got \{err}")
  }
  let root = @ir.hot_root_get(func, 0)
  @debug.assert_eq(@ir.hot_child_count(func, root), 2)
  match @ir.hot_node_exact_instr(func, root) {
    Some(@lib.Instruction::RefCastDescEq(nullable, exact, target)) => {
      @debug.assert_eq(nullable, true)
      @debug.assert_eq(exact, true)
      @debug.assert_eq(target, described_heap)
    }
    other => fail("expected exactified nullable descriptor cast, got \{other}")
  }
}

///|
test "optimize-instructions skips descriptor equality casts under traps-never-happen for exact operands" {
  // OI-J TNH descriptor slice: Binaryen version_130 with
  // `--traps-never-happen --optimize-instructions` removes a descriptor
  // equality cast when the reference operand is already an exact non-null
  // target, because the only remaining observable behavior would be the
  // descriptor equality trap. The explicit descriptor operand may only be
  // erased when it is locally erasable; this test covers the pure fresh
  // descriptor allocation case and does not claim IIT or ref.test_desc support.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let described_heap = @lib.HeapType::new(described_type)
  let nullable_described_ref_type = @lib.RefType::new(true, described_heap)
  let func = @ir.hot_lift_func(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [
              @lib.ValType::ref_type(nullable_described_ref_type),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([@lib.TypeIdx::new(2U)]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::struct_new_default(descriptor_type),
            @lib.Instruction::struct_new_default_desc(described_type),
            @lib.Instruction::struct_new_default(descriptor_type),
            @lib.Instruction::ref_cast_desc_eq_type(nullable_described_ref_type),
          ]),
        ),
      ]),
    ),
    @lib.FuncIdx::new(0U),
  )
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    traps_never_happen=true,
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) => fail("expected descriptor TNH skip success, got \{err}")
  }
  let root = @ir.hot_root_get(func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(func, root),
    Some(@lib.Instruction::struct_new_default_desc(described_type)),
  )
  match @ir.hot_type_results(func, @ir.hot_node_type(func, root)) {
    [@lib.ValType::RefTypeValType(ref_type)] => {
      @debug.assert_eq(ref_type.is_non_nullable(), true)
      @debug.assert_eq(ref_type.is_exact(), true)
      @debug.assert_eq(ref_type.get_heap_type(), described_heap)
    }
    other => fail("expected exact descriptor-constructor result, got \{other}")
  }
}

///|
test "optimize-instructions erases nontrapping ref.get_desc descriptor operands under traps-never-happen" {
  // OI-J TNH descriptor operand breadth: Binaryen version_130 with
  // `--traps-never-happen --optimize-instructions` removes a descriptor
  // equality cast whose explicit descriptor operand is `ref.get_desc` of an
  // already-non-null reference. The `ref.get_desc` operand is only erased here
  // because its child cannot trap and has no effects; effectful descriptor
  // operands and ref.test_desc remain open.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let func_type = @lib.TypeIdx::new(2U)
  let described_heap = @lib.HeapType::new(described_type)
  let described_ref_type = @lib.RefType::new(false, described_heap)
  let func = @ir.hot_lift_func(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::ref_type(described_ref_type)], [
              @lib.ValType::ref_type(described_ref_type),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([func_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_get_desc(described_type),
            @lib.Instruction::ref_cast_desc_eq_type(described_ref_type),
          ]),
        ),
      ]),
    ),
    @lib.FuncIdx::new(0U),
  )
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    traps_never_happen=true,
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) =>
      fail("expected descriptor TNH ref.get_desc skip success, got \{err}")
  }
  let root = @ir.hot_root_get(func, 0)
  let root_node = @ir.hot_node_get(func, root)
  match root_node.op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected local.get after TNH ref.get_desc descriptor erase")
  }
  @debug.assert_eq(root_node.imm0, 0)
  @debug.assert_eq(@ir.hot_child_count(func, root), 0)
}

///|
test "optimize-instructions preserves descriptor effects when skipping descriptor casts under traps-never-happen" {
  // OI-J TNH/effect boundary: ignoring the descriptor-equality trap under TNH
  // must not erase the explicit descriptor operand's side effects. Binaryen
  // preserves a mutable-global descriptor write/read before producing the exact
  // reference result. This covers a representable effectful descriptor operand;
  // broader effectful reference operands and ref.test_desc remain open.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let described_heap = @lib.HeapType::new(described_type)
  let descriptor_heap = @lib.HeapType::new(descriptor_type)
  let nullable_described_ref_type = @lib.RefType::new(true, described_heap)
  let descriptor_ref_type = @lib.RefType::new(
    false,
    descriptor_heap,
    exact=true,
  )
  let func = @ir.hot_lift_func(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::ref_type(descriptor_ref_type)], [
              @lib.ValType::ref_type(nullable_described_ref_type),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([@lib.TypeIdx::new(2U)]))
    .with_global_sec(
      @lib.GlobalSec::new([
        @lib.Global::new(
          @lib.GlobalType::new(
            @lib.ValType::ref_type(descriptor_ref_type),
            true,
          ),
          @lib.Expr::new([@lib.Instruction::struct_new_default(descriptor_type)]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::struct_new_default(descriptor_type),
            @lib.Instruction::struct_new_default_desc(described_type),
            @lib.Instruction::block(
              @lib.BlockType::val_type(
                @lib.ValType::ref_type(descriptor_ref_type),
              ),
              @lib.Expr::new([
                @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
                @lib.Instruction::global_set(@lib.GlobalIdx::new(0U)),
                @lib.Instruction::global_get(@lib.GlobalIdx::new(0U)),
              ]),
            ),
            @lib.Instruction::ref_cast_desc_eq_type(nullable_described_ref_type),
          ]),
        ),
      ]),
    ),
    @lib.FuncIdx::new(0U),
  )
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    traps_never_happen=true,
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) => fail("expected descriptor TNH effect preservation, got \{err}")
  }
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_get(func, root).op {
    @ir.HotOp::Block => ()
    _ => fail("expected effect-preserving descriptor TNH skip block")
  }
  @debug.assert_eq(@ir.hot_child_count(func, root), 2)
  let dropped_descriptor = @ir.hot_child_get(func, root, 0)
  match @ir.hot_node_get(func, dropped_descriptor).op {
    @ir.HotOp::Drop => ()
    _ => fail("expected descriptor operand to be preserved as a dropped prefix")
  }
  let result = @ir.hot_child_get(func, root, 1)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(func, result),
    Some(@lib.Instruction::struct_new_default_desc(described_type)),
  )
}

///|
test "optimize-instructions folds descriptor equality casts on known null refs with pure descriptors" {
  // OI-J representable descriptor success/null boundary: nullable descriptor
  // casts of null return null, and non-null descriptor casts of null trap. The
  // explicit descriptor operand may only be erased when it is pure; broader
  // descriptor equality, ref.test_desc, TNH, and IIT behavior remain open.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let nullable_func_type = @lib.TypeIdx::new(2U)
  let nonnull_func_type = @lib.TypeIdx::new(3U)
  let described_heap = @lib.HeapType::new(described_type)
  let descriptor_heap = @lib.HeapType::new(descriptor_type)
  let nullable_described_ref_type = @lib.RefType::new(
    true,
    described_heap,
    exact=true,
  )
  let nonnull_described_ref_type = @lib.RefType::new(
    false,
    described_heap,
    exact=true,
  )
  let descriptor_ref = @lib.ValType::ref_type(
    @lib.RefType::new(false, descriptor_heap, exact=true),
  )
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([descriptor_ref], [
              @lib.ValType::ref_type(nullable_described_ref_type),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([descriptor_ref], [
              @lib.ValType::ref_type(nonnull_described_ref_type),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([nullable_func_type, nonnull_func_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::ref_null_type(nullable_described_ref_type),
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_cast_desc_eq_type(nullable_described_ref_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::ref_null_type(nullable_described_ref_type),
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_cast_desc_eq_type(nonnull_described_ref_type),
          ]),
        ),
      ]),
    ),
  )
  let nullable_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  let nonnull_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_false(
    nullable_pretty.contains("ref.cast_desc_eq"),
    msg=nullable_pretty,
  )
  assert_true(nullable_pretty.contains("ref.null"), msg=nullable_pretty)
  assert_false(nullable_pretty.contains("local.get"), msg=nullable_pretty)
  assert_false(nonnull_pretty.contains("ref.cast_desc_eq"), msg=nonnull_pretty)
  assert_true(nonnull_pretty.contains("unreachable"), msg=nonnull_pretty)
  assert_false(nonnull_pretty.contains("local.get"), msg=nonnull_pretty)
}

///|
test "optimize-instructions preserves descriptor effects while folding known-null descriptor casts" {
  // OI-J descriptor/effect boundary: known-null descriptor casts can fold only
  // when the explicit descriptor operand is still evaluated. A block that
  // writes then rereads a mutable descriptor global is a representable
  // non-pure descriptor operand; nullable casts become null after that operand
  // is dropped, and non-null casts become unreachable after the same prefix.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let nullable_func_type = @lib.TypeIdx::new(2U)
  let nonnull_func_type = @lib.TypeIdx::new(3U)
  let described_heap = @lib.HeapType::new(described_type)
  let descriptor_heap = @lib.HeapType::new(descriptor_type)
  let nullable_described_ref_type = @lib.RefType::new(
    true,
    described_heap,
    exact=true,
  )
  let nonnull_described_ref_type = @lib.RefType::new(
    false,
    described_heap,
    exact=true,
  )
  let descriptor_ref_type = @lib.RefType::new(
    false,
    descriptor_heap,
    exact=true,
  )
  let descriptor_ref = @lib.ValType::ref_type(descriptor_ref_type)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([descriptor_ref], [
              @lib.ValType::ref_type(nullable_described_ref_type),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([descriptor_ref], [
              @lib.ValType::ref_type(nonnull_described_ref_type),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([nullable_func_type, nonnull_func_type]))
    .with_global_sec(
      @lib.GlobalSec::new([
        @lib.Global::new(
          @lib.GlobalType::new(descriptor_ref, true),
          @lib.Expr::new([@lib.Instruction::struct_new_default(descriptor_type)]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::ref_null_type(nullable_described_ref_type),
            @lib.Instruction::block(
              @lib.BlockType::val_type(descriptor_ref),
              @lib.Expr::new([
                @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
                @lib.Instruction::global_set(@lib.GlobalIdx::new(0U)),
                @lib.Instruction::global_get(@lib.GlobalIdx::new(0U)),
              ]),
            ),
            @lib.Instruction::ref_cast_desc_eq_type(nullable_described_ref_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::ref_null_type(nullable_described_ref_type),
            @lib.Instruction::block(
              @lib.BlockType::val_type(descriptor_ref),
              @lib.Expr::new([
                @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
                @lib.Instruction::global_set(@lib.GlobalIdx::new(0U)),
                @lib.Instruction::global_get(@lib.GlobalIdx::new(0U)),
              ]),
            ),
            @lib.Instruction::ref_cast_desc_eq_type(nonnull_described_ref_type),
          ]),
        ),
      ]),
    ),
  )
  let nullable_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  let nonnull_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_false(
    nullable_pretty.contains("ref.cast_desc_eq"),
    msg=nullable_pretty,
  )
  assert_true(nullable_pretty.contains("ref.null"), msg=nullable_pretty)
  assert_true(nullable_pretty.contains("local.get"), msg=nullable_pretty)
  assert_true(nullable_pretty.contains("global.set"), msg=nullable_pretty)
  assert_true(nullable_pretty.contains("global.get"), msg=nullable_pretty)
  assert_true(nullable_pretty.contains("drop"), msg=nullable_pretty)
  assert_false(nonnull_pretty.contains("ref.cast_desc_eq"), msg=nonnull_pretty)
  assert_true(nonnull_pretty.contains("unreachable"), msg=nonnull_pretty)
  assert_true(nonnull_pretty.contains("local.get"), msg=nonnull_pretty)
  assert_true(nonnull_pretty.contains("global.set"), msg=nonnull_pretty)
  assert_true(nonnull_pretty.contains("global.get"), msg=nonnull_pretty)
  assert_true(nonnull_pretty.contains("drop"), msg=nonnull_pretty)
}

///|
test "optimize-instructions erases descriptor allocation while folding known-null descriptor casts" {
  // OI-J descriptor/allocation boundary: Binaryen version_130 treats a freshly
  // allocated descriptor operand to a known-null descriptor cast as removable.
  // This is narrower than the effect-preserving mutable-global case above;
  // descriptor reads/effects, ref.test_desc, TNH, and IIT remain open.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let nullable_func_type = @lib.TypeIdx::new(2U)
  let nonnull_func_type = @lib.TypeIdx::new(3U)
  let described_heap = @lib.HeapType::new(described_type)
  let descriptor_heap = @lib.HeapType::new(descriptor_type)
  let nullable_described_ref_type = @lib.RefType::new(
    true,
    described_heap,
    exact=true,
  )
  let nonnull_described_ref_type = @lib.RefType::new(
    false,
    described_heap,
    exact=true,
  )
  let descriptor_ref = @lib.ValType::ref_type(
    @lib.RefType::new(false, descriptor_heap, exact=true),
  )
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([descriptor_ref], [
              @lib.ValType::ref_type(nullable_described_ref_type),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([descriptor_ref], [
              @lib.ValType::ref_type(nonnull_described_ref_type),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([nullable_func_type, nonnull_func_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::ref_null_type(nullable_described_ref_type),
            @lib.Instruction::struct_new_default(descriptor_type),
            @lib.Instruction::ref_cast_desc_eq_type(nullable_described_ref_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::ref_null_type(nullable_described_ref_type),
            @lib.Instruction::struct_new_default(descriptor_type),
            @lib.Instruction::ref_cast_desc_eq_type(nonnull_described_ref_type),
          ]),
        ),
      ]),
    ),
  )
  let nullable_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  let nonnull_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_false(
    nullable_pretty.contains("ref.cast_desc_eq"),
    msg=nullable_pretty,
  )
  assert_true(nullable_pretty.contains("ref.null"), msg=nullable_pretty)
  assert_false(
    nullable_pretty.contains("struct.new_default"),
    msg=nullable_pretty,
  )
  assert_false(nonnull_pretty.contains("ref.cast_desc_eq"), msg=nonnull_pretty)
  assert_true(nonnull_pretty.contains("unreachable"), msg=nonnull_pretty)
  assert_false(
    nonnull_pretty.contains("struct.new_default"),
    msg=nonnull_pretty,
  )
}

///|
test "optimize-instructions retargets bottom null when folding nullable descriptor casts" {
  // OI-J descriptor/null exactness slice: Binaryen accepts bottom-typed
  // `(ref.null none)` as the reference input to a descriptor equality cast and,
  // when the nullable cast folds, leaves a null value usable for the declared
  // target. Starshine must not reuse the bottom-typed input node after folding,
  // because HOT/lowering validation needs the replacement to carry the nullable
  // target heap exactly while preserving the descriptor operand call as a drop
  // prefix.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let described_heap = @lib.HeapType::new(described_type)
  let descriptor_heap = @lib.HeapType::new(descriptor_type)
  let nullable_described_ref_type = @lib.RefType::new(
    true,
    described_heap,
    exact=true,
  )
  let descriptor_ref = @lib.ValType::ref_type(
    @lib.RefType::new(false, descriptor_heap, exact=true),
  )
  let descriptor_func_type = @lib.TypeIdx::new(2U)
  let nullable_func_type = @lib.TypeIdx::new(3U)
  let func = @ir.hot_lift_func(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(@lib.CompType::func([], [descriptor_ref])),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [
              @lib.ValType::ref_type(nullable_described_ref_type),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([descriptor_func_type, nullable_func_type]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::struct_new_default(descriptor_type)]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::ref_null(
              @lib.HeapType::abs(@lib.AbsHeapType::none()),
            ),
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::ref_cast_desc_eq_type(nullable_described_ref_type),
          ]),
        ),
      ]),
    ),
    @lib.FuncIdx::new(1U),
  )
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) => fail("expected descriptor bottom-null fold success, got \{err}")
  }
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_get(func, root).op {
    @ir.HotOp::Block => ()
    _ => fail("expected descriptor call to be preserved as a dropped prefix")
  }
  let replacement = @ir.hot_child_get(func, root, 1)
  match @ir.hot_const_get(func, @ir.hot_node_get(func, replacement).imm0) {
    @ir.HotConstPayload::RefNullConst(ref_type) =>
      @debug.assert_eq(ref_type, nullable_described_ref_type)
    other => fail("expected typed ref.null replacement, got \{other}")
  }
}

///|
test "optimize-instructions raw skip retargets bottom null descriptor casts" {
  // Active dispatcher guard for the same OI-J bottom-null descriptor case above:
  // stack-carried descriptor calls can take the raw-skip path, so the public
  // pipeline must still rewrite the descriptor cast to a typed nullable null or
  // non-null trap before final validation.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let descriptor_func_type = @lib.TypeIdx::new(2U)
  let nullable_func_type = @lib.TypeIdx::new(3U)
  let nonnull_func_type = @lib.TypeIdx::new(4U)
  let described_heap = @lib.HeapType::new(described_type)
  let descriptor_heap = @lib.HeapType::new(descriptor_type)
  let nullable_described_ref_type = @lib.RefType::new(
    true,
    described_heap,
    exact=true,
  )
  let nonnull_described_ref_type = @lib.RefType::new(
    false,
    described_heap,
    exact=true,
  )
  let descriptor_ref = @lib.ValType::ref_type(
    @lib.RefType::new(false, descriptor_heap, exact=true),
  )
  let mod_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(@lib.CompType::func([], [descriptor_ref])),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [
              @lib.ValType::ref_type(nullable_described_ref_type),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [
              @lib.ValType::ref_type(nonnull_described_ref_type),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        descriptor_func_type, nullable_func_type, nonnull_func_type,
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::struct_new_default(descriptor_type)]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::ref_null(
              @lib.HeapType::abs(@lib.AbsHeapType::none()),
            ),
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::ref_cast_desc_eq_type(nullable_described_ref_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::ref_null(
              @lib.HeapType::abs(@lib.AbsHeapType::none()),
            ),
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::ref_cast_desc_eq_type(nonnull_described_ref_type),
          ]),
        ),
      ]),
    )
  let optimized = match
    run_hot_pipeline(mod_, HotPipelineOptions::new(), ["optimize-instructions"]) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected raw-skip descriptor bottom-null success, got \{err}")
  }
  match @validate.validate_module(optimized) {
    Ok(_) => ()
    Err(err) => fail(@validate.validation_error_message(err))
  }
  let nullable_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  let nonnull_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_false(
    nullable_pretty.contains("ref.cast_desc_eq"),
    msg=nullable_pretty,
  )
  assert_true(nullable_pretty.contains("ref.null"), msg=nullable_pretty)
  assert_true(nullable_pretty.contains("call"), msg=nullable_pretty)
  assert_false(nonnull_pretty.contains("ref.cast_desc_eq"), msg=nonnull_pretty)
  assert_true(nonnull_pretty.contains("unreachable"), msg=nonnull_pretty)
  assert_true(nonnull_pretty.contains("call"), msg=nonnull_pretty)
}

///|
test "optimize-instructions folds nullable ref.test and ref.cast on known null refs" {
  let eq_heap = @lib.HeapType::abs(@lib.AbsHeapType::eq())
  let eq_ref = @lib.ValType::ref_null(eq_heap)
  let i32_type = @lib.TypeIdx::new(0U)
  let eq_type = @lib.TypeIdx::new(1U)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::i32()]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(@lib.CompType::func([], [eq_ref])),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([i32_type, eq_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::ref_null(eq_heap),
            @lib.Instruction::ref_test(true, eq_heap),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::ref_null(eq_heap),
            @lib.Instruction::ref_cast(true, eq_heap),
          ]),
        ),
      ]),
    ),
  )
  let test_nullable = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  let cast_nullable = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_false(test_nullable.contains("ref.test"), msg=test_nullable)
  assert_true(test_nullable.contains("I32(1)"), msg=test_nullable)
  assert_true(cast_nullable.contains("ref.null"), msg=cast_nullable)
  assert_false(cast_nullable.contains("ref.cast"), msg=cast_nullable)
}

///|
test "optimize-instructions folds non-null ref.test and ref.cast on known null refs" {
  let eq_heap = @lib.HeapType::abs(@lib.AbsHeapType::eq())
  let non_null_eq_ref = @lib.ValType::ref_type(
    @lib.RefType::new(false, eq_heap),
  )
  let i32_type = @lib.TypeIdx::new(0U)
  let eq_type = @lib.TypeIdx::new(1U)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::i32()]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(@lib.CompType::func([], [non_null_eq_ref])),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([i32_type, eq_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::ref_null(eq_heap),
