    Some(@lib.Instruction::i64_ne()),
  )
  let lt8_lhs = @ir.hot_child_get(lt8_func, lt8_root, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(lt8_func, lt8_lhs),
    Some(@lib.Instruction::i64_extend8s()),
  )
  @debug.assert_eq(
    @ir.hot_const_get(
