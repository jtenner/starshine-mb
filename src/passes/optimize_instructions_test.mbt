  @debug.assert_eq(
    locals,
    @lib.Locals::from_types([@lib.ValType::i32(), @lib.ValType::i32()]),
  )
}

///|
test "optimize-instructions does not reorder relational local gets across control-bearing tee payloads" {
  let func = @ir.HotFunc::new(
    locals=@ir.HotLocals::new(params=[@lib.ValType::i32()], locals=[
      @lib.ValType::i32(),
      @lib.ValType::i32(),
    ]),
  )
  let block = @ir.hot_build_block(
    func,
    @lib.BlockType::val_type(@lib.ValType::i32()),
    [],
  )
  let label = @ir.hot_control_node_label(func, block)
  @ir.hot_region_replace_body(func, @ir.hot_region_body_ref(func, block), [
    @ir.hot_build_br(func, label, values=[
      @ir.hot_build_const_i32(func, @lib.I32(7)),
    ]),
  ])
  let tee = @ir.hot_build_local_tee(func, 2, block)
  let limit = @ir.hot_build_local_get(func, 0)
  let compare = @ir.hot_build_compare(func, tee, limit)
  @ir.hot_node_exact_instr_set(func, compare, @lib.Instruction::i32_lt_s())
  @ir.hot_root_append(func, @ir.hot_build_drop(func, compare))
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
  )

  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) =>
      fail("expected optimize-instructions control-tee success, got \{err}")
  }

  @debug.assert_eq(
    @ir.hot_node_exact_instr(func, compare),
    Some(@lib.Instruction::i32_lt_s()),
  )
  match @ir.hot_node_get(func, @ir.hot_child_get(func, compare, 0)).op {
    @ir.HotOp::LocalTee => ()
    _ => fail("expected control-bearing tee subtree to stay on the lhs")
  }
}

///|
test "optimize-instructions does not reorder relational local gets across loop-carried tees" {
  let fixture = @ir.ir_test_build_hot_from_wat(
    "(module (func (param i32) (result i32) (local i32) (block (result i32) (i32.const 0) (loop (param i32) (result i32) (if (result i32) (i32.lt_s (local.tee 1) (local.get 0)) (then (local.get 1) (i32.const 1) (i32.add) (br 1)) (else (local.get 1)))))))",
  )
  let func = fixture.hot_func
  let block_id = @ir.hot_root_get(func, 0)
  let block_body = @ir.hot_region_body_ref(func, block_id)
  let loop_id = @ir.hot_region_get(func, block_body, 0)
  let body_region = @ir.hot_region_body_ref(func, loop_id)
  let if_id = @ir.hot_region_get(func, body_region, 0)
  let compare = @ir.hot_child_get(func, if_id, 0)
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
  )

  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) =>
      fail("expected optimize-instructions loop-carried success, got \{err}")
  }

  @debug.assert_eq(
    @ir.hot_node_exact_instr(func, compare),
    Some(@lib.Instruction::i32_lt_s()),
  )
  match @ir.hot_node_get(func, @ir.hot_child_get(func, compare, 0)).op {
    @ir.HotOp::LocalTee => ()
    _ => fail("expected loop-carried tee subtree to stay on the lhs")
  }
  match @ir.hot_node_get(func, @ir.hot_child_get(func, compare, 1)).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected loop-carried limit local.get to stay on the rhs")
  }
}

///|
test "optimize-instructions visits shared dags once" {
  let func = optimize_instructions_shared_dag_fixture(24)
  let node_count = @ir.hot_node_count(func)
  let perf = HotPerfSession::new()
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    perf=Some(perf),
  )

  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) =>
      fail("expected optimize-instructions shared-dag success, got \{err}")
  }

  let counters = perf_counters(perf)
  // The descriptor truthfully requires UseDef and Effects, so the shared perf
  // session sees one node traversal for each required analysis plus the pass
  // walk. This still guards that the pass itself visits the shared DAG once.
  @debug.assert_eq(counters.traversal_visits, node_count * 3)
}

///|
test "optimize-instructions folds second+fourth+fifth+sixth trees in six-operand mixed i64-result calls" {
  // Red-first OI-F parity slice: Binaryen version_130 independently checks
  // exact add(local, const) trees in operands 2, 4, 5, and 6 around direct
  // first and third leaves on annotated
  // (i32, i64, i32, i64, i32, i64) -> i64 calls in the canonical i64
  // zero-test self-select. A mismatch in any logical slot retains both calls.
  // Source: `OptimizeInstructions.cpp:2891-2947`; oracle:
  // `.tmp/oi-probes/select-idempotent-call-six-i64-result-canonical-final-four-and-first-five-tree-foldability.wat`
  // (`second_fourth_fifth_sixth_equal` and its six mismatch functions).
  let optimize_caller = fn(
    right_first_const : Int,
    right_second_tree_const : Int64,
    right_third_const : Int,
    right_fourth_tree_const : Int64,
    right_fifth_tree_const : Int,
    right_sixth_tree_const : Int64,
  ) raise {
    let wat = "(module (@binaryen.idempotent) (func $id (param i32 i64 i32 i64 i32 i64) (result i64) local.get 0 i64.extend_i32_u local.get 1 i64.add local.get 2 i64.extend_i32_u i64.add local.get 3 i64.add local.get 4 i64.extend_i32_u i64.add local.get 5 i64.add) (func (param i64 i64 i32 i64) (result i64) i64.const 0 i32.const 3 local.get 0 i64.const 5 i64.add i32.const 7 local.get 1 i64.const 11 i64.add local.get 2 i32.const 13 i32.add local.get 3 i64.const 17 i64.add call $id i32.const " +
      right_first_const.to_string() +
      " local.get 0 i64.const " +
      right_second_tree_const.to_string() +
      " i64.add i32.const " +
      right_third_const.to_string() +
      " local.get 1 i64.const " +
      right_fourth_tree_const.to_string() +
      " i64.add local.get 2 i32.const " +
      right_fifth_tree_const.to_string() +
      " i32.add local.get 3 i64.const " +
      right_sixth_tree_const.to_string() +
      " i64.add call $id i64.eqz select))"
    let optimized = match
      pass_test_run_pipeline(wat, ["optimize-instructions"]) {
      Ok(mod_) => mod_
      Err(err) =>
        fail(
          "expected second+fourth+fifth+sixth-tree six-operand mixed i64-result call OI success, got \{err}",
        )
    }
    optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  }
  let equal = optimize_caller(3, 5L, 7, 11L, 13, 17L)
  assert_false(equal.contains("select"), msg=equal)
  @debug.assert_eq(
    optimize_instructions_test_count_substring(equal, "call (Func 0)"),
    1,
  )
  for
    output in [
      optimize_caller(4, 5L, 7, 11L, 13, 17L),
      optimize_caller(3, 6L, 7, 11L, 13, 17L),
      optimize_caller(3, 5L, 8, 11L, 13, 17L),
      optimize_caller(3, 5L, 7, 12L, 13, 17L),
      optimize_caller(3, 5L, 7, 11L, 14, 17L),
      optimize_caller(3, 5L, 7, 11L, 13, 18L),
    ] {
    assert_true(output.contains("select"), msg=output)
    @debug.assert_eq(
      optimize_instructions_test_count_substring(output, "call (Func 0)"),
      2,
    )
  }
}

///|
