  // Grouped OI-G follow-up from
  // `.tmp/oi-g-runtime-select-fill-restore-count648-20260629`: select-produced
  // constant destination/value/size operands made the raw-skipped path keep a
  // size-1 `memory.fill` that Binaryen lowers to `i32.store8`. Keep the rewrite
  // narrow to pure constant select shells so source-visible restore/read
  // behavior is unchanged.
  let source = StringBuilder::new()
