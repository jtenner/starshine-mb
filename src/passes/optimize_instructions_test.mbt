    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func (param $x i32) (result i32)
        #|    local.get $x
        #|    i32.const 255
        #|    i32.and
        #|    i32.const 128
        #|    i32.lt_s)
        #|  (func (param $x i64) (result i32)
        #|    local.get $x
        #|    i64.const 8
        #|    i64.shr_u
        #|    i64.const 42
        #|    i64.ge_s)
        #|  (func (param $p i32) (result i32)
        #|    local.get $p
        #|    i32.load8_u
        #|    i32.const 128
        #|    i32.lt_s))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) =>
