///|
test "optimize-instructions folds integer eq/ne constant compares" {
  // Red-first OI-D parity slice: Binaryen `version_130`
  // `--optimize-instructions` folds same-width integer equality/inequality
  // with two constant operands to `i32.const 0/1`; signed/unsigned relational
  // constant pairs remain separate because the observed oracle probe keeps or
  // canonicalizes those spellings instead of folding them to constants.
  let i32_eq_func = optimize_instructions_test_run_hot(
    "(module (func (result i32) i32.const 7 i32.const 7 i32.eq))",
  )
  let i32_eq_root = @ir.hot_root_get(i32_eq_func, 0)
  match @ir.hot_node_get(i32_eq_func, i32_eq_root).op {
    @ir.HotOp::Const => ()
    _ => fail("expected constant i32.eq to fold to a const")
  }
  @debug.assert_eq(
    @ir.hot_const_get(
      i32_eq_func,
      @ir.hot_node_get(i32_eq_func, i32_eq_root).imm0,
    ),
    @ir.HotConstPayload::i32_const(@lib.I32(1)),
  )

  let i32_ne_func = optimize_instructions_test_run_hot(
    "(module (func (result i32) i32.const 7 i32.const 8 i32.ne))",
  )
  let i32_ne_root = @ir.hot_root_get(i32_ne_func, 0)
  match @ir.hot_node_get(i32_ne_func, i32_ne_root).op {
    @ir.HotOp::Const => ()
    _ => fail("expected constant i32.ne to fold to a const")
  }
  @debug.assert_eq(
    @ir.hot_const_get(
      i32_ne_func,
      @ir.hot_node_get(i32_ne_func, i32_ne_root).imm0,
    ),
    @ir.HotConstPayload::i32_const(@lib.I32(1)),
  )

  let i64_eq_func = optimize_instructions_test_run_hot(
    "(module (func (result i32) i64.const 7 i64.const 8 i64.eq))",
  )
  let i64_eq_root = @ir.hot_root_get(i64_eq_func, 0)
  match @ir.hot_node_get(i64_eq_func, i64_eq_root).op {
    @ir.HotOp::Const => ()
    _ => fail("expected constant i64.eq to fold to a const")
  }
  @debug.assert_eq(
    @ir.hot_const_get(
      i64_eq_func,
      @ir.hot_node_get(i64_eq_func, i64_eq_root).imm0,
    ),
    @ir.HotConstPayload::i32_const(@lib.I32(0)),
  )

  let i64_ne_func = optimize_instructions_test_run_hot(
    "(module (func (result i32) i64.const 7 i64.const 8 i64.ne))",
  )
  let i64_ne_root = @ir.hot_root_get(i64_ne_func, 0)
  match @ir.hot_node_get(i64_ne_func, i64_ne_root).op {
    @ir.HotOp::Const => ()
    _ => fail("expected constant i64.ne to fold to a const")
  }
  @debug.assert_eq(
    @ir.hot_const_get(
      i64_ne_func,
      @ir.hot_node_get(i64_ne_func, i64_ne_root).imm0,
    ),
    @ir.HotConstPayload::i32_const(@lib.I32(1)),
  )
}

///|
fn optimize_instructions_test_assert_i32_const_result(
  wat : String,
  expected : Int,
  label : String,
) -> Unit raise {
  let func = optimize_instructions_test_run_hot(wat)
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_get(func, root).op {
    @ir.HotOp::Const => ()
    _ => fail("expected \{label} to fold to a const")
  }
  @debug.assert_eq(
    @ir.hot_const_get(func, @ir.hot_node_get(func, root).imm0),
    @ir.HotConstPayload::i32_const(@lib.I32(expected)),
  )
}

///|
test "optimize-instructions folds signed constant relational nonnegative-negative pairs" {
  // Coverage/status OI-D slice: Binaryen `version_130`
  // `--optimize-instructions` folds signed relational constant pairs when a
  // nonnegative lhs is compared with a negative rhs. Keep the proof to this
  // sign-disjoint direction because the sibling negative-vs-nonnegative
  // constants remain a mixed keep/canonicalize boundary below.
  optimize_instructions_test_assert_i32_const_result(
    "(module (func (result i32) i32.const 1 i32.const -2 i32.lt_s))", 0, "i32.lt_s",
  )
  optimize_instructions_test_assert_i32_const_result(
    "(module (func (result i32) i32.const 1 i32.const -2 i32.le_s))", 0, "i32.le_s",
  )
  optimize_instructions_test_assert_i32_const_result(
    "(module (func (result i32) i32.const 1 i32.const -2 i32.gt_s))", 1, "i32.gt_s",
  )
  optimize_instructions_test_assert_i32_const_result(
    "(module (func (result i32) i32.const 1 i32.const -2 i32.ge_s))", 1, "i32.ge_s",
  )
  optimize_instructions_test_assert_i32_const_result(
    "(module (func (result i32) i64.const 1 i64.const -2 i64.lt_s))", 0, "i64.lt_s",
  )
  optimize_instructions_test_assert_i32_const_result(
    "(module (func (result i32) i64.const 1 i64.const -2 i64.le_s))", 0, "i64.le_s",
  )
  optimize_instructions_test_assert_i32_const_result(
    "(module (func (result i32) i64.const 1 i64.const -2 i64.gt_s))", 1, "i64.gt_s",
  )
  optimize_instructions_test_assert_i32_const_result(
    "(module (func (result i32) i64.const 1 i64.const -2 i64.ge_s))", 1, "i64.ge_s",
  )
}

///|
test "optimize-instructions keeps signed constant relational mixed boundary" {
  // Boundary/status-only OI-D coverage: Binaryen `version_130`
  // `--optimize-instructions` is mixed for signed relational constant pairs.
  // The oracle probe `.tmp/oi-d-signed-rel-next-probe.wat` canonicalizes
  // `-2 < 1` through a zero compare, keeps `-5 > 5`, and only folds other
  // selected signed pairs. Keep this test narrow so Starshine does not
  // accidentally generalize the unsigned constant relational fold to all signed
  // relational constants.
  let canonical_func = optimize_instructions_test_run_hot(
    "(module (func (result i32) i32.const -2 i32.const 1 i32.lt_s))",
  )
  let canonical_root = @ir.hot_root_get(canonical_func, 0)
  match @ir.hot_node_get(canonical_func, canonical_root).op {
    @ir.HotOp::Compare => ()
    _ => fail("expected signed const lt_s boundary to stay a compare")
  }
  @debug.assert_eq(
    @ir.hot_node_exact_instr(canonical_func, canonical_root),
    Some(@lib.Instruction::i32_le_s()),
  )
  let canonical_rhs = @ir.hot_child_get(canonical_func, canonical_root, 1)
  @debug.assert_eq(
    @ir.hot_const_get(
      canonical_func,
      @ir.hot_node_get(canonical_func, canonical_rhs).imm0,
    ),
    @ir.HotConstPayload::i32_const(@lib.I32(0)),
  )

  let kept_func = optimize_instructions_test_run_hot(
    "(module (func (result i32) i64.const -5 i64.const 5 i64.gt_s))",
  )
  let kept_root = @ir.hot_root_get(kept_func, 0)
  match @ir.hot_node_get(kept_func, kept_root).op {
    @ir.HotOp::Compare => ()
    _ => fail("expected signed const gt_s boundary to stay a compare")
  }
  @debug.assert_eq(
    @ir.hot_node_exact_instr(kept_func, kept_root),
    Some(@lib.Instruction::i64_gt_s()),
  )
}

///|
test "optimize-instructions keeps negative signed constant relational compares" {
  // Boundary/status-only OI-D coverage: Binaryen `version_130`
  // `--optimize-instructions` keeps same-sign negative signed relational
  // constant pairs in the probed forms (`.tmp/oi-d-negative-signed-const-rel-probe.wat`).
  // This narrows the signed-constant boundary so the unsigned constant fold does
  // not become a blanket signed relational fold.
