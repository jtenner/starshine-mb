///|
test "optimize-instructions folds select with identical pure global arms" {
  // Red-first OI-F parity slice: Binaryen `version_130`
  // `--optimize-instructions` folds direct identical `global.get` select arms
  // when the condition is side-effect-free (`.tmp/oi-select-global-arms-probe.wat`).
  // This is intentionally only direct same-global equality, not structural
  // expression equality or an effectful/trapping condition claim.
  let func = optimize_instructions_test_run_hot(
    "(module (global $g (mut i32) (i32.const 42)) (func (param i32) (result i32) (select (global.get $g) (global.get $g) (local.get 0))))",
  )
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_get(func, root).op {
    @ir.HotOp::GlobalGet =>
      @debug.assert_eq(@ir.hot_node_get(func, root).imm0, 0)
    _ =>
      fail("expected identical pure global select arms to fold to global.get")
  }
}

///|
test "optimize-instructions keeps identical mutable global select arms across effectful condition" {
  // Red-first OI-F correctness/parity slice: Binaryen `version_130`
  // `--optimize-instructions` keeps identical `global.get` select arms when the
  // condition can mutate the global (`.tmp/oi-select-mutable-global-effectful-condition-probe.wat`).
  // Folding this to `drop(condition); global.get` would read the mutable global
  // after the call instead of before it, so the effectful-condition identical-arm
  // cleanup must not admit global leaves.
  let func = @ir.HotFunc::new()
  @ir.hot_body_result_type_set(
    func,
    @ir.hot_type_intern_value(func, @lib.ValType::i32()),
  )
  let lhs = @ir.hot_build_global_get(func, 0, @lib.ValType::i32())
  let rhs = @ir.hot_build_global_get(func, 0, @lib.ValType::i32())
  let condition = @ir.hot_build_call(func, 0, [@lib.ValType::i32()], [])
  @ir.hot_root_append(
    func,
    @ir.hot_build_select(func, @lib.ValType::i32(), lhs, rhs, condition),
  )
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) =>
      fail("expected mutable global select boundary success, got \{err}")
  }
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_get(func, root).op {
    @ir.HotOp::Select => {
      @debug.assert_eq(@ir.hot_node_get(func, root).child_count, 3)
      let lhs = @ir.hot_child_get(func, root, 0)
      let rhs = @ir.hot_child_get(func, root, 1)
      let condition = @ir.hot_child_get(func, root, 2)
      match @ir.hot_node_get(func, lhs).op {
        @ir.HotOp::GlobalGet => ()
        _ => fail("expected first global.get arm to stay")
      }
      match @ir.hot_node_get(func, rhs).op {
        @ir.HotOp::GlobalGet => ()
        _ => fail("expected second global.get arm to stay")
      }
      match @ir.hot_node_get(func, condition).op {
        @ir.HotOp::Call => ()
        _ => fail("expected effectful condition call to stay")
      }
    }
    _ =>
      fail(
        "expected identical mutable global select arms to stay across effectful condition",
      )
  }
}

///|
test "optimize-instructions preserves effectful condition when folding identical immutable global select arms" {
  // Red-first OI-F parity slice: Binaryen `version_130`
  // `--optimize-instructions` folds identical immutable `global.get` select arms
  // even when the condition is effectful, preserving that condition as a dropped
  // prefix (`.tmp/oi-select-immutable-global-effectful-probe.wat`). The mutable
  // global boundary above remains no-fold because calls may change mutable globals.
  let module_ctx = @ir.hot_module_context_from_module(
    @lib.Module::new().with_global_sec(
      @lib.GlobalSec::new([
        @lib.Global::new(
          @lib.GlobalType::new(@lib.ValType::i32(), false),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(42))]),
        ),
      ]),
    ),
  )
  let func = @ir.HotFunc::new()
  @ir.hot_body_result_type_set(
    func,
    @ir.hot_type_intern_value(func, @lib.ValType::i32()),
  )
  let lhs = @ir.hot_build_global_get(func, 0, @lib.ValType::i32())
  let rhs = @ir.hot_build_global_get(func, 0, @lib.ValType::i32())
  let condition = @ir.hot_build_call(func, 0, [@lib.ValType::i32()], [])
  @ir.hot_root_append(
    func,
    @ir.hot_build_select(func, @lib.ValType::i32(), lhs, rhs, condition),
  )
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    module_ctx=Some(module_ctx),
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) =>
      fail("expected immutable global select fold success, got \{err}")
  }
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_get(func, root).op {
    @ir.HotOp::Block => ()
    _ => fail("expected identical immutable global select arms to fold")
  }
}

///|
test "optimize-instructions folds select with identical nested select arms" {
  // Red-first OI-F fact slice: Binaryen `version_130`
  // `--optimize-instructions` folds a select whose arms are structurally
  // identical branchless select trees (`.tmp/oi-nested-select-arm-probe.wat`).
  // This locks the arm-equality path to the shared ExpressionAnalyzer-style
  // pure-tree fact instead of another local/const opcode whitelist.
  let func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32 i32 i32) (result i32) (select (select (local.get 0) (local.get 1) (local.get 2)) (select (local.get 0) (local.get 1) (local.get 2)) (local.get 3))))",
  )
  let root = @ir.hot_root_get(func, 0)
  let node = @ir.hot_node_get(func, root)
  match node.op {
    @ir.HotOp::Select => {
      @debug.assert_eq(node.child_count, 3)
      match @ir.hot_node_get(func, @ir.hot_child_get(func, root, 0)).op {
        @ir.HotOp::LocalGet => ()
        other =>
          fail(
            "expected outer select to fold to inner select, got first child \{other}",
          )
      }
    }
    other => fail("expected folded nested select root, got \{other}")
  }
}

///|
test "optimize-instructions folds select with identical memory.size arms" {
  // Red-first OI-F/OI-G fact slice: Binaryen `version_130`
  // `--optimize-instructions` folds identical `memory.size` select arms when the
  // condition is side-effect-free (`.tmp/oi-select-memorysize-arms-probe.wat`).
  // The matching is effect-sensitive state-read equality, not a pure scalar
  // opcode whitelist and not valid across an effectful/growing condition.
  let func = optimize_instructions_test_run_hot(
    "(module (memory 1) (func (param i32) (result i32) (select (memory.size) (memory.size) (local.get 0))))",
  )
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_get(func, root).op {
    @ir.HotOp::MemorySize => ()
    other =>
      fail("expected identical memory.size select arms to fold, got \{other}")
  }
}

