  )
  let i64_ne_operand = @ir.hot_child_get(i64_ne_func, i64_ne_root, 0)
  match @ir.hot_node_get(i64_ne_func, i64_ne_operand).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected eqz(ne i64 zero) rewrite to keep the original operand")
  }

  let i32_eq_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) local.get 0 i32.const 0 i32.eq i32.eqz))",
  )
  let i32_eq_root = @ir.hot_root_get(i32_eq_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(i32_eq_func, i32_eq_root),
    Some(@lib.Instruction::i32_ne()),
  )
  let i32_eq_lhs = @ir.hot_child_get(i32_eq_func, i32_eq_root, 0)
  let i32_eq_rhs = @ir.hot_child_get(i32_eq_func, i32_eq_root, 1)
  match @ir.hot_node_get(i32_eq_func, i32_eq_lhs).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected eqz(eq i32 zero) rewrite to keep the original operand")
  }
  @debug.assert_eq(
    @ir.hot_const_get(
      i32_eq_func,
      @ir.hot_node_get(i32_eq_func, i32_eq_rhs).imm0,
    ),
    @ir.HotConstPayload::i32_const(@lib.I32(0)),
  )
}

///|
test "optimize-instructions folds compare of eqz against boolean constants" {
  // Red-first OI-F boolean parity slice: Binaryen `version_130`
  // `--optimize-instructions` rewrites direct `i32.eq` / `i32.ne` compares
  // between an `i32.eqz` result and exact boolean constants. `eq(eqz(x), 0)`
  // and `ne(eqz(x), 1)` become `x != 0`; `ne(eqz(x), 0)` and
  // `eq(eqz(x), 1)` become `eqz(x)`. This deliberately does not claim
  // arbitrary boolean algebra, non-boolean constants, or branch rewrites.
  let eq_zero_rhs_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) local.get 0 i32.eqz i32.const 0 i32.eq))",
  )
  let eq_zero_rhs_root = @ir.hot_root_get(eq_zero_rhs_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(eq_zero_rhs_func, eq_zero_rhs_root),
    Some(@lib.Instruction::i32_ne()),
  )
  match
    @ir.hot_node_get(
      eq_zero_rhs_func,
      @ir.hot_child_get(eq_zero_rhs_func, eq_zero_rhs_root, 0),
    ).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected eq(eqz(x), 0) to keep the original operand")
  }
  @debug.assert_eq(
    @ir.hot_const_get(
      eq_zero_rhs_func,
      @ir.hot_node_get(
        eq_zero_rhs_func,
        @ir.hot_child_get(eq_zero_rhs_func, eq_zero_rhs_root, 1),
      ).imm0,
    ),
    @ir.HotConstPayload::i32_const(@lib.I32(0)),
  )

  let eq_zero_lhs_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) i32.const 0 local.get 0 i32.eqz i32.eq))",
  )
  let eq_zero_lhs_root = @ir.hot_root_get(eq_zero_lhs_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(eq_zero_lhs_func, eq_zero_lhs_root),
    Some(@lib.Instruction::i32_ne()),
  )

  let ne_zero_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) local.get 0 i32.eqz i32.const 0 i32.ne))",
  )
  let ne_zero_root = @ir.hot_root_get(ne_zero_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(ne_zero_func, ne_zero_root),
    Some(@lib.Instruction::i32_eqz()),
  )
  match
    @ir.hot_node_get(
      ne_zero_func,
      @ir.hot_child_get(ne_zero_func, ne_zero_root, 0),
    ).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected ne(eqz(x), 0) to keep the original operand")
  }

  let eq_one_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) local.get 0 i32.eqz i32.const 1 i32.eq))",
  )
  let eq_one_root = @ir.hot_root_get(eq_one_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(eq_one_func, eq_one_root),
    Some(@lib.Instruction::i32_eqz()),
  )

  let ne_one_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) local.get 0 i32.eqz i32.const 1 i32.ne))",
  )
  let ne_one_root = @ir.hot_root_get(ne_one_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(ne_one_func, ne_one_root),
    Some(@lib.Instruction::i32_ne()),
  )
}

///|
test "optimize-instructions folds compare of i64 eqz against boolean constants" {
  // Red-first OI-F boolean parity slice: Binaryen `version_130`
  // `--optimize-instructions` applies the same exact boolean-constant compare
  // cleanup to direct `i64.eqz` results as to direct `i32.eqz` results.
  // This deliberately covers only direct `i32.eq` / `i32.ne` shells around an
  // `i64.eqz` boolean result and exact i32 constants `0` / `1`.
  let eq_zero_func = optimize_instructions_test_run_hot(
    "(module (func (param i64) (result i32) local.get 0 i64.eqz i32.const 0 i32.eq))",
  )
  let eq_zero_root = @ir.hot_root_get(eq_zero_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(eq_zero_func, eq_zero_root),
    Some(@lib.Instruction::i64_ne()),
  )
  match
    @ir.hot_node_get(
      eq_zero_func,
      @ir.hot_child_get(eq_zero_func, eq_zero_root, 0),
    ).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected eq(i64.eqz(x), 0) to keep the original operand")
  }
  @debug.assert_eq(
    @ir.hot_const_get(
      eq_zero_func,
      @ir.hot_node_get(
        eq_zero_func,
        @ir.hot_child_get(eq_zero_func, eq_zero_root, 1),
      ).imm0,
    ),
    @ir.HotConstPayload::i64_const(@lib.I64(0L)),
  )

  let ne_zero_func = optimize_instructions_test_run_hot(
    "(module (func (param i64) (result i32) local.get 0 i64.eqz i32.const 0 i32.ne))",
  )
  @debug.assert_eq(
    @ir.hot_node_exact_instr(ne_zero_func, @ir.hot_root_get(ne_zero_func, 0)),
    Some(@lib.Instruction::i64_eqz()),
  )

  let eq_one_func = optimize_instructions_test_run_hot(
    "(module (func (param i64) (result i32) local.get 0 i64.eqz i32.const 1 i32.eq))",
  )
  @debug.assert_eq(
    @ir.hot_node_exact_instr(eq_one_func, @ir.hot_root_get(eq_one_func, 0)),
    Some(@lib.Instruction::i64_eqz()),
  )

  let ne_one_func = optimize_instructions_test_run_hot(
    "(module (func (param i64) (result i32) local.get 0 i64.eqz i32.const 1 i32.ne))",
  )
  @debug.assert_eq(
    @ir.hot_node_exact_instr(ne_one_func, @ir.hot_root_get(ne_one_func, 0)),
    Some(@lib.Instruction::i64_ne()),
  )
}

///|
test "optimize-instructions rewrites eqz on integer compares into inverted compares" {
  // Red-first OI-D parity slice: Binaryen `version_130`
  // `--optimize-instructions` rewrites `i32.eqz` around integer relational
  // compare results by inverting the compare opcode and preserving the original
  // operands. This deliberately does not cover compare-to-zero spellings or
  // NaN-sensitive float relational compares.
  let i32_rel_func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32) (result i32) local.get 0 local.get 1 i32.lt_s i32.eqz))",
  )
  let i32_rel_root = @ir.hot_root_get(i32_rel_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(i32_rel_func, i32_rel_root),
    Some(@lib.Instruction::i32_ge_s()),
  )
  let i32_lhs = @ir.hot_child_get(i32_rel_func, i32_rel_root, 0)
  let i32_rhs = @ir.hot_child_get(i32_rel_func, i32_rel_root, 1)
  match @ir.hot_node_get(i32_rel_func, i32_lhs).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected inverted i32 compare to keep the original lhs")
  }
  match @ir.hot_node_get(i32_rel_func, i32_rhs).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected inverted i32 compare to keep the original rhs")
  }

  let i64_rel_func = optimize_instructions_test_run_hot(
    "(module (func (param i64 i64) (result i32) local.get 0 local.get 1 i64.le_u i32.eqz))",
  )
  let i64_rel_root = @ir.hot_root_get(i64_rel_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(i64_rel_func, i64_rel_root),
    Some(@lib.Instruction::i64_gt_u()),
  )
}

///|
test "optimize-instructions rewrites eqz on float eq-ne compares into inverted compares" {
  // Red-first OI-D parity slice: Binaryen `version_130`
  // `--optimize-instructions` rewrites `i32.eqz` around `f32.eq` / `f32.ne`
  // and `f64.eq` / `f64.ne` by inverting only the equality opcode. This is
  // deliberately not a NaN-sensitive float relational inversion: Binaryen kept
  // `i32.eqz(f32.lt(...))` in the prior companion probe.
  let f32_eq_func = optimize_instructions_test_run_hot(
    "(module (func (param f32 f32) (result i32) local.get 0 local.get 1 f32.eq i32.eqz))",
  )
  @debug.assert_eq(
    @ir.hot_node_exact_instr(f32_eq_func, @ir.hot_root_get(f32_eq_func, 0)),
    Some(@lib.Instruction::f32_ne()),
  )

  let f32_ne_func = optimize_instructions_test_run_hot(
    "(module (func (param f32 f32) (result i32) local.get 0 local.get 1 f32.ne i32.eqz))",
  )
  @debug.assert_eq(
    @ir.hot_node_exact_instr(f32_ne_func, @ir.hot_root_get(f32_ne_func, 0)),
    Some(@lib.Instruction::f32_eq()),
  )

  let f64_eq_func = optimize_instructions_test_run_hot(
    "(module (func (param f64 f64) (result i32) local.get 0 local.get 1 f64.eq i32.eqz))",
  )
  @debug.assert_eq(
    @ir.hot_node_exact_instr(f64_eq_func, @ir.hot_root_get(f64_eq_func, 0)),
    Some(@lib.Instruction::f64_ne()),
  )

  let f64_ne_func = optimize_instructions_test_run_hot(
    "(module (func (param f64 f64) (result i32) local.get 0 local.get 1 f64.ne i32.eqz))",
  )
  @debug.assert_eq(
    @ir.hot_node_exact_instr(f64_ne_func, @ir.hot_root_get(f64_ne_func, 0)),
    Some(@lib.Instruction::f64_eq()),
  )
}

///|
test "optimize-instructions applies De Morgan to and of eqz operands" {
  // Red-first OI-F boolean parity slice: Binaryen `version_130`
  // `--optimize-instructions` rewrites `(and (eqz x) (eqz y))` to
  // `eqz(or x y)` while preserving left-to-right operand evaluation. This is
  // deliberately the two-direct-`eqz` i32.and shell only; it does not claim
  // broader boolean algebra, commuted/non-eqz operands, or branch-condition
  // rewrites.
  let local_func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32) (result i32) local.get 0 i32.eqz local.get 1 i32.eqz i32.and))",
  )
  let local_root = @ir.hot_root_get(local_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(local_func, local_root),
    Some(@lib.Instruction::i32_eqz()),
  )
  let local_or = @ir.hot_child_get(local_func, local_root, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(local_func, local_or),
    Some(@lib.Instruction::i32_or()),
  )
  match
    @ir.hot_node_get(local_func, @ir.hot_child_get(local_func, local_or, 0)).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected De Morgan i32.or to keep the first original operand")
  }
  match
    @ir.hot_node_get(local_func, @ir.hot_child_get(local_func, local_or, 1)).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected De Morgan i32.or to keep the second original operand")
  }

  let call_func = optimize_instructions_test_run_hot(
    "(module (global $g (mut i32) (i32.const 0)) (func (param i32) (result i32) call $side i32.eqz local.get 0 i32.eqz i32.and) (func $side (result i32) i32.const 1 global.set $g i32.const 7))",
  )
  let call_root = @ir.hot_root_get(call_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(call_func, call_root),
    Some(@lib.Instruction::i32_eqz()),
  )
  let call_or = @ir.hot_child_get(call_func, call_root, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(call_func, call_or),
    Some(@lib.Instruction::i32_or()),
  )
  match
    @ir.hot_node_get(call_func, @ir.hot_child_get(call_func, call_or, 0)).op {
    @ir.HotOp::Call => ()
    _ => fail("expected De Morgan i32.or to keep the effectful first operand")
  }
}

///|
test "optimize-instructions folds boolean const select arms to condition compares" {
  // Red-first OI-F select parity slice: Binaryen `version_130`
  // `--optimize-instructions` rewrites `(select 1 0 cond)` to
  // `i32.ne(cond, 0)` and `(select 0 1 cond)` to `i32.eqz(cond)`, preserving
  // the original condition operand and its effects. This deliberately covers
  // only direct i32 1/0 and 0/1 select arms, not arbitrary select values,
  // non-i32 arms, or branch-condition rewrites.
  let true_false_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) i32.const 1 i32.const 0 local.get 0 select))",
  )
  let true_false_root = @ir.hot_root_get(true_false_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(true_false_func, true_false_root),
    Some(@lib.Instruction::i32_ne()),
  )
  match
    @ir.hot_node_get(
      true_false_func,
      @ir.hot_child_get(true_false_func, true_false_root, 0),
    ).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected select 1/0 rewrite to keep the condition operand")
  }
  let true_false_zero = @ir.hot_child_get(true_false_func, true_false_root, 1)
  @debug.assert_eq(
    @ir.hot_const_get(
      true_false_func,
      @ir.hot_node_get(true_false_func, true_false_zero).imm0,
    ),
    @ir.HotConstPayload::i32_const(@lib.I32(0)),
  )

  let false_true_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) i32.const 0 i32.const 1 local.get 0 select))",
  )
  let false_true_root = @ir.hot_root_get(false_true_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(false_true_func, false_true_root),
    Some(@lib.Instruction::i32_eqz()),
  )
  match
    @ir.hot_node_get(
      false_true_func,
      @ir.hot_child_get(false_true_func, false_true_root, 0),
    ).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected select 0/1 rewrite to keep the condition operand")
  }

  let call_func = optimize_instructions_test_run_hot(
    "(module (global $g (mut i32) (i32.const 0)) (func (result i32) i32.const 1 i32.const 0 call $side select) (func $side (result i32) i32.const 1 global.set $g i32.const 7))",
  )
  let call_root = @ir.hot_root_get(call_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(call_func, call_root),
    Some(@lib.Instruction::i32_ne()),
  )
  match
    @ir.hot_node_get(call_func, @ir.hot_child_get(call_func, call_root, 0)).op {
    @ir.HotOp::Call => ()
    _ => fail("expected select 1/0 rewrite to keep the effectful condition")
  }
}

///|
test "optimize-instructions removes eqz from select conditions by swapping arms" {
  // Red-first OI-F select parity slice: Binaryen `version_130`
  // `--optimize-instructions` rewrites `(select a b (i32.eqz cond))` to
  // `(select b a cond)`. For exact boolean const arms this composes directly
  // to the existing i32 1/0 and 0/1 condition-compare forms. This deliberately
  // covers only a direct i32.eqz condition shell, not broader condition
  // normalization or branch-condition rewrites.
  let value_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) i32.const 42 i32.const 13 local.get 0 i32.eqz select))",
  )
  let value_root = @ir.hot_root_get(value_func, 0)
  match @ir.hot_node_get(value_func, value_root).op {
    @ir.HotOp::Select => ()
    _ => fail("expected select with swapped arms after removing eqz condition")
  }
  let value_true = @ir.hot_child_get(value_func, value_root, 0)
  let value_false = @ir.hot_child_get(value_func, value_root, 1)
  let value_condition = @ir.hot_child_get(value_func, value_root, 2)
  @debug.assert_eq(
    @ir.hot_const_get(value_func, @ir.hot_node_get(value_func, value_true).imm0),
    @ir.HotConstPayload::i32_const(@lib.I32(13)),
  )
  @debug.assert_eq(
    @ir.hot_const_get(
      value_func,
      @ir.hot_node_get(value_func, value_false).imm0,
    ),
    @ir.HotConstPayload::i32_const(@lib.I32(42)),
  )
  match @ir.hot_node_get(value_func, value_condition).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected swapped select to keep the inner eqz operand")
  }

  let bool_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) i32.const 1 i32.const 0 local.get 0 i32.eqz select))",
  )
  let bool_root = @ir.hot_root_get(bool_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(bool_func, bool_root),
    Some(@lib.Instruction::i32_eqz()),
  )
  match
    @ir.hot_node_get(bool_func, @ir.hot_child_get(bool_func, bool_root, 0)).op {
    @ir.HotOp::LocalGet => ()
    _ =>
      fail(
        "expected boolean const select with eqz condition to fold to eqz of inner operand",
      )
  }

  let call_func = optimize_instructions_test_run_hot(
    "(module (global $g (mut i32) (i32.const 0)) (func (result i32) i32.const 42 i32.const 13 call $side i32.eqz select) (func $side (result i32) i32.const 1 global.set $g i32.const 7))",
  )
  let call_root = @ir.hot_root_get(call_func, 0)
  match @ir.hot_node_get(call_func, call_root).op {
    @ir.HotOp::Select => ()
    _ => fail("expected effectful eqz condition select to remain a select")
  }
  match
    @ir.hot_node_get(call_func, @ir.hot_child_get(call_func, call_root, 2)).op {
    @ir.HotOp::Call => ()
    _ => fail("expected effectful swapped select to keep the call condition")
  }
}

///|
test "optimize-instructions removes zero compares from select conditions" {
  // Red-first OI-F select parity slice: Binaryen `version_130`
  // `--optimize-instructions` rewrites `(select a b (i32.eq cond 0))` to
  // `(select b a cond)` and `(select a b (i32.ne cond 0))` to
  // `(select a b cond)`. Exact i32 boolean const arms compose to the existing
  // condition-compare folds. This deliberately covers only direct i32 eq/ne
  // zero condition shells, not arbitrary compare constants, broader boolean
  // algebra, or branch-condition rewrites.
  let eq_value_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) i32.const 42 i32.const 13 local.get 0 i32.const 0 i32.eq select))",
  )
  let eq_value_root = @ir.hot_root_get(eq_value_func, 0)
  match @ir.hot_node_get(eq_value_func, eq_value_root).op {
    @ir.HotOp::Select => ()
    _ => fail("expected eq-zero condition select to remain a select")
  }
  @debug.assert_eq(
    @ir.hot_const_get(
      eq_value_func,
      @ir.hot_node_get(
        eq_value_func,
        @ir.hot_child_get(eq_value_func, eq_value_root, 0),
      ).imm0,
    ),
    @ir.HotConstPayload::i32_const(@lib.I32(13)),
  )
  @debug.assert_eq(
    @ir.hot_const_get(
      eq_value_func,
      @ir.hot_node_get(
        eq_value_func,
        @ir.hot_child_get(eq_value_func, eq_value_root, 1),
      ).imm0,
    ),
    @ir.HotConstPayload::i32_const(@lib.I32(42)),
  )
  match
    @ir.hot_node_get(
      eq_value_func,
      @ir.hot_child_get(eq_value_func, eq_value_root, 2),
    ).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected eq-zero select condition to become the inner operand")
  }

  let ne_value_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) i32.const 42 i32.const 13 local.get 0 i32.const 0 i32.ne select))",
  )
  let ne_value_root = @ir.hot_root_get(ne_value_func, 0)
  match @ir.hot_node_get(ne_value_func, ne_value_root).op {
    @ir.HotOp::Select => ()
    _ => fail("expected ne-zero condition select to remain a select")
  }
  @debug.assert_eq(
    @ir.hot_const_get(
      ne_value_func,
      @ir.hot_node_get(
        ne_value_func,
        @ir.hot_child_get(ne_value_func, ne_value_root, 0),
      ).imm0,
    ),
    @ir.HotConstPayload::i32_const(@lib.I32(42)),
  )
  @debug.assert_eq(
    @ir.hot_const_get(
      ne_value_func,
      @ir.hot_node_get(
        ne_value_func,
        @ir.hot_child_get(ne_value_func, ne_value_root, 1),
      ).imm0,
    ),
    @ir.HotConstPayload::i32_const(@lib.I32(13)),
  )
  match
    @ir.hot_node_get(
      ne_value_func,
      @ir.hot_child_get(ne_value_func, ne_value_root, 2),
    ).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected ne-zero select condition to become the inner operand")
  }

  let bool_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) i32.const 1 i32.const 0 local.get 0 i32.const 0 i32.eq select))",
  )
  let bool_root = @ir.hot_root_get(bool_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(bool_func, bool_root),
    Some(@lib.Instruction::i32_eqz()),
  )
  match
    @ir.hot_node_get(bool_func, @ir.hot_child_get(bool_func, bool_root, 0)).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected boolean eq-zero select to fold to eqz of inner operand")
  }

  let call_func = optimize_instructions_test_run_hot(
    "(module (global $g (mut i32) (i32.const 0)) (func (result i32) i32.const 42 i32.const 13 call $side i32.const 0 i32.ne select) (func $side (result i32) i32.const 1 global.set $g i32.const 7))",
  )
  let call_root = @ir.hot_root_get(call_func, 0)
  match @ir.hot_node_get(call_func, call_root).op {
    @ir.HotOp::Select => ()
    _ => fail("expected effectful ne-zero condition select to remain a select")
  }
  match
    @ir.hot_node_get(call_func, @ir.hot_child_get(call_func, call_root, 2)).op {
    @ir.HotOp::Call => ()
    _ => fail("expected effectful ne-zero condition to keep the call operand")
  }
}

///|
test "optimize-instructions folds direct compare boolean select arms" {
  // Red-first OI-F select parity slice: Binaryen `version_130`
  // `--optimize-instructions` removes exact i32 boolean select arms around
  // direct compare conditions. `select 1 0 (compare ...)` becomes the compare
  // itself, while `select 0 1 (compare ...)` becomes the compare inverse when
  // Binaryen has a direct inverse spelling. This deliberately does not claim
  // arbitrary non-compare boolean conditions or value-select rewrites.
  let int_true_false_func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32) (result i32) i32.const 1 i32.const 0 local.get 0 local.get 1 i32.lt_s select))",
  )
  let int_true_false_root = @ir.hot_root_get(int_true_false_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(int_true_false_func, int_true_false_root),
    Some(@lib.Instruction::i32_lt_s()),
  )
  match
    @ir.hot_node_get(
      int_true_false_func,
      @ir.hot_child_get(int_true_false_func, int_true_false_root, 0),
    ).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected true/false compare select to keep lhs operand")
  }

  let int_false_true_func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32) (result i32) i32.const 0 i32.const 1 local.get 0 local.get 1 i32.lt_s select))",
  )
  let int_false_true_root = @ir.hot_root_get(int_false_true_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(int_false_true_func, int_false_true_root),
    Some(@lib.Instruction::i32_ge_s()),
  )

  let float_true_false_func = optimize_instructions_test_run_hot(
    "(module (func (param f32 f32) (result i32) i32.const 1 i32.const 0 local.get 0 local.get 1 f32.eq select))",
  )
  let float_true_false_root = @ir.hot_root_get(float_true_false_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(float_true_false_func, float_true_false_root),
    Some(@lib.Instruction::f32_eq()),
  )

  let float_false_true_func = optimize_instructions_test_run_hot(
    "(module (func (param f32 f32) (result i32) i32.const 0 i32.const 1 local.get 0 local.get 1 f32.eq select))",
  )
  let float_false_true_root = @ir.hot_root_get(float_false_true_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(float_false_true_func, float_false_true_root),
    Some(@lib.Instruction::f32_ne()),
  )
}

///|
test "optimize-instructions folds eqz compare boolean select arms" {
  // Red-first OI-F select parity slice: Binaryen `version_130`
  // `--optimize-instructions` removes exact i32 boolean select arms around
  // `i32.eqz(compare ...)` conditions. `select 1 0 (eqz(compare))` becomes
  // the inverse compare, while `select 0 1 (eqz(compare))` becomes the inner
  // compare. This deliberately does not claim arbitrary boolean algebra,
  // branch-condition rewrites, or non-boolean value-select rewrites.
  let i32_true_false_func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32) (result i32) i32.const 1 i32.const 0 local.get 0 local.get 1 i32.eq i32.eqz select))",
  )
  let i32_true_false_root = @ir.hot_root_get(i32_true_false_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(i32_true_false_func, i32_true_false_root),
    Some(@lib.Instruction::i32_ne()),
  )

  let i64_false_true_func = optimize_instructions_test_run_hot(
    "(module (func (param i64 i64) (result i32) i32.const 0 i32.const 1 local.get 0 local.get 1 i64.ne i32.eqz select))",
  )
  let i64_false_true_root = @ir.hot_root_get(i64_false_true_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(i64_false_true_func, i64_false_true_root),
    Some(@lib.Instruction::i64_ne()),
  )

  let relational_true_false_func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32) (result i32) i32.const 1 i32.const 0 local.get 0 local.get 1 i32.lt_u i32.eqz select))",
  )
  let relational_true_false_root = @ir.hot_root_get(
    relational_true_false_func, 0,
  )
  @debug.assert_eq(
    @ir.hot_node_exact_instr(
      relational_true_false_func, relational_true_false_root,
    ),
    Some(@lib.Instruction::i32_ge_u()),
  )

  let float_false_true_func = optimize_instructions_test_run_hot(
    "(module (func (param f64 f64) (result i32) i32.const 0 i32.const 1 local.get 0 local.get 1 f64.eq i32.eqz select))",
  )
  let float_false_true_root = @ir.hot_root_get(float_false_true_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(float_false_true_func, float_false_true_root),
    Some(@lib.Instruction::f64_eq()),
  )
}

///|
test "optimize-instructions folds direct integer equality boolean select arms" {
  // Red-first OI-F select parity slice: Binaryen `version_130`
  // `--optimize-instructions` removes exact i32 boolean select arms around
  // direct integer equality conditions. This covers local/local `i32.eq`,
  // `i32.ne`, `i64.eq`, and `i64.ne` conditions, including exact `0/1` arm
  // inversion. It deliberately does not claim broad nonzero compare-to-const
  // condition normalization, branch rewrites, or non-boolean value selects.
  let i32_eq_true_func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32) (result i32) i32.const 1 i32.const 0 local.get 0 local.get 1 i32.eq select))",
  )
  let i32_eq_true_root = @ir.hot_root_get(i32_eq_true_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(i32_eq_true_func, i32_eq_true_root),
    Some(@lib.Instruction::i32_eq()),
  )

  let i32_eq_false_func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32) (result i32) i32.const 0 i32.const 1 local.get 0 local.get 1 i32.eq select))",
  )
  let i32_eq_false_root = @ir.hot_root_get(i32_eq_false_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(i32_eq_false_func, i32_eq_false_root),
    Some(@lib.Instruction::i32_ne()),
  )

  let i32_ne_false_func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32) (result i32) i32.const 0 i32.const 1 local.get 0 local.get 1 i32.ne select))",
  )
  let i32_ne_false_root = @ir.hot_root_get(i32_ne_false_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(i32_ne_false_func, i32_ne_false_root),
    Some(@lib.Instruction::i32_eq()),
  )

  let i64_eq_true_func = optimize_instructions_test_run_hot(
    "(module (func (param i64 i64) (result i32) i32.const 1 i32.const 0 local.get 0 local.get 1 i64.eq select))",
  )
  let i64_eq_true_root = @ir.hot_root_get(i64_eq_true_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(i64_eq_true_func, i64_eq_true_root),
    Some(@lib.Instruction::i64_eq()),
  )

  let i64_ne_false_func = optimize_instructions_test_run_hot(
    "(module (func (param i64 i64) (result i32) i32.const 0 i32.const 1 local.get 0 local.get 1 i64.ne select))",
  )
  let i64_ne_false_root = @ir.hot_root_get(i64_ne_false_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(i64_ne_false_func, i64_ne_false_root),
    Some(@lib.Instruction::i64_eq()),
  )
}

///|
test "optimize-instructions folds i64 zero-compare boolean select arms" {
  // Red-first OI-F select parity slice: Binaryen `version_130`
  // `--optimize-instructions` canonicalizes exact i32 boolean arms over direct
  // i64 zero-compare select conditions. `i64.eq(x, 0)` with `1/0` arms becomes
  // `i64.eqz(x)`, `i64.eq(x, 0)` with `0/1` arms becomes `i64.ne(x, 0)`, and
  // direct `i64.ne(x, 0)` mirrors those forms without an extra eqz shell. This
  // deliberately does not claim non-boolean value-select rewrites or broader
  // i64 compare normalization.
  let eq_true_false_func = optimize_instructions_test_run_hot(
    "(module (func (param i64) (result i32) i32.const 1 i32.const 0 local.get 0 i64.const 0 i64.eq select))",
  )
  let eq_true_false_root = @ir.hot_root_get(eq_true_false_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(eq_true_false_func, eq_true_false_root),
    Some(@lib.Instruction::i64_eqz()),
  )
  match
    @ir.hot_node_get(
      eq_true_false_func,
      @ir.hot_child_get(eq_true_false_func, eq_true_false_root, 0),
    ).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected i64 eq-zero boolean true/false select to keep operand")
  }

  let eq_false_true_func = optimize_instructions_test_run_hot(
    "(module (func (param i64) (result i32) i32.const 0 i32.const 1 local.get 0 i64.const 0 i64.eq select))",
  )
  let eq_false_true_root = @ir.hot_root_get(eq_false_true_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(eq_false_true_func, eq_false_true_root),
    Some(@lib.Instruction::i64_ne()),
  )
  let eq_false_true_lhs = @ir.hot_child_get(
    eq_false_true_func, eq_false_true_root, 0,
  )
  let eq_false_true_rhs = @ir.hot_child_get(
    eq_false_true_func, eq_false_true_root, 1,
  )
  match @ir.hot_node_get(eq_false_true_func, eq_false_true_lhs).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected i64 eq-zero boolean false/true select to keep operand")
  }
  @debug.assert_eq(
    @ir.hot_const_get(
      eq_false_true_func,
      @ir.hot_node_get(eq_false_true_func, eq_false_true_rhs).imm0,
    ),
    @ir.HotConstPayload::i64_const(@lib.I64(0L)),
  )

  let ne_true_false_func = optimize_instructions_test_run_hot(
    "(module (func (param i64) (result i32) i32.const 1 i32.const 0 local.get 0 i64.const 0 i64.ne select))",
  )
  let ne_true_false_root = @ir.hot_root_get(ne_true_false_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(ne_true_false_func, ne_true_false_root),
    Some(@lib.Instruction::i64_ne()),
  )
  let ne_true_false_lhs = @ir.hot_child_get(
    ne_true_false_func, ne_true_false_root, 0,
  )
  let ne_true_false_rhs = @ir.hot_child_get(
    ne_true_false_func, ne_true_false_root, 1,
  )
  match @ir.hot_node_get(ne_true_false_func, ne_true_false_lhs).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected i64 ne-zero boolean true/false select to keep operand")
  }
  @debug.assert_eq(
    @ir.hot_const_get(
      ne_true_false_func,
      @ir.hot_node_get(ne_true_false_func, ne_true_false_rhs).imm0,
    ),
    @ir.HotConstPayload::i64_const(@lib.I64(0L)),
  )

  let ne_false_true_func = optimize_instructions_test_run_hot(
    "(module (func (param i64) (result i32) i32.const 0 i32.const 1 local.get 0 i64.const 0 i64.ne select))",
  )
  let ne_false_true_root = @ir.hot_root_get(ne_false_true_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(ne_false_true_func, ne_false_true_root),
    Some(@lib.Instruction::i64_eqz()),
  )
  match
    @ir.hot_node_get(
      ne_false_true_func,
      @ir.hot_child_get(ne_false_true_func, ne_false_true_root, 0),
    ).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected i64 ne-zero boolean false/true select to keep operand")
  }

  let value_func = optimize_instructions_test_run_hot(
    "(module (func (param i64) (result i32) i32.const 42 i32.const 13 local.get 0 i64.const 0 i64.eq select))",
  )
  let value_root = @ir.hot_root_get(value_func, 0)
  match @ir.hot_node_get(value_func, value_root).op {
    @ir.HotOp::Select => ()
    _ => fail("expected non-boolean i64 zero-compare select to stay a select")
  }
  @debug.assert_eq(
    @ir.hot_node_exact_instr(
      value_func,
      @ir.hot_child_get(value_func, value_root, 2),
    ),
    Some(@lib.Instruction::i64_eqz()),
  )
}

///|
test "optimize-instructions folds i64 eqz boolean select arms" {
  // Red-first OI-F select parity slice: Binaryen `version_130`
  // `--optimize-instructions` keeps value selects with an `i64.eqz` condition,
  // but composes exact i32 boolean arms to `i64.eqz(x)` for `1/0` and
  // `i64.ne(x, 0)` for `0/1`. This deliberately covers only direct i64.eqz
  // select-condition shells with exact i32 boolean arms, not non-boolean value
  // selects, i32 condition normalization, branch rewrites, or broader boolean
  // algebra.
  let true_false_func = optimize_instructions_test_run_hot(
    "(module (func (param i64) (result i32) i32.const 1 i32.const 0 local.get 0 i64.eqz select))",
  )
  let true_false_root = @ir.hot_root_get(true_false_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(true_false_func, true_false_root),
    Some(@lib.Instruction::i64_eqz()),
  )
  match
    @ir.hot_node_get(
      true_false_func,
      @ir.hot_child_get(true_false_func, true_false_root, 0),
    ).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected i64 eqz boolean true/false select to keep the operand")
  }

  let false_true_func = optimize_instructions_test_run_hot(
    "(module (func (param i64) (result i32) i32.const 0 i32.const 1 local.get 0 i64.eqz select))",
  )
  let false_true_root = @ir.hot_root_get(false_true_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(false_true_func, false_true_root),
    Some(@lib.Instruction::i64_ne()),
  )
  let false_true_lhs = @ir.hot_child_get(false_true_func, false_true_root, 0)
  let false_true_rhs = @ir.hot_child_get(false_true_func, false_true_root, 1)
  match @ir.hot_node_get(false_true_func, false_true_lhs).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected i64 eqz boolean false/true select to keep the operand")
  }
  @debug.assert_eq(
    @ir.hot_const_get(
      false_true_func,
      @ir.hot_node_get(false_true_func, false_true_rhs).imm0,
    ),
    @ir.HotConstPayload::i64_const(@lib.I64(0L)),
  )

  let value_func = optimize_instructions_test_run_hot(
    "(module (func (param i64) (result i32) i32.const 42 i32.const 13 local.get 0 i64.eqz select))",
  )
  let value_root = @ir.hot_root_get(value_func, 0)
  match @ir.hot_node_get(value_func, value_root).op {
    @ir.HotOp::Select => ()
    _ => fail("expected non-boolean i64 eqz select to stay a select")
  }
  @debug.assert_eq(
    @ir.hot_node_exact_instr(
      value_func,
      @ir.hot_child_get(value_func, value_root, 2),
    ),
    Some(@lib.Instruction::i64_eqz()),
  )
}

///|
test "optimize-instructions rewrites double eqz into ne zero" {
  let i32_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) local.get 0 i32.eqz i32.eqz))",
  )
  let i32_root = @ir.hot_root_get(i32_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(i32_func, i32_root),
    Some(@lib.Instruction::i32_ne()),
  )
  let i32_lhs = @ir.hot_child_get(i32_func, i32_root, 0)
  let i32_rhs = @ir.hot_child_get(i32_func, i32_root, 1)
  match @ir.hot_node_get(i32_func, i32_lhs).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected i32 double-eqz rewrite to keep the original operand")
  }
  @debug.assert_eq(
    @ir.hot_const_get(i32_func, @ir.hot_node_get(i32_func, i32_rhs).imm0),
    @ir.HotConstPayload::i32_const(@lib.I32(0)),
  )

  let i64_func = optimize_instructions_test_run_hot(
    "(module (func (param i64) (result i32) local.get 0 i64.eqz i32.eqz))",
  )
  let i64_root = @ir.hot_root_get(i64_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(i64_func, i64_root),
    Some(@lib.Instruction::i64_ne()),
  )
  let i64_lhs = @ir.hot_child_get(i64_func, i64_root, 0)
  let i64_rhs = @ir.hot_child_get(i64_func, i64_root, 1)
  match @ir.hot_node_get(i64_func, i64_lhs).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected i64 double-eqz rewrite to keep the original operand")
  }
  @debug.assert_eq(
    @ir.hot_const_get(i64_func, @ir.hot_node_get(i64_func, i64_rhs).imm0),
    @ir.HotConstPayload::i64_const(@lib.I64(0L)),
  )
}

///|
test "optimize-instructions folds constant false void ifs to nops" {
  let optimized = match
    pass_test_run_pipeline(
      "(module (func i32.const 0 if nop else nop end i64.const 3 drop))",
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) => fail("expected optimize-instructions success, got \{err}")
  }

  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("(if"), msg=pretty)
  assert_true(pretty.contains("i64.const I64(3)"), msg=pretty)
}

///|
test "optimize-instructions folds constant true result ifs to the chosen arm" {
  let optimized = match
    pass_test_run_pipeline(
      "(module (func (result i32) i32.const 1 if (result i32) i32.const 7 else i32.const 9 end))",
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) => fail("expected optimize-instructions success, got \{err}")
  }

  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("(if"), msg=pretty)
  assert_true(pretty.contains("I32(7)"), msg=pretty)
}

///|
test "optimize-instructions constant-if folding preserves hot label ownership" {
  let func = optimize_instructions_test_run_hot(
    "(module (func (result i32) i32.const 1 if (result i32) i32.const 7 else i32.const 9 end))",
  )
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_get(func, root).op {
    @ir.HotOp::Block => ()
    other => fail("expected constant result if to become a block, got \{other}")
  }
  match @ir.hot_verify_core(func) {
    Ok(_) => ()
    Err(err) =>
      fail("expected constant-if fold label owners to verify, got \{err}")
  }
}

///|
test "optimize-instructions sinks same-global if set arms to one set of value if" {
  // Red-first OI-F/OI-D parity reduction from
  // `.tmp/oi-f-effectful-family-classify-20260627/.../case-000002-gen-valid-transform-oi-effectful-sibling`:
  // Binaryen version_130 sinks same-global `if` arms into a single
  // `global.set (if (result ...))`, shrinking the effectful-sibling family.
  let func = optimize_instructions_test_run_hot(
    "(module (global $g (mut i32) (i32.const 0)) (func (param i32) local.get 0 if i32.const 7 global.set $g else i32.const 9 global.set $g end))",
  )
  let root = @ir.hot_root_get(func, 0)
  let set_id = match @ir.hot_node_get(func, root).op {
    @ir.HotOp::Block => {
      let body = @ir.hot_region_body_ref(func, root)
      @debug.assert_eq(@ir.hot_region_root_count(func, body), 1)
      @ir.hot_region_get(func, body, 0)
    }
    _ => root
  }
  let set_node = @ir.hot_node_get(func, set_id)
  match set_node.op {
    @ir.HotOp::GlobalSet => ()
    other => fail("expected if arms to sink into one global.set, got \{other}")
  }
  @debug.assert_eq(set_node.imm0, 0)
  @debug.assert_eq(set_node.child_count, 1)
  let value_if = @ir.hot_child_get(func, set_id, 0)
  match @ir.hot_node_get(func, value_if).op {
    @ir.HotOp::If => ()
    other => fail("expected global.set value to be an if, got \{other}")
  }
  match @ir.hot_verify_core(func) {
    Ok(_) => ()
    Err(err) => fail("expected sunk global.set(if) shape to verify, got \{err}")
  }
}

///|
test "optimize-instructions folds dropped pure constant add" {
  // OI-F effectful-sibling reductions also showed stale native output keeping
  // dropped `i32.const 2; i32.const 3; i32.add`. The pass-owned OI-D behavior is
  // to fold that pure add before it is dropped; this guards the focused shape.
  let func = optimize_instructions_test_run_hot(
    "(module (func i32.const 2 i32.const 3 i32.add drop))",
  )
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_get(func, root).op {
    @ir.HotOp::Drop => ()
    other => fail("expected root to stay a drop of folded add, got \{other}")
  }
  let folded = @ir.hot_child_get(func, root, 0)
  match @ir.hot_node_get(func, folded).op {
    @ir.HotOp::Const => ()
    other =>
      fail("expected dropped pure i32.add to fold to const, got \{other}")
  }
  @debug.assert_eq(
    @ir.hot_const_get(func, @ir.hot_node_get(func, folded).imm0),
    @ir.HotConstPayload::i32_const(@lib.I32(5)),
  )
}

///|
test "optimize-instructions raw skip folds nested pure constant add" {
  // Follow-up from `.tmp/oi-f-effectful-family-fix2-20260627`: after the first
  // dropped add and same-global if sink were fixed, the remaining size loss kept
  // `i32.add (i32.const 6) (i32.const 7)` nested under a dropped multiply inside
  // a raw-skipped large function, while Binaryen folds that add to `i32.const 13`.
  let source = StringBuilder::new()
  source.write_string("(module (func (local i32")
  for i = 0; i < 1024; i = i + 1 {
    let _ = i
    source.write_string(" i32")
  }
  source.write_string(
    ") i32.const 6 i32.const 7 i32.add i32.const 3 i32.mul drop))",
  )
  let trace : Array[String] = []
  let optimized = match
    pass_test_run_pipeline(
      source.to_string(),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(trace=Some(fn(line) { trace.push(line) })),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected optimize-instructions raw skip success, got \{err}")
  }
  assert_true(
    trace.any(fn(line) {
      line.contains(
        "pass[optimize-instructions]:skip-raw reason=large-local-optimize-instructions",
      )
    }),
    msg="expected large-local raw skip in \{trace}",
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("i32.add"), msg=pretty)
  assert_true(pretty.contains("I32(13)"), msg=pretty)
  assert_true(pretty.contains("i32.mul"), msg=pretty)
}

///|
test "optimize-instructions raw skip lowers select-wrapped tiny memory copy" {
  // Grouped OI-G follow-up from
  // `.tmp/oi-g-runtime-select-copy-restore-count621-20260629`: select-produced
  // constant destination/source/size operands made the raw-skipped path keep a
  // size-1 `memory.copy` that Binaryen lowers to load8/store8. The rewrite is
  // intentionally limited to pure constant select shells, preserving source and
  // destination addresses plus the byte restore contract.
  let source = StringBuilder::new()
  source.write_string("(module (memory 1) (func (result i32) (local i32 i32")
  for i = 0; i < 1024; i = i + 1 {
    let _ = i
    source.write_string(" i32")
  }
  source.write_string(
    ") i32.const 64 i32.load8_u local.set 0 i32.const 64 i32.const 64 i32.const 1 select (result i32) i32.const 32 i32.const 32 i32.const 1 select (result i32) i32.const 1 i32.const 1 i32.const 0 select (result i32) memory.copy i32.const 64 i32.load8_u local.set 1 i32.const 64 local.get 0 i32.store8 local.get 1 i32.const 0 i32.const 1 select (result i32)))",
  )
  let trace : Array[String] = []
  let optimized = match
    pass_test_run_pipeline(
      source.to_string(),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(trace=Some(fn(line) { trace.push(line) })),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected optimize-instructions raw skip success, got \{err}")
  }
  assert_true(
    trace.any(fn(line) {
      line.contains(
        "pass[optimize-instructions]:skip-raw reason=large-local-optimize-instructions",
      )
    }),
    msg="expected large-local raw skip in \{trace}",
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("memory.copy"), msg=pretty)
  assert_false(pretty.contains("select"), msg=pretty)
  assert_true(pretty.contains("i32.load8u"), msg=pretty)
  assert_true(pretty.contains("i32.store8"), msg=pretty)
}

///|
test "optimize-instructions raw skip lowers select-wrapped byte memory fill" {
  // Grouped OI-G follow-up from
  // `.tmp/oi-g-runtime-select-fill-restore-count648-20260629`: select-produced
  // constant destination/value/size operands made the raw-skipped path keep a
  // size-1 `memory.fill` that Binaryen lowers to `i32.store8`. Keep the rewrite
  // narrow to pure constant select shells so source-visible restore/read
  // behavior is unchanged.
  let source = StringBuilder::new()
  source.write_string("(module (memory 1) (func (result i32) (local i32 i32")
  for i = 0; i < 1024; i = i + 1 {
    let _ = i
    source.write_string(" i32")
  }
  source.write_string(
    ") i32.const 64 i32.load8_u local.set 0 i32.const 64 i32.const 64 i32.const 1 select (result i32) i32.const 42 i32.const 42 i32.const 1 select (result i32) i32.const 1 i32.const 1 i32.const 0 select (result i32) memory.fill i32.const 64 i32.load8_u local.set 1 i32.const 64 local.get 0 i32.store8 local.get 1 i32.const 0 i32.const 1 select (result i32)))",
  )
  let trace : Array[String] = []
  let optimized = match
    pass_test_run_pipeline(
      source.to_string(),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(trace=Some(fn(line) { trace.push(line) })),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected optimize-instructions raw skip success, got \{err}")
  }
  assert_true(
    trace.any(fn(line) {
      line.contains(
        "pass[optimize-instructions]:skip-raw reason=large-local-optimize-instructions",
      )
    }),
    msg="expected large-local raw skip in \{trace}",
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("memory.fill"), msg=pretty)
  assert_false(pretty.contains("select"), msg=pretty)
  assert_true(pretty.contains("i32.store8"), msg=pretty)
  assert_true(pretty.contains("I32(42)"), msg=pretty)
}

///|
test "optimize-instructions raw skip folds constant if and eqz select shells" {
  // OI-F count40 follow-up from
  // `.tmp/oi-f-effectful-family-count40-20260630`: the remaining
  // `oi-if-select-shell` residuals include size-losing raw-skipped select
  // shells where a literal condition is wrapped in `i32.eqz`. Keep this narrow:
  // direct i32 literal `eqz` conditions with pure stack operands only, plus the
  // adjacent no-result `if` shape where both branches are a single pure value
  // followed by `drop`. Binaryen reshapes that shell to a dropped value-if; it
  // does not delete branch bodies.
  let source = StringBuilder::new()
  source.write_string("(module (func (local i32")
  for i = 0; i < 1024; i = i + 1 {
    let _ = i
    source.write_string(" i32")
  }
  source.write_string(
    ") i32.const 0 if i32.const 1 drop else i32.const 2 drop end i32.const 44 i32.const 55 i32.const 0 i32.eqz select drop))",
  )
  let trace : Array[String] = []
  let optimized = match
    pass_test_run_pipeline(
      source.to_string(),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(trace=Some(fn(line) { trace.push(line) })),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected optimize-instructions raw skip success, got \{err}")
  }
  assert_true(
    trace.any(fn(line) {
      line.contains(
        "pass[optimize-instructions]:skip-raw reason=large-local-optimize-instructions",
      )
    }),
    msg="expected large-local raw skip in \{trace}",
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_true(pretty.contains("if"), msg=pretty)
  assert_false(pretty.contains("if (Void)"), msg=pretty)
  assert_false(pretty.contains("select"), msg=pretty)
  assert_false(pretty.contains("i32.eqz"), msg=pretty)
  @debug.assert_eq(
    optimize_instructions_test_count_substring(pretty, "drop"),
    2,
    msg=pretty,
  )
  assert_true(pretty.contains("I32(1)"), msg=pretty)
  assert_true(pretty.contains("I32(2)"), msg=pretty)
  assert_true(pretty.contains("I32(44)"), msg=pretty)
  assert_false(pretty.contains("I32(55)"), msg=pretty)
}

///|
test "optimize-instructions raw skip reshapes dropped trapping dead if arms" {
  // OI-F grouped source-backed follow-up from
  // `.tmp/oi-f-source-profile-count40-20260630/.../case-000002-gen-valid-transform-oi-effectful-sibling`:
  // Binaryen keeps a value-if plus outer drop for the constant-live branch
  // instead of Starshine's size-losing void-if with branch-local drops. Preserve
  // the dead divide-by-zero arm inside the `if` so the trap remains conditional.
  let source = StringBuilder::new()
  source.write_string(
    "(module (global $g (mut i32) (i32.const 0)) (func (local i32",
  )
  for i = 0; i < 1024; i = i + 1 {
    let _ = i
    source.write_string(" i32")
  }
  source.write_string(
    ") i32.const 101 global.set $g global.get $g drop i32.const 1 if i32.const 102 global.set $g else i32.const 103 global.set $g end i32.const 104 global.set $g i32.const 10 i32.const 105 global.set $g i32.const 20 i32.const 1 select drop i32.const 106 global.set $g i32.const 2 i32.const 3 i32.add drop i32.const 1 if i32.const 9 drop else i32.const 1 i32.const 0 i32.div_u drop end))",
  )
  let trace : Array[String] = []
  let optimized = match
    pass_test_run_pipeline(
      source.to_string(),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(trace=Some(fn(line) { trace.push(line) })),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected optimize-instructions raw skip success, got \{err}")
  }
  assert_true(
    trace.any(fn(line) {
      line.contains(
        "pass[optimize-instructions]:skip-raw reason=large-local-optimize-instructions",
      )
    }),
    msg="expected large-local raw skip in \{trace}",
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_true(pretty.contains("if"), msg=pretty)
  assert_false(pretty.contains("if (Void)"), msg=pretty)
  assert_true(pretty.contains("i32.div_u"), msg=pretty)
  @debug.assert_eq(
    optimize_instructions_test_count_substring(pretty, "drop"),
    4,
    msg=pretty,
  )
}

///|
test "optimize-instructions raw skip folds identical pure select arms after effectful condition" {
  // OI-F source-backed profile follow-up from
  // `.tmp/oi-f-boolean-profile-targeted-count4-20260630`: Binaryen folds
  // identical nontrapping select arms even when the condition calls a helper
  // that mutates a private global, preserving the condition as a dropped prefix.
  // Keep this narrow to byte-identical, single-instruction pure arms; trapping
  // or effectful arms must not be reordered across the condition.
  let source = StringBuilder::new()
  source.write_string(
    "(module (global $g (mut i32) (i32.const 0)) (func (local i32",
  )
  for i = 0; i < 1024; i = i + 1 {
    let _ = i
    source.write_string(" i32")
  }
  source.write_string(
    ") i32.const 9 i32.const 9 call $effect select drop) (func $effect (result i32) i32.const 1 global.set $g i32.const 1))",
  )
  let trace : Array[String] = []
  let optimized = match
    pass_test_run_pipeline(
      source.to_string(),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(trace=Some(fn(line) { trace.push(line) })),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected optimize-instructions raw skip success, got \{err}")
  }
  assert_true(
    trace.any(fn(line) {
      line.contains(
        "pass[optimize-instructions]:skip-raw reason=large-local-optimize-instructions",
      )
    }),
    msg="expected large-local raw skip in \{trace}",
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("select"), msg=pretty)
  assert_true(pretty.contains("call"), msg=pretty)
  @debug.assert_eq(
    optimize_instructions_test_count_substring(pretty, "drop"),
    2,
    msg=pretty,
  )
}

///|
test "optimize-instructions raw skip simplifies memory.size nonzero if conditions" {
  // Follow-up from `.tmp/oi-g-live-nonzero-copy-boundary-count77-20260628`:
  // the new live nonzero memory-copy transform exposed a raw-skip mismatch where
  // Binaryen uses `memory.size` directly as an if condition, while Starshine kept
  // the equivalent `i32.ne (memory.size) (i32.const 0)` shell. This is only a
  // condition-context rewrite; value-producing `i32.ne` still has 0/1 semantics.
  let source = StringBuilder::new()
  source.write_string("(module (memory 1) (func (local i32")
  for i = 0; i < 1024; i = i + 1 {
    let _ = i
    source.write_string(" i32")
  }
  source.write_string(
    ") memory.size i32.const 0 i32.ne if i32.const 0 i32.const 0 i32.const 1 memory.copy i32.const 0 i32.load8_u drop end))",
  )
  let trace : Array[String] = []
  let optimized = match
    pass_test_run_pipeline(
      source.to_string(),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(trace=Some(fn(line) { trace.push(line) })),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected optimize-instructions raw skip success, got \{err}")
  }
  assert_true(
    trace.any(fn(line) {
      line.contains(
        "pass[optimize-instructions]:skip-raw reason=large-local-optimize-instructions",
      )
    }),
    msg="expected large-local raw skip in \{trace}",
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_true(pretty.contains("memory.size"), msg=pretty)
  assert_false(pretty.contains("i32.ne"), msg=pretty)
}

///|
test "optimize-instructions raw skip folds constant memory access offsets" {
  // Grouped OI-G follow-up from
  // `.tmp/oi-g-live-nonzero-mid-copy-boundary-count110-20260628`: the sampled
  // live page-middle copy/read residuals no longer differ in memory.copy/fill
  // opcode counts or canonical size, but large-local/raw-skipped functions still
  // kept Starshine's `const + static-offset` load/store spelling while Binaryen
  // folds the static offset into the constant address. Mirror that narrow raw
  // fallback for nonnegative constant memory32 addresses and non-overflowing
  // memory64 addresses; nonconstant address folding remains out of scope.
  let source32 = StringBuilder::new()
  source32.write_string("(module (memory 1) (func (local i32")
  for i = 0; i < 1024; i = i + 1 {
    let _ = i
    source32.write_string(" i32")
  }
  source32.write_string(
    ") i32.const 4 i32.load offset=12 drop i32.const 8 i32.const 9 i32.store offset=16))",
  )
  let trace32 : Array[String] = []
  let optimized32 = match
    pass_test_run_pipeline(
      source32.to_string(),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(
        trace=Some(fn(line) { trace32.push(line) }),
      ),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail(
        "expected optimize-instructions memory32 raw skip success, got \{err}",
      )
  }
  assert_true(
    trace32.any(fn(line) {
      line.contains(
        "pass[optimize-instructions]:skip-raw reason=large-local-optimize-instructions",
      )
    }),
    msg="expected memory32 large-local raw skip in \{trace32}",
  )
  let pretty32 = optimized32.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_true(pretty32.contains("I32(16)"), msg=pretty32)
  assert_true(pretty32.contains("I32(24)"), msg=pretty32)
  assert_false(pretty32.contains("offset=U64(12)"), msg=pretty32)
  assert_false(pretty32.contains("offset=U64(16)"), msg=pretty32)
  assert_false(pretty32.contains("I32(4)"), msg=pretty32)
  assert_false(pretty32.contains("I32(8)"), msg=pretty32)

  let func_type64 = @lib.RecType::new(
    @lib.SubType::comp_type(@lib.CompType::func([], [])),
  )
  let input64 = @lib.Module::new()
    .with_type_sec(@lib.TypeSec::new([func_type64]))
    .with_func_sec(@lib.FuncSec::new([@lib.TypeIdx::new(0U)]))
    .with_mem_sec(
      @lib.MemSec::new([@lib.MemType::new(@lib.Limits::i64(1UL, None))]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::single(1025U, @lib.ValType::i32()),
          @lib.Expr::new([
            @lib.Instruction::i64_const(@lib.I64(8L)),
            @lib.Instruction::i64_load(
              @lib.MemArg::new(@lib.U32(3), None, @lib.U64(24UL)),
            ),
            @lib.Instruction::drop(),
            @lib.Instruction::i64_const(@lib.I64(12L)),
            @lib.Instruction::i32_const(@lib.I32(9)),
            @lib.Instruction::i32_store8(
              @lib.MemArg::new(@lib.U32(0), None, @lib.U64(20UL)),
            ),
          ]),
        ),
      ]),
    )
  match @validate.validate_module(input64) {
    Ok(_) => ()
    Err(err) => fail("expected valid memory64 raw skip input, got \{err}")
  }
  let trace64 : Array[String] = []
  let optimized64 = match
    run_hot_pipeline(
      input64,
      HotPipelineOptions::new(trace=Some(fn(line) { trace64.push(line) })),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail(
        "expected optimize-instructions memory64 raw skip success, got \{err}",
      )
  }
  assert_true(
    trace64.any(fn(line) {
      line.contains(
        "pass[optimize-instructions]:skip-raw reason=large-local-optimize-instructions",
      )
    }),
    msg="expected memory64 large-local raw skip in \{trace64}",
  )
  let pretty64 = optimized64.pretty_print_func(@lib.FuncIdx::new(0U))
  @debug.assert_eq(
    optimize_instructions_test_count_substring(pretty64, "I64(32)"),
    2,
  )
  assert_false(pretty64.contains("offset=U64(24)"), msg=pretty64)
  assert_false(pretty64.contains("offset=U64(20)"), msg=pretty64)
  assert_false(pretty64.contains("I64(8)"), msg=pretty64)
  assert_false(pretty64.contains("I64(12)"), msg=pretty64)
}

///|
test "optimize-instructions raw skip rewrites memory.size page-byte multiply to shift" {
  // Follow-up from
  // `.tmp/oi-g-live-nonzero-end-fill-restore-boundary-count91-full-20260628`:
  // the live end-byte fill/read transform exposed canonical size-losing raw-skip
  // drift where Binaryen rewrites `memory.size * 65536` to `memory.size << 16`
  // inside the guarded end-byte address expression. Keep this as a narrow raw
  // fallback for adjacent memory.size / power-of-two multiply spellings.
  let source = StringBuilder::new()
  source.write_string("(module (memory 1) (func (local i32")
  for i = 0; i < 1024; i = i + 1 {
    let _ = i
    source.write_string(" i32")
  }
  source.write_string(
    ") memory.size i32.const 0 i32.ne if memory.size i32.const 65536 i32.mul i32.const 1 i32.sub memory.size i32.const 65536 i32.mul i32.const 1 i32.sub i32.load8_u i32.store8 end))",
  )
  let trace : Array[String] = []
  let optimized = match
    pass_test_run_pipeline(
      source.to_string(),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(trace=Some(fn(line) { trace.push(line) })),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected optimize-instructions raw skip success, got \{err}")
  }
  assert_true(
    trace.any(fn(line) {
      line.contains(
        "pass[optimize-instructions]:skip-raw reason=large-local-optimize-instructions",
      )
    }),
    msg="expected large-local raw skip in \{trace}",
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("i32.mul"), msg=pretty)
  assert_true(pretty.contains("i32.shl"), msg=pretty)
  assert_true(pretty.contains("I32(16)"), msg=pretty)
}

///|
test "optimize-instructions raw skip folds ordered const eq ne" {
  // Grouped OI-G count-18 follow-up from
  // `.tmp/oi-g-memory-family-memory64-boundary-fix-count18-20260628`: the
  // `live-effect-trap-boundaries + oi-commuted-operands` representative was a
  // canonical size-losing raw-skip mismatch because Binaryen folds the sampled
  // ordered adjacent const equality spelling (`7 == 42`) to `i32.const 0`, while
  // keeping the reverse spelling (`42 == 7`). Mirror that narrow raw fallback
  // contract without claiming broader dropped-compare cleanup.
  let source = StringBuilder::new()
  source.write_string("(module (func (local i32")
  for i = 0; i < 1024; i = i + 1 {
    let _ = i
    source.write_string(" i32")
  }
  source.write_string(
    ") i32.const 42 i32.const 7 i32.eq drop i32.const 7 i32.const 42 i32.eq drop i64.const 42 i64.const 7 i64.ne drop i64.const 7 i64.const 42 i64.ne drop))",
  )
  let trace : Array[String] = []
  let optimized = match
    pass_test_run_pipeline(
      source.to_string(),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(trace=Some(fn(line) { trace.push(line) })),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected optimize-instructions raw skip success, got \{err}")
  }
  assert_true(
    trace.any(fn(line) {
      line.contains(
        "pass[optimize-instructions]:skip-raw reason=large-local-optimize-instructions",
      )
    }),
    msg="expected large-local raw skip in \{trace}",
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_true(pretty.contains("i32.eq"), msg=pretty)
  assert_true(pretty.contains("i64.ne"), msg=pretty)
  assert_true(pretty.contains("I32(0)"), msg=pretty)
  assert_true(pretty.contains("I32(1)"), msg=pretty)
}

///|
test "optimize-instructions raw skip folds scalar sub i64 add sub and wrap constants" {
  // Follow-up from `.tmp/oi-f-effectful-family-fix3-20260627`: the remaining
  // size-losing `oi-effectful-sibling` representative still kept raw-skipped
  // OI-D scalar constant spellings that the HOT pass already folds. Keep the
  // raw escape narrow and pure: adjacent constants with exact scalar opcodes.
  let source = StringBuilder::new()
  source.write_string("(module (func (local i32")
  for i = 0; i < 1024; i = i + 1 {
    let _ = i
    source.write_string(" i32")
  }
  source.write_string(
    ") i32.const 84 i32.const 3 i32.sub drop i64.const 99 i64.const 5 i64.add drop i64.const 99 i64.const 5 i64.sub drop i64.const 4294967297 i32.wrap_i64 drop))",
  )
  let trace : Array[String] = []
  let optimized = match
    pass_test_run_pipeline(
      source.to_string(),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(trace=Some(fn(line) { trace.push(line) })),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected optimize-instructions raw skip success, got \{err}")
  }
  assert_true(
    trace.any(fn(line) {
      line.contains(
        "pass[optimize-instructions]:skip-raw reason=large-local-optimize-instructions",
      )
    }),
    msg="expected large-local raw skip in \{trace}",
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("i32.sub"), msg=pretty)
  assert_false(pretty.contains("i64.add"), msg=pretty)
  assert_false(pretty.contains("i64.sub"), msg=pretty)
  assert_false(pretty.contains("i32.wrap_i64"), msg=pretty)
  assert_true(pretty.contains("I32(81)"), msg=pretty)
  assert_true(pretty.contains("I64(104)"), msg=pretty)
  assert_true(pretty.contains("I64(94)"), msg=pretty)
  assert_true(pretty.contains("I32(1)"), msg=pretty)
}

///|
test "optimize-instructions raw skip rewrites nonnegative signed scalar spellings" {
  // Follow-up from `.tmp/oi-f-effectful-family-fix4-20260627`: the sampled
  // private-global `oi-effectful-sibling` representative no longer loses
  // normalized size, but raw-skip OI still keeps signed compare/div/rem/shift
  // spellings for nonnegative constants where Binaryen prints unsigned forms.
  // Keep this narrow: adjacent constants and nonnegative operands; zero
  // div/rem divisors are included only because signed and unsigned integer
  // div/rem both trap before producing a value.
  let source = StringBuilder::new()
  source.write_string("(module (func (local i32")
  for i = 0; i < 1024; i = i + 1 {
    let _ = i
    source.write_string(" i32")
  }
  source.write_string(
    ") i32.const 11 i32.const 3 i32.lt_s drop i32.const 11 i32.const 3 i32.gt_s drop i32.const 11 i32.const 3 i32.le_s drop i32.const 11 i32.const 3 i32.ge_s drop i32.const 84 i32.const 3 i32.div_s drop i32.const 84 i32.const 3 i32.rem_s drop i32.const 84 i32.const 3 i32.shr_s drop i32.const 1 i32.const 0 i32.div_s drop i32.const 1 i32.const 0 i32.rem_s drop i64.const 11 i64.const 3 i64.lt_s drop i64.const 11 i64.const 3 i64.gt_s drop i64.const 11 i64.const 3 i64.le_s drop i64.const 11 i64.const 3 i64.ge_s drop i64.const 84 i64.const 3 i64.div_s drop i64.const 84 i64.const 3 i64.rem_s drop i64.const 84 i64.const 3 i64.shr_s drop i64.const 1 i64.const 0 i64.div_s drop i64.const 1 i64.const 0 i64.rem_s drop))",
  )
  let trace : Array[String] = []
  let optimized = match
    pass_test_run_pipeline(
      source.to_string(),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(trace=Some(fn(line) { trace.push(line) })),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected optimize-instructions raw skip success, got \{err}")
  }
  assert_true(
    trace.any(fn(line) {
      line.contains(
        "pass[optimize-instructions]:skip-raw reason=large-local-optimize-instructions",
      )
    }),
    msg="expected large-local raw skip in \{trace}",
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("i32.lt_s"), msg=pretty)
  assert_false(pretty.contains("i32.gt_s"), msg=pretty)
  assert_false(pretty.contains("i32.le_s"), msg=pretty)
  assert_false(pretty.contains("i32.ge_s"), msg=pretty)
  assert_false(pretty.contains("i32.div_s"), msg=pretty)
  assert_false(pretty.contains("i32.rem_s"), msg=pretty)
  assert_false(pretty.contains("i32.shr_s"), msg=pretty)
  assert_false(pretty.contains("i64.lt_s"), msg=pretty)
  assert_false(pretty.contains("i64.gt_s"), msg=pretty)
  assert_false(pretty.contains("i64.le_s"), msg=pretty)
  assert_false(pretty.contains("i64.ge_s"), msg=pretty)
  assert_false(pretty.contains("i64.div_s"), msg=pretty)
  assert_false(pretty.contains("i64.rem_s"), msg=pretty)
  assert_false(pretty.contains("i64.shr_s"), msg=pretty)
  assert_true(pretty.contains("i32.lt_u"), msg=pretty)
  assert_true(pretty.contains("i32.gt_u"), msg=pretty)
  assert_true(pretty.contains("i32.le_u"), msg=pretty)
  assert_true(pretty.contains("i32.ge_u"), msg=pretty)
  assert_true(pretty.contains("i32.div_u"), msg=pretty)
  assert_true(pretty.contains("i32.rem_u"), msg=pretty)
  assert_true(pretty.contains("i32.shr_u"), msg=pretty)
  assert_true(pretty.contains("i64.lt_u"), msg=pretty)
  assert_true(pretty.contains("i64.gt_u"), msg=pretty)
  assert_true(pretty.contains("i64.le_u"), msg=pretty)
  assert_true(pretty.contains("i64.ge_u"), msg=pretty)
  assert_true(pretty.contains("i64.div_u"), msg=pretty)
  assert_true(pretty.contains("i64.rem_u"), msg=pretty)
  assert_true(pretty.contains("i64.shr_u"), msg=pretty)
}

///|
test "optimize-instructions raw skip rewrites finite float sub spellings" {
  // Follow-up from `.tmp/oi-f-effectful-family-fix5-20260627`: after the
  // sampled private-global representative reached normalized size parity and
  // integer scalar spellings matched, raw-skip OI still kept finite float
  // subtraction spellings where Binaryen prints add-with-negated-constant. Keep
  // this narrow: adjacent finite nonzero constants and no NaN or signed-zero
  // boundary widening.
  let source = StringBuilder::new()
  source.write_string("(module (func (local i32")
  for i = 0; i < 1024; i = i + 1 {
    let _ = i
    source.write_string(" i32")
  }
  source.write_string(
    ") f32.const 9.25 f32.const 2.5 f32.sub drop f64.const 16.75 f64.const 3.5 f64.sub drop))",
  )
  let trace : Array[String] = []
  let optimized = match
    pass_test_run_pipeline(
      source.to_string(),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(trace=Some(fn(line) { trace.push(line) })),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected optimize-instructions raw skip success, got \{err}")
  }
  assert_true(
    trace.any(fn(line) {
      line.contains(
        "pass[optimize-instructions]:skip-raw reason=large-local-optimize-instructions",
      )
    }),
    msg="expected large-local raw skip in \{trace}",
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("f32.sub"), msg=pretty)
  assert_false(pretty.contains("f64.sub"), msg=pretty)
  assert_true(pretty.contains("f32.add"), msg=pretty)
  assert_true(pretty.contains("f64.add"), msg=pretty)
  assert_true(pretty.contains("F32(-2.5)"), msg=pretty)
  assert_true(pretty.contains("F64(-3.5)"), msg=pretty)
}

///|
test "optimize-instructions raw skip rewrites f64 div by two before finite sub" {
  // Follow-up from `.tmp/oi-f-effectful-family-fix6-20260627`: direct finite
  // float subtraction spellings are gone in the sampled private-global
  // representative, but Binaryen still rewrites the nested finite
  // `(f64.div x 2.0) - c` shell to `f64.add(f64.mul x 0.5, -c)`.
  let source = StringBuilder::new()
  source.write_string("(module (func (local i32")
  for i = 0; i < 1024; i = i + 1 {
    let _ = i
    source.write_string(" i32")
  }
  source.write_string(
    ") f64.const 6.5 f64.const 2 f64.div f64.const 1.5 f64.sub drop))",
  )
  let trace : Array[String] = []
  let optimized = match
    pass_test_run_pipeline(
      source.to_string(),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(trace=Some(fn(line) { trace.push(line) })),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected optimize-instructions raw skip success, got \{err}")
  }
  assert_true(
    trace.any(fn(line) {
      line.contains(
        "pass[optimize-instructions]:skip-raw reason=large-local-optimize-instructions",
      )
    }),
    msg="expected large-local raw skip in \{trace}",
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("f64.sub"), msg=pretty)
  assert_false(pretty.contains("f64.div"), msg=pretty)
  assert_true(pretty.contains("f64.mul"), msg=pretty)
  assert_true(pretty.contains("f64.add"), msg=pretty)
  assert_true(pretty.contains("F64(0.5)"), msg=pretty)
  assert_true(pretty.contains("F64(-1.5)"), msg=pretty)
}

///|
test "optimize-instructions preserves block-wrapped try_table catch depths in ref locals" {
  let source =
    #|(module
    #|  (type $box (sub (struct)))
    #|  (func $f (param i32) (result (ref null $box)) (local (ref null $box))
    #|    block
    #|      try_table (catch_all 0)
    #|        i32.const 0
    #|        if
    #|          ref.null $box
    #|          local.set 1
    #|        else
    #|          ref.null $box
    #|          local.set 1
    #|        end
    #|      end
    #|    end
    #|    local.get 1)
    #|  (func (export "run") (result (ref null $box))
    #|    i32.const 99
    #|    call $f))
  let optimized = match
    pass_test_run_pipeline(source, ["optimize-instructions"]) {
    Ok(mod_) => mod_
    Err(err) =>
      fail(
        "expected optimize-instructions try_table ref-local success, got \{err}",
      )
  }
  match @validate.validate_module(optimized) {
    Ok(_) => ()
    Err(err) =>
      fail(
        "expected optimize-instructions try_table ref-local output to validate, got \{err}",
      )
  }
}

///|
test "optimize-instructions folds select with constant false and pure dead arm" {
  let func = optimize_instructions_test_run_hot(
    "(module (func (result i32) (select (i32.add (i32.const 1) (i32.const 2)) (i32.const 7) (i32.const 0))))",
  )
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_get(func, root).op {
    @ir.HotOp::Const =>
      @debug.assert_eq(
        @ir.hot_const_get(func, @ir.hot_node_get(func, root).imm0),
        @ir.HotConstPayload::i32_const(@lib.I32(7)),
      )
    _ => fail("expected constant-false select to become the false arm")
  }
}

