  // inverse seven-descriptor-argument slice is source-probed separately from
  // the 7-ref/2-desc case and stays independent from arbitrary arity,
  // non-local/effectful arguments, indirect/call_ref, return_call*, multivalue,
  // escaping control/EH, and TNH/IIT widening.
  optimize_instructions_test_assert_mixed_direct_call_descriptor_miss(2, 7)
}

///|
test "optimize-instructions folds descriptor casts with mixed 5-ref 7-desc call exact descriptor misses" {
  // OI-J descriptor/effect order slice: Binaryen version_130 also folds the
  // exact descriptor miss when the reference call takes five pure local
  // arguments and the descriptor call takes seven pure local arguments. This
  // inverse seven-descriptor-argument slice is source-probed separately from
  // the 7-ref/5-desc case and stays independent from arbitrary arity,
  // non-local/effectful arguments, indirect/call_ref, return_call*, multivalue,
  // escaping control/EH, and TNH/IIT widening.
  optimize_instructions_test_assert_mixed_direct_call_descriptor_miss(5, 7)
}

///|
test "optimize-instructions folds descriptor casts with mixed 6-ref 7-desc call exact descriptor misses" {
  // OI-J descriptor/effect order slice: Binaryen version_130 also folds the
  // exact descriptor miss when the reference call takes six pure local arguments
  // and the descriptor call takes seven pure local arguments. This inverse mixed
  // seven-descriptor-argument slice stays independent from arbitrary arity,
  // non-local/effectful arguments, indirect/call_ref, return_call*, multivalue,
  // escaping control/EH, and TNH/IIT widening.
  optimize_instructions_test_assert_mixed_direct_call_descriptor_miss(6, 7)
}

///|
test "optimize-instructions rewrites exact-result descriptor cast misses before final validation" {
  // OI-J descriptor validation boundary: Binaryen version_130 also rewrites the
  // exact-result spelling of the strict-subtype/exact-descriptor miss to
  // `unreachable`. Starshine's final validator rejects that exact-result
  // descriptor cast if it survives optimization, so the public pipeline must
  // fold it before final module validation instead of relying on the narrower
  // already-valid inexact-result HOT fixture above.
  let base_type = @lib.TypeIdx::new(0U)
  let base_descriptor_type = @lib.TypeIdx::new(1U)
  let subtype = @lib.TypeIdx::new(2U)
  let subtype_descriptor = @lib.TypeIdx::new(3U)
  let func_type = @lib.TypeIdx::new(4U)
  let base_heap = @lib.HeapType::new(base_type)
  let exact_base_ref_type = @lib.RefType::new(false, base_heap, exact=true)
  let sub_ref_type = @lib.RefType::new(false, @lib.HeapType::new(subtype))
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
            ]),
            metadata=@lib.TypeMetadata::new(
              descriptor=Some(base_descriptor_type),
            ),
          ),
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(base_type)),
          ),
          @lib.SubType::new(
            false,
            [base_type],
            @lib.CompType::struct_([
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i64()),
                @lib.Mut::const_(),
              ),
            ]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(subtype_descriptor)),
          ),
          @lib.SubType::new(
            false,
            [base_descriptor_type],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(subtype)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::ref_type(sub_ref_type)], [
              @lib.ValType::ref_type(exact_base_ref_type),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([func_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::struct_new_default(base_descriptor_type),
            @lib.Instruction::ref_cast_desc_eq_type(exact_base_ref_type),
          ]),
        ),
      ]),
    )
  let optimized = match
    run_hot_pipeline(module_, HotPipelineOptions::new(), [
      "optimize-instructions",
    ]) {
    Ok(mod_) => mod_
    Err(err) =>
      fail(
        "expected exact-result descriptor miss to fold before final validation, got \{err}",
      )
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_true(pretty.contains("unreachable"), msg=pretty)
  assert_false(pretty.contains("ref.cast_desc_eq"), msg=pretty)
}

///|
test "optimize-instructions exactifies nullable descriptor casts on strict-subtype operands before final validation" {
  // OI-J descriptor exactness validation slice: Binaryen version_130 rewrites a
  // nullable descriptor equality cast fed by a nullable strict-subtype operand
  // plus a fresh exact descriptor for the supertype to `ref.cast_desc_eq (ref
  // null (exact $base))`. Non-null subtype values still trap and null still
  // passes; the public Starshine pipeline must accept the exactified cast during
  // final validation instead of failing after the optimizer does the Binaryen
  // rewrite. Effectful operands, TNH/IIT, ref.test_desc, and descriptor BrOn
  // remain out of scope.
  let base_type = @lib.TypeIdx::new(0U)
  let base_descriptor_type = @lib.TypeIdx::new(1U)
  let subtype = @lib.TypeIdx::new(2U)
  let subtype_descriptor = @lib.TypeIdx::new(3U)
  let func_type = @lib.TypeIdx::new(4U)
  let base_heap = @lib.HeapType::new(base_type)
  let sub_heap = @lib.HeapType::new(subtype)
  let nullable_base_ref_type = @lib.RefType::new(true, base_heap)
  let nullable_sub_ref_type = @lib.RefType::new(true, sub_heap)
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
            ]),
            metadata=@lib.TypeMetadata::new(
              descriptor=Some(base_descriptor_type),
            ),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(base_type)),
          ),
          @lib.SubType::new(
            false,
            [base_type],
            @lib.CompType::struct_([
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i64()),
                @lib.Mut::const_(),
              ),
            ]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(subtype_descriptor)),
          ),
          @lib.SubType::new(
            false,
            [base_descriptor_type],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(subtype)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func(
              [@lib.ValType::ref_type(nullable_sub_ref_type)],
              [@lib.ValType::ref_type(nullable_base_ref_type)],
            ),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([func_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::struct_new_default(base_descriptor_type),
            @lib.Instruction::ref_cast_desc_eq_type(nullable_base_ref_type),
          ]),
        ),
      ]),
    )
  let optimized = match
    run_hot_pipeline(module_, HotPipelineOptions::new(), [
      "optimize-instructions",
    ]) {
    Ok(mod_) => mod_
    Err(err) =>
      fail(
        "expected nullable strict-subtype descriptor cast to exactify and validate, got \{err}",
      )
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_true(pretty.contains("ref.cast_desc_eq"), msg=pretty)
  assert_true(pretty.contains("Exact"), msg=pretty)
}

///|
test "optimize-instructions exactifies nullable descriptor casts with exact descriptor operands" {
  // OI-J descriptor exactness breadth: Binaryen version_130 rewrites a nullable
  // descriptor equality cast fed by an inexact nullable reference plus an exact
  // descriptor object for the same heap to `ref.cast_desc_eq (ref null (exact
  // $target))`. The descriptor equality check remains; only the result type's
  // exactness is strengthened. This does not claim ref.test_desc, TNH/IIT, or
  // subtype descriptor breadth beyond exact same-target descriptor operands.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let described_heap = @lib.HeapType::new(described_type)
  let nullable_described_ref_type = @lib.RefType::new(true, described_heap)
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func(
              [@lib.ValType::ref_type(nullable_described_ref_type)],
              [@lib.ValType::ref_type(nullable_described_ref_type)],
            ),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([@lib.TypeIdx::new(2U)]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::struct_new_default(descriptor_type),
            @lib.Instruction::ref_cast_desc_eq_type(nullable_described_ref_type),
          ]),
        ),
      ]),
    )
  let func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(0U))
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    module_ctx=Some(@ir.hot_module_context_from_module(module_)),
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) => fail("expected nullable descriptor exactification, got \{err}")
  }
  let root = @ir.hot_root_get(func, 0)
  @debug.assert_eq(@ir.hot_child_count(func, root), 2)
  match @ir.hot_node_exact_instr(func, root) {
    Some(@lib.Instruction::RefCastDescEq(nullable, exact, target)) => {
      @debug.assert_eq(nullable, true)
      @debug.assert_eq(exact, true)
      @debug.assert_eq(target, described_heap)
    }
    other => fail("expected exactified nullable descriptor cast, got \{other}")
  }
}

///|
test "optimize-instructions moves ref.as_non_null into exact descriptor casts" {
  // OI-J skipNonNullCast/trapOnNull exactness: Binaryen version_130 default,
  // IIT, and TNH modes rewrite `ref.as_non_null(ref.cast_desc_eq (ref null
  // $target) ...)` into a non-null `ref.cast_desc_eq (ref (exact $target))`
  // when the exact same-target descriptor operand proves exactness. This is a
  // narrow success-path descriptor-cast case; it does not cover ref.test_desc
  // or broad TNH/IIT descriptor skipping.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let described_heap = @lib.HeapType::new(described_type)
  let nullable_described_ref_type = @lib.RefType::new(true, described_heap)
  let nonnull_described_ref_type = @lib.RefType::new(false, described_heap)
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func(
              [@lib.ValType::ref_type(nullable_described_ref_type)],
              [@lib.ValType::ref_type(nonnull_described_ref_type)],
            ),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([@lib.TypeIdx::new(2U)]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::struct_new_default(descriptor_type),
            @lib.Instruction::ref_cast_desc_eq_type(nullable_described_ref_type),
            @lib.Instruction::ref_as_non_null(),
          ]),
        ),
      ]),
    )
  let func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(0U))
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    module_ctx=Some(@ir.hot_module_context_from_module(module_)),
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) => fail("expected descriptor as_non_null folding, got \{err}")
  }
  let root = @ir.hot_root_get(func, 0)
  @debug.assert_eq(@ir.hot_child_count(func, root), 2)
  match @ir.hot_node_exact_instr(func, root) {
    Some(@lib.Instruction::RefCastDescEq(nullable, exact, target)) => {
      @debug.assert_eq(nullable, false)
      @debug.assert_eq(exact, true)
      @debug.assert_eq(target, described_heap)
    }
    other => fail("expected non-null exact descriptor cast, got \{other}")
  }
}

///|
test "optimize-instructions exactifies descriptor casts with exact subtype descriptors" {
  // OI-J exactness/useful-type-info breadth: Binaryen version_130 default,
  // IIT, and TNH modes rewrite an inexact base-heap descriptor cast whose
  // descriptor operand is an exact descriptor for a strict subtype to
  // `ref.cast_desc_eq (ref (exact $sub))`. The explicit descriptor equality
  // check remains because it proves the stronger subtype exactness. This is a
  // narrow exact subtype-descriptor case; ref.test_desc and broader descriptor
  // control/effect shapes remain open.
  let base_type = @lib.TypeIdx::new(0U)
  let base_descriptor_type = @lib.TypeIdx::new(1U)
  let subtype = @lib.TypeIdx::new(2U)
  let subtype_descriptor = @lib.TypeIdx::new(3U)
  let func_type = @lib.TypeIdx::new(4U)
  let base_heap = @lib.HeapType::new(base_type)
  let subtype_heap = @lib.HeapType::new(subtype)
  let base_ref_type = @lib.RefType::new(false, base_heap)
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(
              descriptor=Some(base_descriptor_type),
            ),
          ),
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(base_type)),
          ),
          @lib.SubType::new(
            false,
            [base_type],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(subtype_descriptor)),
          ),
          @lib.SubType::new(
            false,
            [base_descriptor_type],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(subtype)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::ref_type(base_ref_type)], [
              @lib.ValType::ref_type(base_ref_type),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([func_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::struct_new_default(subtype_descriptor),
            @lib.Instruction::ref_cast_desc_eq_type(base_ref_type),
          ]),
        ),
      ]),
    )
  let func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(0U))
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    module_ctx=Some(@ir.hot_module_context_from_module(module_)),
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) => fail("expected exact subtype descriptor narrowing, got \{err}")
  }
  let root = @ir.hot_root_get(func, 0)
  @debug.assert_eq(@ir.hot_child_count(func, root), 2)
  match @ir.hot_node_exact_instr(func, root) {
    Some(@lib.Instruction::RefCastDescEq(nullable, exact, target)) => {
      @debug.assert_eq(nullable, false)
      @debug.assert_eq(exact, true)
      @debug.assert_eq(target, subtype_heap)
    }
    other => fail("expected exact subtype descriptor cast, got \{other}")
  }

  let func_tnh = @ir.hot_lift_func(module_, @lib.FuncIdx::new(0U))
  let ctx_tnh = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    traps_never_happen=true,
    module_ctx=Some(@ir.hot_module_context_from_module(module_)),
  )
  match hot_pass_run(ctx_tnh, func_tnh) {
    Ok(_) => ()
    Err(err) =>
      fail("expected TNH exact subtype descriptor preservation, got \{err}")
  }
  let root_tnh = @ir.hot_root_get(func_tnh, 0)
  match @ir.hot_node_exact_instr(func_tnh, root_tnh) {
    Some(@lib.Instruction::RefCastDescEq(nullable, exact, target)) => {
      @debug.assert_eq(nullable, false)
      @debug.assert_eq(exact, true)
      @debug.assert_eq(target, subtype_heap)
    }
    other => fail("expected TNH exact subtype descriptor cast, got \{other}")
  }
}

///|
test "optimize-instructions preserves exactifying descriptor casts under traps-never-happen" {
  // OI-J descriptor exactness/TNH breadth: Binaryen version_130 still preserves
  // a descriptor equality cast under `--traps-never-happen` when an exact
  // same-target descriptor operand can strengthen an inexact reference result to
  // exact. Skipping the cast would lose the useful exactness proof even though
  // TNH may ignore descriptor-equality traps. This is a narrow same-target
  // descriptor operand case; broader exactness and ref.test_desc remain open.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let described_heap = @lib.HeapType::new(described_type)
  let nullable_described_ref_type = @lib.RefType::new(true, described_heap)
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func(
              [@lib.ValType::ref_type(nullable_described_ref_type)],
              [@lib.ValType::ref_type(nullable_described_ref_type)],
            ),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([@lib.TypeIdx::new(2U)]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::struct_new_default(descriptor_type),
            @lib.Instruction::ref_cast_desc_eq_type(nullable_described_ref_type),
          ]),
        ),
      ]),
    )
  let func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(0U))
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    traps_never_happen=true,
    module_ctx=Some(@ir.hot_module_context_from_module(module_)),
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) =>
      fail("expected TNH descriptor exactification preservation, got \{err}")
  }
  let root = @ir.hot_root_get(func, 0)
  @debug.assert_eq(@ir.hot_child_count(func, root), 2)
  match @ir.hot_node_exact_instr(func, root) {
    Some(@lib.Instruction::RefCastDescEq(nullable, exact, target)) => {
      @debug.assert_eq(nullable, true)
      @debug.assert_eq(exact, true)
      @debug.assert_eq(target, described_heap)
    }
    other =>
      fail(
        "expected exactifying descriptor cast to remain under TNH, got \{other}",
      )
  }
}

///|
fn optimize_instructions_test_lift_nullable_descriptor_operand_cast() -> @ir.HotFunc {
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let func_type = @lib.TypeIdx::new(2U)
  let described_heap = @lib.HeapType::new(described_type)
  let descriptor_heap = @lib.HeapType::new(descriptor_type)
  let exact_described_ref_type = @lib.RefType::new(
    false,
    described_heap,
    exact=true,
  )
  let nullable_exact_descriptor_ref = @lib.ValType::ref_type(
    @lib.RefType::new(true, descriptor_heap, exact=true),
  )
  @ir.hot_lift_func(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func(
              [
                @lib.ValType::ref_type(exact_described_ref_type),
                nullable_exact_descriptor_ref,
              ],
              [@lib.ValType::ref_type(exact_described_ref_type)],
            ),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([func_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_cast_desc_eq_type(exact_described_ref_type),
          ]),
        ),
      ]),
    ),
    @lib.FuncIdx::new(0U),
  )
}

///|
test "optimize-instructions moves descriptor null checks into descriptor casts" {
  // OI-J descriptor exactness/trapOnNull breadth: Binaryen version_130 default
  // and IIT modes remove an explicit `ref.as_non_null` from the descriptor
  // operand of `ref.cast_desc_eq`, leaving the descriptor cast itself to carry
  // the descriptor null trap. TNH may erase the cast entirely; this test covers
  // the default representable descriptor-operand simplification only.
  let func = optimize_instructions_test_lift_nullable_descriptor_operand_cast()
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) =>
      fail("expected descriptor null-check simplification, got \{err}")
  }
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_exact_instr(func, root) {
    Some(@lib.Instruction::RefCastDescEq(_, _, _)) => ()
    other => fail("expected descriptor cast to remain, got \{other}")
  }
  let descriptor_operand = @ir.hot_child_get(func, root, 1)
  match @ir.hot_node_get(func, descriptor_operand).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected descriptor operand null check folded into cast")
  }
  @debug.assert_eq(@ir.hot_node_get(func, descriptor_operand).imm0, 1)
}

///|
test "optimize-instructions erases descriptor operand null checks under traps-never-happen" {
  // OI-J TNH descriptor-operand breadth: the same nullable exact descriptor
  // operand can be fully erased when TNH lets the pass ignore both the explicit
  // descriptor null check and the descriptor-equality trap. Broader trapping
  // descriptor operands and ref.test_desc remain open.
  let func = optimize_instructions_test_lift_nullable_descriptor_operand_cast()
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    traps_never_happen=true,
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) => fail("expected descriptor TNH null-check erase, got \{err}")
  }
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_get(func, root).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected local.get after descriptor operand TNH erase")
  }
  @debug.assert_eq(@ir.hot_node_get(func, root).imm0, 0)
}

///|
test "optimize-instructions skips descriptor equality casts under traps-never-happen for exact operands" {
  // OI-J TNH descriptor slice: Binaryen version_130 with
  // `--traps-never-happen --optimize-instructions` removes a descriptor
  // equality cast when the reference operand is already an exact non-null
  // target, because the only remaining observable behavior would be the
  // descriptor equality trap. The explicit descriptor operand may only be
  // erased when it is locally erasable; this test covers the pure fresh
  // descriptor allocation case and does not claim IIT or ref.test_desc support.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let described_heap = @lib.HeapType::new(described_type)
  let nullable_described_ref_type = @lib.RefType::new(true, described_heap)
  let func = @ir.hot_lift_func(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [
              @lib.ValType::ref_type(nullable_described_ref_type),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([@lib.TypeIdx::new(2U)]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::struct_new_default(descriptor_type),
            @lib.Instruction::struct_new_default_desc(described_type),
            @lib.Instruction::struct_new_default(descriptor_type),
            @lib.Instruction::ref_cast_desc_eq_type(nullable_described_ref_type),
          ]),
        ),
      ]),
    ),
    @lib.FuncIdx::new(0U),
  )
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    traps_never_happen=true,
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) => fail("expected descriptor TNH skip success, got \{err}")
  }
  let root = @ir.hot_root_get(func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(func, root),
    Some(@lib.Instruction::struct_new_default_desc(described_type)),
  )
  match @ir.hot_type_results(func, @ir.hot_node_type(func, root)) {
    [@lib.ValType::RefTypeValType(ref_type)] => {
      @debug.assert_eq(ref_type.is_non_nullable(), true)
      @debug.assert_eq(ref_type.is_exact(), true)
      @debug.assert_eq(ref_type.get_heap_type(), described_heap)
    }
    other => fail("expected exact descriptor-constructor result, got \{other}")
  }
}

///|
test "optimize-instructions skips nullable descriptor casts under traps-never-happen" {
  // OI-J TNH descriptor-cast breadth: Binaryen version_130 with
  // `--traps-never-happen --optimize-instructions` removes a nullable
  // descriptor equality cast when the reference operand already has the same
  // nullable heap type and the descriptor check is the only remaining trap.
  // This covers only non-exact nullable casts where replacing the cast with the
  // operand is type-valid; exact casts with inexact operands and ref.test_desc
  // remain open.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let func_type = @lib.TypeIdx::new(2U)
  let described_heap = @lib.HeapType::new(described_type)
  let descriptor_heap = @lib.HeapType::new(descriptor_type)
  let nullable_described_ref_type = @lib.RefType::new(true, described_heap)
  let descriptor_ref_type = @lib.RefType::new(false, descriptor_heap)
  let func = @ir.hot_lift_func(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func(
              [@lib.ValType::ref_type(nullable_described_ref_type)],
              [@lib.ValType::ref_type(nullable_described_ref_type)],
            ),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([func_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::from_types([@lib.ValType::ref_type(descriptor_ref_type)]),
          @lib.Expr::new([
            @lib.Instruction::struct_new_default(descriptor_type),
            @lib.Instruction::local_set(@lib.LocalIdx::new(1U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
            @lib.Instruction::ref_cast_desc_eq_type(nullable_described_ref_type),
          ]),
        ),
      ]),
    ),
    @lib.FuncIdx::new(0U),
  )
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    traps_never_happen=true,
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) =>
      fail("expected nullable descriptor TNH skip success, got \{err}")
  }
  @debug.assert_eq(@ir.hot_root_count(func), 2)
  match @ir.hot_node_get(func, @ir.hot_root_get(func, 0)).op {
    @ir.HotOp::LocalSet => ()
    _ => fail("expected descriptor local.set side effect to remain")
  }
  let root = @ir.hot_root_get(func, 1)
  let root_node = @ir.hot_node_get(func, root)
  match root_node.op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected local.get after nullable descriptor TNH skip")
  }
  @debug.assert_eq(root_node.imm0, 0)
}

///|
test "optimize-instructions erases nontrapping ref.get_desc descriptor operands under traps-never-happen" {
  // OI-J TNH descriptor operand breadth: Binaryen version_130 with
  // `--traps-never-happen --optimize-instructions` removes a descriptor
  // equality cast whose explicit descriptor operand is `ref.get_desc` of an
  // already-non-null reference. The `ref.get_desc` operand is only erased here
  // because its child cannot trap and has no effects; effectful descriptor
  // operands and ref.test_desc remain open.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let func_type = @lib.TypeIdx::new(2U)
  let described_heap = @lib.HeapType::new(described_type)
  let described_ref_type = @lib.RefType::new(false, described_heap)
  let func = @ir.hot_lift_func(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::ref_type(described_ref_type)], [
              @lib.ValType::ref_type(described_ref_type),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([func_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_get_desc(described_type),
            @lib.Instruction::ref_cast_desc_eq_type(described_ref_type),
          ]),
        ),
      ]),
    ),
    @lib.FuncIdx::new(0U),
  )
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    traps_never_happen=true,
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) =>
      fail("expected descriptor TNH ref.get_desc skip success, got \{err}")
  }
  let root = @ir.hot_root_get(func, 0)
  let root_node = @ir.hot_node_get(func, root)
  match root_node.op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected local.get after TNH ref.get_desc descriptor erase")
  }
  @debug.assert_eq(root_node.imm0, 0)
  @debug.assert_eq(@ir.hot_child_count(func, root), 0)
}

///|
test "optimize-instructions moves standalone ref.get_desc select and if null checks" {
  // OI-J standalone ref.get_desc trapOnNull breadth: Binaryen version_130
  // default and TNH modes simplify `ref.get_desc(ref.as_non_null(select ...))`
  // and `ref.get_desc(ref.as_non_null(if ...))` to leave the select/if as the
  // nullable child of `ref.get_desc`. This is a narrow branch-free nullable
  // value-child family and does not claim nested control, escaping branches,
  // descriptor operands, ref.test_desc, or generalized effect localization.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let described_heap = @lib.HeapType::new(described_type)
  let descriptor_heap = @lib.HeapType::new(descriptor_type)
  let nullable_described_val_type = @lib.ValType::ref_type(
    @lib.RefType::new(true, described_heap),
  )
  let descriptor_val_type = @lib.ValType::ref_type(
    @lib.RefType::new(false, descriptor_heap),
  )
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func(
              [
                nullable_described_val_type,
                nullable_described_val_type,
                @lib.ValType::i32(),
              ],
              [descriptor_val_type],
            ),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([@lib.TypeIdx::new(2U), @lib.TypeIdx::new(2U)]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(2U)),
            @lib.Instruction::select(types=Some([nullable_described_val_type])),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_get_desc(described_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(2U)),
            @lib.Instruction::if_(
              @lib.BlockType::val_type(nullable_described_val_type),
              [@lib.Instruction::local_get(@lib.LocalIdx::new(0U))],
              Some([@lib.Instruction::local_get(@lib.LocalIdx::new(1U))]),
            ),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_get_desc(described_type),
          ]),
        ),
      ]),
    )
  let optimized = optimize_instructions_test_run_module(module_)
  match optimized.code_sec {
    Some(
      @lib.CodeSec(
        [@lib.Func(_, @lib.Expr(select_body)), @lib.Func(_, @lib.Expr(if_body))]
      )
    ) => {
      @debug.assert_eq(select_body.length(), 5)
      match select_body[3] {
        @lib.Select(_) => ()
        other => fail("expected select child before ref.get_desc, got \{other}")
      }
      match select_body[4] {
        @lib.RefGetDesc(type_idx) => @debug.assert_eq(type_idx, described_type)
        other => fail("expected select-produced ref.get_desc, got \{other}")
      }
      @debug.assert_eq(if_body.length(), 3)
      match if_body[1] {
        @lib.If(_, _, _) => ()
        other => fail("expected if child before ref.get_desc, got \{other}")
      }
      match if_body[2] {
        @lib.RefGetDesc(type_idx) => @debug.assert_eq(type_idx, described_type)
        other => fail("expected if-produced ref.get_desc, got \{other}")
      }
    }
    other => fail("expected two optimized ref.get_desc funcs, got \{other}")
  }

  let tnh_ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    traps_never_happen=true,
    module_ctx=Some(@ir.hot_module_context_from_module(module_)),
  )
  let tnh_select_func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(0U))
  match hot_pass_run(tnh_ctx, tnh_select_func) {
    Ok(_) => ()
    Err(err) =>
      fail("expected TNH standalone select ref.get_desc success, got \{err}")
  }
  let tnh_select_root = @ir.hot_root_get(tnh_select_func, 0)
  let tnh_select_child = @ir.hot_child_get(tnh_select_func, tnh_select_root, 0)
  match @ir.hot_node_get(tnh_select_func, tnh_select_child).op {
    @ir.HotOp::Select => ()
    other => fail("expected TNH standalone select child, got \{other}")
  }
  let tnh_if_func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(1U))
  match hot_pass_run(tnh_ctx, tnh_if_func) {
    Ok(_) => ()
    Err(err) =>
      fail("expected TNH standalone if ref.get_desc success, got \{err}")
  }
  let tnh_if_root = @ir.hot_root_get(tnh_if_func, 0)
  let tnh_if_child = @ir.hot_child_get(tnh_if_func, tnh_if_root, 0)
  match @ir.hot_node_get(tnh_if_func, tnh_if_child).op {
    @ir.HotOp::If => ()
    other => fail("expected TNH standalone if child, got \{other}")
  }
}

///|
test "optimize-instructions traps standalone ref.get_desc known-null children" {
  // OI-J standalone ref.get_desc known-null child slice: Binaryen version_130
  // rewrites `ref.get_desc(ref.as_non_null(ref.null))` and the same known-null
  // result through local.tee / branch-free block children to a trap-producing
  // unreachable shape. This is separate from nullable-child null-check movement:
  // the result is not `ref.get_desc(child)`, and only the direct ref.null,
  // local.tee(ref.null), and branch-free block ending in ref.null families are
  // covered here. It does not claim generalized known-null dataflow, nested
  // call/control/EH operands, descriptor operands, ref.test_desc,
  // ref.cast_desc_eq exactness paths, indirect/call_ref/return_call*, or TNH/IIT
  // mode behavior beyond Binaryen's same observed trap-producing shape.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let described_heap = @lib.HeapType::new(described_type)
  let descriptor_heap = @lib.HeapType::new(descriptor_type)
  let nullable_described_ref_type = @lib.RefType::new(true, described_heap)
  let nullable_described_val_type = @lib.ValType::ref_type(
    nullable_described_ref_type,
  )
  let descriptor_val_type = @lib.ValType::ref_type(
    @lib.RefType::new(false, descriptor_heap),
  )
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [descriptor_val_type]),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        @lib.TypeIdx::new(2U),
        @lib.TypeIdx::new(2U),
        @lib.TypeIdx::new(2U),
      ]),
    )
    .with_global_sec(
      @lib.GlobalSec::new([
        @lib.Global::new(
          @lib.GlobalType::new(@lib.ValType::i32(), true),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::ref_null_type(nullable_described_ref_type),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_get_desc(described_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::single(1U, nullable_described_val_type),
          @lib.Expr::new([
            @lib.Instruction::ref_null_type(nullable_described_ref_type),
            @lib.Instruction::local_tee(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_get_desc(described_type),
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::drop(),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(nullable_described_val_type),
              @lib.Expr::new([
                @lib.Instruction::i32_const(@lib.I32(1)),
                @lib.Instruction::global_set(@lib.GlobalIdx::new(0U)),
                @lib.Instruction::ref_null_type(nullable_described_ref_type),
              ]),
            ),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_get_desc(described_type),
          ]),
        ),
      ]),
    )
  let optimized = optimize_instructions_test_run_module(module_)
  let direct_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(direct_pretty.contains("ref.get_desc"), msg=direct_pretty)
  assert_false(direct_pretty.contains("ref.as_non_null"), msg=direct_pretty)
  assert_true(direct_pretty.contains("unreachable"), msg=direct_pretty)
  let tee_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_false(tee_pretty.contains("ref.get_desc"), msg=tee_pretty)
  assert_false(tee_pretty.contains("ref.as_non_null"), msg=tee_pretty)
  optimize_instructions_assert_strings_in_order(tee_pretty, [
    "ref.null", "local.set", "unreachable",
  ])
  let block_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_false(block_pretty.contains("ref.get_desc"), msg=block_pretty)
  assert_false(block_pretty.contains("ref.as_non_null"), msg=block_pretty)
  optimize_instructions_assert_strings_in_order(block_pretty, [
    "I32(1)", "global.set", "ref.null", "unreachable",
  ])
}

///|
test "optimize-instructions moves standalone ref.get_desc global and tee null checks" {
  // OI-J standalone ref.get_desc nullable leaf/chunk slice: Binaryen version_130
  // default/TNH simplify `ref.get_desc(ref.as_non_null(child))` to keep the
  // nullable `global.get` or `local.tee` child directly under `ref.get_desc`.
  // The local.tee subset is limited to nontrapping nullable reference leaves
  // (`local.get` / `global.get`) so it does not claim ref.null-to-unreachable,
  // nested call/control operands, descriptor operands, ref.test_desc,
  // ref.cast_desc_eq exactness paths, effect localization, or broader TNH/IIT.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let described_heap = @lib.HeapType::new(described_type)
  let descriptor_heap = @lib.HeapType::new(descriptor_type)
  let nullable_described_ref_type = @lib.RefType::new(true, described_heap)
  let nullable_described_val_type = @lib.ValType::ref_type(
    nullable_described_ref_type,
  )
  let descriptor_val_type = @lib.ValType::ref_type(
    @lib.RefType::new(false, descriptor_heap),
  )
  let no_param_func_type = @lib.TypeIdx::new(2U)
  let param_func_type = @lib.TypeIdx::new(3U)
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [descriptor_val_type]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([nullable_described_val_type], [
              descriptor_val_type,
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        no_param_func_type, no_param_func_type, param_func_type, no_param_func_type,
      ]),
    )
    .with_global_sec(
      @lib.GlobalSec::new([
        @lib.Global::new(
          @lib.GlobalType::new(nullable_described_val_type, false),
          @lib.Expr::new([
            @lib.Instruction::ref_null_type(nullable_described_ref_type),
          ]),
        ),
        @lib.Global::new(
          @lib.GlobalType::new(nullable_described_val_type, true),
          @lib.Expr::new([
            @lib.Instruction::ref_null_type(nullable_described_ref_type),
          ]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::global_get(@lib.GlobalIdx::new(0U)),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_get_desc(described_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::global_get(@lib.GlobalIdx::new(1U)),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_get_desc(described_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::single(1U, nullable_described_val_type),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::local_tee(@lib.LocalIdx::new(1U)),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_get_desc(described_type),
            @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
            @lib.Instruction::drop(),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::single(1U, nullable_described_val_type),
          @lib.Expr::new([
            @lib.Instruction::global_get(@lib.GlobalIdx::new(1U)),
            @lib.Instruction::local_tee(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_get_desc(described_type),
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::drop(),
          ]),
        ),
      ]),
    )
  let optimized = optimize_instructions_test_run_module(module_)
  let immutable_global_pretty = optimized.pretty_print_func(
    @lib.FuncIdx::new(0U),
  )
  assert_false(
    immutable_global_pretty.contains("ref.as_non_null"),
    msg=immutable_global_pretty,
  )
  optimize_instructions_assert_strings_in_order(immutable_global_pretty, [
    "global.get", "ref.get_desc",
  ])
  let mutable_global_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_false(
    mutable_global_pretty.contains("ref.as_non_null"),
    msg=mutable_global_pretty,
  )
  optimize_instructions_assert_strings_in_order(mutable_global_pretty, [
    "global.get", "ref.get_desc",
  ])
  let tee_local_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_false(
    tee_local_pretty.contains("ref.as_non_null"),
    msg=tee_local_pretty,
  )
  optimize_instructions_assert_strings_in_order(tee_local_pretty, [
    "local.get", "local.tee", "ref.get_desc",
  ])
  let tee_global_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(3U))
  assert_false(
    tee_global_pretty.contains("ref.as_non_null"),
    msg=tee_global_pretty,
  )
  optimize_instructions_assert_strings_in_order(tee_global_pretty, [
    "global.get", "local.tee", "ref.get_desc",
  ])

  let tnh_ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    traps_never_happen=true,
    module_ctx=Some(@ir.hot_module_context_from_module(module_)),
  )
  let tnh_global_func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(0U))
  match hot_pass_run(tnh_ctx, tnh_global_func) {
    Ok(_) => ()
    Err(err) =>
      fail(
        "expected TNH standalone global.get ref.get_desc success, got \{err}",
      )
  }
  let tnh_global_root = @ir.hot_root_get(tnh_global_func, 0)
  let tnh_global_child = @ir.hot_child_get(tnh_global_func, tnh_global_root, 0)
  match @ir.hot_node_get(tnh_global_func, tnh_global_child).op {
    @ir.HotOp::GlobalGet => ()
    other => fail("expected TNH standalone global.get child, got \{other}")
  }
  let tnh_tee_func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(2U))
  match hot_pass_run(tnh_ctx, tnh_tee_func) {
    Ok(_) => ()
    Err(err) =>
      fail("expected TNH standalone local.tee ref.get_desc success, got \{err}")
  }
  let tnh_tee_root = @ir.hot_root_get(tnh_tee_func, 0)
  let tnh_tee_child = @ir.hot_child_get(tnh_tee_func, tnh_tee_root, 0)
  match @ir.hot_node_get(tnh_tee_func, tnh_tee_child).op {
    @ir.HotOp::LocalTee | @ir.HotOp::LocalGet => ()
    other =>
      fail("expected TNH standalone local.tee/local.get child, got \{other}")
  }
}

///|
test "optimize-instructions moves standalone ref.get_desc direct-call null checks" {
  // OI-J standalone ref.get_desc direct-call child slice: Binaryen version_130
  // default/TNH simplify `ref.get_desc(ref.as_non_null(call ...))` to put the
  // nullable direct-call result directly under `ref.get_desc` for no-parameter
  // calls and for parameterized direct calls whose operands are nontrapping
  // leaves. This narrow family does not include indirect/call_ref/return_call,
  // multivalue, nested call/control operands, escaping control/EH, descriptor
  // operands, ref.test_desc, or generalized effect localization.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let nullable_described_ref_type = @lib.RefType::new(
    true,
    @lib.HeapType::new(described_type),
  )
  let descriptor_ref_type = @lib.RefType::new(
    false,
    @lib.HeapType::new(descriptor_type),
  )
  let nullable_described_val_type = @lib.ValType::ref_type(
    nullable_described_ref_type,
  )
  let descriptor_val_type = @lib.ValType::ref_type(descriptor_ref_type)
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [nullable_described_val_type]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func(
              [nullable_described_val_type, @lib.ValType::i32()],
              [nullable_described_val_type],
            ),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [descriptor_val_type]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([nullable_described_val_type], [
              descriptor_val_type,
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        @lib.TypeIdx::new(2U),
        @lib.TypeIdx::new(3U),
        @lib.TypeIdx::new(4U),
        @lib.TypeIdx::new(5U),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::ref_null_type(nullable_described_ref_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::local_get(@lib.LocalIdx::new(0U))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_get_desc(described_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::call(@lib.FuncIdx::new(1U)),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_get_desc(described_type),
          ]),
        ),
      ]),
    )
  let optimized = optimize_instructions_test_run_module(module_)
  match optimized.code_sec {
    Some(
      @lib.CodeSec(
        [
          _,
          _,
          @lib.Func(_, @lib.Expr(no_param_body)),
          @lib.Func(_, @lib.Expr(param_body)),
        ]
      )
    ) => {
      @debug.assert_eq(no_param_body.length(), 2)
      match no_param_body[0] {
        @lib.Call(func_idx) => @debug.assert_eq(func_idx, @lib.FuncIdx::new(0U))
        other => fail("expected no-param direct call child, got \{other}")
      }
      match no_param_body[1] {
        @lib.RefGetDesc(type_idx) => @debug.assert_eq(type_idx, described_type)
        other =>
          fail("expected no-param call-produced ref.get_desc, got \{other}")
      }
      @debug.assert_eq(param_body.length(), 4)
      match param_body[0] {
        @lib.LocalGet(arg) => @debug.assert_eq(arg, @lib.LocalIdx::new(0U))
        other => fail("expected parameterized call local operand, got \{other}")
      }
      match param_body[1] {
        @lib.I32Const(@lib.I32(7)) => ()
        other => fail("expected parameterized call const operand, got \{other}")
      }
      match param_body[2] {
        @lib.Call(func_idx) => @debug.assert_eq(func_idx, @lib.FuncIdx::new(1U))
        other => fail("expected parameterized direct call child, got \{other}")
      }
      match param_body[3] {
        @lib.RefGetDesc(type_idx) => @debug.assert_eq(type_idx, described_type)
        other =>
          fail(
            "expected parameterized call-produced ref.get_desc, got \{other}",
          )
      }
    }
    other =>
      fail("expected optimized direct-call ref.get_desc funcs, got \{other}")
  }

  let tnh_ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    traps_never_happen=true,
    module_ctx=Some(@ir.hot_module_context_from_module(module_)),
  )
  let tnh_no_param_func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(2U))
  match hot_pass_run(tnh_ctx, tnh_no_param_func) {
    Ok(_) => ()
    Err(err) =>
      fail(
        "expected TNH standalone no-param call ref.get_desc success, got \{err}",
      )
  }
  let tnh_no_param_root = @ir.hot_root_get(tnh_no_param_func, 0)
  let tnh_no_param_child = @ir.hot_child_get(
    tnh_no_param_func, tnh_no_param_root, 0,
  )
  match @ir.hot_node_get(tnh_no_param_func, tnh_no_param_child).op {
    @ir.HotOp::Call => ()
    other => fail("expected TNH standalone no-param call child, got \{other}")
  }
  let tnh_param_func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(3U))
  match hot_pass_run(tnh_ctx, tnh_param_func) {
    Ok(_) => ()
    Err(err) =>
      fail(
        "expected TNH standalone parameterized call ref.get_desc success, got \{err}",
      )
  }
  let tnh_param_root = @ir.hot_root_get(tnh_param_func, 0)
  let tnh_param_child = @ir.hot_child_get(tnh_param_func, tnh_param_root, 0)
  match @ir.hot_node_get(tnh_param_func, tnh_param_child).op {
    @ir.HotOp::Call => ()
    other =>
      fail("expected TNH standalone parameterized call child, got \{other}")
  }
}

///|
test "optimize-instructions moves standalone ref.get_desc call_ref null checks" {
  // OI-J standalone ref.get_desc call_ref child slice: Binaryen version_130
  // default/TNH/IIT directize `ref.func` + `call_ref` children and simplify
  // `ref.get_desc(ref.as_non_null(call_ref ...))` to put the direct call result
  // under `ref.get_desc`. This is deliberately just the exact `ref.func`
  // target family; return_call_ref, table/indirect targets, multivalue,
  // escaping control/EH, descriptor-cast operands, and ref.test_desc remain
  // separate surfaces.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let nullable_call_ref_type = @lib.TypeIdx::new(2U)
  let nonnull_call_ref_type = @lib.TypeIdx::new(3U)
  let get_desc_type = @lib.TypeIdx::new(4U)
  let described_heap = @lib.HeapType::new(described_type)
  let nullable_described_ref_type = @lib.RefType::new(true, described_heap)
  let nonnull_described_ref_type = @lib.RefType::new(false, described_heap)
  let descriptor_ref_type = @lib.RefType::new(
    false,
    @lib.HeapType::new(descriptor_type),
  )
  let descriptor_val_type = @lib.ValType::ref_type(descriptor_ref_type)
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [
              @lib.ValType::ref_type(nullable_described_ref_type),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [
              @lib.ValType::ref_type(nonnull_described_ref_type),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [descriptor_val_type]),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        nullable_call_ref_type, nonnull_call_ref_type, get_desc_type, get_desc_type,
      ]),
    )
    .with_elem_sec(
      @lib.ElemSec::new([
        @lib.Elem::new(
          @lib.ElemMode::declarative(),
          @lib.ElemKind::funcs([@lib.FuncIdx::new(0U), @lib.FuncIdx::new(1U)]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::struct_new_default(descriptor_type),
            @lib.Instruction::struct_new_default_desc(described_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::struct_new_default(descriptor_type),
            @lib.Instruction::struct_new_default_desc(described_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::ref_func(@lib.FuncIdx::new(0U)),
            @lib.Instruction::call_ref(nullable_call_ref_type),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_get_desc(described_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::ref_func(@lib.FuncIdx::new(1U)),
            @lib.Instruction::call_ref(nonnull_call_ref_type),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_get_desc(described_type),
          ]),
        ),
      ]),
    )
  let assert_call_ref_ref_get_desc = fn(
    mod_ : @lib.Module,
    label : String,
  ) -> Unit raise {
    match mod_.code_sec {
      Some(
        @lib.CodeSec(
          [
            _,
            _,
            @lib.Func(_, @lib.Expr(nullable_body)),
            @lib.Func(_, @lib.Expr(nonnull_body)),
          ]
        )
      ) => {
        @debug.assert_eq(
          nullable_body,
          [
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::ref_get_desc(described_type),
          ],
          msg="\{label} nullable call_ref descriptor child",
        )
        @debug.assert_eq(
          nonnull_body,
          [
            @lib.Instruction::call(@lib.FuncIdx::new(1U)),
            @lib.Instruction::ref_get_desc(described_type),
          ],
          msg="\{label} nonnull call_ref descriptor child: \{nonnull_body}",
        )
      }
      other =>
        fail("expected optimized call_ref ref.get_desc funcs, got \{other}")
    }
  }
  assert_call_ref_ref_get_desc(
    optimize_instructions_test_run_module(module_),
    "default",
  )
  let iit_optimized = match
    run_hot_pipeline(
      module_,
      HotPipelineOptions::new(ignore_implicit_traps=true),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) => fail("expected IIT call_ref ref.get_desc success, got \{err}")
  }
  assert_call_ref_ref_get_desc(iit_optimized, "IIT")
}

///|
test "optimize-instructions moves standalone ref.get_desc indirect call_ref null checks" {
  // OI-J standalone ref.get_desc table-target call_ref child slice: Binaryen
  // version_130 default/TNH/IIT directize typed-table `call_ref` children to
  // `call_indirect` and simplify `ref.get_desc(ref.as_non_null(call_ref ...))`
  // to put the indirect call result under `ref.get_desc`. This is deliberately
  // a bounded typed-table family with nontrapping leaf arguments and table
  // indexes; return_call_ref, select/block targets, multivalue, nested
  // effectful/trapping operands, escaping control/EH, descriptor-cast operands,
  // and ref.test_desc remain separate surfaces.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let nullable_call_ref_type = @lib.TypeIdx::new(2U)
  let nonnull_call_ref_type = @lib.TypeIdx::new(3U)
  let get_desc_type = @lib.TypeIdx::new(4U)
  let described_heap = @lib.HeapType::new(described_type)
  let nullable_described_ref_type = @lib.RefType::new(true, described_heap)
  let nonnull_described_ref_type = @lib.RefType::new(false, described_heap)
  let nullable_func_ref_type = @lib.RefType::new(
    true,
    @lib.HeapType::new(nullable_call_ref_type),
  )
  let nonnull_func_ref_type = @lib.RefType::new(
    true,
    @lib.HeapType::new(nonnull_call_ref_type),
  )
  let descriptor_ref_type = @lib.RefType::new(
    false,
    @lib.HeapType::new(descriptor_type),
  )
  let descriptor_val_type = @lib.ValType::ref_type(descriptor_ref_type)
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::i32()], [
              @lib.ValType::ref_type(nullable_described_ref_type),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::i32()], [
              @lib.ValType::ref_type(nonnull_described_ref_type),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::i32()], [descriptor_val_type]),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        nullable_call_ref_type, nonnull_call_ref_type, get_desc_type, get_desc_type,
      ]),
    )
    .with_table_sec(
      @lib.TableSec::new([
        @lib.Table::new(
          @lib.TableType::new(
            nullable_func_ref_type,
            @lib.Limits::i32(1U, Some(1U)),
          ),
          None,
        ),
        @lib.Table::new(
          @lib.TableType::new(
            nonnull_func_ref_type,
            @lib.Limits::i32(1U, Some(1U)),
          ),
          None,
        ),
      ]),
    )
    .with_elem_sec(
      @lib.ElemSec::new([
        @lib.Elem::new(
          @lib.ElemMode::active(
            @lib.TableIdx::new(0U),
            @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
          ),
          @lib.ElemKind::typed_exprs(nullable_func_ref_type, [
            @lib.Expr::new([@lib.Instruction::ref_func(@lib.FuncIdx::new(0U))]),
          ]),
        ),
        @lib.Elem::new(
          @lib.ElemMode::active(
            @lib.TableIdx::new(1U),
            @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
          ),
          @lib.ElemKind::typed_exprs(nonnull_func_ref_type, [
            @lib.Expr::new([@lib.Instruction::ref_func(@lib.FuncIdx::new(1U))]),
          ]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::drop(),
            @lib.Instruction::struct_new_default(descriptor_type),
            @lib.Instruction::struct_new_default_desc(described_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::drop(),
            @lib.Instruction::struct_new_default(descriptor_type),
            @lib.Instruction::struct_new_default_desc(described_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::table_get(@lib.TableIdx::new(0U)),
            @lib.Instruction::call_ref(nullable_call_ref_type),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_get_desc(described_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::table_get(@lib.TableIdx::new(1U)),
            @lib.Instruction::call_ref(nonnull_call_ref_type),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_get_desc(described_type),
          ]),
        ),
      ]),
    )
  let assert_indirect_ref_get_desc = fn(
    mod_ : @lib.Module,
    label : String,
  ) -> Unit raise {
    match mod_.code_sec {
      Some(
        @lib.CodeSec(
          [
            _,
            _,
            @lib.Func(_, @lib.Expr(nullable_body)),
            @lib.Func(_, @lib.Expr(nonnull_body)),
          ]
        )
      ) => {
        @debug.assert_eq(
          nullable_body,
          [
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::call_indirect(
              nullable_call_ref_type,
              @lib.TableIdx::new(0U),
            ),
            @lib.Instruction::ref_get_desc(described_type),
          ],
          msg="\{label} nullable indirect call_ref descriptor child: \{nullable_body}",
        )
        @debug.assert_eq(
          nonnull_body,
          [
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::call_indirect(
              nonnull_call_ref_type,
              @lib.TableIdx::new(1U),
            ),
            @lib.Instruction::ref_get_desc(described_type),
          ],
          msg="\{label} nonnull indirect call_ref descriptor child: \{nonnull_body}",
        )
      }
      other =>
        fail(
          "expected optimized indirect call_ref ref.get_desc funcs, got \{other}",
        )
    }
  }
  assert_indirect_ref_get_desc(
    optimize_instructions_test_run_module(module_),
    "default",
  )
  let iit_optimized = match
    run_hot_pipeline(
      module_,
      HotPipelineOptions::new(ignore_implicit_traps=true),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected IIT indirect call_ref ref.get_desc success, got \{err}")
  }
  assert_indirect_ref_get_desc(iit_optimized, "IIT")
}

///|
test "optimize-instructions moves standalone ref.get_desc branch-free block null checks" {
  // OI-J finite block-child slice: Binaryen version_130 simplifies standalone
  // `ref.get_desc(ref.as_non_null(child))` to `ref.get_desc(child)` for the
  // direct-local baseline, branch-free blocks whose ordered effect/trap roots
  // stay before the final nullable local, and self-contained br/br_if blocks
  // whose branches target the descriptor child block itself. Descriptor casts,
  // ref.test_desc, escaping-control standalone children, and broader control/EH
  // children remain outside this slice; TNH coverage below follows Binaryen's
  // trap-skipping mode for the same finite child families.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let described_heap = @lib.HeapType::new(described_type)
  let nullable_described_ref_type = @lib.RefType::new(true, described_heap)
  let nullable_described_val_type = @lib.ValType::ref_type(
    nullable_described_ref_type,
  )
  let nonnull_described_val_type = @lib.ValType::ref_type(
    @lib.RefType::new(false, described_heap),
  )
  let anyref = @lib.ValType::anyref()
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([nullable_described_val_type], [anyref]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func(
              [nullable_described_val_type, nullable_described_val_type],
              [anyref],
            ),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([nullable_described_val_type], [
              nonnull_described_val_type,
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        @lib.TypeIdx::new(2U),
        @lib.TypeIdx::new(2U),
        @lib.TypeIdx::new(2U),
        @lib.TypeIdx::new(2U),
        @lib.TypeIdx::new(3U),
        @lib.TypeIdx::new(3U),
        @lib.TypeIdx::new(2U),
        @lib.TypeIdx::new(2U),
        @lib.TypeIdx::new(2U),
        @lib.TypeIdx::new(4U),
      ]),
    )
    .with_global_sec(
      @lib.GlobalSec::new([
        @lib.Global::new(
          @lib.GlobalType::new(@lib.ValType::i32(), true),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_get_desc(described_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(nullable_described_val_type),
              @lib.Expr::new([
                @lib.Instruction::i32_const(@lib.I32(1)),
                @lib.Instruction::global_set(@lib.GlobalIdx::new(0U)),
                @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
              ]),
            ),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_get_desc(described_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(nullable_described_val_type),
              @lib.Expr::new([
                @lib.Instruction::i32_const(@lib.I32(1)),
                @lib.Instruction::i32_const(@lib.I32(0)),
                @lib.Instruction::i32_div_u(),
                @lib.Instruction::drop(),
                @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
              ]),
            ),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_get_desc(described_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(nullable_described_val_type),
              @lib.Expr::new([
                @lib.Instruction::i32_const(@lib.I32(1)),
                @lib.Instruction::global_set(@lib.GlobalIdx::new(0U)),
                @lib.Instruction::i32_const(@lib.I32(2)),
                @lib.Instruction::global_set(@lib.GlobalIdx::new(0U)),
                @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
              ]),
            ),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_get_desc(described_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(nullable_described_val_type),
              @lib.Expr::new([
                @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
                @lib.Instruction::br(@lib.LabelIdx::new(0U)),
                @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
              ]),
            ),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_get_desc(described_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(nullable_described_val_type),
              @lib.Expr::new([
                @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
                @lib.Instruction::i32_const(@lib.I32(1)),
                @lib.Instruction::br_if(@lib.LabelIdx::new(0U)),
                @lib.Instruction::drop(),
                @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
              ]),
            ),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_get_desc(described_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(nullable_described_val_type),
              @lib.Expr::new([
                @lib.Instruction::global_get(@lib.GlobalIdx::new(0U)),
                @lib.Instruction::if_(
                  @lib.BlockType::void_(),
                  [
                    @lib.Instruction::i32_const(@lib.I32(3)),
                    @lib.Instruction::global_set(@lib.GlobalIdx::new(0U)),
                  ],
                  None,
                ),
                @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
              ]),
            ),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_get_desc(described_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(nullable_described_val_type),
              @lib.Expr::new([
                @lib.Instruction::loop_(
                  @lib.BlockType::void_(),
                  @lib.Expr::new([]),
                ),
                @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
              ]),
            ),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_get_desc(described_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(nullable_described_val_type),
              @lib.Expr::new([
                @lib.Instruction::try_table(
                  @lib.BlockType::void_(),
                  [],
                  @lib.Expr::new([]),
                ),
                @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
              ]),
            ),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_get_desc(described_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_as_non_null(),
          ]),
        ),
      ]),
    )
  let optimized = optimize_instructions_test_run_module(module_)
  let pure_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_true(pure_pretty.contains("ref.get_desc"), msg=pure_pretty)
  assert_false(pure_pretty.contains("ref.as_non_null"), msg=pure_pretty)
  let effect_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_true(effect_pretty.contains("ref.get_desc"), msg=effect_pretty)
  assert_false(effect_pretty.contains("ref.as_non_null"), msg=effect_pretty)
  optimize_instructions_assert_strings_in_order(effect_pretty, [
    "I32(1)", "global.set", "local.get", "ref.get_desc",
  ])
  let trapping_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_true(trapping_pretty.contains("ref.get_desc"), msg=trapping_pretty)
  assert_false(trapping_pretty.contains("ref.as_non_null"), msg=trapping_pretty)
  optimize_instructions_assert_strings_in_order(trapping_pretty, [
    "i32.div", "drop", "local.get", "ref.get_desc",
  ])
  let ordered_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(3U))
  assert_false(ordered_pretty.contains("ref.as_non_null"), msg=ordered_pretty)
  optimize_instructions_assert_strings_in_order(ordered_pretty, [
    "I32(1)", "global.set", "I32(2)", "global.set", "local.get", "ref.get_desc",
  ])
  let br_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(4U))
  assert_false(br_pretty.contains("ref.as_non_null"), msg=br_pretty)
  assert_true(br_pretty.contains("br"), msg=br_pretty)
  let br_if_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(5U))
  assert_false(br_if_pretty.contains("ref.as_non_null"), msg=br_if_pretty)
  assert_true(br_if_pretty.contains("br_if"), msg=br_if_pretty)
  let if_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(6U))
  assert_true(if_pretty.contains("ref.as_non_null"), msg=if_pretty)
  assert_true(if_pretty.contains("if"), msg=if_pretty)
  let loop_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(7U))
  assert_true(loop_pretty.contains("ref.as_non_null"), msg=loop_pretty)
  assert_true(loop_pretty.contains("loop"), msg=loop_pretty)
  let try_table_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(8U))
  assert_true(
    try_table_pretty.contains("ref.as_non_null"),
    msg=try_table_pretty,
  )
  assert_true(try_table_pretty.contains("try_table"), msg=try_table_pretty)
  let quarantine_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(9U))
  assert_true(
    quarantine_pretty.contains("ref.as_non_null"),
    msg=quarantine_pretty,
  )

  let tnh_ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    traps_never_happen=true,
    module_ctx=Some(@ir.hot_module_context_from_module(module_)),
  )
  let tnh_direct_func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(0U))
  match hot_pass_run(tnh_ctx, tnh_direct_func) {
    Ok(_) => ()
    Err(err) =>
      fail(
        "expected standalone ref.get_desc TNH direct-local success, got \{err}",
      )
  }
  let tnh_direct_root = @ir.hot_root_get(tnh_direct_func, 0)
  match @ir.hot_node_exact_instr(tnh_direct_func, tnh_direct_root) {
    Some(@lib.Instruction::RefGetDesc(_)) => ()
    other => fail("expected TNH direct root to stay ref.get_desc, got \{other}")
  }
  let tnh_direct_child = @ir.hot_child_get(tnh_direct_func, tnh_direct_root, 0)
  match @ir.hot_node_get(tnh_direct_func, tnh_direct_child).op {
    @ir.HotOp::LocalGet => ()
    other => fail("expected TNH direct-local child, got \{other}")
  }

  let tnh_block_func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(1U))
  match hot_pass_run(tnh_ctx, tnh_block_func) {
    Ok(_) => ()
    Err(err) =>
      fail(
        "expected standalone ref.get_desc TNH branch-free block success, got \{err}",
      )
  }
  let tnh_block_root = @ir.hot_root_get(tnh_block_func, 0)
  match @ir.hot_node_exact_instr(tnh_block_func, tnh_block_root) {
    Some(@lib.Instruction::RefGetDesc(_)) => ()
    other => fail("expected TNH block root to stay ref.get_desc, got \{other}")
  }
  let tnh_block_child = @ir.hot_child_get(tnh_block_func, tnh_block_root, 0)
  match @ir.hot_node_get(tnh_block_func, tnh_block_child).op {
    @ir.HotOp::Block => ()
    other => fail("expected TNH branch-free block child, got \{other}")
  }
  let tnh_block_body = @ir.hot_region_body_ref(tnh_block_func, tnh_block_child)
  @debug.assert_eq(@ir.hot_region_root_count(tnh_block_func, tnh_block_body), 2)
  let tnh_block_first = @ir.hot_region_get(tnh_block_func, tnh_block_body, 0)
  match @ir.hot_node_get(tnh_block_func, tnh_block_first).op {
    @ir.HotOp::GlobalSet => ()
    other =>
      fail("expected TNH branch-free block to keep global.set, got \{other}")
  }
  let tnh_block_final = @ir.hot_region_get(tnh_block_func, tnh_block_body, 1)
  match @ir.hot_node_get(tnh_block_func, tnh_block_final).op {
    @ir.HotOp::LocalGet => ()
    other =>
      fail("expected TNH branch-free block final local.get, got \{other}")
  }

  let tnh_trapping_block_func = @ir.hot_lift_func(
    module_,
    @lib.FuncIdx::new(2U),
  )
  match hot_pass_run(tnh_ctx, tnh_trapping_block_func) {
    Ok(_) => ()
    Err(err) => fail("expected TNH trapping block success, got \{err}")
  }
  let tnh_trapping_root = @ir.hot_root_get(tnh_trapping_block_func, 0)
  let tnh_trapping_child = @ir.hot_child_get(
    tnh_trapping_block_func, tnh_trapping_root, 0,
  )
  match @ir.hot_node_get(tnh_trapping_block_func, tnh_trapping_child).op {
    @ir.HotOp::Block => ()
    other => fail("expected TNH trapping block child, got \{other}")
  }
  let tnh_trapping_body = @ir.hot_region_body_ref(
    tnh_trapping_block_func, tnh_trapping_child,
  )
  @debug.assert_eq(
    @ir.hot_region_root_count(tnh_trapping_block_func, tnh_trapping_body),
    2,
  )
  let tnh_trapping_first = @ir.hot_region_get(
    tnh_trapping_block_func, tnh_trapping_body, 0,
  )
  match @ir.hot_node_get(tnh_trapping_block_func, tnh_trapping_first).op {
    @ir.HotOp::Drop => ()
    other =>
      fail("expected TNH trapping block to keep dropped div, got \{other}")
  }
  let tnh_trapping_final = @ir.hot_region_get(
    tnh_trapping_block_func, tnh_trapping_body, 1,
  )
  match @ir.hot_node_get(tnh_trapping_block_func, tnh_trapping_final).op {
    @ir.HotOp::LocalGet => ()
    other => fail("expected TNH trapping block final local.get, got \{other}")
  }

  let tnh_ordered_block_func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(3U))
  match hot_pass_run(tnh_ctx, tnh_ordered_block_func) {
    Ok(_) => ()
    Err(err) => fail("expected TNH ordered block success, got \{err}")
  }
  let tnh_ordered_root = @ir.hot_root_get(tnh_ordered_block_func, 0)
  let tnh_ordered_child = @ir.hot_child_get(
    tnh_ordered_block_func, tnh_ordered_root, 0,
  )
  match @ir.hot_node_get(tnh_ordered_block_func, tnh_ordered_child).op {
    @ir.HotOp::Block => ()
    other => fail("expected TNH ordered block child, got \{other}")
  }
  let tnh_ordered_body = @ir.hot_region_body_ref(
    tnh_ordered_block_func, tnh_ordered_child,
  )
  @debug.assert_eq(
    @ir.hot_region_root_count(tnh_ordered_block_func, tnh_ordered_body),
    3,
  )
  let tnh_ordered_first = @ir.hot_region_get(
    tnh_ordered_block_func, tnh_ordered_body, 0,
  )
  match @ir.hot_node_get(tnh_ordered_block_func, tnh_ordered_first).op {
    @ir.HotOp::GlobalSet => ()
    other => fail("expected first TNH ordered root global.set, got \{other}")
  }
  let tnh_ordered_second = @ir.hot_region_get(
    tnh_ordered_block_func, tnh_ordered_body, 1,
  )
  match @ir.hot_node_get(tnh_ordered_block_func, tnh_ordered_second).op {
    @ir.HotOp::GlobalSet => ()
    other => fail("expected second TNH ordered root global.set, got \{other}")
  }
  let tnh_ordered_final = @ir.hot_region_get(
    tnh_ordered_block_func, tnh_ordered_body, 2,
  )
  match @ir.hot_node_get(tnh_ordered_block_func, tnh_ordered_final).op {
    @ir.HotOp::LocalGet => ()
    other => fail("expected TNH ordered block final local.get, got \{other}")
  }

  let tnh_br_func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(4U))
  match hot_pass_run(tnh_ctx, tnh_br_func) {
    Ok(_) => ()
    Err(err) => fail("expected TNH self-contained br block success, got \{err}")
  }
  let tnh_br_root = @ir.hot_root_get(tnh_br_func, 0)
  let tnh_br_child = @ir.hot_child_get(tnh_br_func, tnh_br_root, 0)
  match @ir.hot_node_get(tnh_br_func, tnh_br_child).op {
    @ir.HotOp::Block => ()
    other => fail("expected TNH self-contained br block child, got \{other}")
  }
  let tnh_br_body = @ir.hot_region_body_ref(tnh_br_func, tnh_br_child)
  let tnh_br_final = @ir.hot_region_get(
    tnh_br_func,
    tnh_br_body,
    @ir.hot_region_root_count(tnh_br_func, tnh_br_body) - 1,
  )
  match @ir.hot_node_get(tnh_br_func, tnh_br_final).op {
    @ir.HotOp::Br => ()
    other => fail("expected TNH self-contained br final root, got \{other}")
  }

  let tnh_br_if_func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(5U))
  match hot_pass_run(tnh_ctx, tnh_br_if_func) {
    Ok(_) => ()
    Err(err) =>
      fail("expected TNH self-contained br_if block success, got \{err}")
  }
  let tnh_br_if_root = @ir.hot_root_get(tnh_br_if_func, 0)
  let tnh_br_if_child = @ir.hot_child_get(tnh_br_if_func, tnh_br_if_root, 0)
  match @ir.hot_node_get(tnh_br_if_func, tnh_br_if_child).op {
    @ir.HotOp::Block => ()
    other => fail("expected TNH self-contained br_if block child, got \{other}")
  }
  let tnh_br_if_body = @ir.hot_region_body_ref(tnh_br_if_func, tnh_br_if_child)
  let tnh_br_if_final = @ir.hot_region_get(
    tnh_br_if_func,
    tnh_br_if_body,
    @ir.hot_region_root_count(tnh_br_if_func, tnh_br_if_body) - 1,
  )
  match @ir.hot_node_get(tnh_br_if_func, tnh_br_if_final).op {
    @ir.HotOp::LocalGet => ()
    other =>
      fail("expected TNH self-contained br_if final local.get, got \{other}")
  }
}

///|
test "optimize-instructions moves standalone ref.get_desc br_table block null checks" {
  // OI-J standalone self-contained branch-table slice: Binaryen version_130
  // default/IIT/TNH simplify `ref.get_desc(ref.as_non_null(block ... br_table))`
  // when every branch-table target remains inside the descriptor child block.
  // Escaping branch tables and descriptor operands stay outside this slice.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let described_heap = @lib.HeapType::new(described_type)
  let nullable_described_ref_type = @lib.RefType::new(true, described_heap)
  let nullable_described_val_type = @lib.ValType::ref_type(
    nullable_described_ref_type,
  )
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func(
              [
                nullable_described_val_type,
                nullable_described_val_type,
                @lib.ValType::i32(),
              ],
              [@lib.ValType::anyref()],
            ),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([@lib.TypeIdx::new(2U)]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(nullable_described_val_type),
              @lib.Expr::new([
                @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
                @lib.Instruction::local_get(@lib.LocalIdx::new(2U)),
                @lib.Instruction::br_table(
                  [@lib.LabelIdx::new(0U)],
                  @lib.LabelIdx::new(0U),
                ),
              ]),
            ),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_get_desc(described_type),
          ]),
        ),
      ]),
    )
  let func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(0U))
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    module_ctx=Some(@ir.hot_module_context_from_module(module_)),
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) =>
      fail("expected standalone br_table ref.get_desc success, got \{err}")
  }
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_exact_instr(func, root) {
    Some(@lib.Instruction::RefGetDesc(_)) => ()
    other => fail("expected standalone root ref.get_desc, got \{other}")
  }
  let child = @ir.hot_child_get(func, root, 0)
  match @ir.hot_node_get(func, child).op {
    @ir.HotOp::Block => ()
    other => fail("expected self-contained br_table block child, got \{other}")
  }
  let body = @ir.hot_region_body_ref(func, child)
  @debug.assert_eq(@ir.hot_region_root_count(func, body), 1)
  let branch = @ir.hot_region_get(func, body, 0)
  match @ir.hot_node_get(func, branch).op {
    @ir.HotOp::BrTable => ()
    other => fail("expected terminal self-contained br_table, got \{other}")
  }

  let tnh_func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(0U))
  let tnh_ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    traps_never_happen=true,
    module_ctx=Some(@ir.hot_module_context_from_module(module_)),
  )
  match hot_pass_run(tnh_ctx, tnh_func) {
    Ok(_) => ()
    Err(err) =>
      fail("expected TNH standalone br_table ref.get_desc success, got \{err}")
  }
  let tnh_root = @ir.hot_root_get(tnh_func, 0)
  match @ir.hot_node_exact_instr(tnh_func, tnh_root) {
    Some(@lib.Instruction::RefGetDesc(_)) => ()
    other => fail("expected TNH standalone root ref.get_desc, got \{other}")
  }
  let tnh_child = @ir.hot_child_get(tnh_func, tnh_root, 0)
  match @ir.hot_node_get(tnh_func, tnh_child).op {
    @ir.HotOp::Block => ()
    other => fail("expected TNH self-contained br_table block, got \{other}")
  }
}

///|
test "optimize-instructions moves standalone ref.get_desc escaping branch block null checks" {
  // OI-J standalone escaping-branch block slice: Binaryen version_130 default
  // mode simplifies `ref.get_desc(ref.as_non_null(block ...))` to
  // `ref.get_desc(block ...)` when direct `br`, value `br_if`, or value
  // `br_table` exits the descriptor child block to an outer label. The branch
  // payloads and conditions stay in source order and bypass the moved null
  // check exactly as they bypassed the original `ref.as_non_null`. This finite
  // family does not claim escaping `br_on_*`, nested control/EH,
  // descriptor-cast descriptor operands, or generalized label localization.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let described_heap = @lib.HeapType::new(described_type)
  let nullable_described_ref_type = @lib.RefType::new(true, described_heap)
  let nullable_described_val_type = @lib.ValType::ref_type(
    nullable_described_ref_type,
  )
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func(
              [nullable_described_val_type, nullable_described_val_type],
              [nullable_described_val_type],
            ),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func(
              [
                nullable_described_val_type,
                nullable_described_val_type,
                @lib.ValType::i32(),
              ],
              [nullable_described_val_type],
            ),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        @lib.TypeIdx::new(2U),
        @lib.TypeIdx::new(3U),
        @lib.TypeIdx::new(3U),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(nullable_described_val_type),
              @lib.Expr::new([
                @lib.Instruction::block(
                  @lib.BlockType::val_type(nullable_described_val_type),
                  @lib.Expr::new([
                    @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
                    @lib.Instruction::br(@lib.LabelIdx::new(1U)),
                    @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
                  ]),
                ),
                @lib.Instruction::ref_as_non_null(),
                @lib.Instruction::ref_get_desc(described_type),
                @lib.Instruction::drop(),
                @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
              ]),
            ),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(nullable_described_val_type),
              @lib.Expr::new([
                @lib.Instruction::block(
                  @lib.BlockType::val_type(nullable_described_val_type),
                  @lib.Expr::new([
                    @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
                    @lib.Instruction::local_get(@lib.LocalIdx::new(2U)),
                    @lib.Instruction::br_if(@lib.LabelIdx::new(1U)),
                    @lib.Instruction::drop(),
                    @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
                  ]),
                ),
                @lib.Instruction::ref_as_non_null(),
                @lib.Instruction::ref_get_desc(described_type),
                @lib.Instruction::drop(),
                @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
              ]),
            ),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(nullable_described_val_type),
              @lib.Expr::new([
                @lib.Instruction::block(
                  @lib.BlockType::val_type(nullable_described_val_type),
                  @lib.Expr::new([
                    @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
                    @lib.Instruction::local_get(@lib.LocalIdx::new(2U)),
                    @lib.Instruction::br_table(
                      [@lib.LabelIdx::new(1U)],
                      @lib.LabelIdx::new(1U),
                    ),
                  ]),
                ),
                @lib.Instruction::ref_as_non_null(),
                @lib.Instruction::ref_get_desc(described_type),
                @lib.Instruction::drop(),
                @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
              ]),
            ),
          ]),
        ),
      ]),
    )
  let optimized = optimize_instructions_test_run_module(module_)
  let br_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_true(br_pretty.contains("ref.get_desc"), msg=br_pretty)
  assert_true(br_pretty.contains("br"), msg=br_pretty)
  assert_false(br_pretty.contains("ref.as_non_null"), msg=br_pretty)
  optimize_instructions_assert_strings_in_order(br_pretty, [
    "local.get", "br", "ref.get_desc", "drop", "local.get",
  ])
  let br_if_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_true(br_if_pretty.contains("ref.get_desc"), msg=br_if_pretty)
  assert_true(br_if_pretty.contains("br_if"), msg=br_if_pretty)
  assert_false(br_if_pretty.contains("ref.as_non_null"), msg=br_if_pretty)
  optimize_instructions_assert_strings_in_order(br_if_pretty, [
    "br_if", "drop", "local.get", "ref.get_desc", "drop", "local.get",
  ])
  let br_table_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_true(br_table_pretty.contains("ref.get_desc"), msg=br_table_pretty)
  assert_true(br_table_pretty.contains("br_table"), msg=br_table_pretty)
  assert_false(br_table_pretty.contains("ref.as_non_null"), msg=br_table_pretty)
  optimize_instructions_assert_strings_in_order(br_table_pretty, [
    "br_table", "ref.get_desc", "drop", "local.get",
  ])
}

///|
test "optimize-instructions moves standalone ref.get_desc br_on_non_null block null checks" {
  // OI-J standalone self-contained reference-branch slice: Binaryen version_130
  // default/IIT/TNH simplify `ref.get_desc(ref.as_non_null(block ...
  // br_on_non_null ... ref.null))` when the non-null branch targets the
  // descriptor child block itself and the fallthrough is an explicit nullable
  // ref.null. This does not claim br_on_null, br_on_cast*, escaping labels,
  // descriptor operands, or broader descriptor/exactness behavior.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let described_heap = @lib.HeapType::new(described_type)
  let nullable_described_val_type = @lib.ValType::ref_type(
    @lib.RefType::new(true, described_heap),
  )
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([nullable_described_val_type], [
              @lib.ValType::anyref(),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([@lib.TypeIdx::new(2U)]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(nullable_described_val_type),
              @lib.Expr::new([
                @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
                @lib.Instruction::br_on_non_null(@lib.LabelIdx::new(0U)),
                @lib.Instruction::ref_null(described_heap),
              ]),
            ),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_get_desc(described_type),
          ]),
        ),
      ]),
    )
  let func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(0U))
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    module_ctx=Some(@ir.hot_module_context_from_module(module_)),
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) =>
      fail(
        "expected standalone br_on_non_null ref.get_desc success, got \{err}",
      )
  }
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_exact_instr(func, root) {
    Some(@lib.Instruction::RefGetDesc(_)) => ()
    other => fail("expected standalone root ref.get_desc, got \{other}")
  }
  let child = @ir.hot_child_get(func, root, 0)
  match @ir.hot_node_get(func, child).op {
    @ir.HotOp::Block => ()
    other =>
      fail("expected self-contained br_on_non_null block child, got \{other}")
  }
  let body = @ir.hot_region_body_ref(func, child)
  @debug.assert_eq(@ir.hot_region_root_count(func, body), 2)
  let branch = @ir.hot_region_get(func, body, 0)
  match @ir.hot_node_get(func, branch).op {
    @ir.HotOp::BrOnNonNull => ()
    other => fail("expected internal br_on_non_null root, got \{other}")
  }
  let final_root = @ir.hot_region_get(func, body, 1)
  match @ir.hot_node_get(func, final_root).op {
    @ir.HotOp::RefNull => ()
    other => fail("expected br_on_non_null fallthrough ref.null, got \{other}")
  }

  let tnh_func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(0U))
  let tnh_ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    traps_never_happen=true,
    module_ctx=Some(@ir.hot_module_context_from_module(module_)),
  )
  match hot_pass_run(tnh_ctx, tnh_func) {
    Ok(_) => ()
    Err(err) =>
      fail(
        "expected TNH standalone br_on_non_null ref.get_desc success, got \{err}",
      )
  }
  let tnh_root = @ir.hot_root_get(tnh_func, 0)
  match @ir.hot_node_exact_instr(tnh_func, tnh_root) {
    Some(@lib.Instruction::RefGetDesc(_)) => ()
    other => fail("expected TNH standalone root ref.get_desc, got \{other}")
  }
  let tnh_child = @ir.hot_child_get(tnh_func, tnh_root, 0)
  match @ir.hot_node_get(tnh_func, tnh_child).op {
    @ir.HotOp::Block => ()
    other =>
      fail("expected TNH self-contained br_on_non_null block, got \{other}")
  }
}

