///|
test "optimize-instructions folds prefixed nonthrowing try fallthrough chains" {
  // Red-first OI-F behavior-parity slice: Binaryen v130 proves the complete Try
  // body does not throw, selects its final value through `getFallthrough`, and
  // preserves an effectful body prefix under a drop. The focused oracle also
  // proves recursive block -> try composition while call/throw bodies remain
  // boundaries: `.tmp/oi-probes/boolean-eqz-fallthrough-try.wat`.
  let i32_type = @lib.ValType::i32()
  let i64_type = @lib.ValType::i64()

  let i32_func = @ir.HotFunc::new(locals=@ir.HotLocals::new(locals=[i32_type]))
  @ir.hot_body_result_type_set(
    i32_func,
    @ir.hot_type_intern_value(i32_func, i32_type),
  )
  let i32_try = @ir.hot_build_try(
    i32_func,
    @lib.BlockType::val_type(i32_type),
    [
      @ir.hot_build_local_set(i32_func, 0, @ir.hot_build_local_get(i32_func, 0)),
      @ir.hot_build_const_i32(i32_func, @lib.I32(0)),
    ],
    catch_body=Some([@ir.hot_build_const_i32(i32_func, @lib.I32(9))]),
  )
  let i32_condition = @ir.hot_build_unary(i32_func, i32_type, i32_try)
  @ir.hot_node_exact_instr_set(
    i32_func,
    i32_condition,
    @lib.Instruction::i32_eqz(),
  )
  @ir.hot_root_append(
    i32_func,
    @ir.hot_build_if(
      i32_func,
      @lib.BlockType::val_type(i32_type),
      i32_condition,
      [@ir.hot_build_const_i32(i32_func, @lib.I32(11))],
      else_body=Some([@ir.hot_build_const_i32(i32_func, @lib.I32(22))]),
    ),
  )
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
  )
  match hot_pass_run(ctx, i32_func) {
    Ok(_) => ()
    Err(err) => fail("expected prefixed i32 try optimization, got \{err}")
  }
  let i32_result = @ir.hot_child_get(i32_func, @ir.hot_root_get(i32_func, 0), 0)
  match @ir.hot_node_get(i32_func, i32_result).op {
    @ir.HotOp::Block => ()
    other => fail("expected preserved prefixed i32 try block, got \{other}")
  }
  let i32_result_body = @ir.hot_region_body_ref(i32_func, i32_result)
  @debug.assert_eq(@ir.hot_region_root_count(i32_func, i32_result_body), 2)
  let i32_drop = @ir.hot_region_get(i32_func, i32_result_body, 0)
  match @ir.hot_node_get(i32_func, i32_drop).op {
    @ir.HotOp::Drop => ()
    other => fail("expected dropped prefixed i32 try, got \{other}")
  }
  match
    @ir.hot_node_get(i32_func, @ir.hot_child_get(i32_func, i32_drop, 0)).op {
    @ir.HotOp::Try => ()
    other => fail("expected complete i32 try under drop, got \{other}")
  }
  let i32_truth = @ir.hot_region_get(i32_func, i32_result_body, 1)
  @debug.assert_eq(
    @ir.hot_const_get(i32_func, @ir.hot_node_get(i32_func, i32_truth).imm0),
    @ir.HotConstPayload::i32_const(@lib.I32(1)),
  )

  let i64_func = @ir.HotFunc::new(locals=@ir.HotLocals::new(locals=[i32_type]))
  @ir.hot_body_result_type_set(
    i64_func,
    @ir.hot_type_intern_value(i64_func, i32_type),
  )
  let i64_try = @ir.hot_build_try(
    i64_func,
    @lib.BlockType::val_type(i64_type),
    [
      @ir.hot_build_local_set(i64_func, 0, @ir.hot_build_local_get(i64_func, 0)),
      @ir.hot_build_const_i64(i64_func, @lib.I64(9L)),
    ],
    catch_body=Some([@ir.hot_build_const_i64(i64_func, @lib.I64(0L))]),
  )
  let wrapped_i64_try = @ir.hot_build_block(
    i64_func,
    @lib.BlockType::val_type(i64_type),
    [i64_try],
  )
  let i64_condition = @ir.hot_build_unary(i64_func, i32_type, wrapped_i64_try)
  @ir.hot_node_exact_instr_set(
    i64_func,
    i64_condition,
    @lib.Instruction::i64_eqz(),
  )
  @ir.hot_root_append(
    i64_func,
    @ir.hot_build_if(
      i64_func,
      @lib.BlockType::val_type(i32_type),
      i64_condition,
      [@ir.hot_build_const_i32(i64_func, @lib.I32(11))],
      else_body=Some([@ir.hot_build_const_i32(i64_func, @lib.I32(22))]),
    ),
  )
  let i64_ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
  )
  match hot_pass_run(i64_ctx, i64_func) {
    Ok(_) => ()
    Err(err) =>
      fail("expected recursive prefixed i64 try optimization, got \{err}")
  }
  let i64_result = @ir.hot_child_get(i64_func, @ir.hot_root_get(i64_func, 0), 0)
  match @ir.hot_node_get(i64_func, i64_result).op {
    @ir.HotOp::Block => ()
    other => fail("expected preserved recursive i64 try block, got \{other}")
  }
  let i64_result_body = @ir.hot_region_body_ref(i64_func, i64_result)
  let i64_drop = @ir.hot_region_get(i64_func, i64_result_body, 0)
  let dropped_i64_operand = @ir.hot_child_get(i64_func, i64_drop, 0)
  match @ir.hot_node_get(i64_func, dropped_i64_operand).op {
    @ir.HotOp::Block => ()
    other => fail("expected complete outer i64 block under drop, got \{other}")
  }
  let dropped_i64_body = @ir.hot_region_body_ref(i64_func, dropped_i64_operand)
  match
    @ir.hot_node_get(
      i64_func,
      @ir.hot_region_get(i64_func, dropped_i64_body, 0),
    ).op {
    @ir.HotOp::Try => ()
    other =>
      fail("expected nested i64 try to remain in dropped block, got \{other}")
  }
  let i64_truth = @ir.hot_region_get(i64_func, i64_result_body, 1)
  @debug.assert_eq(
    @ir.hot_const_get(i64_func, @ir.hot_node_get(i64_func, i64_truth).imm0),
    @ir.HotConstPayload::i32_const(@lib.I32(0)),
  )

  let throwing = @ir.HotFunc::new()
  @ir.hot_body_result_type_set(
    throwing,
    @ir.hot_type_intern_value(throwing, i32_type),
  )
  let throwing_try = @ir.hot_build_try(
    throwing,
    @lib.BlockType::val_type(i32_type),
    [
      @ir.hot_build_throw(throwing, @lib.TagIdx::new(0U), []),
      @ir.hot_build_const_i32(throwing, @lib.I32(0)),
    ],
    catch_body=Some([@ir.hot_build_const_i32(throwing, @lib.I32(9))]),
  )
  let throwing_condition = @ir.hot_build_unary(throwing, i32_type, throwing_try)
  @ir.hot_node_exact_instr_set(
    throwing,
    throwing_condition,
    @lib.Instruction::i32_eqz(),
  )
  @ir.hot_root_append(
    throwing,
    @ir.hot_build_if(
      throwing,
      @lib.BlockType::val_type(i32_type),
      throwing_condition,
      [@ir.hot_build_const_i32(throwing, @lib.I32(11))],
      else_body=Some([@ir.hot_build_const_i32(throwing, @lib.I32(22))]),
    ),
  )
  let throwing_ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
  )
  match hot_pass_run(throwing_ctx, throwing) {
    Ok(_) => ()
    Err(err) => fail("expected throwing try boundary validation, got \{err}")
  }
  @debug.assert_eq(
    @ir.hot_node_exact_instr(
      throwing,
      @ir.hot_child_get(throwing, @ir.hot_root_get(throwing, 0), 0),
    ),
    Some(@lib.Instruction::i32_eqz()),
  )

  let calling = @ir.HotFunc::new()
  @ir.hot_body_result_type_set(
    calling,
    @ir.hot_type_intern_value(calling, i32_type),
  )
  let calling_try = @ir.hot_build_try(
    calling,
    @lib.BlockType::val_type(i32_type),
    [@ir.hot_build_call(calling, 0, [i32_type], [])],
    catch_body=Some([@ir.hot_build_const_i32(calling, @lib.I32(9))]),
  )
  let calling_condition = @ir.hot_build_unary(calling, i32_type, calling_try)
  @ir.hot_node_exact_instr_set(
    calling,
    calling_condition,
    @lib.Instruction::i32_eqz(),
  )
  @ir.hot_root_append(
    calling,
    @ir.hot_build_if(
      calling,
      @lib.BlockType::val_type(i32_type),
      calling_condition,
      [@ir.hot_build_const_i32(calling, @lib.I32(11))],
      else_body=Some([@ir.hot_build_const_i32(calling, @lib.I32(22))]),
    ),
  )
  let calling_ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
  )
  match hot_pass_run(calling_ctx, calling) {
    Ok(_) => ()
    Err(err) => fail("expected call try boundary validation, got \{err}")
  }
  @debug.assert_eq(
    @ir.hot_node_exact_instr(
      calling,
      @ir.hot_child_get(calling, @ir.hot_root_get(calling, 0), 0),
    ),
    Some(@lib.Instruction::i32_eqz()),
  )
}

///|
test "optimize-instructions folds eqz through nonthrowing try block bodies" {
  // Red-first OI-F behavior-parity slice: Binaryen v130
  // `EffectAnalyzer(..., try.body).throws()` recursively inspects a nested
  // block region before `getFallthrough` selects its constant tail. A call in
  // that owned region remains an exceptional boundary. Oracle:
  // `.tmp/oi-probes/boolean-eqz-fallthrough-try.wat`.
  let i32_type = @lib.ValType::i32()
  let pure = @ir.HotFunc::new()
  @ir.hot_body_result_type_set(pure, @ir.hot_type_intern_value(pure, i32_type))
  let pure_block = @ir.hot_build_block(
    pure,
    @lib.BlockType::val_type(i32_type),
    [@ir.hot_build_const_i32(pure, @lib.I32(0))],
  )
  let pure_try = @ir.hot_build_try(
    pure,
    @lib.BlockType::val_type(i32_type),
    [pure_block],
    catch_body=Some([@ir.hot_build_const_i32(pure, @lib.I32(9))]),
  )
  let pure_condition = @ir.hot_build_unary(pure, i32_type, pure_try)
  @ir.hot_node_exact_instr_set(
    pure,
    pure_condition,
    @lib.Instruction::i32_eqz(),
  )
  @ir.hot_root_append(
    pure,
    @ir.hot_build_if(
      pure,
      @lib.BlockType::val_type(i32_type),
      pure_condition,
      [@ir.hot_build_const_i32(pure, @lib.I32(11))],
      else_body=Some([@ir.hot_build_const_i32(pure, @lib.I32(22))]),
    ),
  )
  let pure_ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
  )
  match hot_pass_run(pure_ctx, pure) {
    Ok(_) => ()
    Err(err) => fail("expected nested block try optimization, got \{err}")
  }
  let pure_result = @ir.hot_child_get(pure, @ir.hot_root_get(pure, 0), 0)
  match @ir.hot_node_get(pure, pure_result).op {
    @ir.HotOp::Const => ()
    other => fail("expected nested block try truth constant, got \{other}")
  }
  @debug.assert_eq(
    @ir.hot_const_get(pure, @ir.hot_node_get(pure, pure_result).imm0),
    @ir.HotConstPayload::i32_const(@lib.I32(1)),
  )

  let calling = @ir.HotFunc::new()
  @ir.hot_body_result_type_set(
    calling,
    @ir.hot_type_intern_value(calling, i32_type),
  )
  let call = @ir.hot_build_call(calling, 0, [i32_type], [])
  let calling_block = @ir.hot_build_block(
    calling,
    @lib.BlockType::val_type(i32_type),
    [
      @ir.hot_build_drop(calling, call),
      @ir.hot_build_const_i32(calling, @lib.I32(0)),
    ],
  )
  let calling_try = @ir.hot_build_try(
    calling,
    @lib.BlockType::val_type(i32_type),
    [calling_block],
    catch_body=Some([@ir.hot_build_const_i32(calling, @lib.I32(9))]),
  )
  let calling_condition = @ir.hot_build_unary(calling, i32_type, calling_try)
  @ir.hot_node_exact_instr_set(
    calling,
    calling_condition,
    @lib.Instruction::i32_eqz(),
  )
  @ir.hot_root_append(
    calling,
    @ir.hot_build_if(
      calling,
      @lib.BlockType::val_type(i32_type),
      calling_condition,
      [@ir.hot_build_const_i32(calling, @lib.I32(11))],
      else_body=Some([@ir.hot_build_const_i32(calling, @lib.I32(22))]),
    ),
  )
  let calling_ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
  )
  match hot_pass_run(calling_ctx, calling) {
    Ok(_) => ()
    Err(err) => fail("expected nested block call boundary, got \{err}")
  }
  @debug.assert_eq(
    @ir.hot_node_exact_instr(
      calling,
      @ir.hot_child_get(calling, @ir.hot_root_get(calling, 0), 0),
    ),
    Some(@lib.Instruction::i32_eqz()),
  )
}

///|
test "optimize-instructions folds recursive eqz fallthrough wrapper chains" {
  // Red-first OI-F behavior-parity slice: Binaryen v130 `getFallthrough`
  // repeatedly applies `getImmediateFallthrough`, then preserves only the
  // original operand effects required by `getDroppedChildrenAndAppend`.
  // Oracle: `.tmp/oi-probes/boolean-eqz-fallthrough-next.wat`.
  let pure_block = optimize_instructions_test_run_hot(
    "(module (func (result i32) (if (result i32) (i32.eqz (block (result i32) (i32.const 0))) (then (i32.const 11)) (else (i32.const 22)))))",
  )
  let pure_block_condition = @ir.hot_child_get(
    pure_block,
    @ir.hot_root_get(pure_block, 0),
    0,
  )
  match @ir.hot_node_get(pure_block, pure_block_condition).op {
    @ir.HotOp::Const =>
      @debug.assert_eq(
        @ir.hot_const_get(
          pure_block,
          @ir.hot_node_get(pure_block, pure_block_condition).imm0,
        ),
        @ir.HotConstPayload::i32_const(@lib.I32(1)),
      )
    other => fail("expected pure single-root block to erase, got \{other}")
  }

  let pure_i32 = optimize_instructions_test_run_hot(
    "(module (func (result i32) (if (result i32) (i32.eqz (block (result i32) (loop (result i32) (i32.const 0)))) (then (i32.const 11)) (else (i32.const 22)))))",
  )
  let pure_i32_condition = @ir.hot_child_get(
    pure_i32,
    @ir.hot_root_get(pure_i32, 0),
    0,
  )
  match @ir.hot_node_get(pure_i32, pure_i32_condition).op {
    @ir.HotOp::Const =>
      @debug.assert_eq(
        @ir.hot_const_get(
          pure_i32,
          @ir.hot_node_get(pure_i32, pure_i32_condition).imm0,
        ),
        @ir.HotConstPayload::i32_const(@lib.I32(1)),
      )
    other => fail("expected pure nested i32 wrappers to erase, got \{other}")
  }

  let pure_i64 = optimize_instructions_test_run_hot(
    "(module (func (result i32) (if (result i32) (i64.eqz (loop (result i64) (block (result i64) (i64.const 9)))) (then (i32.const 11)) (else (i32.const 22)))))",
  )
  let pure_i64_condition = @ir.hot_child_get(
    pure_i64,
    @ir.hot_root_get(pure_i64, 0),
    0,
  )
  match @ir.hot_node_get(pure_i64, pure_i64_condition).op {
    @ir.HotOp::Const =>
      @debug.assert_eq(
        @ir.hot_const_get(
          pure_i64,
          @ir.hot_node_get(pure_i64, pure_i64_condition).imm0,
        ),
        @ir.HotConstPayload::i32_const(@lib.I32(0)),
      )
    other => fail("expected pure nested i64 wrappers to erase, got \{other}")
  }

  let tee = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) (if (result i32) (i32.eqz (local.tee 0 (loop (result i32) (i32.const 0)))) (then (i32.const 11)) (else (i32.const 22)))))",
  )
  let tee_condition = @ir.hot_child_get(tee, @ir.hot_root_get(tee, 0), 0)
  match @ir.hot_node_get(tee, tee_condition).op {
    @ir.HotOp::Block => ()
    other => fail("expected nested tee preservation block, got \{other}")
  }
  let tee_body = @ir.hot_region_body_ref(tee, tee_condition)
  @debug.assert_eq(@ir.hot_region_root_count(tee, tee_body), 2)
  let tee_drop = @ir.hot_region_get(tee, tee_body, 0)
  match @ir.hot_node_get(tee, tee_drop).op {
    @ir.HotOp::Drop => ()
    other => fail("expected nested tee evaluation drop, got \{other}")
  }
  match @ir.hot_node_get(tee, @ir.hot_child_get(tee, tee_drop, 0)).op {
    @ir.HotOp::LocalTee => ()
    other => fail("expected dropped outer local.tee, got \{other}")
  }

  let effectful = optimize_instructions_test_run_hot(
    "(module (global (mut i32) (i32.const 0)) (func (param i32) (result i32) (if (result i32) (i32.eqz (block (result i32) (global.set 0 (local.get 0)) (loop (result i32) (i32.const 0)))) (then (i32.const 11)) (else (i32.const 22)))))",
  )
  let effectful_condition = @ir.hot_child_get(
    effectful,
    @ir.hot_root_get(effectful, 0),
    0,
  )
  match @ir.hot_node_get(effectful, effectful_condition).op {
    @ir.HotOp::Block => ()
    other => fail("expected effectful nested preservation block, got \{other}")
  }
  let effectful_body = @ir.hot_region_body_ref(effectful, effectful_condition)
  @debug.assert_eq(@ir.hot_region_root_count(effectful, effectful_body), 2)
  let effectful_drop = @ir.hot_region_get(effectful, effectful_body, 0)
  match @ir.hot_node_get(effectful, effectful_drop).op {
    @ir.HotOp::Drop => ()
    other => fail("expected effectful nested operand drop, got \{other}")
  }
}

///|
test "optimize-instructions applies De Morgan to and of eqz operands" {
  // Red-first OI-F boolean parity slice: Binaryen `version_130`
  // `--optimize-instructions` rewrites `(and (eqz x) (eqz y))` to
  // `eqz(or x y)` while preserving left-to-right operand evaluation. This is
  // deliberately the two-direct-`eqz` i32.and shell only; it does not claim
  // broader boolean algebra, commuted/non-eqz operands, or branch-condition
  // rewrites.
  let local_func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32) (result i32) local.get 0 i32.eqz local.get 1 i32.eqz i32.and))",
  )
  let local_root = @ir.hot_root_get(local_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(local_func, local_root),
    Some(@lib.Instruction::i32_eqz()),
  )
  let local_or = @ir.hot_child_get(local_func, local_root, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(local_func, local_or),
    Some(@lib.Instruction::i32_or()),
  )
  match
    @ir.hot_node_get(local_func, @ir.hot_child_get(local_func, local_or, 0)).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected De Morgan i32.or to keep the first original operand")
  }
  match
    @ir.hot_node_get(local_func, @ir.hot_child_get(local_func, local_or, 1)).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected De Morgan i32.or to keep the second original operand")
  }

  let call_func = optimize_instructions_test_run_hot(
    "(module (global $g (mut i32) (i32.const 0)) (func (param i32) (result i32) call $side i32.eqz local.get 0 i32.eqz i32.and) (func $side (result i32) i32.const 1 global.set $g i32.const 7))",
  )
  let call_root = @ir.hot_root_get(call_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(call_func, call_root),
    Some(@lib.Instruction::i32_eqz()),
  )
  let call_or = @ir.hot_child_get(call_func, call_root, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(call_func, call_or),
    Some(@lib.Instruction::i32_or()),
  )
  match
    @ir.hot_node_get(call_func, @ir.hot_child_get(call_func, call_or, 0)).op {
    @ir.HotOp::Call => ()
    _ => fail("expected De Morgan i32.or to keep the effectful first operand")
  }
}

///|
test "optimize-instructions folds boolean const select arms to condition compares" {
  // Red-first OI-F select parity slice: Binaryen `version_130`
  // `--optimize-instructions` rewrites `(select 1 0 cond)` to
  // `i32.ne(cond, 0)` and `(select 0 1 cond)` to `i32.eqz(cond)`, preserving
  // the original condition operand and its effects. This deliberately covers
  // only direct i32 1/0 and 0/1 select arms, not arbitrary select values,
  // non-i32 arms, or branch-condition rewrites.
  let true_false_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) i32.const 1 i32.const 0 local.get 0 select))",
  )
  let true_false_root = @ir.hot_root_get(true_false_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(true_false_func, true_false_root),
    Some(@lib.Instruction::i32_ne()),
  )
  match
    @ir.hot_node_get(
      true_false_func,
      @ir.hot_child_get(true_false_func, true_false_root, 0),
    ).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected select 1/0 rewrite to keep the condition operand")
  }
  let true_false_zero = @ir.hot_child_get(true_false_func, true_false_root, 1)
  @debug.assert_eq(
    @ir.hot_const_get(
      true_false_func,
      @ir.hot_node_get(true_false_func, true_false_zero).imm0,
    ),
    @ir.HotConstPayload::i32_const(@lib.I32(0)),
  )

  let false_true_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) i32.const 0 i32.const 1 local.get 0 select))",
  )
  let false_true_root = @ir.hot_root_get(false_true_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(false_true_func, false_true_root),
    Some(@lib.Instruction::i32_eqz()),
  )
  match
    @ir.hot_node_get(
      false_true_func,
      @ir.hot_child_get(false_true_func, false_true_root, 0),
    ).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected select 0/1 rewrite to keep the condition operand")
  }

  let call_func = optimize_instructions_test_run_hot(
    "(module (global $g (mut i32) (i32.const 0)) (func (result i32) i32.const 1 i32.const 0 call $side select) (func $side (result i32) i32.const 1 global.set $g i32.const 7))",
  )
  let call_root = @ir.hot_root_get(call_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(call_func, call_root),
    Some(@lib.Instruction::i32_ne()),
  )
  match
    @ir.hot_node_get(call_func, @ir.hot_child_get(call_func, call_root, 0)).op {
    @ir.HotOp::Call => ()
    _ => fail("expected select 1/0 rewrite to keep the effectful condition")
  }
}

///|
test "optimize-instructions folds i32 truthy self-selects through consecutive-input facts" {
  // Red-first OI-F parity slice: Binaryen version_130 `optimizeSelect` uses
  // `areConsecutiveInputsEqualAndFoldable` to rewrite `select(x, 0, x)` to
  // `x`. The source and `.tmp/oi-probes/select-consecutive-inputs.wat` oracle
  // both preserve the selected value directly, without a boolean compare shell.
  let func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) local.get 0 i32.const 0 local.get 0 select))",
  )
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_get(func, root).op {
    @ir.HotOp::LocalGet =>
      @debug.assert_eq(@ir.hot_node_get(func, root).imm0, 0)
    other =>
      fail("expected truthy self-select to become local.get, got \{other}")
  }
}

///|
test "optimize-instructions preserves i32 falsy self-select evaluation before zero" {
  // Red-first OI-F parity slice: Binaryen version_130's sibling consecutive
  // rule rewrites `select(0, x, x)` to `drop(x); 0`, preserving the earlier arm
  // evaluation while removing the repeated pure condition evaluation. The
  // oracle is `.tmp/oi-probes/select-consecutive-inputs.wat`.
  let func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) i32.const 0 local.get 0 local.get 0 select))",
  )
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_get(func, root).op {
    @ir.HotOp::Block => ()
    other => fail("expected falsy self-select to become a block, got \{other}")
  }
  let body = @ir.hot_region_body_ref(func, root)
  @debug.assert_eq(@ir.hot_region_root_count(func, body), 2)
  let preserved = @ir.hot_region_get(func, body, 0)
  match @ir.hot_node_get(func, preserved).op {
    @ir.HotOp::Drop => ()
    other => fail("expected preserved selected-value drop, got \{other}")
  }
  match @ir.hot_node_get(func, @ir.hot_child_get(func, preserved, 0)).op {
    @ir.HotOp::LocalGet => ()
    other => fail("expected preserved local.get evaluation, got \{other}")
  }
  let zero = @ir.hot_region_get(func, body, 1)
  @debug.assert_eq(
    @ir.hot_const_get(func, @ir.hot_node_get(func, zero).imm0),
    @ir.HotConstPayload::i32_const(@lib.I32(0)),
  )
}

///|
test "optimize-instructions folds i64 zero-test self-selects through consecutive-input facts" {
  // Red-first OI-F parity slice: Binaryen version_130 `optimizeSelect` folds
  // four i64 self-select forms driven by `i64.eqz(x)` or `i64.ne(x, 0)`.
  // Matching truthy selection forwards `x`; matching falsy selection preserves
  // the earlier `x` evaluation with a drop before returning i64 zero. Oracle:
  // `.tmp/oi-probes/select-consecutive-inputs.wat`.
  let assert_forwarded = fn(wat : String, label : String) raise {
    let func = optimize_instructions_test_run_hot(wat)
    let root = @ir.hot_root_get(func, 0)
    match @ir.hot_node_get(func, root).op {
      @ir.HotOp::LocalGet =>
        @debug.assert_eq(@ir.hot_node_get(func, root).imm0, 0)
      other => fail("expected \{label} to forward local.get, got \{other}")
    }
  }
  let assert_dropped_zero = fn(wat : String, label : String) raise {
    let func = optimize_instructions_test_run_hot(wat)
    let root = @ir.hot_root_get(func, 0)
    match @ir.hot_node_get(func, root).op {
      @ir.HotOp::Block => ()
      other => fail("expected \{label} to become a block, got \{other}")
    }
    let body = @ir.hot_region_body_ref(func, root)
    @debug.assert_eq(@ir.hot_region_root_count(func, body), 2)
    let preserved = @ir.hot_region_get(func, body, 0)
    match @ir.hot_node_get(func, preserved).op {
      @ir.HotOp::Drop => ()
      other => fail("expected \{label} to preserve x with drop, got \{other}")
    }
    match @ir.hot_node_get(func, @ir.hot_child_get(func, preserved, 0)).op {
      @ir.HotOp::LocalGet => ()
      other => fail("expected \{label} dropped local.get, got \{other}")
    }
    let zero = @ir.hot_region_get(func, body, 1)
    @debug.assert_eq(
      @ir.hot_const_get(func, @ir.hot_node_get(func, zero).imm0),
      @ir.HotConstPayload::i64_const(@lib.I64(0L)),
    )
  }
  assert_forwarded(
    "(module (func (param i64) (result i64) i64.const 0 local.get 0 local.get 0 i64.eqz select))",
    "eqz false-arm self-select",
  )
  assert_forwarded(
    "(module (func (param i64) (result i64) local.get 0 i64.const 0 local.get 0 i64.const 0 i64.ne select))",
    "ne true-arm self-select",
  )
  assert_dropped_zero(
    "(module (func (param i64) (result i64) local.get 0 i64.const 0 local.get 0 i64.eqz select))",
    "eqz true-arm zero-result self-select",
  )
  assert_dropped_zero(
    "(module (func (param i64) (result i64) i64.const 0 local.get 0 local.get 0 i64.const 0 i64.ne select))",
    "ne false-arm zero-result self-select",
  )
}

///|
test "optimize-instructions folds no-arg idempotent-call self-selects" {
  // Red-first OI-F parity slice: Binaryen version_130
  // `areConsecutiveInputsEqualAndFoldable` treats a repeated direct call marked
  // `@binaryen.idempotent` as foldable when it has no operands. The official
  // source is `OptimizeInstructions.cpp:2891-2947`; the focused oracle is
  // `.tmp/oi-probes/select-idempotent-call-foldability.wat`.
  let optimize_caller = fn(body : String) raise {
    let wat = "(module (@binaryen.idempotent) (func $id (result i32) i32.const 1) (func (result i32) " +
      body +
      "))"
    let optimized = match
      pass_test_run_pipeline(wat, ["optimize-instructions"]) {
      Ok(mod_) => mod_
      Err(err) => fail("expected idempotent-call OI success, got \{err}")
    }
    optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  }
  let truthy = optimize_caller("call $id i32.const 0 call $id select")
  assert_false(truthy.contains("select"), msg=truthy)
  @debug.assert_eq(
    optimize_instructions_test_count_substring(truthy, "call (Func 0)"),
    1,
  )
  let falsy = optimize_caller("i32.const 0 call $id call $id select")
  assert_false(falsy.contains("select"), msg=falsy)
  @debug.assert_eq(
    optimize_instructions_test_count_substring(falsy, "call (Func 0)"),
    1,
  )
  assert_true(falsy.contains("drop"), msg=falsy)
}

