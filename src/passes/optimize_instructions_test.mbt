///|
test "optimize-instructions keeps swapped flat relational memory.copy outside equality fact" {
  // Boundary guard for the explicit commutative equality fact: Binaryen v130
  // keeps swapped `i32.lt_u` operands as a live `memory.copy` under the dynamic
  // trap-relaxed probe. Do not classify all comparisons as commutative.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func (export "ltu-swap") (param $a i32) (param $b i32) (param $size i32)
        #|    local.get $a
        #|    local.get $b
        #|    i32.lt_u
        #|    local.get $b
        #|    local.get $a
        #|    i32.lt_u
        #|    local.get $size
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(traps_never_happen=true),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected relational memory.copy boundary success, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_true(pretty.contains("memory.copy"), msg=pretty)
  assert_true(pretty.contains("i32.lt_u"), msg=pretty)
}

///|
test "optimize-instructions keeps swapped flat shift memory.copy outside equality fact" {
  // Boundary guard for the explicit commutative-op fact: Binaryen v130 keeps
  // swapped `i32.shl` address operands under the same trap-relaxed probe, so the
  // raw bridge must not classify all binary operators as commutative.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func (export "shl-swap") (param $a i32) (param $b i32) (param $size i32)
        #|    local.get $a
        #|    local.get $b
        #|    i32.shl
        #|    local.get $b
        #|    local.get $a
        #|    i32.shl
        #|    local.get $size
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(traps_never_happen=true),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected shifted memory.copy boundary success, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_true(pretty.contains("memory.copy"), msg=pretty)
  optimize_instructions_assert_strings_in_order(pretty, [
    "local.get (Local 0)", "local.get (Local 1)", "i32.shl", "local.get (Local 1)",
    "local.get (Local 0)", "i32.shl", "local.get (Local 2)", "memory.copy",
  ])
}

///|
test "optimize-instructions drops long flat stack same-address memory.copy" {
  // OI-G raw stack-expression equality breadth: Binaryen v130 keeps using
  // `ExpressionAnalyzer::equal` for a repeated 17-instruction left-associated
  // pure scalar address tree. This raises the raw bridge's bounded candidate
  // fact budget without changing the operator set; deeper/non-flat/control
  // operands remain separate source-backed work.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func (export "long-flat") (param $addr i32) (param $size i32)
        #|    local.get $addr
        #|    i32.const 1
        #|    i32.add
        #|    i32.const 2
        #|    i32.add
        #|    i32.const 3
        #|    i32.add
        #|    i32.const 4
        #|    i32.add
        #|    i32.const 5
        #|    i32.add
        #|    i32.const 6
        #|    i32.add
        #|    i32.const 7
        #|    i32.add
        #|    i32.const 8
        #|    i32.add
        #|    local.get $addr
        #|    i32.const 1
        #|    i32.add
        #|    i32.const 2
        #|    i32.add
        #|    i32.const 3
        #|    i32.add
        #|    i32.const 4
        #|    i32.add
        #|    i32.const 5
        #|    i32.add
        #|    i32.const 6
        #|    i32.add
        #|    i32.const 7
        #|    i32.add
        #|    i32.const 8
        #|    i32.add
        #|    local.get $size
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(traps_never_happen=true),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected long flat stack memory.copy TNH success, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("memory.copy"), msg=pretty)
  assert_true(pretty.contains("drop"), msg=pretty)
}

///|
test "optimize-instructions drops nested flat stack same-address memory.copy" {
  // OI-G raw stack-expression equality breadth: Binaryen v130 parses the
  // fallthrough address operands as expression trees for `areConsecutiveInputsEqual`.
  // Repeated nested pure scalar stack expressions and nested expressions whose
  // inner `i32.add` operands are commuted are equal under that source-backed
  // `ExpressionAnalyzer::equal` path; keep the raw bridge fact-shaped while the
  // public WAT path still lowers these operands to flat stack instructions.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func (export "nested-same") (param $addr i32) (param $size i32)
        #|    local.get $addr
        #|    i32.const 4
        #|    i32.add
        #|    i32.const 8
        #|    i32.sub
        #|    local.get $addr
        #|    i32.const 4
        #|    i32.add
        #|    i32.const 8
        #|    i32.sub
        #|    local.get $size
        #|    memory.copy)
        #|  (func (export "nested-commuted-add") (param $addr i32) (param $size i32)
        #|    local.get $addr
        #|    i32.const 4
        #|    i32.add
        #|    i32.const 8
        #|    i32.sub
        #|    i32.const 4
        #|    local.get $addr
        #|    i32.add
        #|    i32.const 8
        #|    i32.sub
        #|    local.get $size
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(traps_never_happen=true),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected nested flat stack memory.copy TNH success, got \{err}")
  }
  for func_idx = 0; func_idx < 2; func_idx = func_idx + 1 {
    let pretty = optimized.pretty_print_func(
      @lib.FuncIdx::new(func_idx.reinterpret_as_uint()),
    )
    assert_false(pretty.contains("memory.copy"), msg=pretty)
    assert_true(pretty.contains("drop"), msg=pretty)
  }
}

///|
test "optimize-instructions keeps different nested flat stack memory.copy outside equality fact" {
  // Boundary guard for the bounded flat expression-tree fact: Binaryen v130
  // keeps nested pure scalar address trees with different constant payloads, so
  // same outer operators are not enough to prove equal runtime addresses.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
