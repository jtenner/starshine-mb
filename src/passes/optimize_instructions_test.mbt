///|
test "optimize-instructions expands constant sixteen-byte memory.fill to v128.store" {
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func (param $dst i32)
        #|    local.get $dst
        #|    i32.const 0
        #|    i32.const 16
        #|    memory.fill)
        #|  (func (param $dst i32)
        #|    local.get $dst
        #|    i32.const 171
        #|    i32.const 16
        #|    memory.fill))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected sixteen-byte memory.fill optimize success, got \{err}")
  }
  let zero = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(zero.contains("memory.fill"), msg=zero)
  assert_true(zero.contains("v128.const"), msg=zero)
  assert_true(zero.contains("v128.store"), msg=zero)
  let nonzero = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_false(nonzero.contains("memory.fill"), msg=nonzero)
  assert_true(nonzero.contains("v128.const"), msg=nonzero)
  assert_true(nonzero.contains("v128.store"), msg=nonzero)
  assert_true(nonzero.contains("abab"), msg=nonzero)
}

///|
test "optimize-instructions keeps shrink-level one memory.fill size/value boundaries" {
  // OI-G tiny memory.fill fact: Binaryen version_130 `optimizeMemoryFill`
  // keeps nonzero 4/8-byte fills and all 16-byte fills at shrink level one,
  // while still lowering zero 4/8-byte fills and constant 1/2-byte fills.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func (param $dst i32)
        #|    local.get $dst
        #|    i32.const 171
        #|    i32.const 4
        #|    memory.fill
        #|    local.get $dst
        #|    i32.const 171
        #|    i32.const 8
        #|    memory.fill
        #|    local.get $dst
        #|    i32.const 0
        #|    i32.const 16
        #|    memory.fill
        #|    local.get $dst
        #|    i32.const 0
        #|    i32.const 4
        #|    memory.fill
        #|    local.get $dst
        #|    i32.const 0
        #|    i32.const 8
        #|    memory.fill
        #|    local.get $dst
        #|    i32.const 171
        #|    i32.const 2
        #|    memory.fill))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(shrink_level=1),
    ) {
    Ok(mod_) => mod_
    Err(err) => fail("expected shrink-level memory.fill success, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  @debug.assert_eq(
    optimize_instructions_test_count_substring(pretty, "memory.fill"),
    3,
    msg=pretty,
  )
  assert_true(pretty.contains("i32.store16"), msg=pretty)
  assert_true(pretty.contains("i32.store"), msg=pretty)
  assert_true(pretty.contains("i64.store"), msg=pretty)
  assert_false(pretty.contains("v128.store"), msg=pretty)
}

