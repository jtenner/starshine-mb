///|
test "optimize-instructions hoists repeated matching unary select arm chains" {
  // Red-first OI-F ternary parity slice: Binaryen version_130 repeats the
  // shallow-equal one-child loop until the select sits below the full matching
  // shell chain. Oracle: `.tmp/oi-probes/select-matching-unary-hoist.wat`
  // `nested`, which emits `i32.eqz(i32.clz(select(...)))`.
  let func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32 i32) (result i32) local.get 0 i32.clz i32.eqz local.get 1 i32.clz i32.eqz local.get 2 select))",
  )
  let root = @ir.hot_root_get(func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(func, root),
    Some(@lib.Instruction::i32_eqz()),
  )
  let inner_clz = @ir.hot_child_get(func, root, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(func, inner_clz),
    Some(@lib.Instruction::i32_clz()),
  )
  let inner_select = @ir.hot_child_get(func, inner_clz, 0)
  match @ir.hot_node_get(func, inner_select).op {
    @ir.HotOp::Select => ()
    other =>
      fail("expected repeated matching shells above inner select, got \{other}")
  }
}

///|
test "optimize-instructions removes eqz from select conditions by swapping arms" {
  // Red-first OI-F select parity slice: Binaryen `version_130`
  // `--optimize-instructions` rewrites `(select a b (i32.eqz cond))` to
  // `(select b a cond)`. For exact boolean const arms this composes directly
  // to the existing i32 1/0 and 0/1 condition-compare forms. This deliberately
  // covers only a direct i32.eqz condition shell, not broader condition
  // normalization or branch-condition rewrites.
  let value_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) i32.const 42 i32.const 13 local.get 0 i32.eqz select))",
  )
  let value_root = @ir.hot_root_get(value_func, 0)
  match @ir.hot_node_get(value_func, value_root).op {
    @ir.HotOp::Select => ()
    _ => fail("expected select with swapped arms after removing eqz condition")
  }
  let value_true = @ir.hot_child_get(value_func, value_root, 0)
  let value_false = @ir.hot_child_get(value_func, value_root, 1)
  let value_condition = @ir.hot_child_get(value_func, value_root, 2)
  @debug.assert_eq(
    @ir.hot_const_get(value_func, @ir.hot_node_get(value_func, value_true).imm0),
    @ir.HotConstPayload::i32_const(@lib.I32(13)),
  )
  @debug.assert_eq(
    @ir.hot_const_get(
      value_func,
      @ir.hot_node_get(value_func, value_false).imm0,
    ),
    @ir.HotConstPayload::i32_const(@lib.I32(42)),
  )
  match @ir.hot_node_get(value_func, value_condition).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected swapped select to keep the inner eqz operand")
  }

  let bool_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) i32.const 1 i32.const 0 local.get 0 i32.eqz select))",
  )
  let bool_root = @ir.hot_root_get(bool_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(bool_func, bool_root),
    Some(@lib.Instruction::i32_eqz()),
  )
  match
    @ir.hot_node_get(bool_func, @ir.hot_child_get(bool_func, bool_root, 0)).op {
    @ir.HotOp::LocalGet => ()
    _ =>
      fail(
        "expected boolean const select with eqz condition to fold to eqz of inner operand",
      )
  }

  let call_func = optimize_instructions_test_run_hot(
    "(module (global $g (mut i32) (i32.const 0)) (func (result i32) i32.const 42 i32.const 13 call $side i32.eqz select) (func $side (result i32) i32.const 1 global.set $g i32.const 7))",
  )
  let call_root = @ir.hot_root_get(call_func, 0)
  match @ir.hot_node_get(call_func, call_root).op {
    @ir.HotOp::Select => ()
    _ => fail("expected effectful eqz condition select to remain a select")
  }
  match
    @ir.hot_node_get(call_func, @ir.hot_child_get(call_func, call_root, 2)).op {
    @ir.HotOp::Call => ()
    _ => fail("expected effectful swapped select to keep the call condition")
  }
}

///|
test "optimize-instructions removes zero compares from select conditions" {
  // Red-first OI-F select parity slice: Binaryen `version_130`
  // `--optimize-instructions` rewrites `(select a b (i32.eq cond 0))` to
  // `(select b a cond)` and `(select a b (i32.ne cond 0))` to
  // `(select a b cond)`. Exact i32 boolean const arms compose to the existing
  // condition-compare folds. This deliberately covers only direct i32 eq/ne
  // zero condition shells, not arbitrary compare constants, broader boolean
  // algebra, or branch-condition rewrites.
  let eq_value_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) i32.const 42 i32.const 13 local.get 0 i32.const 0 i32.eq select))",
  )
  let eq_value_root = @ir.hot_root_get(eq_value_func, 0)
  match @ir.hot_node_get(eq_value_func, eq_value_root).op {
    @ir.HotOp::Select => ()
    _ => fail("expected eq-zero condition select to remain a select")
  }
  @debug.assert_eq(
    @ir.hot_const_get(
      eq_value_func,
      @ir.hot_node_get(
        eq_value_func,
        @ir.hot_child_get(eq_value_func, eq_value_root, 0),
      ).imm0,
    ),
    @ir.HotConstPayload::i32_const(@lib.I32(13)),
  )
  @debug.assert_eq(
    @ir.hot_const_get(
      eq_value_func,
      @ir.hot_node_get(
        eq_value_func,
        @ir.hot_child_get(eq_value_func, eq_value_root, 1),
      ).imm0,
    ),
    @ir.HotConstPayload::i32_const(@lib.I32(42)),
  )
  match
    @ir.hot_node_get(
      eq_value_func,
      @ir.hot_child_get(eq_value_func, eq_value_root, 2),
    ).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected eq-zero select condition to become the inner operand")
  }

  let ne_value_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) i32.const 42 i32.const 13 local.get 0 i32.const 0 i32.ne select))",
  )
  let ne_value_root = @ir.hot_root_get(ne_value_func, 0)
  match @ir.hot_node_get(ne_value_func, ne_value_root).op {
    @ir.HotOp::Select => ()
    _ => fail("expected ne-zero condition select to remain a select")
  }
  @debug.assert_eq(
    @ir.hot_const_get(
      ne_value_func,
      @ir.hot_node_get(
        ne_value_func,
        @ir.hot_child_get(ne_value_func, ne_value_root, 0),
      ).imm0,
    ),
    @ir.HotConstPayload::i32_const(@lib.I32(42)),
  )
  @debug.assert_eq(
    @ir.hot_const_get(
      ne_value_func,
      @ir.hot_node_get(
        ne_value_func,
        @ir.hot_child_get(ne_value_func, ne_value_root, 1),
      ).imm0,
    ),
    @ir.HotConstPayload::i32_const(@lib.I32(13)),
  )
  match
    @ir.hot_node_get(
      ne_value_func,
      @ir.hot_child_get(ne_value_func, ne_value_root, 2),
    ).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected ne-zero select condition to become the inner operand")
  }

  let bool_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) i32.const 1 i32.const 0 local.get 0 i32.const 0 i32.eq select))",
  )
  let bool_root = @ir.hot_root_get(bool_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(bool_func, bool_root),
    Some(@lib.Instruction::i32_eqz()),
  )
  match
    @ir.hot_node_get(bool_func, @ir.hot_child_get(bool_func, bool_root, 0)).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected boolean eq-zero select to fold to eqz of inner operand")
  }

  let call_func = optimize_instructions_test_run_hot(
    "(module (global $g (mut i32) (i32.const 0)) (func (result i32) i32.const 42 i32.const 13 call $side i32.const 0 i32.ne select) (func $side (result i32) i32.const 1 global.set $g i32.const 7))",
  )
  let call_root = @ir.hot_root_get(call_func, 0)
  match @ir.hot_node_get(call_func, call_root).op {
    @ir.HotOp::Select => ()
    _ => fail("expected effectful ne-zero condition select to remain a select")
  }
  match
    @ir.hot_node_get(call_func, @ir.hot_child_get(call_func, call_root, 2)).op {
    @ir.HotOp::Call => ()
    _ => fail("expected effectful ne-zero condition to keep the call operand")
  }
}

///|
test "optimize-instructions folds direct compare boolean select arms" {
  // Red-first OI-F select parity slice: Binaryen `version_130`
  // `--optimize-instructions` removes exact i32 boolean select arms around
  // direct compare conditions. `select 1 0 (compare ...)` becomes the compare
  // itself, while `select 0 1 (compare ...)` becomes the compare inverse when
  // Binaryen has a direct inverse spelling. This deliberately does not claim
  // arbitrary non-compare boolean conditions or value-select rewrites.
  let int_true_false_func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32) (result i32) i32.const 1 i32.const 0 local.get 0 local.get 1 i32.lt_s select))",
  )
  let int_true_false_root = @ir.hot_root_get(int_true_false_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(int_true_false_func, int_true_false_root),
    Some(@lib.Instruction::i32_lt_s()),
  )
  match
    @ir.hot_node_get(
      int_true_false_func,
      @ir.hot_child_get(int_true_false_func, int_true_false_root, 0),
    ).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected true/false compare select to keep lhs operand")
  }

  let int_false_true_func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32) (result i32) i32.const 0 i32.const 1 local.get 0 local.get 1 i32.lt_s select))",
  )
  let int_false_true_root = @ir.hot_root_get(int_false_true_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(int_false_true_func, int_false_true_root),
    Some(@lib.Instruction::i32_ge_s()),
  )

  let float_true_false_func = optimize_instructions_test_run_hot(
    "(module (func (param f32 f32) (result i32) i32.const 1 i32.const 0 local.get 0 local.get 1 f32.eq select))",
  )
  let float_true_false_root = @ir.hot_root_get(float_true_false_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(float_true_false_func, float_true_false_root),
    Some(@lib.Instruction::f32_eq()),
  )

  let float_false_true_func = optimize_instructions_test_run_hot(
    "(module (func (param f32 f32) (result i32) i32.const 0 i32.const 1 local.get 0 local.get 1 f32.eq select))",
  )
  let float_false_true_root = @ir.hot_root_get(float_false_true_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(float_false_true_func, float_false_true_root),
    Some(@lib.Instruction::f32_ne()),
  )
}

///|
test "optimize-instructions folds eqz compare boolean select arms" {
  // Red-first OI-F select parity slice: Binaryen `version_130`
  // `--optimize-instructions` removes exact i32 boolean select arms around
  // `i32.eqz(compare ...)` conditions. `select 1 0 (eqz(compare))` becomes
  // the inverse compare, while `select 0 1 (eqz(compare))` becomes the inner
  // compare. This deliberately does not claim arbitrary boolean algebra,
  // branch-condition rewrites, or non-boolean value-select rewrites.
  let i32_true_false_func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32) (result i32) i32.const 1 i32.const 0 local.get 0 local.get 1 i32.eq i32.eqz select))",
  )
  let i32_true_false_root = @ir.hot_root_get(i32_true_false_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(i32_true_false_func, i32_true_false_root),
    Some(@lib.Instruction::i32_ne()),
  )

  let i64_false_true_func = optimize_instructions_test_run_hot(
    "(module (func (param i64 i64) (result i32) i32.const 0 i32.const 1 local.get 0 local.get 1 i64.ne i32.eqz select))",
  )
  let i64_false_true_root = @ir.hot_root_get(i64_false_true_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(i64_false_true_func, i64_false_true_root),
    Some(@lib.Instruction::i64_ne()),
  )

  let relational_true_false_func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32) (result i32) i32.const 1 i32.const 0 local.get 0 local.get 1 i32.lt_u i32.eqz select))",
  )
  let relational_true_false_root = @ir.hot_root_get(
    relational_true_false_func, 0,
  )
  @debug.assert_eq(
    @ir.hot_node_exact_instr(
      relational_true_false_func, relational_true_false_root,
    ),
    Some(@lib.Instruction::i32_ge_u()),
  )

  let float_false_true_func = optimize_instructions_test_run_hot(
    "(module (func (param f64 f64) (result i32) i32.const 0 i32.const 1 local.get 0 local.get 1 f64.eq i32.eqz select))",
  )
  let float_false_true_root = @ir.hot_root_get(float_false_true_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(float_false_true_func, float_false_true_root),
    Some(@lib.Instruction::f64_eq()),
  )
}

///|
test "optimize-instructions folds direct integer equality boolean select arms" {
  // Red-first OI-F select parity slice: Binaryen `version_130`
  // `--optimize-instructions` removes exact i32 boolean select arms around
  // direct integer equality conditions. This covers local/local `i32.eq`,
  // `i32.ne`, `i64.eq`, and `i64.ne` conditions, including exact `0/1` arm
  // inversion. It deliberately does not claim broad nonzero compare-to-const
  // condition normalization, branch rewrites, or non-boolean value selects.
  let i32_eq_true_func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32) (result i32) i32.const 1 i32.const 0 local.get 0 local.get 1 i32.eq select))",
  )
  let i32_eq_true_root = @ir.hot_root_get(i32_eq_true_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(i32_eq_true_func, i32_eq_true_root),
    Some(@lib.Instruction::i32_eq()),
  )

  let i32_eq_false_func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32) (result i32) i32.const 0 i32.const 1 local.get 0 local.get 1 i32.eq select))",
  )
  let i32_eq_false_root = @ir.hot_root_get(i32_eq_false_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(i32_eq_false_func, i32_eq_false_root),
    Some(@lib.Instruction::i32_ne()),
  )

  let i32_ne_false_func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32) (result i32) i32.const 0 i32.const 1 local.get 0 local.get 1 i32.ne select))",
  )
  let i32_ne_false_root = @ir.hot_root_get(i32_ne_false_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(i32_ne_false_func, i32_ne_false_root),
    Some(@lib.Instruction::i32_eq()),
  )

  let i64_eq_true_func = optimize_instructions_test_run_hot(
    "(module (func (param i64 i64) (result i32) i32.const 1 i32.const 0 local.get 0 local.get 1 i64.eq select))",
  )
  let i64_eq_true_root = @ir.hot_root_get(i64_eq_true_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(i64_eq_true_func, i64_eq_true_root),
    Some(@lib.Instruction::i64_eq()),
  )

  let i64_ne_false_func = optimize_instructions_test_run_hot(
    "(module (func (param i64 i64) (result i32) i32.const 0 i32.const 1 local.get 0 local.get 1 i64.ne select))",
  )
  let i64_ne_false_root = @ir.hot_root_get(i64_ne_false_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(i64_ne_false_func, i64_ne_false_root),
    Some(@lib.Instruction::i64_eq()),
  )
}

///|
test "optimize-instructions folds i64 zero-compare boolean select arms" {
  // Red-first OI-F select parity slice: Binaryen `version_130`
  // `--optimize-instructions` canonicalizes exact i32 boolean arms over direct
  // i64 zero-compare select conditions. `i64.eq(x, 0)` with `1/0` arms becomes
  // `i64.eqz(x)`, `i64.eq(x, 0)` with `0/1` arms becomes `i64.ne(x, 0)`, and
  // direct `i64.ne(x, 0)` mirrors those forms without an extra eqz shell. This
  // deliberately does not claim non-boolean value-select rewrites or broader
  // i64 compare normalization.
  let eq_true_false_func = optimize_instructions_test_run_hot(
    "(module (func (param i64) (result i32) i32.const 1 i32.const 0 local.get 0 i64.const 0 i64.eq select))",
  )
  let eq_true_false_root = @ir.hot_root_get(eq_true_false_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(eq_true_false_func, eq_true_false_root),
    Some(@lib.Instruction::i64_eqz()),
  )
  match
    @ir.hot_node_get(
      eq_true_false_func,
      @ir.hot_child_get(eq_true_false_func, eq_true_false_root, 0),
    ).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected i64 eq-zero boolean true/false select to keep operand")
  }

  let eq_false_true_func = optimize_instructions_test_run_hot(
    "(module (func (param i64) (result i32) i32.const 0 i32.const 1 local.get 0 i64.const 0 i64.eq select))",
  )
  let eq_false_true_root = @ir.hot_root_get(eq_false_true_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(eq_false_true_func, eq_false_true_root),
    Some(@lib.Instruction::i64_ne()),
  )
  let eq_false_true_lhs = @ir.hot_child_get(
    eq_false_true_func, eq_false_true_root, 0,
  )
  let eq_false_true_rhs = @ir.hot_child_get(
    eq_false_true_func, eq_false_true_root, 1,
  )
  match @ir.hot_node_get(eq_false_true_func, eq_false_true_lhs).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected i64 eq-zero boolean false/true select to keep operand")
  }
  @debug.assert_eq(
    @ir.hot_const_get(
      eq_false_true_func,
      @ir.hot_node_get(eq_false_true_func, eq_false_true_rhs).imm0,
    ),
    @ir.HotConstPayload::i64_const(@lib.I64(0L)),
  )

  let ne_true_false_func = optimize_instructions_test_run_hot(
    "(module (func (param i64) (result i32) i32.const 1 i32.const 0 local.get 0 i64.const 0 i64.ne select))",
  )
  let ne_true_false_root = @ir.hot_root_get(ne_true_false_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(ne_true_false_func, ne_true_false_root),
    Some(@lib.Instruction::i64_ne()),
  )
  let ne_true_false_lhs = @ir.hot_child_get(
    ne_true_false_func, ne_true_false_root, 0,
  )
  let ne_true_false_rhs = @ir.hot_child_get(
    ne_true_false_func, ne_true_false_root, 1,
  )
  match @ir.hot_node_get(ne_true_false_func, ne_true_false_lhs).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected i64 ne-zero boolean true/false select to keep operand")
  }
  @debug.assert_eq(
    @ir.hot_const_get(
      ne_true_false_func,
      @ir.hot_node_get(ne_true_false_func, ne_true_false_rhs).imm0,
    ),
    @ir.HotConstPayload::i64_const(@lib.I64(0L)),
  )

  let ne_false_true_func = optimize_instructions_test_run_hot(
    "(module (func (param i64) (result i32) i32.const 0 i32.const 1 local.get 0 i64.const 0 i64.ne select))",
  )
  let ne_false_true_root = @ir.hot_root_get(ne_false_true_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(ne_false_true_func, ne_false_true_root),
    Some(@lib.Instruction::i64_eqz()),
  )
  match
    @ir.hot_node_get(
      ne_false_true_func,
      @ir.hot_child_get(ne_false_true_func, ne_false_true_root, 0),
    ).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected i64 ne-zero boolean false/true select to keep operand")
  }

  let value_func = optimize_instructions_test_run_hot(
    "(module (func (param i64) (result i32) i32.const 42 i32.const 13 local.get 0 i64.const 0 i64.eq select))",
  )
  let value_root = @ir.hot_root_get(value_func, 0)
  match @ir.hot_node_get(value_func, value_root).op {
    @ir.HotOp::Select => ()
    _ => fail("expected non-boolean i64 zero-compare select to stay a select")
  }
  @debug.assert_eq(
    @ir.hot_node_exact_instr(
      value_func,
      @ir.hot_child_get(value_func, value_root, 2),
    ),
    Some(@lib.Instruction::i64_eqz()),
  )
}

///|
test "optimize-instructions folds i64 eqz boolean select arms" {
  // Red-first OI-F select parity slice: Binaryen `version_130`
  // `--optimize-instructions` keeps value selects with an `i64.eqz` condition,
  // but composes exact i32 boolean arms to `i64.eqz(x)` for `1/0` and
  // `i64.ne(x, 0)` for `0/1`. This deliberately covers only direct i64.eqz
  // select-condition shells with exact i32 boolean arms, not non-boolean value
  // selects, i32 condition normalization, branch rewrites, or broader boolean
  // algebra.
  let true_false_func = optimize_instructions_test_run_hot(
    "(module (func (param i64) (result i32) i32.const 1 i32.const 0 local.get 0 i64.eqz select))",
  )
  let true_false_root = @ir.hot_root_get(true_false_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(true_false_func, true_false_root),
    Some(@lib.Instruction::i64_eqz()),
  )
  match
    @ir.hot_node_get(
      true_false_func,
      @ir.hot_child_get(true_false_func, true_false_root, 0),
    ).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected i64 eqz boolean true/false select to keep the operand")
  }

  let false_true_func = optimize_instructions_test_run_hot(
    "(module (func (param i64) (result i32) i32.const 0 i32.const 1 local.get 0 i64.eqz select))",
  )
  let false_true_root = @ir.hot_root_get(false_true_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(false_true_func, false_true_root),
    Some(@lib.Instruction::i64_ne()),
  )
  let false_true_lhs = @ir.hot_child_get(false_true_func, false_true_root, 0)
  let false_true_rhs = @ir.hot_child_get(false_true_func, false_true_root, 1)
  match @ir.hot_node_get(false_true_func, false_true_lhs).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected i64 eqz boolean false/true select to keep the operand")
  }
  @debug.assert_eq(
    @ir.hot_const_get(
      false_true_func,
      @ir.hot_node_get(false_true_func, false_true_rhs).imm0,
    ),
    @ir.HotConstPayload::i64_const(@lib.I64(0L)),
  )

  let value_func = optimize_instructions_test_run_hot(
    "(module (func (param i64) (result i32) i32.const 42 i32.const 13 local.get 0 i64.eqz select))",
  )
  let value_root = @ir.hot_root_get(value_func, 0)
  match @ir.hot_node_get(value_func, value_root).op {
    @ir.HotOp::Select => ()
    _ => fail("expected non-boolean i64 eqz select to stay a select")
  }
  @debug.assert_eq(
    @ir.hot_node_exact_instr(
      value_func,
      @ir.hot_child_get(value_func, value_root, 2),
    ),
    Some(@lib.Instruction::i64_eqz()),
  )
}

///|
test "optimize-instructions rewrites double eqz into ne zero" {
  let i32_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) local.get 0 i32.eqz i32.eqz))",
  )
  let i32_root = @ir.hot_root_get(i32_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(i32_func, i32_root),
    Some(@lib.Instruction::i32_ne()),
  )
  let i32_lhs = @ir.hot_child_get(i32_func, i32_root, 0)
  let i32_rhs = @ir.hot_child_get(i32_func, i32_root, 1)
  match @ir.hot_node_get(i32_func, i32_lhs).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected i32 double-eqz rewrite to keep the original operand")
  }
  @debug.assert_eq(
    @ir.hot_const_get(i32_func, @ir.hot_node_get(i32_func, i32_rhs).imm0),
    @ir.HotConstPayload::i32_const(@lib.I32(0)),
  )

  let i64_func = optimize_instructions_test_run_hot(
    "(module (func (param i64) (result i32) local.get 0 i64.eqz i32.eqz))",
  )
  let i64_root = @ir.hot_root_get(i64_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(i64_func, i64_root),
    Some(@lib.Instruction::i64_ne()),
  )
  let i64_lhs = @ir.hot_child_get(i64_func, i64_root, 0)
  let i64_rhs = @ir.hot_child_get(i64_func, i64_root, 1)
  match @ir.hot_node_get(i64_func, i64_lhs).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected i64 double-eqz rewrite to keep the original operand")
  }
  @debug.assert_eq(
    @ir.hot_const_get(i64_func, @ir.hot_node_get(i64_func, i64_rhs).imm0),
    @ir.HotConstPayload::i64_const(@lib.I64(0L)),
  )
}

///|
