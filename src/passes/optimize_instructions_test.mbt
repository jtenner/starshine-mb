  assert_true(i32_pretty.contains("i32.lt_u"), msg=i32_pretty)
  assert_false(i32_pretty.contains("i32.lt_s"), msg=i32_pretty)
  let i64_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
