        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(2U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(3U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(4U)),
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(5U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(6U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(7U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(8U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(9U)),
            @lib.Instruction::call(@lib.FuncIdx::new(1U)),
            @lib.Instruction::ref_cast_desc_eq_type(base_ref_type),
          ]),
        ),
      ]),
    )
  let optimized = optimize_instructions_test_run_module(module_)
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_false(pretty.contains("ref.cast_desc_eq"), msg=pretty)
  match optimized.code_sec {
    Some(
      @lib.CodeSec(
        [
          _,
          _,
          @lib.Func(
            _,
            @lib.Expr(
              [
                @lib.LocalGet(arg0),
                @lib.LocalGet(arg1),
                @lib.LocalGet(arg2),
                @lib.LocalGet(arg3),
                @lib.LocalGet(arg4),
                @lib.Call(ref_func),
                @lib.Drop,
                @lib.LocalGet(arg5),
                @lib.LocalGet(arg6),
                @lib.LocalGet(arg7),
                @lib.LocalGet(arg8),
                @lib.LocalGet(arg9),
                @lib.Call(desc_func),
                @lib.Drop,
                @lib.Unreachable,
              ]
            )
          ),
        ]
      )
    ) => {
      @debug.assert_eq(arg0, @lib.LocalIdx::new(0U))
      @debug.assert_eq(arg1, @lib.LocalIdx::new(1U))
      @debug.assert_eq(arg2, @lib.LocalIdx::new(2U))
      @debug.assert_eq(arg3, @lib.LocalIdx::new(3U))
      @debug.assert_eq(arg4, @lib.LocalIdx::new(4U))
      @debug.assert_eq(ref_func, @lib.FuncIdx::new(0U))
      @debug.assert_eq(arg5, @lib.LocalIdx::new(5U))
      @debug.assert_eq(arg6, @lib.LocalIdx::new(6U))
      @debug.assert_eq(arg7, @lib.LocalIdx::new(7U))
      @debug.assert_eq(arg8, @lib.LocalIdx::new(8U))
      @debug.assert_eq(arg9, @lib.LocalIdx::new(9U))
      @debug.assert_eq(desc_func, @lib.FuncIdx::new(1U))
    }
    _ =>
      fail(
        "expected five ref args; call ref; drop; five desc args; call desc; drop; unreachable",
      )
  }
}

///|
test "optimize-instructions folds descriptor casts with six-arg call exact descriptor misses" {
  // OI-J descriptor/effect order slice: Binaryen version_130 also folds the
  // exact descriptor miss when both direct calls take exactly six pure local
  // arguments. This is the first deliberately widened >5-per-call direct-call
  // slice; it does not imply arbitrary arity or non-local/effectful arguments.
  optimize_instructions_test_assert_mixed_direct_call_descriptor_miss(6, 6)
}

///|
test "optimize-instructions folds descriptor casts with mixed 6-ref 5-desc call exact descriptor misses" {
  // OI-J descriptor/effect order slice: Binaryen version_130 also folds the
  // exact descriptor miss when the reference call takes six pure local
  // arguments and the descriptor call takes five pure local arguments. Keep
  // this one-sided >5 mixed-arity slice independent from arbitrary arity,
  // effectful/trapping arguments, indirect/call_ref, return_call*, multivalue,
  // escaping control/EH, and TNH/IIT widening.
  optimize_instructions_test_assert_mixed_direct_call_descriptor_miss(6, 5)
}

///|
test "optimize-instructions folds descriptor casts with mixed 5-ref 6-desc call exact descriptor misses" {
  // OI-J descriptor/effect order slice: Binaryen version_130 also folds the
  // exact descriptor miss when the reference call takes five pure local
  // arguments and the descriptor call takes six pure local arguments. This is
  // the inverse one-sided >5 mixed-arity slice after the 6-ref/5-desc proof; it
  // still does not imply arbitrary arity, non-local/effectful arguments,
  // indirect/call_ref, return_call*, multivalue, escaping control/EH, or
  // TNH/IIT widening.
  optimize_instructions_test_assert_mixed_direct_call_descriptor_miss(5, 6)
}

