  // Red-first OI-E behavior-parity slice: Binaryen v130 folds the impossible
  // maxBits compare through a drop-wrapped atomic cmpxchg prefix while keeping
  // the ordered compare-exchange/trap before the folded constant.
  let memarg = @lib.MemArg::new(@lib.U32(2U), None, @lib.U64(0UL))
  let func_type = @lib.RecType::new(
    @lib.SubType::comp_type(
      @lib.CompType::func(
        [
          @lib.ValType::i32(),
          @lib.ValType::i32(),
          @lib.ValType::i32(),
          @lib.ValType::i32(),
        ],
        [@lib.ValType::i32()],
      ),
    ),
  )
  let input = @lib.Module::new()
    .with_type_sec(@lib.TypeSec::new([func_type]))
    .with_func_sec(@lib.FuncSec::new([@lib.TypeIdx::new(0U)]))
    .with_mem_sec(
      @lib.MemSec::new([
        @lib.MemType::new(@lib.Limits::i32(1U, Some(1U)), shared=true),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(@lib.ValType::i32()),
              @lib.Expr::new([
                @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
                @lib.Instruction::local_get(@lib.LocalIdx::new(2U)),
