///|
test "optimize-instructions moves standalone ref.get_desc br_on_null block null checks" {
  // OI-J standalone self-contained br_on_null slice: Binaryen version_130
  // default/IIT/TNH simplify `ref.get_desc(ref.as_non_null(block ...))` for the
  // narrow br_on_null trampoline shape where a zero-result inner block catches
  // the null branch, the non-null fallthrough immediately branches to the
  // descriptor child block, and the outer fallthrough is explicit ref.null.
  // This does not claim br_on_cast*, escaping labels, descriptor operands,
  // generalized nested control, or broader descriptor/exactness behavior.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let described_heap = @lib.HeapType::new(described_type)
  let nullable_described_val_type = @lib.ValType::ref_type(
    @lib.RefType::new(true, described_heap),
  )
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([nullable_described_val_type], [
              @lib.ValType::anyref(),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([@lib.TypeIdx::new(2U)]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(nullable_described_val_type),
              @lib.Expr::new([
                @lib.Instruction::block(
                  @lib.BlockType::void_(),
                  @lib.Expr::new([
                    @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
                    @lib.Instruction::br_on_null(@lib.LabelIdx::new(0U)),
                    @lib.Instruction::br(@lib.LabelIdx::new(1U)),
                  ]),
                ),
                @lib.Instruction::ref_null(described_heap),
              ]),
            ),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_get_desc(described_type),
          ]),
        ),
      ]),
    )
  let func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(0U))
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    module_ctx=Some(@ir.hot_module_context_from_module(module_)),
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) =>
      fail("expected standalone br_on_null ref.get_desc success, got \{err}")
  }
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_exact_instr(func, root) {
    Some(@lib.Instruction::RefGetDesc(_)) => ()
    other => fail("expected standalone root ref.get_desc, got \{other}")
  }
  let child = @ir.hot_child_get(func, root, 0)
  match @ir.hot_node_get(func, child).op {
    @ir.HotOp::Block => ()
    other =>
      fail("expected self-contained br_on_null block child, got \{other}")
  }
  let body = @ir.hot_region_body_ref(func, child)
  @debug.assert_eq(@ir.hot_region_root_count(func, body), 2)
  let nested = @ir.hot_region_get(func, body, 0)
  match @ir.hot_node_get(func, nested).op {
    @ir.HotOp::Block => ()
    other => fail("expected br_on_null trampoline block root, got \{other}")
  }
  let final_root = @ir.hot_region_get(func, body, 1)
  match @ir.hot_node_get(func, final_root).op {
    @ir.HotOp::RefNull => ()
    other =>
      fail("expected br_on_null outer fallthrough ref.null, got \{other}")
  }

  let tnh_func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(0U))
  let tnh_ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    traps_never_happen=true,
    module_ctx=Some(@ir.hot_module_context_from_module(module_)),
  )
  match hot_pass_run(tnh_ctx, tnh_func) {
    Ok(_) => ()
    Err(err) =>
      fail(
        "expected TNH standalone br_on_null ref.get_desc success, got \{err}",
      )
  }
  let tnh_root = @ir.hot_root_get(tnh_func, 0)
  match @ir.hot_node_exact_instr(tnh_func, tnh_root) {
    Some(@lib.Instruction::RefGetDesc(_)) => ()
    other => fail("expected TNH standalone root ref.get_desc, got \{other}")
  }
  let tnh_child = @ir.hot_child_get(tnh_func, tnh_root, 0)
  match @ir.hot_node_get(tnh_func, tnh_child).op {
    @ir.HotOp::Block => ()
    other => fail("expected TNH self-contained br_on_null block, got \{other}")
  }
}

///|
test "optimize-instructions moves ref.get_desc child null checks into descriptor casts" {
  // OI-J descriptor-operand trapOnNull breadth: Binaryen version_130 default
  // and IIT modes preserve the descriptor equality cast, but simplify
  // `ref.get_desc(ref.as_non_null(local.get nullable))` to
  // `ref.get_desc(local.get nullable)`, moving the nullable child trap into the
  // descriptor cast. TNH may erase both the cast and pure descriptor operand;
  // that paired TNH behavior remains covered by the following test.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let described_heap = @lib.HeapType::new(described_type)
  let nullable_described_ref_type = @lib.RefType::new(true, described_heap)
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func(
              [@lib.ValType::ref_type(nullable_described_ref_type)],
              [@lib.ValType::ref_type(nullable_described_ref_type)],
            ),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([@lib.TypeIdx::new(2U)]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_get_desc(described_type),
            @lib.Instruction::ref_cast_desc_eq_type(nullable_described_ref_type),
          ]),
        ),
      ]),
    )
  let func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(0U))
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    module_ctx=Some(@ir.hot_module_context_from_module(module_)),
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) =>
      fail(
        "expected descriptor ref.get_desc child null-check simplification, got \{err}",
      )
  }
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_exact_instr(func, root) {
    Some(@lib.Instruction::RefCastDescEq(_, _, _)) => ()
    other => fail("expected descriptor cast to remain, got \{other}")
  }
  @debug.assert_eq(@ir.hot_child_count(func, root), 2)
  let descriptor_operand = @ir.hot_child_get(func, root, 1)
  match @ir.hot_node_exact_instr(func, descriptor_operand) {
    Some(@lib.Instruction::RefGetDesc(_)) => ()
    other => fail("expected ref.get_desc descriptor operand, got \{other}")
  }
  @debug.assert_eq(@ir.hot_child_count(func, descriptor_operand), 1)
  let child = @ir.hot_child_get(func, descriptor_operand, 0)
  match @ir.hot_node_get(func, child).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected ref.get_desc child null check folded into cast")
  }
  @debug.assert_eq(@ir.hot_node_get(func, child).imm0, 0)
}

///|
test "optimize-instructions moves select-produced ref.get_desc child null checks into descriptor casts" {
  // OI-J descriptor-operand trapOnNull breadth: Binaryen version_130 default
  // and IIT modes preserve the descriptor equality cast, but simplify a
  // select-produced nullable child from
  // `ref.get_desc(ref.as_non_null(select ...))` to `ref.get_desc(select ...)`,
  // leaving the descriptor cast to carry the null trap. This broadens the
  // prior direct-local and block-produced child slices without claiming general
  // effectful/control descriptor operands or ref.test_desc.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let described_heap = @lib.HeapType::new(described_type)
  let nullable_described_ref_type = @lib.RefType::new(true, described_heap)
  let nullable_described_val_type = @lib.ValType::ref_type(
    nullable_described_ref_type,
  )
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func(
              [
                nullable_described_val_type,
                nullable_described_val_type,
                @lib.ValType::i32(),
              ],
              [nullable_described_val_type],
            ),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([@lib.TypeIdx::new(2U)]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(2U)),
            @lib.Instruction::select(types=Some([nullable_described_val_type])),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_get_desc(described_type),
            @lib.Instruction::ref_cast_desc_eq_type(nullable_described_ref_type),
          ]),
        ),
      ]),
    )
  let func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(0U))
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    module_ctx=Some(@ir.hot_module_context_from_module(module_)),
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) =>
      fail(
        "expected select-produced descriptor ref.get_desc null-check simplification, got \{err}",
      )
  }
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_exact_instr(func, root) {
    Some(@lib.Instruction::RefCastDescEq(_, _, _)) => ()
    other => fail("expected descriptor cast to remain, got \{other}")
  }
  @debug.assert_eq(@ir.hot_child_count(func, root), 2)
  let descriptor_operand = @ir.hot_child_get(func, root, 1)
  match @ir.hot_node_exact_instr(func, descriptor_operand) {
    Some(@lib.Instruction::RefGetDesc(_)) => ()
    other => fail("expected ref.get_desc descriptor operand, got \{other}")
  }
  @debug.assert_eq(@ir.hot_child_count(func, descriptor_operand), 1)
  let child = @ir.hot_child_get(func, descriptor_operand, 0)
  match @ir.hot_node_get(func, child).op {
    @ir.HotOp::Select => ()
    _ =>
      fail("expected select child after descriptor null check moved into cast")
  }
}

