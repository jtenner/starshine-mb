///|
test "optimize-instructions folds select with identical pure numeric expression arms" {
  // Red-first OI-F parity slice: Binaryen `version_130`
  // `--optimize-instructions` folds same-order local/constant numeric
  // expression arms such as `i32.add(local.get, const)`,
  // `i64.add(local.get, const)`, direct i32/i64/f32/f64 compare
  // local/constant shells, direct f32/f64 binary local/constant shells
  // including min/max, direct f32/f64 conversion local shells, and direct i64
  // unary local shells when the condition is
  // side-effect-free (`.tmp/oi-select-identical-binary-arms-probe.wat`,
  // `.tmp/oi-select-identical-float-binary-arms-probe.wat`,
  // `.tmp/oi-select-identical-float-minmax-arms-probe.wat`,
  // `.tmp/oi-select-identical-compare-arms-probe.wat`,
  // `.tmp/oi-select-identical-conversion-arms-probe.wat`,
  // `.tmp/oi-select-identical-i64-unary-arms-probe.wat`). This deliberately
  // stays at narrow direct same-payload shells, not arbitrary structural
  // equality, commuted operands, or effectful/trapping condition handling.
  let i32_func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32) (result i32) (select (i32.add (local.get 0) (i32.const 7)) (i32.add (local.get 0) (i32.const 7)) (local.get 1))))",
  )
  let i32_root = @ir.hot_root_get(i32_func, 0)
  match @ir.hot_node_exact_instr(i32_func, i32_root) {
    Some(instr) if instr == @lib.Instruction::i32_add() => ()
    _ => fail("expected identical pure i32.add select arms to fold")
  }

  let i64_func = optimize_instructions_test_run_hot(
    "(module (func (param i64 i32) (result i64) (select (i64.add (local.get 0) (i64.const 7)) (i64.add (local.get 0) (i64.const 7)) (local.get 1))))",
  )
  let i64_root = @ir.hot_root_get(i64_func, 0)
  match @ir.hot_node_exact_instr(i64_func, i64_root) {
    Some(instr) if instr == @lib.Instruction::i64_add() => ()
    _ => fail("expected identical pure i64.add select arms to fold")
  }

  let f32_binary_func = optimize_instructions_test_run_hot(
    "(module (func (param f32 i32) (result f32) (select (f32.add (local.get 0) (f32.const 1.5)) (f32.add (local.get 0) (f32.const 1.5)) (local.get 1))))",
  )
  let f32_binary_root = @ir.hot_root_get(f32_binary_func, 0)
  match @ir.hot_node_exact_instr(f32_binary_func, f32_binary_root) {
    Some(instr) if instr == @lib.Instruction::f32_add() => ()
    _ => fail("expected identical pure f32.add select arms to fold")
  }

  let f64_binary_func = optimize_instructions_test_run_hot(
    "(module (func (param f64 i32) (result f64) (select (f64.mul (local.get 0) (f64.const 4.0)) (f64.mul (local.get 0) (f64.const 4.0)) (local.get 1))))",
  )
  let f64_binary_root = @ir.hot_root_get(f64_binary_func, 0)
  match @ir.hot_node_exact_instr(f64_binary_func, f64_binary_root) {
    Some(instr) if instr == @lib.Instruction::f64_mul() => ()
    _ => fail("expected identical pure f64.mul select arms to fold")
  }

  let f32_min_func = optimize_instructions_test_run_hot(
    "(module (func (param f32 i32) (result f32) (select (f32.min (local.get 0) (f32.const 1.25)) (f32.min (local.get 0) (f32.const 1.25)) (local.get 1))))",
  )
  let f32_min_root = @ir.hot_root_get(f32_min_func, 0)
  match @ir.hot_node_exact_instr(f32_min_func, f32_min_root) {
    Some(instr) if instr == @lib.Instruction::f32_min() => ()
    _ => fail("expected identical pure f32.min select arms to fold")
  }

  let f64_max_func = optimize_instructions_test_run_hot(
    "(module (func (param f64 i32) (result f64) (select (f64.max (local.get 0) (f64.const -4.5)) (f64.max (local.get 0) (f64.const -4.5)) (local.get 1))))",
  )
  let f64_max_root = @ir.hot_root_get(f64_max_func, 0)
  match @ir.hot_node_exact_instr(f64_max_func, f64_max_root) {
    Some(instr) if instr == @lib.Instruction::f64_max() => ()
    _ => fail("expected identical pure f64.max select arms to fold")
  }

  let i32_compare_func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32) (result i32) (select (i32.eq (local.get 0) (i32.const 7)) (i32.eq (local.get 0) (i32.const 7)) (local.get 1))))",
  )
  let i32_compare_root = @ir.hot_root_get(i32_compare_func, 0)
  match @ir.hot_node_exact_instr(i32_compare_func, i32_compare_root) {
    Some(instr) if instr == @lib.Instruction::i32_eq() => ()
    _ => fail("expected identical pure i32.eq select arms to fold")
  }

  let i64_compare_func = optimize_instructions_test_run_hot(
    "(module (func (param i64 i32) (result i32) (select (i64.lt_u (local.get 0) (i64.const 9)) (i64.lt_u (local.get 0) (i64.const 9)) (local.get 1))))",
  )
  let i64_compare_root = @ir.hot_root_get(i64_compare_func, 0)
  match @ir.hot_node_exact_instr(i64_compare_func, i64_compare_root) {
    Some(instr) if instr == @lib.Instruction::i64_lt_u() => ()
    _ => fail("expected identical pure i64.lt_u select arms to fold")
  }

  let f32_compare_func = optimize_instructions_test_run_hot(
    "(module (func (param f32 i32) (result i32) (select (f32.gt (local.get 0) (f32.const 1.5)) (f32.gt (local.get 0) (f32.const 1.5)) (local.get 1))))",
  )
  let f32_compare_root = @ir.hot_root_get(f32_compare_func, 0)
  match @ir.hot_node_exact_instr(f32_compare_func, f32_compare_root) {
    Some(instr) if instr == @lib.Instruction::f32_gt() => ()
    _ => fail("expected identical pure f32.gt select arms to fold")
  }

  let f64_compare_func = optimize_instructions_test_run_hot(
    "(module (func (param f64 i32) (result i32) (select (f64.le (local.get 0) (f64.const -2.25)) (f64.le (local.get 0) (f64.const -2.25)) (local.get 1))))",
  )
  let f64_compare_root = @ir.hot_root_get(f64_compare_func, 0)
  match @ir.hot_node_exact_instr(f64_compare_func, f64_compare_root) {
    Some(instr) if instr == @lib.Instruction::f64_le() => ()
    _ => fail("expected identical pure f64.le select arms to fold")
  }

  let f32_convert_func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32) (result f32) (select (f32.convert_i32_s (local.get 0)) (f32.convert_i32_s (local.get 0)) (local.get 1))))",
  )
  let f32_convert_root = @ir.hot_root_get(f32_convert_func, 0)
  match @ir.hot_node_exact_instr(f32_convert_func, f32_convert_root) {
    Some(instr) if instr == @lib.Instruction::f32_convert_i32s() => ()
    _ => fail("expected identical pure f32.convert_i32_s select arms to fold")
  }

  let f64_convert_func = optimize_instructions_test_run_hot(
    "(module (func (param f32 i32) (result f64) (select (f64.promote_f32 (local.get 0)) (f64.promote_f32 (local.get 0)) (local.get 1))))",
  )
  let f64_convert_root = @ir.hot_root_get(f64_convert_func, 0)
  match @ir.hot_node_exact_instr(f64_convert_func, f64_convert_root) {
    Some(instr) if instr == @lib.Instruction::f64_promote_f32() => ()
    _ => fail("expected identical pure f64.promote_f32 select arms to fold")
  }

  let i64_unary_func = optimize_instructions_test_run_hot(
    "(module (func (param i64 i32) (result i64) (select (i64.clz (local.get 0)) (i64.clz (local.get 0)) (local.get 1))))",
  )
  let i64_unary_root = @ir.hot_root_get(i64_unary_func, 0)
  match @ir.hot_node_exact_instr(i64_unary_func, i64_unary_root) {
    Some(instr) if instr == @lib.Instruction::i64_clz() => ()
    _ => fail("expected identical pure i64.clz select arms to fold")
  }

  let f32_unary_func = optimize_instructions_test_run_hot(
    "(module (func (param f32 i32) (result f32) (select (f32.abs (local.get 0)) (f32.abs (local.get 0)) (local.get 1))))",
  )
  let f32_unary_root = @ir.hot_root_get(f32_unary_func, 0)
  match @ir.hot_node_exact_instr(f32_unary_func, f32_unary_root) {
    Some(instr) if instr == @lib.Instruction::f32_abs() => ()
    _ => fail("expected identical pure f32.abs select arms to fold")
  }

  let f64_unary_func = optimize_instructions_test_run_hot(
    "(module (func (param f64 i32) (result f64) (select (f64.neg (local.get 0)) (f64.neg (local.get 0)) (local.get 1))))",
  )
  let f64_unary_root = @ir.hot_root_get(f64_unary_func, 0)
  match @ir.hot_node_exact_instr(f64_unary_func, f64_unary_root) {
    Some(instr) if instr == @lib.Instruction::f64_neg() => ()
    _ => fail("expected identical pure f64.neg select arms to fold")
  }
}

///|
test "optimize-instructions folds select with identical pure global arms" {
  // Red-first OI-F parity slice: Binaryen `version_130`
  // `--optimize-instructions` folds direct identical `global.get` select arms
  // when the condition is side-effect-free (`.tmp/oi-select-global-arms-probe.wat`).
  // This is intentionally only direct same-global equality, not structural
  // expression equality or an effectful/trapping condition claim.
  let func = optimize_instructions_test_run_hot(
    "(module (global $g (mut i32) (i32.const 42)) (func (param i32) (result i32) (select (global.get $g) (global.get $g) (local.get 0))))",
  )
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_get(func, root).op {
    @ir.HotOp::GlobalGet =>
      @debug.assert_eq(@ir.hot_node_get(func, root).imm0, 0)
    _ =>
      fail("expected identical pure global select arms to fold to global.get")
  }
}

///|
test "optimize-instructions keeps identical mutable global select arms across effectful condition" {
  // Red-first OI-F correctness/parity slice: Binaryen `version_130`
  // `--optimize-instructions` keeps identical `global.get` select arms when the
  // condition can mutate the global (`.tmp/oi-select-mutable-global-effectful-condition-probe.wat`).
  // Folding this to `drop(condition); global.get` would read the mutable global
  // after the call instead of before it, so the effectful-condition identical-arm
  // cleanup must not admit global leaves.
  let func = @ir.HotFunc::new()
  @ir.hot_body_result_type_set(
    func,
    @ir.hot_type_intern_value(func, @lib.ValType::i32()),
  )
  let lhs = @ir.hot_build_global_get(func, 0, @lib.ValType::i32())
  let rhs = @ir.hot_build_global_get(func, 0, @lib.ValType::i32())
  let condition = @ir.hot_build_call(func, 0, [@lib.ValType::i32()], [])
  @ir.hot_root_append(
    func,
    @ir.hot_build_select(func, @lib.ValType::i32(), lhs, rhs, condition),
  )
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) =>
      fail("expected mutable global select boundary success, got \{err}")
  }
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_get(func, root).op {
    @ir.HotOp::Select => {
      @debug.assert_eq(@ir.hot_node_get(func, root).child_count, 3)
      let lhs = @ir.hot_child_get(func, root, 0)
      let rhs = @ir.hot_child_get(func, root, 1)
      let condition = @ir.hot_child_get(func, root, 2)
      match @ir.hot_node_get(func, lhs).op {
        @ir.HotOp::GlobalGet => ()
        _ => fail("expected first global.get arm to stay")
      }
      match @ir.hot_node_get(func, rhs).op {
        @ir.HotOp::GlobalGet => ()
        _ => fail("expected second global.get arm to stay")
      }
      match @ir.hot_node_get(func, condition).op {
        @ir.HotOp::Call => ()
        _ => fail("expected effectful condition call to stay")
      }
    }
    _ =>
      fail(
        "expected identical mutable global select arms to stay across effectful condition",
      )
  }
}

///|
test "optimize-instructions preserves effectful condition when folding identical immutable global select arms" {
  // Red-first OI-F parity slice: Binaryen `version_130`
  // `--optimize-instructions` folds identical immutable `global.get` select arms
  // even when the condition is effectful, preserving that condition as a dropped
  // prefix (`.tmp/oi-select-immutable-global-effectful-probe.wat`). The mutable
  // global boundary above remains no-fold because calls may change mutable globals.
  let module_ctx = @ir.hot_module_context_from_module(
    @lib.Module::new().with_global_sec(
      @lib.GlobalSec::new([
        @lib.Global::new(
          @lib.GlobalType::new(@lib.ValType::i32(), false),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(42))]),
        ),
      ]),
    ),
  )
  let func = @ir.HotFunc::new()
  @ir.hot_body_result_type_set(
    func,
    @ir.hot_type_intern_value(func, @lib.ValType::i32()),
  )
  let lhs = @ir.hot_build_global_get(func, 0, @lib.ValType::i32())
  let rhs = @ir.hot_build_global_get(func, 0, @lib.ValType::i32())
  let condition = @ir.hot_build_call(func, 0, [@lib.ValType::i32()], [])
  @ir.hot_root_append(
    func,
    @ir.hot_build_select(func, @lib.ValType::i32(), lhs, rhs, condition),
  )
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    module_ctx=Some(module_ctx),
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) =>
      fail("expected immutable global select fold success, got \{err}")
  }
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_get(func, root).op {
    @ir.HotOp::Block => ()
    _ => fail("expected identical immutable global select arms to fold")
  }
}

///|
test "optimize-instructions folds select with identical pure ref.null arms" {
  // Red-first OI-F parity slice: Binaryen `version_130`
  // `--optimize-instructions` folds direct identical `ref.null` select arms
  // when the condition is side-effect-free (`.tmp/oi-select-refnull-arms-probe.wat`).
  // This is intentionally only direct ref.null equality, not broader reference
  // value or structural-expression equality.
  let func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result funcref) (select (ref.null func) (ref.null func) (local.get 0))))",
  )
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_get(func, root).op {
    @ir.HotOp::RefNull => ()
    _ =>
      fail("expected identical pure ref.null select arms to fold to ref.null")
  }
}

///|
test "optimize-instructions folds select with identical pure ref.func arms" {
  // Red-first OI-F parity slice: Binaryen `version_130`
  // `--optimize-instructions` folds direct identical `ref.func` select arms
  // when the condition is side-effect-free (`.tmp/oi-select-reffunc-arms-probe.wat`).
  // This is intentionally only direct same-function equality, not broader
  // reference value, table, or structural-expression equality.
  let func = optimize_instructions_test_run_hot(
    "(module (type $t (func (param i32) (result funcref))) (func $target (type $t) (param i32) (result funcref) (select (ref.func $target) (ref.func $target) (local.get 0))) (elem declare func $target))",
  )
  let root = @ir.hot_root_get(func, 0)
  let node = @ir.hot_node_get(func, root)
  match node.op {
    @ir.HotOp::RefFunc => @debug.assert_eq(node.imm0, 0)
    _ =>
      fail("expected identical pure ref.func select arms to fold to ref.func")
  }
}

///|
test "optimize-instructions folds select with identical pure float constant arms" {
  // Red-first OI-F parity slice: Binaryen `version_130`
  // `--optimize-instructions` folds identical f32/f64 constant select arms when
  // the condition is side-effect-free (`.tmp/oi-select-float-arms-probe.wat`).
  // This deliberately stays at direct constant equality and does not claim
  // broader structural-expression equality, NaN-payload equality, or
  // reference-constant parity.
  let f32_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result f32) (select (f32.const 3.5) (f32.const 3.5) (local.get 0))))",
  )
  let f32_root = @ir.hot_root_get(f32_func, 0)
  match @ir.hot_node_get(f32_func, f32_root).op {
    @ir.HotOp::Const =>
      @debug.assert_eq(
        @ir.hot_const_get(f32_func, @ir.hot_node_get(f32_func, f32_root).imm0),
        @ir.HotConstPayload::f32_const(@lib.F32::new(3.5)),
      )
    _ => fail("expected identical f32 constant select arms to fold")
  }
  let f64_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result f64) (select (f64.const -2.5) (f64.const -2.5) (local.get 0))))",
  )
  let f64_root = @ir.hot_root_get(f64_func, 0)
  match @ir.hot_node_get(f64_func, f64_root).op {
    @ir.HotOp::Const =>
      @debug.assert_eq(
        @ir.hot_const_get(f64_func, @ir.hot_node_get(f64_func, f64_root).imm0),
        @ir.HotConstPayload::f64_const(@lib.F64(-2.5)),
      )
    _ => fail("expected identical f64 constant select arms to fold")
  }
}

///|
test "optimize-instructions folds select with identical pure ref.i31 arms" {
  // Red-first OI-F parity slice: Binaryen `version_130`
  // `--optimize-instructions` folds direct identical `ref.i31` select arms
  // with the same pure i32 payload when the condition is side-effect-free
  // (`.tmp/oi-select-refi31-arms-probe.wat`). Follow-up oracle probe
  // `.tmp/oi-select-refi31-add-arms-probe.wat` shows the same fold for a
  // narrow same `i32.add(local.get, const)` payload shell; follow-up probe
  // `.tmp/oi-select-refi31-sub-arms-probe.wat` does the same for same-order
  // `i32.sub(local.get, const)`. Follow-up probe
  // `.tmp/oi-select-refi31-mul-arms-probe.wat` does the same for same-order
  // `i32.mul(local.get, const)`. Follow-up probe
  // `.tmp/oi-select-refi31-and-arms-probe.wat` does the same for same-order
  // `i32.and(local.get, const)`. Follow-up probe
  // `.tmp/oi-select-refi31-or-xor-arms-probe.wat` does the same for
  // same-order `i32.or(local.get, const)` and `i32.xor(local.get, const)`.
  // Follow-up probe `.tmp/oi-select-refi31-shift-arms-probe.wat` adds
  // same-order `i32.shl`, `i32.shr_u`, `i32.shr_s`, `i32.rotl`, and
  // `i32.rotr` local/constant payload shells. Follow-up probe
  // `.tmp/oi-select-refi31-unary-arms-probe.wat` adds direct `i32.eqz`,
  // `i32.clz`, `i32.ctz`, and `i32.popcnt` local-payload shells. Follow-up
  // probe `.tmp/oi-select-refi31-signext-arms-probe.wat` adds direct
  // `i32.extend8_s` and `i32.extend16_s` local-payload shells. Follow-up
  // probe `.tmp/oi-select-refi31-truncsat-arms-probe.wat` adds direct
  // `i32.trunc_sat_f32_s` and `i32.trunc_sat_f64_u` local-payload shells.
  // Follow-up probe `.tmp/oi-select-refi31-reinterpret-arms-probe.wat` adds
  // direct `i32.reinterpret_f32` local-payload shells. Follow-up probe
  // `.tmp/oi-select-refi31-wrap-arms-probe.wat` adds direct `i32.wrap_i64`
  // local-payload shells. Follow-up probe
  // `.tmp/oi-select-refi31-divrem-arms-probe.wat` adds same-order
  // `i32.div_s`, `i32.div_u`, `i32.rem_s`, and `i32.rem_u` local/constant
  // payload shells. This stays at direct same-payload i31 construction, not
  // arbitrary reference or broad structural expression equality.
  let const_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result (ref i31)) (select (ref.i31 (i32.const 7)) (ref.i31 (i32.const 7)) (local.get 0))))",
  )
  let const_root = @ir.hot_root_get(const_func, 0)
  match @ir.hot_node_exact_instr(const_func, const_root) {
    Some(@lib.Instruction::RefI31) => ()
    _ => fail("expected identical pure ref.i31 const arms to fold to ref.i31")
  }

  let add_func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32) (result (ref i31)) (select (ref.i31 (i32.add (local.get 0) (i32.const 1))) (ref.i31 (i32.add (local.get 0) (i32.const 1))) (local.get 1))))",
  )
  let add_root = @ir.hot_root_get(add_func, 0)
  match @ir.hot_node_exact_instr(add_func, add_root) {
    Some(@lib.Instruction::RefI31) => ()
    _ => fail("expected identical pure ref.i31 add arms to fold to ref.i31")
  }

  let sub_func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32) (result (ref i31)) (select (ref.i31 (i32.sub (local.get 0) (i32.const 1))) (ref.i31 (i32.sub (local.get 0) (i32.const 1))) (local.get 1))))",
  )
  let sub_root = @ir.hot_root_get(sub_func, 0)
  match @ir.hot_node_exact_instr(sub_func, sub_root) {
    Some(@lib.Instruction::RefI31) => ()
    _ => fail("expected identical pure ref.i31 sub arms to fold to ref.i31")
  }

  let mul_func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32) (result (ref i31)) (select (ref.i31 (i32.mul (local.get 0) (i32.const 3))) (ref.i31 (i32.mul (local.get 0) (i32.const 3))) (local.get 1))))",
  )
  let mul_root = @ir.hot_root_get(mul_func, 0)
  match @ir.hot_node_exact_instr(mul_func, mul_root) {
    Some(@lib.Instruction::RefI31) => ()
    _ => fail("expected identical pure ref.i31 mul arms to fold to ref.i31")
  }

  let and_func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32) (result (ref i31)) (select (ref.i31 (i32.and (local.get 0) (i32.const 7))) (ref.i31 (i32.and (local.get 0) (i32.const 7))) (local.get 1))))",
  )
