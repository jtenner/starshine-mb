}

///|
test "optimize-instructions folds select with identical pure v128 splat arms" {
  // Red-first OI-F parity slice: Binaryen `version_130`
  // `--optimize-instructions` folds direct identical SIMD splat select arms when
  // both arms use the same splat instruction over the same local and the
  // condition is side-effect-free
  // (`.tmp/oi-select-identical-v128-splat-arms-probe.wat`). This deliberately
  // stays at exact same-lane splat/local shells, not SIMD algebraic equality,
  // lane-equivalent spellings, or arbitrary structural expression equality.
  let func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32) (result v128) (select (i8x16.splat (local.get 0)) (i8x16.splat (local.get 0)) (local.get 1))))",
  )
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_exact_instr(func, root) {
    Some(instr) if instr == @lib.Instruction::i8x16_splat() => ()
    _ => fail("expected identical pure v128 splat select arms to fold")
  }
}

///|
test "optimize-instructions preserves effectful condition when folding identical ref.i31 select arms" {
  // Red-first OI-F parity slice: Binaryen `version_130`
  // `--optimize-instructions` folds identical direct `ref.i31` select arms
  // even when the condition is effectful, preserving that condition as a
  // dropped prefix
  // (`.tmp/oi-select-identical-refi31-effectful-condition-probe.wat`). This
  // deliberately stays at nontrapping `ref.i31` shells whose i32 payloads are
  // local or already-covered nontrapping local/constant, local/local, and unary forms; do not
  // extend to arbitrary reference expression equality or trapping payloads
  // without fresh oracle evidence.
  let local_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result (ref i31)) (select (ref.i31 (local.get 0)) (ref.i31 (local.get 0)) (call $effect))) (func $effect (result i32) (i32.const 1)))",
  )
  let local_root = @ir.hot_root_get(local_func, 0)
  match @ir.hot_node_get(local_func, local_root).op {
    @ir.HotOp::Block => ()
    _ =>
      fail(
        "expected identical ref.i31 local select arms to fold while preserving the effectful condition",
      )
  }

  let add_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result (ref i31)) (select (ref.i31 (i32.add (local.get 0) (i32.const 1))) (ref.i31 (i32.add (local.get 0) (i32.const 1))) (call $effect))) (func $effect (result i32) (i32.const 1)))",
  )
  let add_root = @ir.hot_root_get(add_func, 0)
  match @ir.hot_node_get(add_func, add_root).op {
    @ir.HotOp::Block => ()
    _ =>
      fail(
        "expected identical ref.i31 add select arms to fold while preserving the effectful condition",
      )
  }

  let local_local_add_func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32) (result (ref i31)) (select (ref.i31 (i32.add (local.get 0) (local.get 1))) (ref.i31 (i32.add (local.get 0) (local.get 1))) (call $effect))) (func $effect (result i32) (i32.const 1)))",
  )
  let local_local_add_root = @ir.hot_root_get(local_local_add_func, 0)
  match @ir.hot_node_get(local_local_add_func, local_local_add_root).op {
    @ir.HotOp::Block => ()
    _ =>
      fail(
        "expected identical ref.i31 local-local add select arms to fold while preserving the effectful condition",
      )
  }
}

