  }
  @debug.assert_eq(
    @ir.hot_const_get(i32_func, @ir.hot_node_get(i32_func, i32_root).imm0),
    @ir.HotConstPayload::i32_const(@lib.I32(0)),
  )

  let i64_func = optimize_instructions_test_run_hot(
    "(module (func (param i64) (result i32) local.get 0 i64.const 1023 i64.and i64.const 4 i64.shr_u i64.const 64 i64.eq))",
  )
  let i64_root = @ir.hot_root_get(i64_func, 0)
  match @ir.hot_node_get(i64_func, i64_root).op {
    @ir.HotOp::Const => ()
    _ => fail("expected nested i64 and/shr_u maxBits eq to fold to a const")
  }
  @debug.assert_eq(
    @ir.hot_const_get(i64_func, @ir.hot_node_get(i64_func, i64_root).imm0),
    @ir.HotConstPayload::i32_const(@lib.I32(0)),
  )

  let source =
    #|(module
    #|  (func $test (result i32)
    #|    call $effect
    #|    i32.const 1023
    #|    i32.and
    #|    i32.const 4
    #|    i32.shr_u
    #|    i32.const 64
    #|    i32.eq)
    #|  (func $effect (result i32) i32.const 7))
    #|
  let effect_func = optimize_instructions_test_run_hot(source)
  let root = @ir.hot_root_get(effect_func, 0)
  match @ir.hot_node_get(effect_func, root).op {
    @ir.HotOp::Block => ()
    _ => fail("expected recursive maxBits compare to become drop+const block")
  }
  let body = @ir.hot_region_body_ref(effect_func, root)
  @debug.assert_eq(@ir.hot_region_root_count(effect_func, body), 2)
  let dropped = @ir.hot_region_get(effect_func, body, 0)
  match @ir.hot_node_get(effect_func, dropped).op {
    @ir.HotOp::Drop => ()
    _ => fail("expected recursive maxBits fold to preserve lhs with a drop")
  }
  let shifted = @ir.hot_child_get(effect_func, dropped, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(effect_func, shifted),
    Some(@lib.Instruction::i32_shr_u()),
  )
  let masked = @ir.hot_child_get(effect_func, shifted, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(effect_func, masked),
    Some(@lib.Instruction::i32_and()),
  )
  let result = @ir.hot_region_get(effect_func, body, 1)
  match @ir.hot_node_get(effect_func, result).op {
    @ir.HotOp::Const => ()
    _ => fail("expected recursive maxBits folded result to be const")
  }
  @debug.assert_eq(
    @ir.hot_const_get(effect_func, @ir.hot_node_get(effect_func, result).imm0),
    @ir.HotConstPayload::i32_const(@lib.I32(0)),
  )
}

///|
test "optimize-instructions replaces zero maxBits expressions with zero" {
  // Red-first OI-D fact slice: Binaryen v130 calls `replaceZeroBitsWithZero`
  // after unary/binary OI and replaces non-constant integer expressions whose
  // `Bits::getMaxBits` is zero with a typed zero. The Starshine fact starts with
  // the pure recursive maxBits subset: bounded `and` followed by a right shift
  // that removes every remaining possible bit.
  let i32_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) local.get 0 i32.const 1 i32.and i32.const 1 i32.shr_u))",
  )
  let i32_root = @ir.hot_root_get(i32_func, 0)
  match @ir.hot_node_get(i32_func, i32_root).op {
    @ir.HotOp::Const => ()
    _ => fail("expected zero-bit i32 expression to become const zero")
  }
  @debug.assert_eq(
    @ir.hot_const_get(i32_func, @ir.hot_node_get(i32_func, i32_root).imm0),
    @ir.HotConstPayload::i32_const(@lib.I32(0)),
  )

  let i64_func = optimize_instructions_test_run_hot(
    "(module (func (param i64) (result i64) local.get 0 i64.const 1 i64.and i64.const 1 i64.shr_u))",
  )
  let i64_root = @ir.hot_root_get(i64_func, 0)
  match @ir.hot_node_get(i64_func, i64_root).op {
    @ir.HotOp::Const => ()
    _ => fail("expected zero-bit i64 expression to become const zero")
  }
  @debug.assert_eq(
    @ir.hot_const_get(i64_func, @ir.hot_node_get(i64_func, i64_root).imm0),
    @ir.HotConstPayload::i64_const(@lib.I64(0L)),
  )
}

///|
test "optimize-instructions preserves effects for zero maxBits replacement" {
  // Red-first OI-D fact slice: Binaryen v130 `replaceZeroBitsWithZero`
  // delegates erased children to `getDroppedChildrenAndAppend`. For a
  // non-trapping zero-bit shift with an effectful left child, the effectful
  // child is dropped before the typed zero replacement instead of blocking the
  // rewrite.
  let source =
    #|(module
    #|  (func $test (result i32)
    #|    call $side
    #|    i32.const 1
    #|    i32.and
    #|    i32.const 1
    #|    i32.shr_u)
    #|  (func $side (result i32) i32.const 7))
    #|
  let func = optimize_instructions_test_run_hot(source)
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_get(func, root).op {
    @ir.HotOp::Block => ()
    _ =>
      fail(
        "expected non-pure zero maxBits expression to become drop+const block",
      )
  }
  let body = @ir.hot_region_body_ref(func, root)
  @debug.assert_eq(@ir.hot_region_root_count(func, body), 2)
  let dropped = @ir.hot_region_get(func, body, 0)
  match @ir.hot_node_get(func, dropped).op {
    @ir.HotOp::Drop => ()
    _ =>
      fail(
        "expected zero maxBits rewrite to preserve effectful child with drop",
      )
  }
  @debug.assert_eq(
    @ir.hot_node_exact_instr(func, @ir.hot_child_get(func, dropped, 0)),
    Some(@lib.Instruction::i32_and()),
  )
  let result = @ir.hot_region_get(func, body, 1)
  @debug.assert_eq(
    @ir.hot_const_get(func, @ir.hot_node_get(func, result).imm0),
    @ir.HotConstPayload::i32_const(@lib.I32(0)),
  )
}

///|
test "optimize-instructions replaces boolean maxBits shifts with zero" {
  // Red-first OI-D fact slice: Binaryen v130 `Bits::getMaxBits` proves `eqz`
  // and compare results are i32 booleans (maxBits == 1). A one-bit unsigned
  // right shift therefore has maxBits zero and feeds `replaceZeroBitsWithZero`.
  let eqz_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) local.get 0 i32.eqz i32.const 1 i32.shr_u))",
  )
  let eqz_root = @ir.hot_root_get(eqz_func, 0)
  match @ir.hot_node_get(eqz_func, eqz_root).op {
    @ir.HotOp::Const => ()
    _ => fail("expected shifted i32.eqz boolean maxBits to become const zero")
  }
  @debug.assert_eq(
    @ir.hot_const_get(eqz_func, @ir.hot_node_get(eqz_func, eqz_root).imm0),
    @ir.HotConstPayload::i32_const(@lib.I32(0)),
  )

  let compare_func = optimize_instructions_test_run_hot(
    "(module (func (param i64) (result i32) local.get 0 local.get 0 i64.eq i32.const 1 i32.shr_u))",
  )
  let compare_root = @ir.hot_root_get(compare_func, 0)
  match @ir.hot_node_get(compare_func, compare_root).op {
    @ir.HotOp::Const => ()
    _ => fail("expected shifted compare boolean maxBits to become const zero")
  }
  @debug.assert_eq(
    @ir.hot_const_get(
      compare_func,
      @ir.hot_node_get(compare_func, compare_root).imm0,
    ),
    @ir.HotConstPayload::i32_const(@lib.I32(0)),
  )
}

///|
test "optimize-instructions rewrites boolean maxBits binary consumers" {
  // Red-first OI-D fact slice: Binaryen v130 uses `Bits::getMaxBits(left) == 1`
  // in `visitBinary` to erase boolean comparisons and boolean `or 1` / `xor 1`
  // shells. Keep this as a consumer of `OiUnsignedMaxValueFact`, not a direct
  // compare/eqz whitelist in the binary visitor.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (func (param $x i32) (result i32)
        #|    local.get $x
        #|    i32.eqz
        #|    i32.const 1
        #|    i32.eq)
        #|  (func (param $x i32) (result i32)
        #|    local.get $x
        #|    i32.eqz
        #|    i32.const 0
        #|    i32.ne)
        #|  (func (param $x i32) (result i32)
        #|    local.get $x
        #|    i32.eqz
        #|    i32.const 1
        #|    i32.or)
        #|  (func (param $x i32) (result i32)
        #|    local.get $x
        #|    i32.eqz
        #|    i32.const 1
        #|    i32.xor))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected boolean maxBits binary optimize success, got \{err}")
  }
  let eq_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_true(eq_pretty.contains("i32.eqz"), msg=eq_pretty)
  assert_false(eq_pretty.contains("i32.eq\n"), msg=eq_pretty)
  let ne_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_true(ne_pretty.contains("i32.eqz"), msg=ne_pretty)
  assert_false(ne_pretty.contains("i32.ne"), msg=ne_pretty)
  let or_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_true(or_pretty.contains("I32(1)"), msg=or_pretty)
  assert_false(or_pretty.contains("i32.or"), msg=or_pretty)
  let xor_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(3U))
  assert_true(xor_pretty.contains("i32.ne"), msg=xor_pretty)
  assert_false(xor_pretty.contains("i32.xor"), msg=xor_pretty)
}

///|
test "optimize-instructions preserves effects for boolean maxBits or-one" {
  // Red-first OI-D fact slice: Binaryen v130 rewrites one-bit `x | 1` to a
  // typed constant one, but preserves an effectful boolean child with
  // `getDroppedChildrenAndAppend`. This covers both i32 and i64 result types.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (func $side32 (result i32) i32.const 7)
        #|  (func $side64 (result i64) i64.const 7)
        #|  (func (result i32)
        #|    call $side32
        #|    i32.eqz
        #|    i32.const 1
        #|    i32.or)
        #|  (func (result i64)
        #|    call $side64
        #|    i64.const 1
        #|    i64.and
        #|    i64.const 1
        #|    i64.or))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected effectful boolean or-one optimize success, got \{err}")
  }
  let i32_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_true(i32_pretty.contains("drop"), msg=i32_pretty)
  assert_true(i32_pretty.contains("i32.eqz"), msg=i32_pretty)
  assert_true(i32_pretty.contains("I32(1)"), msg=i32_pretty)
  assert_false(i32_pretty.contains("i32.or"), msg=i32_pretty)
  let i64_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(3U))
  assert_true(i64_pretty.contains("drop"), msg=i64_pretty)
  assert_true(i64_pretty.contains("i64.and"), msg=i64_pretty)
  assert_true(i64_pretty.contains("I64(1)"), msg=i64_pretty)
  assert_false(i64_pretty.contains("i64.or"), msg=i64_pretty)
}

///|
test "optimize-instructions rewrites i64 boolean maxBits binary consumers" {
  // Red-first OI-D fact slice: Binaryen v130 applies the same
  // `Bits::getMaxBits(left) == 1` binary-consumer family to i64 boolean values,
  // wrapping i64 boolean results back to i32 for compare shells and extending the
  // xor inversion back to i64.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (func (param $x i64) (result i32)
        #|    local.get $x
        #|    i64.const 1
        #|    i64.and
        #|    i64.const 1
        #|    i64.eq)
        #|  (func (param $x i64) (result i32)
        #|    local.get $x
        #|    i64.const 1
        #|    i64.and
        #|    i64.const 0
        #|    i64.ne)
        #|  (func (param $x i64) (result i64)
        #|    local.get $x
        #|    i64.const 1
        #|    i64.and
        #|    i64.const 1
        #|    i64.or)
        #|  (func (param $x i64) (result i64)
        #|    local.get $x
        #|    i64.const 1
        #|    i64.and
        #|    i64.const 1
        #|    i64.xor))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected i64 boolean maxBits binary optimize success, got \{err}")
  }
  let eq_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_true(eq_pretty.contains("i32.wrap_i64"), msg=eq_pretty)
  assert_false(eq_pretty.contains("i64.eq"), msg=eq_pretty)
  let ne_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_true(ne_pretty.contains("i32.wrap_i64"), msg=ne_pretty)
  assert_false(ne_pretty.contains("i64.ne"), msg=ne_pretty)
  let or_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_true(or_pretty.contains("I64(1)"), msg=or_pretty)
  assert_false(or_pretty.contains("i64.or"), msg=or_pretty)
  let xor_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(3U))
  assert_true(xor_pretty.contains("i64.extend_i32u"), msg=xor_pretty)
  assert_true(xor_pretty.contains("i64.eqz"), msg=xor_pretty)
  assert_false(xor_pretty.contains("i64.xor"), msg=xor_pretty)
}

///|
test "optimize-instructions replaces arithmetic maxBits shifts with zero" {
  // Red-first OI-D fact slice: Binaryen v130 `Bits::getMaxBits` bounds add,
  // multiply, and left shift from their operands. When a following unsigned
  // shift removes every possible result bit, `replaceZeroBitsWithZero` turns
  // the pure expression into a typed zero.
  let i32_add_func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32) (result i32) local.get 0 i32.const 15 i32.and local.get 1 i32.const 15 i32.and i32.add i32.const 5 i32.shr_u))",
  )
  let i32_add_root = @ir.hot_root_get(i32_add_func, 0)
  match @ir.hot_node_get(i32_add_func, i32_add_root).op {
    @ir.HotOp::Const => ()
    _ => fail("expected shifted bounded i32.add maxBits to become const zero")
  }
  @debug.assert_eq(
    @ir.hot_const_get(
      i32_add_func,
      @ir.hot_node_get(i32_add_func, i32_add_root).imm0,
    ),
    @ir.HotConstPayload::i32_const(@lib.I32(0)),
  )

  let i32_shl_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) local.get 0 i32.const 3 i32.and i32.const 2 i32.shl i32.const 4 i32.shr_u))",
  )
  let i32_shl_root = @ir.hot_root_get(i32_shl_func, 0)
  match @ir.hot_node_get(i32_shl_func, i32_shl_root).op {
    @ir.HotOp::Const => ()
    _ => fail("expected shifted bounded i32.shl maxBits to become const zero")
  }
  @debug.assert_eq(
    @ir.hot_const_get(
      i32_shl_func,
      @ir.hot_node_get(i32_shl_func, i32_shl_root).imm0,
    ),
    @ir.HotConstPayload::i32_const(@lib.I32(0)),
  )

  let i64_mul_func = optimize_instructions_test_run_hot(
    "(module (func (param i64 i64) (result i64) local.get 0 i64.const 7 i64.and local.get 1 i64.const 3 i64.and i64.mul i64.const 5 i64.shr_u))",
  )
  let i64_mul_root = @ir.hot_root_get(i64_mul_func, 0)
  match @ir.hot_node_get(i64_mul_func, i64_mul_root).op {
    @ir.HotOp::Const => ()
    _ => fail("expected shifted bounded i64.mul maxBits to become const zero")
  }
  @debug.assert_eq(
    @ir.hot_const_get(
      i64_mul_func,
      @ir.hot_node_get(i64_mul_func, i64_mul_root).imm0,
    ),
    @ir.HotConstPayload::i64_const(@lib.I64(0L)),
  )
}

