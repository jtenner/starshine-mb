            metadata=@lib.TypeMetadata::new(describes=Some(base_type)),
          ),
          @lib.SubType::new(
            false,
            [base_type],
            @lib.CompType::struct_([
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i64()),
                @lib.Mut::const_(),
              ),
            ]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(subtype_descriptor)),
          ),
          @lib.SubType::new(
            false,
            [base_descriptor_type],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(subtype)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([sub_val_type], [
              @lib.ValType::ref_type(base_ref_type),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([func_type]))
    .with_global_sec(
      @lib.GlobalSec::new([
        @lib.Global::new(
          @lib.GlobalType::new(@lib.ValType::i32(), true),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::block(
              @lib.BlockType::val_type(descriptor_val_type),
              @lib.Expr::new([
                @lib.Instruction::i32_const(@lib.I32(1)),
                @lib.Instruction::global_set(@lib.GlobalIdx::new(0U)),
                @lib.Instruction::struct_new_default(base_descriptor_type),
              ]),
            ),
            @lib.Instruction::ref_cast_desc_eq_type(base_ref_type),
          ]),
        ),
      ]),
    )
  let optimized = optimize_instructions_test_run_module(module_)
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_true(pretty.contains("global.set"), msg=pretty)
  assert_true(pretty.contains("unreachable"), msg=pretty)
  assert_false(pretty.contains("ref.cast_desc_eq"), msg=pretty)
}

///|
test "optimize-instructions folds descriptor casts with both effectful exact descriptor miss operands" {
  // OI-J descriptor/effect slice: Binaryen version_130 rewrites the
  // strict-subtype/exact-descriptor miss to `drop(effectful-ref);
  // drop(effectful-descriptor); unreachable` when both operands have
  // straight-line effects. This preserves reference-before-descriptor operand
  // order while still keeping escaping control/EH, multivalue operands,
  // nullable descriptor cases, and TNH/IIT open.
  let base_type = @lib.TypeIdx::new(0U)
  let base_descriptor_type = @lib.TypeIdx::new(1U)
  let subtype = @lib.TypeIdx::new(2U)
  let subtype_descriptor = @lib.TypeIdx::new(3U)
  let func_type = @lib.TypeIdx::new(4U)
  let base_heap = @lib.HeapType::new(base_type)
  let base_ref_type = @lib.RefType::new(false, base_heap)
  let base_descriptor_ref_type = @lib.RefType::new(
    false,
    @lib.HeapType::new(base_descriptor_type),
    exact=true,
  )
  let sub_ref_type = @lib.RefType::new(false, @lib.HeapType::new(subtype))
  let sub_val_type = @lib.ValType::ref_type(sub_ref_type)
  let descriptor_val_type = @lib.ValType::ref_type(base_descriptor_ref_type)
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
            ]),
            metadata=@lib.TypeMetadata::new(
              descriptor=Some(base_descriptor_type),
            ),
          ),
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(base_type)),
          ),
          @lib.SubType::new(
            false,
            [base_type],
            @lib.CompType::struct_([
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i64()),
                @lib.Mut::const_(),
              ),
            ]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(subtype_descriptor)),
          ),
          @lib.SubType::new(
            false,
            [base_descriptor_type],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(subtype)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([sub_val_type], [
              @lib.ValType::ref_type(base_ref_type),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([func_type]))
    .with_global_sec(
      @lib.GlobalSec::new([
        @lib.Global::new(
          @lib.GlobalType::new(@lib.ValType::i32(), true),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
        ),
        @lib.Global::new(
          @lib.GlobalType::new(@lib.ValType::i32(), true),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(sub_val_type),
              @lib.Expr::new([
                @lib.Instruction::i32_const(@lib.I32(1)),
                @lib.Instruction::global_set(@lib.GlobalIdx::new(0U)),
                @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
              ]),
            ),
            @lib.Instruction::block(
              @lib.BlockType::val_type(descriptor_val_type),
              @lib.Expr::new([
                @lib.Instruction::i32_const(@lib.I32(2)),
                @lib.Instruction::global_set(@lib.GlobalIdx::new(1U)),
                @lib.Instruction::struct_new_default(base_descriptor_type),
              ]),
            ),
            @lib.Instruction::ref_cast_desc_eq_type(base_ref_type),
          ]),
        ),
      ]),
    )
  let optimized = optimize_instructions_test_run_module(module_)
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_true(pretty.contains("global.set"), msg=pretty)
  assert_true(pretty.contains("Global 0"), msg=pretty)
  assert_true(pretty.contains("Global 1"), msg=pretty)
  assert_true(pretty.contains("unreachable"), msg=pretty)
  assert_false(pretty.contains("ref.cast_desc_eq"), msg=pretty)
}

///|
test "optimize-instructions folds descriptor casts with call-produced exact descriptor miss refs" {
  // OI-J descriptor/effect slice: Binaryen version_130 rewrites the
  // strict-subtype/exact-descriptor miss to `drop(call-produced-ref);
  // unreachable` when the reference operand is a direct call with side effects.
  // This keeps the call's global write and possible traps before the descriptor
  // cast trap, while leaving indirect/call_ref/control/EH/multivalue and
  // effectful descriptor call operands for separate evidence-backed slices.
  let base_type = @lib.TypeIdx::new(0U)
  let base_descriptor_type = @lib.TypeIdx::new(1U)
  let subtype = @lib.TypeIdx::new(2U)
  let subtype_descriptor = @lib.TypeIdx::new(3U)
  let make_func_type = @lib.TypeIdx::new(4U)
  let cast_func_type = @lib.TypeIdx::new(5U)
  let base_heap = @lib.HeapType::new(base_type)
  let base_ref_type = @lib.RefType::new(false, base_heap)
  let sub_ref_type = @lib.RefType::new(false, @lib.HeapType::new(subtype))
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
            ]),
            metadata=@lib.TypeMetadata::new(
              descriptor=Some(base_descriptor_type),
            ),
          ),
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(base_type)),
          ),
          @lib.SubType::new(
            false,
            [base_type],
            @lib.CompType::struct_([
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i64()),
                @lib.Mut::const_(),
              ),
            ]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(subtype_descriptor)),
          ),
          @lib.SubType::new(
            false,
            [base_descriptor_type],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(subtype)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::ref_type(sub_ref_type)]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::ref_type(base_ref_type)]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([make_func_type, cast_func_type]))
    .with_global_sec(
      @lib.GlobalSec::new([
        @lib.Global::new(
          @lib.GlobalType::new(@lib.ValType::i32(), true),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::global_set(@lib.GlobalIdx::new(0U)),
            @lib.Instruction::struct_new_default(subtype_descriptor),
            @lib.Instruction::struct_new_default_desc(subtype),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::struct_new_default(base_descriptor_type),
            @lib.Instruction::ref_cast_desc_eq_type(base_ref_type),
          ]),
        ),
      ]),
    )
  let optimized = optimize_instructions_test_run_module(module_)
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_true(pretty.contains("call"), msg=pretty)
  assert_true(pretty.contains("unreachable"), msg=pretty)
  assert_false(pretty.contains("ref.cast_desc_eq"), msg=pretty)
}

///|
fn optimize_instructions_test_descriptor_call_operand_miss_module(
  desc_arg_count : Int,
  const_call_args? : Bool = false,
  i64_const_call_args? : Bool = false,
  global_call_args? : Bool = false,
  effectful_block_call_args? : Bool = false,
  direct_call_args? : Bool = false,
  parameterized_direct_call_args? : Bool = false,
  reference_direct_call_args? : Bool = false,
  parameterized_reference_direct_call_args? : Bool = false,
  local_tee_call_args? : Bool = false,
  trapping_scalar_call_args? : Bool = false,
  select_call_args? : Bool = false,
) -> @lib.Module {
  let base_type = @lib.TypeIdx::new(0U)
  let base_descriptor_type = @lib.TypeIdx::new(1U)
  let subtype = @lib.TypeIdx::new(2U)
  let subtype_descriptor = @lib.TypeIdx::new(3U)
  let make_desc_func_type = @lib.TypeIdx::new(4U)
  let cast_func_type = @lib.TypeIdx::new(5U)
  let direct_arg_func_type = @lib.TypeIdx::new(6U)
  let base_heap = @lib.HeapType::new(base_type)
  let base_ref_type = @lib.RefType::new(false, base_heap)
  let base_descriptor_ref_type = @lib.RefType::new(
    false,
    @lib.HeapType::new(base_descriptor_type),
    exact=true,
  )
  let sub_ref_type = @lib.RefType::new(false, @lib.HeapType::new(subtype))
  let desc_body = if i64_const_call_args ||
    reference_direct_call_args ||
    parameterized_reference_direct_call_args ||
    desc_arg_count == 0 {
    [
      @lib.Instruction::i32_const(@lib.I32(17)),
      @lib.Instruction::global_set(@lib.GlobalIdx::new(0U)),
    ]
  } else {
    optimize_instructions_test_local_sum_then_global_set(
      desc_arg_count,
      @lib.GlobalIdx::new(0U),
    )
  }
  desc_body.push(@lib.Instruction::struct_new_default(base_descriptor_type))
  let cast_params : Array[@lib.ValType] = [@lib.ValType::ref_type(sub_ref_type)]
  if !const_call_args &&
    !i64_const_call_args &&
    !global_call_args &&
    !effectful_block_call_args &&
    !direct_call_args &&
    !parameterized_direct_call_args &&
    !reference_direct_call_args &&
    !parameterized_reference_direct_call_args &&
    !local_tee_call_args &&
    !trapping_scalar_call_args &&
    !select_call_args {
    for arg = 0; arg < desc_arg_count; arg = arg + 1 {
      cast_params.push(@lib.ValType::i32())
    }
  } else if trapping_scalar_call_args {
    cast_params.push(@lib.ValType::i32())
  } else if select_call_args {
    for arg = 0; arg < desc_arg_count * 3; arg = arg + 1 {
      cast_params.push(@lib.ValType::i32())
    }
  }
  let desc_call_params = if i64_const_call_args {
    optimize_instructions_test_i64_params(desc_arg_count)
  } else if reference_direct_call_args ||
    parameterized_reference_direct_call_args {
    let params : Array[@lib.ValType] = []
    for arg = 0; arg < desc_arg_count; arg = arg + 1 {
      ignore(arg)
      params.push(@lib.ValType::ref_type(base_descriptor_ref_type))
    }
    params
  } else {
    optimize_instructions_test_i32_params(desc_arg_count)
  }
  let cast_body : Array[@lib.Instruction] = [
    @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
  ]
  for arg = 0; arg < desc_arg_count; arg = arg + 1 {
    if const_call_args {
      cast_body.push(@lib.Instruction::i32_const(@lib.I32(200 + arg)))
    } else if i64_const_call_args {
      cast_body.push(
        @lib.Instruction::i64_const(@lib.I64((200 + arg).to_int64())),
      )
    } else if global_call_args {
      cast_body.push(
        @lib.Instruction::global_get(@lib.GlobalIdx::new((arg % 2).to_uint())),
      )
    } else if effectful_block_call_args {
      cast_body.push(
        @lib.Instruction::block(
          @lib.BlockType::val_type(@lib.ValType::i32()),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(300 + arg)),
            @lib.Instruction::global_set(@lib.GlobalIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(200 + arg)),
          ]),
        ),
      )
    } else if direct_call_args {
      cast_body.push(
        @lib.Instruction::call(@lib.FuncIdx::new((arg + 2).to_uint())),
      )
    } else if parameterized_direct_call_args {
      cast_body.push(@lib.Instruction::i32_const(@lib.I32(400 + arg)))
      cast_body.push(
        @lib.Instruction::call(@lib.FuncIdx::new((arg + 2).to_uint())),
      )
    } else if reference_direct_call_args {
      cast_body.push(
        @lib.Instruction::call(@lib.FuncIdx::new((arg + 2).to_uint())),
      )
    } else if parameterized_reference_direct_call_args {
      cast_body.push(@lib.Instruction::i32_const(@lib.I32(450 + arg)))
      cast_body.push(
        @lib.Instruction::call(@lib.FuncIdx::new((arg + 2).to_uint())),
      )
    } else if local_tee_call_args {
      cast_body.push(@lib.Instruction::i32_const(@lib.I32(500 + arg)))
      cast_body.push(
        @lib.Instruction::local_tee(@lib.LocalIdx::new((arg + 1).to_uint())),
      )
    } else if trapping_scalar_call_args {
      cast_body.push(@lib.Instruction::i32_const(@lib.I32(600 + arg)))
      cast_body.push(@lib.Instruction::local_get(@lib.LocalIdx::new(1U)))
      cast_body.push(@lib.Instruction::i32_div_s())
    } else if select_call_args {
      let base_local = arg * 3 + 1
      cast_body.push(
        @lib.Instruction::local_get(@lib.LocalIdx::new(base_local.to_uint())),
      )
      cast_body.push(
        @lib.Instruction::local_get(
          @lib.LocalIdx::new((base_local + 1).to_uint()),
        ),
      )
      cast_body.push(
        @lib.Instruction::local_get(
          @lib.LocalIdx::new((base_local + 2).to_uint()),
        ),
      )
      cast_body.push(
        @lib.Instruction::select(types=Some([@lib.ValType::i32()])),
      )
    } else {
      cast_body.push(
        @lib.Instruction::local_get(@lib.LocalIdx::new((arg + 1).to_uint())),
      )
    }
  }
  cast_body.push(@lib.Instruction::call(@lib.FuncIdx::new(0U)))
  cast_body.push(@lib.Instruction::ref_cast_desc_eq_type(base_ref_type))
  let type_sec = @lib.TypeSec::new([
    @lib.RecType::group([
      @lib.SubType::new(
        false,
        [],
        @lib.CompType::struct_([
          @lib.FieldType::new(
            @lib.StorageType::val_type(@lib.ValType::i32()),
            @lib.Mut::const_(),
          ),
        ]),
        metadata=@lib.TypeMetadata::new(descriptor=Some(base_descriptor_type)),
      ),
      @lib.SubType::new(
        false,
        [],
        @lib.CompType::struct_([]),
        metadata=@lib.TypeMetadata::new(describes=Some(base_type)),
      ),
      @lib.SubType::new(
        false,
        [base_type],
        @lib.CompType::struct_([
          @lib.FieldType::new(
            @lib.StorageType::val_type(@lib.ValType::i32()),
            @lib.Mut::const_(),
          ),
          @lib.FieldType::new(
            @lib.StorageType::val_type(@lib.ValType::i64()),
            @lib.Mut::const_(),
          ),
        ]),
        metadata=@lib.TypeMetadata::new(descriptor=Some(subtype_descriptor)),
      ),
      @lib.SubType::new(
        false,
        [base_descriptor_type],
        @lib.CompType::struct_([]),
        metadata=@lib.TypeMetadata::new(describes=Some(subtype)),
      ),
    ]),
    @lib.RecType::new(
      @lib.SubType::comp_type(
        @lib.CompType::func(desc_call_params, [
          @lib.ValType::ref_type(base_descriptor_ref_type),
        ]),
      ),
    ),
    @lib.RecType::new(
      @lib.SubType::comp_type(
        @lib.CompType::func(cast_params, [@lib.ValType::ref_type(base_ref_type)]),
      ),
    ),
    @lib.RecType::new(
      @lib.SubType::comp_type(
        @lib.CompType::func(
          if parameterized_direct_call_args ||
            parameterized_reference_direct_call_args {
            [@lib.ValType::i32()]
          } else {
            []
          },
          if reference_direct_call_args ||
            parameterized_reference_direct_call_args {
            [@lib.ValType::ref_type(base_descriptor_ref_type)]
          } else {
            [@lib.ValType::i32()]
          },
        ),
      ),
    ),
  ])
  let func_types : Array[@lib.TypeIdx] = [make_desc_func_type, cast_func_type]
  if direct_call_args ||
    parameterized_direct_call_args ||
    reference_direct_call_args ||
    parameterized_reference_direct_call_args {
    for arg = 0; arg < desc_arg_count; arg = arg + 1 {
      ignore(arg)
      func_types.push(direct_arg_func_type)
    }
  }
  let cast_locals = if local_tee_call_args {
    @lib.Locals::single(desc_arg_count.to_uint(), @lib.ValType::i32())
  } else {
    @lib.Locals::empty()
  }
  let code_funcs : Array[@lib.Func] = [
    @lib.Func::new(@lib.Locals::empty(), @lib.Expr::new(desc_body)),
    @lib.Func::new(cast_locals, @lib.Expr::new(cast_body)),
  ]
  if direct_call_args ||
    parameterized_direct_call_args ||
    reference_direct_call_args ||
    parameterized_reference_direct_call_args {
    for arg = 0; arg < desc_arg_count; arg = arg + 1 {
      code_funcs.push(
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new(
            if reference_direct_call_args ||
              parameterized_reference_direct_call_args {
              [
                if parameterized_reference_direct_call_args {
                  @lib.Instruction::local_get(@lib.LocalIdx::new(0U))
                } else {
                  @lib.Instruction::i32_const(@lib.I32(300 + arg))
                },
                @lib.Instruction::global_set(@lib.GlobalIdx::new(0U)),
                @lib.Instruction::struct_new_default(base_descriptor_type),
              ]
            } else {
              [
                if parameterized_direct_call_args {
                  @lib.Instruction::local_get(@lib.LocalIdx::new(0U))
                } else {
                  @lib.Instruction::i32_const(@lib.I32(300 + arg))
                },
                @lib.Instruction::global_set(@lib.GlobalIdx::new(0U)),
                @lib.Instruction::i32_const(@lib.I32(200 + arg)),
              ]
            },
          ),
        ),
      )
    }
  }
  @lib.Module::new()
  .with_type_sec(type_sec)
  .with_func_sec(@lib.FuncSec::new(func_types))
  .with_global_sec(
    @lib.GlobalSec::new([
      @lib.Global::new(
        @lib.GlobalType::new(@lib.ValType::i32(), true),
        @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
      ),
      @lib.Global::new(
        @lib.GlobalType::new(@lib.ValType::i32(), true),
        @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
      ),
    ]),
  )
  .with_code_sec(@lib.CodeSec::new(code_funcs))
}

///|
fn optimize_instructions_test_assert_descriptor_call_operand_miss(
  desc_arg_count : Int,
  const_call_args? : Bool = false,
  i64_const_call_args? : Bool = false,
  global_call_args? : Bool = false,
  effectful_block_call_args? : Bool = false,
  direct_call_args? : Bool = false,
  parameterized_direct_call_args? : Bool = false,
  reference_direct_call_args? : Bool = false,
  parameterized_reference_direct_call_args? : Bool = false,
  local_tee_call_args? : Bool = false,
  trapping_scalar_call_args? : Bool = false,
  select_call_args? : Bool = false,
) -> Unit raise {
  let module_ = optimize_instructions_test_descriptor_call_operand_miss_module(
    desc_arg_count,
    const_call_args~,
    i64_const_call_args~,
    global_call_args~,
    effectful_block_call_args~,
    direct_call_args~,
    parameterized_direct_call_args~,
    reference_direct_call_args~,
    parameterized_reference_direct_call_args~,
    local_tee_call_args~,
    trapping_scalar_call_args~,
    select_call_args~,
  )
  let optimized = optimize_instructions_test_run_module(module_)
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_false(pretty.contains("ref.cast_desc_eq"), msg=pretty)
  let expected : Array[@lib.Instruction] = []
  for arg = 0; arg < desc_arg_count; arg = arg + 1 {
    if const_call_args {
      expected.push(@lib.Instruction::i32_const(@lib.I32(200 + arg)))
    } else if i64_const_call_args {
      expected.push(
        @lib.Instruction::i64_const(@lib.I64((200 + arg).to_int64())),
      )
    } else if global_call_args {
      expected.push(
        @lib.Instruction::global_get(@lib.GlobalIdx::new((arg % 2).to_uint())),
      )
    } else if effectful_block_call_args {
      expected.push(
        @lib.Instruction::block(
          @lib.BlockType::val_type(@lib.ValType::i32()),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(300 + arg)),
            @lib.Instruction::global_set(@lib.GlobalIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(200 + arg)),
          ]),
        ),
      )
    } else if direct_call_args {
      expected.push(
        @lib.Instruction::call(@lib.FuncIdx::new((arg + 2).to_uint())),
      )
    } else if parameterized_direct_call_args {
      expected.push(@lib.Instruction::i32_const(@lib.I32(400 + arg)))
      expected.push(
        @lib.Instruction::call(@lib.FuncIdx::new((arg + 2).to_uint())),
      )
    } else if reference_direct_call_args {
      expected.push(
        @lib.Instruction::call(@lib.FuncIdx::new((arg + 2).to_uint())),
      )
    } else if parameterized_reference_direct_call_args {
      expected.push(@lib.Instruction::i32_const(@lib.I32(450 + arg)))
      expected.push(
        @lib.Instruction::call(@lib.FuncIdx::new((arg + 2).to_uint())),
      )
    } else if local_tee_call_args {
      expected.push(@lib.Instruction::i32_const(@lib.I32(500 + arg)))
      expected.push(
        @lib.Instruction::local_tee(@lib.LocalIdx::new((arg + 1).to_uint())),
      )
    } else if trapping_scalar_call_args {
      expected.push(@lib.Instruction::i32_const(@lib.I32(600 + arg)))
      expected.push(@lib.Instruction::local_get(@lib.LocalIdx::new(1U)))
      expected.push(@lib.Instruction::i32_div_s())
    } else if select_call_args {
      let base_local = arg * 3 + 1
      expected.push(
        @lib.Instruction::local_get(@lib.LocalIdx::new(base_local.to_uint())),
      )
      expected.push(
        @lib.Instruction::local_get(
          @lib.LocalIdx::new((base_local + 1).to_uint()),
        ),
      )
      expected.push(
        @lib.Instruction::local_get(
          @lib.LocalIdx::new((base_local + 2).to_uint()),
        ),
      )
      expected.push(@lib.Instruction::select(types=Some([@lib.ValType::i32()])))
    } else {
      expected.push(
        @lib.Instruction::local_get(@lib.LocalIdx::new((arg + 1).to_uint())),
      )
    }
  }
  expected.push(@lib.Instruction::call(@lib.FuncIdx::new(0U)))
  expected.push(@lib.Instruction::drop())
  expected.push(@lib.Instruction::unreachable_())
  match optimized.code_sec {
    Some(@lib.CodeSec(funcs)) if funcs.length() >= 2 =>
      match funcs[1] {
        @lib.Func(_, @lib.Expr(body)) => @debug.assert_eq(body, expected)
      }
    _ => fail("expected descriptor-call operand miss module with cast function")
  }
}

///|
test "optimize-instructions folds descriptor casts with call-produced exact descriptor operands" {
  // OI-J descriptor/effect slice: Binaryen version_130 rewrites the
  // strict-subtype/exact-descriptor miss to `drop(call-produced-descriptor);
  // unreachable` when the reference operand is pure and the descriptor operand
  // is a direct call with side effects. This preserves the descriptor call after
  // the pure reference operand and before the descriptor-cast trap, while
  // leaving indirect/call_ref/control/EH/multivalue and both-call operand
  // combinations for separate evidence-backed slices.
  optimize_instructions_test_assert_descriptor_call_operand_miss(0)
}

///|
test "optimize-instructions folds descriptor operand call misses with local arguments" {
  // Same semantic miss family for a strict-subtype pure reference operand plus
  // ordered pure local.get descriptor-call arguments. The local reference is
  // erased as pure; descriptor arguments and the effectful direct descriptor
  // call stay before unreachable.
  optimize_instructions_test_assert_descriptor_call_operand_miss(3)
}

///|
test "optimize-instructions folds descriptor operand call misses with i64 constant arguments" {
  // Same descriptor-operand miss family for ordered nontrapping i64 constants.
  // This covers scalar constants without treating exact-success skipping or
  // both-call descriptor misses as the same semantic shape.
  optimize_instructions_test_assert_descriptor_call_operand_miss(
    3,
    i64_const_call_args=true,
  )
}

///|
test "optimize-instructions folds descriptor operand call misses with global arguments" {
  // Same descriptor-operand miss family for ordered global.get arguments. The
  // globals are read before the descriptor call, then the call result is dropped
  // before the known-failing descriptor equality cast becomes unreachable.
  optimize_instructions_test_assert_descriptor_call_operand_miss(
    3,
    global_call_args=true,
  )
}

///|
test "optimize-instructions folds descriptor operand call misses with effectful block arguments" {
  // Same descriptor-operand miss family for a pure strict-subtype reference
  // operand plus ordered branch-free effectful descriptor-call argument blocks.
  // The argument blocks remain call arguments, preserving their effects/traps
  // before the direct descriptor call result is dropped and the cast becomes
  // unreachable. This does not widen exact-success skipping or both-direct-call
  // descriptor miss scanning.
  optimize_instructions_test_assert_descriptor_call_operand_miss(
    2,
    effectful_block_call_args=true,
  )
}

///|
test "optimize-instructions folds descriptor operand call misses with direct call arguments" {
  // Same pure-reference/direct-descriptor-call descriptor-miss family for
  // ordered no-parameter direct descriptor-call arguments. Binaryen preserves
  // the argument calls in source order before dropping the exact descriptor call
  // result and replacing the impossible descriptor equality cast with
  // unreachable. This does not claim indirect, call_ref, return_call*,
  // multivalue, control, EH, exact-success, or both-direct-call breadth.
  optimize_instructions_test_assert_descriptor_call_operand_miss(
    2,
    direct_call_args=true,
  )
}

///|
test "optimize-instructions folds descriptor operand call misses with parameterized direct call arguments" {
  // Same pure-reference/direct-descriptor-call descriptor-miss family for
  // ordered parameterized direct descriptor-call arguments whose own operands
  // are nontrapping constants. Binaryen preserves each argument operand before
  // its direct call, then drops the exact descriptor call result before the
  // impossible cast becomes unreachable. This does not claim reference-result,
  // indirect, call_ref, return_call*, multivalue, control, EH, TNH/IIT,
  // exact-success, or both-direct-call breadth.
  optimize_instructions_test_assert_descriptor_call_operand_miss(
    2,
    parameterized_direct_call_args=true,
  )
}

///|
test "optimize-instructions folds descriptor operand call misses with reference-result direct call arguments" {
  // Same pure-reference/direct-descriptor-call descriptor-miss family for
  // descriptor-call arguments produced by ordered no-parameter direct calls
  // returning non-null references. Binaryen preserves each direct call before
  // dropping the exact descriptor result and replacing the impossible descriptor
  // equality cast with unreachable. This does not claim indirect, call_ref,
  // return_call*, multivalue, control, EH, TNH/IIT, exact-success, or both-call
  // descriptor miss breadth.
  optimize_instructions_test_assert_descriptor_call_operand_miss(
    2,
    reference_direct_call_args=true,
  )
}

///|
test "optimize-instructions folds descriptor operand call misses with parameterized reference-result direct call arguments" {
  // Same pure-reference/direct-descriptor-call descriptor-miss family for
  // reference-result direct descriptor-call arguments whose operands are
  // nontrapping scalar leaves. The scalar operands and direct reference calls
  // stay in source order before the exact descriptor call result is dropped.
  // This keeps nested call/control operands, indirect/call_ref/return_call*,
  // multivalue, control/EH, TNH/IIT, exact-success, and both-call descriptor
  // miss breadth separate.
  optimize_instructions_test_assert_descriptor_call_operand_miss(
    2,
    parameterized_reference_direct_call_args=true,
  )
}

///|
test "optimize-instructions folds descriptor operand call misses with local.tee arguments" {
  // Same pure-reference/direct-descriptor-call descriptor-miss family for
  // ordered local.tee descriptor-call arguments. The tee's scalar producer and
  // local write stay in source order before the descriptor call result is
  // dropped and the impossible cast becomes unreachable. This covers local
  // state-preserving value arguments without widening exact-success,
  // both-direct-call, nested-control, EH, multivalue, or TNH/IIT behavior.
  optimize_instructions_test_assert_descriptor_call_operand_miss(
    2,
    local_tee_call_args=true,
  )
}

///|
test "optimize-instructions folds descriptor operand call misses with trapping scalar arguments" {
  // Same pure-reference/direct-descriptor-call descriptor-miss family for
  // ordered value-typed scalar expressions that may trap. Binaryen preserves
  // each expression in source order as a descriptor-call argument, then drops the
  // exact descriptor result and replaces the impossible descriptor equality cast
  // with unreachable. This does not claim nested call/control, EH, multivalue,
  // TNH/IIT, exact-success, or both-direct-call breadth.
  optimize_instructions_test_assert_descriptor_call_operand_miss(
    2,
    trapping_scalar_call_args=true,
  )
}

///|
test "optimize-instructions folds descriptor operand call misses with pure select arguments" {
  // Same pure-reference/direct-descriptor-call descriptor-miss family for
  // ordered side-effect-free select expressions. Binaryen preserves each
  // select's local leaves in source order as descriptor-call arguments, drops
  // the exact descriptor result, and replaces the impossible descriptor equality
  // cast with unreachable. This does not claim nested control/EH, multivalue,
  // TNH/IIT, exact-success, or both-direct-call descriptor breadth.
  optimize_instructions_test_assert_descriptor_call_operand_miss(
    2,
    select_call_args=true,
  )
}

///|
test "optimize-instructions folds descriptor casts with call_ref exact descriptor producers" {
  // OI-J descriptor-producer family: Binaryen version_130 folds an exact
  // descriptor miss when the descriptor operand is produced by `ref.func` plus
  // `call_ref`, directizing the descriptor call before dropping it and replacing
  // the impossible descriptor equality cast with `unreachable`. This keeps the
  // family semantic (call_ref descriptor producers) rather than adding arity or
  // probe-label exceptions, and it does not claim return_call_ref, indirect
  // calls, multivalue, control/EH, TNH/IIT, exact-success, or exactification
  // breadth.
  let base_type = @lib.TypeIdx::new(0U)
  let base_descriptor_type = @lib.TypeIdx::new(1U)
  let subtype = @lib.TypeIdx::new(2U)
  let subtype_descriptor = @lib.TypeIdx::new(3U)
  let make_desc_func_type = @lib.TypeIdx::new(4U)
  let make_ref_func_type = @lib.TypeIdx::new(5U)
  let cast_pure_func_type = @lib.TypeIdx::new(6U)
  let cast_both_func_type = @lib.TypeIdx::new(7U)
  let base_heap = @lib.HeapType::new(base_type)
  let subtype_heap = @lib.HeapType::new(subtype)
  let base_ref_type = @lib.RefType::new(false, base_heap)
  let subtype_ref_type = @lib.RefType::new(false, subtype_heap)
  let exact_base_descriptor_ref_type = @lib.RefType::new(
    false,
    @lib.HeapType::new(base_descriptor_type),
    exact=true,
  )
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(
              descriptor=Some(base_descriptor_type),
            ),
          ),
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(base_type)),
          ),
          @lib.SubType::new(
            false,
            [base_type],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(subtype_descriptor)),
          ),
          @lib.SubType::new(
            false,
            [base_descriptor_type],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(subtype)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [
              @lib.ValType::ref_type(exact_base_descriptor_ref_type),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::ref_type(subtype_ref_type)]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::ref_type(subtype_ref_type)], [
              @lib.ValType::ref_type(base_ref_type),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::ref_type(base_ref_type)]),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        make_desc_func_type, make_ref_func_type, cast_pure_func_type, cast_both_func_type,
      ]),
    )
    .with_elem_sec(
      @lib.ElemSec::new([
        @lib.Elem::new(
          @lib.ElemMode::declarative(),
          @lib.ElemKind::funcs([@lib.FuncIdx::new(0U)]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::struct_new_default(base_descriptor_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::struct_new_default(subtype_descriptor),
            @lib.Instruction::struct_new_default_desc(subtype),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_func(@lib.FuncIdx::new(0U)),
            @lib.Instruction::call_ref(make_desc_func_type),
            @lib.Instruction::ref_cast_desc_eq_type(base_ref_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(1U)),
            @lib.Instruction::ref_func(@lib.FuncIdx::new(0U)),
            @lib.Instruction::call_ref(make_desc_func_type),
            @lib.Instruction::ref_cast_desc_eq_type(base_ref_type),
          ]),
        ),
      ]),
    ),
  )
  match optimized.code_sec {
    Some(
      @lib.CodeSec(
        [
          _,
          _,
          @lib.Func(_, @lib.Expr(pure_body)),
          @lib.Func(_, @lib.Expr(both_body)),
        ]
      )
    ) => {
      @debug.assert_eq(pure_body, [
        @lib.Instruction::call(@lib.FuncIdx::new(0U)),
        @lib.Instruction::drop(),
        @lib.Instruction::unreachable_(),
      ])
      @debug.assert_eq(both_body, [
        @lib.Instruction::call(@lib.FuncIdx::new(1U)),
        @lib.Instruction::drop(),
        @lib.Instruction::call(@lib.FuncIdx::new(0U)),
        @lib.Instruction::drop(),
        @lib.Instruction::unreachable_(),
      ])
    }
    _ => fail("expected four-function call_ref descriptor producer module")
  }
}

///|
test "optimize-instructions exactifies descriptor casts with call_ref exact descriptor producers" {
  // OI-J descriptor-producer exactification family: Binaryen version_130
  // directizes a `ref.func` + `call_ref` descriptor producer to the underlying
  // descriptor call before exactifying an inexact same-heap descriptor cast. This
  // is not the exact-success skip family: the residual descriptor equality check
  // stays in source order because the reference result is not already exact.
  // Keep return_call_ref, indirect calls, multivalue, control/EH, TNH/IIT, and
  // descriptor-miss behavior separate from this bounded call_ref producer slice.
  let base_type = @lib.TypeIdx::new(0U)
  let base_descriptor_type = @lib.TypeIdx::new(1U)
  let make_desc_func_type = @lib.TypeIdx::new(2U)
  let make_ref_func_type = @lib.TypeIdx::new(3U)
  let cast_func_type = @lib.TypeIdx::new(4U)
  let base_heap = @lib.HeapType::new(base_type)
  let base_ref_type = @lib.RefType::new(false, base_heap)
  let exact_base_ref_type = @lib.RefType::new(false, base_heap, exact=true)
  let exact_base_descriptor_ref_type = @lib.RefType::new(
    false,
    @lib.HeapType::new(base_descriptor_type),
    exact=true,
  )
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(
              descriptor=Some(base_descriptor_type),
            ),
          ),
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(base_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [
              @lib.ValType::ref_type(exact_base_descriptor_ref_type),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::ref_type(base_ref_type)]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::ref_type(base_ref_type)]),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        make_desc_func_type, make_ref_func_type, cast_func_type,
      ]),
    )
    .with_elem_sec(
      @lib.ElemSec::new([
        @lib.Elem::new(
          @lib.ElemMode::declarative(),
          @lib.ElemKind::funcs([@lib.FuncIdx::new(0U)]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::struct_new_default(base_descriptor_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::struct_new_default_desc(base_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(1U)),
            @lib.Instruction::ref_func(@lib.FuncIdx::new(0U)),
            @lib.Instruction::call_ref(make_desc_func_type),
            @lib.Instruction::ref_cast_desc_eq_type(base_ref_type),
          ]),
        ),
      ]),
    ),
  )
  match optimized.code_sec {
    Some(@lib.CodeSec([_, _, @lib.Func(_, @lib.Expr(body))])) =>
      @debug.assert_eq(body, [
        @lib.Instruction::call(@lib.FuncIdx::new(1U)),
        @lib.Instruction::call(@lib.FuncIdx::new(0U)),
        @lib.Instruction::ref_cast_desc_eq_type(exact_base_ref_type),
      ])
    _ =>
      fail("expected three-function call_ref descriptor exactification module")
  }
}

