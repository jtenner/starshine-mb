///|
test "optimize-instructions keeps exact descriptor successes with call_ref exact descriptor producers" {
  // OI-J call_ref descriptor-producer exact-success boundary: Binaryen
  // version_130 directizes the `ref.func` + `call_ref` descriptor producer to
  // the underlying descriptor call, but keeps the explicit exact descriptor
  // equality cast in default mode. This is deliberately not the pure-local
  // direct-call exact-success skip family and does not claim TNH/IIT,
  // return_call_ref, indirect descriptors, multivalue, or control/EH breadth.
  let base_type = @lib.TypeIdx::new(0U)
  let base_descriptor_type = @lib.TypeIdx::new(1U)
  let make_desc0_func_type = @lib.TypeIdx::new(2U)
  let make_ref0_func_type = @lib.TypeIdx::new(3U)
  let make_desc1_func_type = @lib.TypeIdx::new(4U)
  let make_ref1_func_type = @lib.TypeIdx::new(5U)
  let cast0_func_type = @lib.TypeIdx::new(6U)
  let cast1_func_type = @lib.TypeIdx::new(7U)
  let base_heap = @lib.HeapType::new(base_type)
  let exact_base_ref_type = @lib.RefType::new(false, base_heap, exact=true)
  let exact_base_descriptor_ref_type = @lib.RefType::new(
    false,
    @lib.HeapType::new(base_descriptor_type),
    exact=true,
  )
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(
              descriptor=Some(base_descriptor_type),
            ),
          ),
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(base_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [
              @lib.ValType::ref_type(exact_base_descriptor_ref_type),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [
              @lib.ValType::ref_type(exact_base_ref_type),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::i32()], [
              @lib.ValType::ref_type(exact_base_descriptor_ref_type),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::i32()], [
              @lib.ValType::ref_type(exact_base_ref_type),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [
              @lib.ValType::ref_type(exact_base_ref_type),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::i32(), @lib.ValType::i32()], [
              @lib.ValType::ref_type(exact_base_ref_type),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        make_desc0_func_type, make_ref0_func_type, make_desc1_func_type, make_ref1_func_type,
        cast0_func_type, cast1_func_type,
      ]),
    )
    .with_elem_sec(
      @lib.ElemSec::new([
        @lib.Elem::new(
          @lib.ElemMode::declarative(),
          @lib.ElemKind::funcs([@lib.FuncIdx::new(0U), @lib.FuncIdx::new(2U)]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::struct_new_default(base_descriptor_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::struct_new_default_desc(base_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::struct_new_default(base_descriptor_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::call(@lib.FuncIdx::new(2U)),
            @lib.Instruction::struct_new_default_desc(base_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(1U)),
            @lib.Instruction::ref_func(@lib.FuncIdx::new(0U)),
            @lib.Instruction::call_ref(make_desc0_func_type),
            @lib.Instruction::ref_cast_desc_eq_type(exact_base_ref_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::call(@lib.FuncIdx::new(3U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
            @lib.Instruction::ref_func(@lib.FuncIdx::new(2U)),
            @lib.Instruction::call_ref(make_desc1_func_type),
            @lib.Instruction::ref_cast_desc_eq_type(exact_base_ref_type),
          ]),
        ),
      ]),
    ),
  )
  match optimized.code_sec {
    Some(
      @lib.CodeSec(
        [
          _,
          _,
          _,
          _,
          @lib.Func(_, @lib.Expr(no_arg_body)),
          @lib.Func(_, @lib.Expr(param_body)),
        ]
      )
    ) => {
      @debug.assert_eq(no_arg_body, [
        @lib.Instruction::call(@lib.FuncIdx::new(1U)),
        @lib.Instruction::call(@lib.FuncIdx::new(0U)),
        @lib.Instruction::ref_cast_desc_eq_type(exact_base_ref_type),
      ])
      @debug.assert_eq(param_body, [
        @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
        @lib.Instruction::call(@lib.FuncIdx::new(3U)),
        @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
        @lib.Instruction::call(@lib.FuncIdx::new(2U)),
        @lib.Instruction::ref_cast_desc_eq_type(exact_base_ref_type),
      ])
    }
    _ => fail("expected call_ref exact descriptor-success boundary module")
  }
}

///|
test "optimize-instructions localizes call_ref exact descriptor successes under traps-never-happen" {
  // OI-J call_ref descriptor-producer TNH exact-success family: Binaryen
  // version_130 directizes exact `ref.func` + `call_ref` descriptor producers,
  // skips the exact descriptor equality trap under `--traps-never-happen`, and
  // preserves both direct-call operands in stack order before dropping the
  // descriptor result and returning the saved reference. Binaryen localizes both
  // calls to scratch locals for this probe; Starshine's raw stack form is a
  // smaller equivalent representation for the same operand order. This is
  // distinct from default-mode exact-success behavior, which keeps the explicit
  // `ref.cast_desc_eq`.
  let base_type = @lib.TypeIdx::new(0U)
  let base_descriptor_type = @lib.TypeIdx::new(1U)
  let make_desc0_func_type = @lib.TypeIdx::new(2U)
  let make_ref0_func_type = @lib.TypeIdx::new(3U)
  let make_desc1_func_type = @lib.TypeIdx::new(4U)
  let make_ref1_func_type = @lib.TypeIdx::new(5U)
  let cast0_func_type = @lib.TypeIdx::new(6U)
  let cast1_func_type = @lib.TypeIdx::new(7U)
  let base_heap = @lib.HeapType::new(base_type)
  let exact_base_ref_type = @lib.RefType::new(false, base_heap, exact=true)
  let exact_base_descriptor_ref_type = @lib.RefType::new(
    false,
    @lib.HeapType::new(base_descriptor_type),
    exact=true,
  )
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(
              descriptor=Some(base_descriptor_type),
            ),
          ),
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(base_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [
              @lib.ValType::ref_type(exact_base_descriptor_ref_type),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [
              @lib.ValType::ref_type(exact_base_ref_type),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::i32()], [
              @lib.ValType::ref_type(exact_base_descriptor_ref_type),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::i32()], [
              @lib.ValType::ref_type(exact_base_ref_type),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [
              @lib.ValType::ref_type(exact_base_ref_type),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::i32(), @lib.ValType::i32()], [
              @lib.ValType::ref_type(exact_base_ref_type),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        make_desc0_func_type, make_ref0_func_type, make_desc1_func_type, make_ref1_func_type,
        cast0_func_type, cast1_func_type,
      ]),
    )
    .with_elem_sec(
      @lib.ElemSec::new([
        @lib.Elem::new(
          @lib.ElemMode::declarative(),
          @lib.ElemKind::funcs([@lib.FuncIdx::new(0U), @lib.FuncIdx::new(2U)]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::struct_new_default(base_descriptor_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::struct_new_default_desc(base_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::struct_new_default(base_descriptor_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::call(@lib.FuncIdx::new(2U)),
            @lib.Instruction::struct_new_default_desc(base_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(1U)),
            @lib.Instruction::ref_func(@lib.FuncIdx::new(0U)),
            @lib.Instruction::call_ref(make_desc0_func_type),
            @lib.Instruction::ref_cast_desc_eq_type(exact_base_ref_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::call(@lib.FuncIdx::new(3U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
            @lib.Instruction::ref_func(@lib.FuncIdx::new(2U)),
            @lib.Instruction::call_ref(make_desc1_func_type),
            @lib.Instruction::ref_cast_desc_eq_type(exact_base_ref_type),
          ]),
        ),
      ]),
    )
  match @validate.validate_module(module_) {
    Ok(_) => ()
    Err(err) => abort("unexpected invalid call_ref TNH fixture: \{err}")
  }
  let optimized = match
    run_hot_pipeline(
      module_,
      HotPipelineOptions::new(traps_never_happen=true),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected call_ref descriptor TNH pipeline success, got \{err}")
  }
  match optimized.code_sec {
    Some(
      @lib.CodeSec(
        [
          _,
          _,
          _,
          _,
          @lib.Func(_, @lib.Expr(no_arg_body)),
          @lib.Func(_, @lib.Expr(param_body)),
        ]
      )
    ) => {
      @debug.assert_eq(no_arg_body, [
        @lib.Instruction::call(@lib.FuncIdx::new(1U)),
        @lib.Instruction::call(@lib.FuncIdx::new(0U)),
        @lib.Instruction::drop(),
      ])
      @debug.assert_eq(param_body, [
        @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
        @lib.Instruction::call(@lib.FuncIdx::new(3U)),
        @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
        @lib.Instruction::call(@lib.FuncIdx::new(2U)),
        @lib.Instruction::drop(),
      ])
    }
    _ => fail("expected call_ref TNH exact descriptor-success module")
  }
}

///|
test "optimize-instructions localizes indirect call_ref exact descriptor successes under traps-never-happen" {
  // OI-J typed-table call_ref TNH exact-success family: Binaryen version_130
  // directizes a table-target `call_ref` reference producer to `call_indirect`,
  // keeps the exact descriptor-success cast in default/IIT modes, and removes
  // only the descriptor equality trap under `--traps-never-happen` while still
  // preserving the indirect call and descriptor call in source order. This is
  // limited to a single-result exact typed-table reference producer with
  // nontrapping leaf call/table operands; return_call_ref, descriptor-side
  // indirect producers, multivalue, control/EH, and effectful operands remain
  // separate semantic families.
  let base_type = @lib.TypeIdx::new(0U)
  let base_descriptor_type = @lib.TypeIdx::new(1U)
  let make_ref_type = @lib.TypeIdx::new(2U)
  let make_desc_type = @lib.TypeIdx::new(3U)
  let cast_type = @lib.TypeIdx::new(4U)
  let base_heap = @lib.HeapType::new(base_type)
  let exact_base_ref_type = @lib.RefType::new(false, base_heap, exact=true)
  let exact_base_descriptor_ref_type = @lib.RefType::new(
    false,
    @lib.HeapType::new(base_descriptor_type),
    exact=true,
  )
  let nullable_make_ref_ref_type = @lib.RefType::new(
    true,
    @lib.HeapType::new(make_ref_type),
  )
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(
              descriptor=Some(base_descriptor_type),
            ),
          ),
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(base_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::i32()], [
              @lib.ValType::ref_type(exact_base_ref_type),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [
              @lib.ValType::ref_type(exact_base_descriptor_ref_type),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::i32()], [
              @lib.ValType::ref_type(exact_base_ref_type),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([make_ref_type, make_desc_type, cast_type]),
    )
    .with_table_sec(
      @lib.TableSec::new([
        @lib.Table::new(
          @lib.TableType::new(
            nullable_make_ref_ref_type,
            @lib.Limits::i32(1U, Some(1U)),
          ),
          None,
        ),
      ]),
    )
    .with_elem_sec(
      @lib.ElemSec::new([
        @lib.Elem::new(
          @lib.ElemMode::active(
            @lib.TableIdx::new(0U),
            @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
          ),
          @lib.ElemKind::typed_exprs(nullable_make_ref_ref_type, [
            @lib.Expr::new([@lib.Instruction::ref_func(@lib.FuncIdx::new(0U))]),
          ]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::drop(),
            @lib.Instruction::call(@lib.FuncIdx::new(1U)),
            @lib.Instruction::struct_new_default_desc(base_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::struct_new_default(base_descriptor_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::table_get(@lib.TableIdx::new(0U)),
            @lib.Instruction::call_ref(make_ref_type),
            @lib.Instruction::call(@lib.FuncIdx::new(1U)),
            @lib.Instruction::ref_cast_desc_eq_type(exact_base_ref_type),
          ]),
        ),
      ]),
    )
  match @validate.validate_module(module_) {
    Ok(_) => ()
    Err(err) =>
      abort("unexpected invalid indirect call_ref TNH fixture: \{err}")
  }
  let default_optimized = optimize_instructions_test_run_module(module_)
  match default_optimized.code_sec {
    Some(@lib.CodeSec([_, _, @lib.Func(_, @lib.Expr(default_body))])) =>
      @debug.assert_eq(default_body, [
        @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
        @lib.Instruction::i32_const(@lib.I32(0)),
        @lib.Instruction::call_indirect(make_ref_type, @lib.TableIdx::new(0U)),
        @lib.Instruction::call(@lib.FuncIdx::new(1U)),
        @lib.Instruction::ref_cast_desc_eq_type(exact_base_ref_type),
      ])
    _ =>
      fail("expected indirect call_ref default exact descriptor-success module")
  }
  let iit_optimized = match
    run_hot_pipeline(
      module_,
      HotPipelineOptions::new(ignore_implicit_traps=true),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail(
        "expected indirect call_ref descriptor IIT pipeline success, got \{err}",
      )
  }
  match iit_optimized.code_sec {
    Some(@lib.CodeSec([_, _, @lib.Func(_, @lib.Expr(iit_body))])) =>
      @debug.assert_eq(iit_body, [
        @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
        @lib.Instruction::i32_const(@lib.I32(0)),
        @lib.Instruction::call_indirect(make_ref_type, @lib.TableIdx::new(0U)),
        @lib.Instruction::call(@lib.FuncIdx::new(1U)),
        @lib.Instruction::ref_cast_desc_eq_type(exact_base_ref_type),
      ])
    _ => fail("expected indirect call_ref IIT exact descriptor-success module")
  }
  let tnh_optimized = match
    run_hot_pipeline(
      module_,
      HotPipelineOptions::new(traps_never_happen=true),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail(
        "expected indirect call_ref descriptor TNH pipeline success, got \{err}",
      )
  }
  match tnh_optimized.code_sec {
    Some(@lib.CodeSec([_, _, @lib.Func(_, @lib.Expr(tnh_body))])) =>
      @debug.assert_eq(tnh_body, [
        @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
        @lib.Instruction::i32_const(@lib.I32(0)),
        @lib.Instruction::call_indirect(make_ref_type, @lib.TableIdx::new(0U)),
        @lib.Instruction::call(@lib.FuncIdx::new(1U)),
        @lib.Instruction::drop(),
      ])
    _ => fail("expected indirect call_ref TNH exact descriptor-success module")
  }
}

///|
test "optimize-instructions folds descriptor casts with typed-table call_ref descriptor producers" {
  // OI-J descriptor-side typed-table call_ref producer family: Binaryen
  // version_130 directizes a table-target `call_ref` descriptor producer to
  // `call_indirect` before folding a strict-subtype/exact-descriptor miss to
  // source-order drops plus `unreachable` in default, IIT, and TNH modes. This
  // is deliberately separate from the prior reference-producer TNH exact-success
  // slice: the descriptor operand is indirect here, the cast is a real miss, and
  // exact-success, exactification, return_call_ref, multivalue, control/EH, and
  // broader effectful operands remain separate semantic work.
  let base_type = @lib.TypeIdx::new(0U)
  let base_descriptor_type = @lib.TypeIdx::new(1U)
  let subtype = @lib.TypeIdx::new(2U)
  let subtype_descriptor = @lib.TypeIdx::new(3U)
  let make_desc_type = @lib.TypeIdx::new(4U)
  let make_ref_type = @lib.TypeIdx::new(5U)
  let cast_type = @lib.TypeIdx::new(6U)
  let base_heap = @lib.HeapType::new(base_type)
  let subtype_heap = @lib.HeapType::new(subtype)
  let base_ref_type = @lib.RefType::new(false, base_heap)
  let subtype_ref_type = @lib.RefType::new(false, subtype_heap)
  let exact_base_descriptor_ref_type = @lib.RefType::new(
    false,
    @lib.HeapType::new(base_descriptor_type),
    exact=true,
  )
  let nullable_make_desc_ref_type = @lib.RefType::new(
    true,
    @lib.HeapType::new(make_desc_type),
  )
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(
              descriptor=Some(base_descriptor_type),
            ),
          ),
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(base_type)),
          ),
          @lib.SubType::new(
            false,
            [base_type],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(subtype_descriptor)),
          ),
          @lib.SubType::new(
            false,
            [base_descriptor_type],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(subtype)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::i32()], [
              @lib.ValType::ref_type(exact_base_descriptor_ref_type),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::ref_type(subtype_ref_type)]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::i32()], [
              @lib.ValType::ref_type(base_ref_type),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([make_desc_type, make_ref_type, cast_type]),
    )
    .with_table_sec(
      @lib.TableSec::new([
        @lib.Table::new(
          @lib.TableType::new(
            nullable_make_desc_ref_type,
            @lib.Limits::i32(1U, Some(1U)),
          ),
          None,
        ),
      ]),
    )
    .with_elem_sec(
      @lib.ElemSec::new([
        @lib.Elem::new(
          @lib.ElemMode::active(
            @lib.TableIdx::new(0U),
            @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
          ),
          @lib.ElemKind::typed_exprs(nullable_make_desc_ref_type, [
            @lib.Expr::new([@lib.Instruction::ref_func(@lib.FuncIdx::new(0U))]),
          ]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::drop(),
            @lib.Instruction::struct_new_default(base_descriptor_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::struct_new_default(subtype_descriptor),
            @lib.Instruction::struct_new_default_desc(subtype),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(1U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::table_get(@lib.TableIdx::new(0U)),
            @lib.Instruction::call_ref(make_desc_type),
            @lib.Instruction::ref_cast_desc_eq_type(base_ref_type),
          ]),
        ),
      ]),
    )
  match @validate.validate_module(module_) {
    Ok(_) => ()
    Err(err) =>
      abort(
        "unexpected invalid typed-table call_ref descriptor fixture: \{err}",
      )
  }
  let expected = [
    @lib.Instruction::call(@lib.FuncIdx::new(1U)),
    @lib.Instruction::drop(),
    @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
    @lib.Instruction::i32_const(@lib.I32(0)),
    @lib.Instruction::call_indirect(make_desc_type, @lib.TableIdx::new(0U)),
    @lib.Instruction::drop(),
    @lib.Instruction::unreachable_(),
  ]
  let default_optimized = optimize_instructions_test_run_module(module_)
  match default_optimized.code_sec {
    Some(@lib.CodeSec([_, _, @lib.Func(_, @lib.Expr(default_body))])) =>
      @debug.assert_eq(default_body, expected)
    _ => fail("expected typed-table call_ref descriptor default miss module")
  }
  let iit_optimized = match
    run_hot_pipeline(
      module_,
      HotPipelineOptions::new(ignore_implicit_traps=true),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail(
        "expected typed-table call_ref descriptor IIT pipeline success, got \{err}",
      )
  }
  match iit_optimized.code_sec {
    Some(@lib.CodeSec([_, _, @lib.Func(_, @lib.Expr(iit_body))])) =>
      @debug.assert_eq(iit_body, expected)
    _ => fail("expected typed-table call_ref descriptor IIT miss module")
  }
  let tnh_optimized = match
    run_hot_pipeline(
      module_,
      HotPipelineOptions::new(traps_never_happen=true),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail(
        "expected typed-table call_ref descriptor TNH pipeline success, got \{err}",
      )
  }
  match tnh_optimized.code_sec {
    Some(@lib.CodeSec([_, _, @lib.Func(_, @lib.Expr(tnh_body))])) =>
      @debug.assert_eq(tnh_body, expected)
    _ => fail("expected typed-table call_ref descriptor TNH miss module")
  }
}

///|
test "optimize-instructions localizes typed-table call_ref descriptor successes under traps-never-happen" {
  // OI-J descriptor-side typed-table call_ref exact-success family: Binaryen
  // version_130 directizes the descriptor operand's table-target `call_ref` to
  // `call_indirect`, keeps the exact descriptor equality cast in default/IIT
  // modes, and removes only that descriptor trap under `--traps-never-happen`.
  // This complements the strict-subtype descriptor-miss slice above; descriptor
  // exactification/narrowing, return_call_ref, multivalue, control/EH, and
  // broader effectful operands remain separate semantic work.
  let base_type = @lib.TypeIdx::new(0U)
  let base_descriptor_type = @lib.TypeIdx::new(1U)
  let make_desc_type = @lib.TypeIdx::new(2U)
  let make_ref_type = @lib.TypeIdx::new(3U)
  let cast_type = @lib.TypeIdx::new(4U)
  let base_heap = @lib.HeapType::new(base_type)
  let exact_base_ref_type = @lib.RefType::new(false, base_heap, exact=true)
  let exact_base_descriptor_ref_type = @lib.RefType::new(
    false,
    @lib.HeapType::new(base_descriptor_type),
    exact=true,
  )
  let nullable_make_desc_ref_type = @lib.RefType::new(
    true,
    @lib.HeapType::new(make_desc_type),
  )
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(
              descriptor=Some(base_descriptor_type),
            ),
          ),
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(base_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::i32()], [
              @lib.ValType::ref_type(exact_base_descriptor_ref_type),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [
              @lib.ValType::ref_type(exact_base_ref_type),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::i32()], [
              @lib.ValType::ref_type(exact_base_ref_type),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([make_desc_type, make_ref_type, cast_type]),
    )
    .with_table_sec(
      @lib.TableSec::new([
        @lib.Table::new(
          @lib.TableType::new(
            nullable_make_desc_ref_type,
            @lib.Limits::i32(1U, Some(1U)),
          ),
          None,
        ),
      ]),
    )
    .with_elem_sec(
      @lib.ElemSec::new([
        @lib.Elem::new(
          @lib.ElemMode::active(
            @lib.TableIdx::new(0U),
            @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
          ),
          @lib.ElemKind::typed_exprs(nullable_make_desc_ref_type, [
            @lib.Expr::new([@lib.Instruction::ref_func(@lib.FuncIdx::new(0U))]),
          ]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::drop(),
            @lib.Instruction::struct_new_default(base_descriptor_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::struct_new_default(base_descriptor_type),
            @lib.Instruction::struct_new_default_desc(base_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(1U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::table_get(@lib.TableIdx::new(0U)),
            @lib.Instruction::call_ref(make_desc_type),
            @lib.Instruction::ref_cast_desc_eq_type(exact_base_ref_type),
          ]),
        ),
      ]),
    )
  match @validate.validate_module(module_) {
    Ok(_) => ()
    Err(err) =>
      abort(
        "unexpected invalid typed-table call_ref descriptor success fixture: \{err}",
      )
  }
  let default_expected = [
    @lib.Instruction::call(@lib.FuncIdx::new(1U)),
    @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
    @lib.Instruction::i32_const(@lib.I32(0)),
    @lib.Instruction::call_indirect(make_desc_type, @lib.TableIdx::new(0U)),
    @lib.Instruction::ref_cast_desc_eq_type(exact_base_ref_type),
  ]
  let default_optimized = optimize_instructions_test_run_module(module_)
  match default_optimized.code_sec {
    Some(@lib.CodeSec([_, _, @lib.Func(_, @lib.Expr(default_body))])) =>
      @debug.assert_eq(default_body, default_expected)
    _ => fail("expected typed-table call_ref descriptor default success module")
  }
  let iit_optimized = match
    run_hot_pipeline(
      module_,
      HotPipelineOptions::new(ignore_implicit_traps=true),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail(
        "expected typed-table call_ref descriptor success IIT pipeline success, got \{err}",
      )
  }
  match iit_optimized.code_sec {
    Some(@lib.CodeSec([_, _, @lib.Func(_, @lib.Expr(iit_body))])) =>
      @debug.assert_eq(iit_body, default_expected)
    _ => fail("expected typed-table call_ref descriptor IIT success module")
  }
  let tnh_optimized = match
    run_hot_pipeline(
      module_,
      HotPipelineOptions::new(traps_never_happen=true),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail(
        "expected typed-table call_ref descriptor success TNH pipeline success, got \{err}",
      )
  }
  match tnh_optimized.code_sec {
    Some(@lib.CodeSec([_, _, @lib.Func(_, @lib.Expr(tnh_body))])) =>
      @debug.assert_eq(tnh_body, [
        @lib.Instruction::call(@lib.FuncIdx::new(1U)),
        @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
        @lib.Instruction::i32_const(@lib.I32(0)),
        @lib.Instruction::call_indirect(make_desc_type, @lib.TableIdx::new(0U)),
        @lib.Instruction::drop(),
      ])
    _ => fail("expected typed-table call_ref descriptor TNH success module")
  }
}

///|
test "optimize-instructions folds descriptor casts with both operands call-produced exact descriptor misses" {
  // OI-J descriptor/effect order slice: Binaryen version_130 rewrites the
  // strict-subtype/exact-descriptor miss to `drop(call-produced-ref);
  // drop(call-produced-descriptor); unreachable` when both operands are direct
  // calls. This preserves the original operand order and both calls' side
  // effects before the descriptor-cast trap. It deliberately stays limited to
  // no-parameter direct calls; parameterized calls, indirect/call_ref producers,
  // control/EH/multivalue operands, TNH/IIT, and nullable null-only descriptor
  // casts remain separate fail-closed surfaces.
  let base_type = @lib.TypeIdx::new(0U)
  let base_descriptor_type = @lib.TypeIdx::new(1U)
  let subtype = @lib.TypeIdx::new(2U)
  let subtype_descriptor = @lib.TypeIdx::new(3U)
  let make_ref_func_type = @lib.TypeIdx::new(4U)
  let make_desc_func_type = @lib.TypeIdx::new(5U)
  let cast_func_type = @lib.TypeIdx::new(6U)
  let base_heap = @lib.HeapType::new(base_type)
  let base_ref_type = @lib.RefType::new(false, base_heap)
  let base_descriptor_ref_type = @lib.RefType::new(
    false,
    @lib.HeapType::new(base_descriptor_type),
    exact=true,
  )
  let sub_ref_type = @lib.RefType::new(false, @lib.HeapType::new(subtype))
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
            ]),
            metadata=@lib.TypeMetadata::new(
              descriptor=Some(base_descriptor_type),
            ),
          ),
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(base_type)),
          ),
          @lib.SubType::new(
            false,
            [base_type],
            @lib.CompType::struct_([
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i64()),
                @lib.Mut::const_(),
              ),
            ]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(subtype_descriptor)),
          ),
          @lib.SubType::new(
            false,
            [base_descriptor_type],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(subtype)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::ref_type(sub_ref_type)]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [
              @lib.ValType::ref_type(base_descriptor_ref_type),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::ref_type(base_ref_type)]),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        make_ref_func_type, make_desc_func_type, cast_func_type,
      ]),
    )
    .with_global_sec(
      @lib.GlobalSec::new([
        @lib.Global::new(
          @lib.GlobalType::new(@lib.ValType::i32(), true),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
        ),
        @lib.Global::new(
          @lib.GlobalType::new(@lib.ValType::i32(), true),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::global_set(@lib.GlobalIdx::new(0U)),
            @lib.Instruction::struct_new_default(subtype_descriptor),
            @lib.Instruction::struct_new_default_desc(subtype),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(9)),
            @lib.Instruction::global_set(@lib.GlobalIdx::new(1U)),
            @lib.Instruction::struct_new_default(base_descriptor_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::call(@lib.FuncIdx::new(1U)),
            @lib.Instruction::ref_cast_desc_eq_type(base_ref_type),
          ]),
        ),
      ]),
    )
  let optimized = optimize_instructions_test_run_module(module_)
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_true(pretty.contains("call"), msg=pretty)
  assert_true(pretty.contains("unreachable"), msg=pretty)
  assert_false(pretty.contains("ref.cast_desc_eq"), msg=pretty)
  match optimized.code_sec {
    Some(
      @lib.CodeSec(
        [
          _,
          _,
          @lib.Func(
            _,
            @lib.Expr(
              [
                @lib.Call(ref_func),
                @lib.Drop,
                @lib.Call(desc_func),
                @lib.Drop,
                @lib.Unreachable,
              ]
            )
          ),
        ]
      )
    ) => {
      @debug.assert_eq(ref_func, @lib.FuncIdx::new(0U))
      @debug.assert_eq(desc_func, @lib.FuncIdx::new(1U))
    }
    _ => fail("expected call/ref drop, call/descriptor drop, unreachable")
  }
}

///|
test "optimize-instructions folds descriptor casts with parameterized call exact descriptor misses" {
  // OI-J descriptor/effect order slice: Binaryen version_130 rewrites the
  // strict-subtype/exact-descriptor miss to `drop(call $make_ref(local.get));
  // drop(call $make_desc(local.get)); unreachable` when both direct calls take
  // pure local arguments. This narrows the direct-call surface beyond the
  // no-parameter case while still keeping indirect/call_ref, multivalue,
  // effectful arguments, escaping control/EH, TNH/IIT, and nullable null-only
  // descriptor casts fail-closed.
  let base_type = @lib.TypeIdx::new(0U)
  let base_descriptor_type = @lib.TypeIdx::new(1U)
  let subtype = @lib.TypeIdx::new(2U)
  let subtype_descriptor = @lib.TypeIdx::new(3U)
  let make_ref_func_type = @lib.TypeIdx::new(4U)
  let make_desc_func_type = @lib.TypeIdx::new(5U)
  let cast_func_type = @lib.TypeIdx::new(6U)
  let base_heap = @lib.HeapType::new(base_type)
  let base_ref_type = @lib.RefType::new(false, base_heap)
  let base_descriptor_ref_type = @lib.RefType::new(
    false,
    @lib.HeapType::new(base_descriptor_type),
    exact=true,
  )
  let sub_ref_type = @lib.RefType::new(false, @lib.HeapType::new(subtype))
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
            ]),
            metadata=@lib.TypeMetadata::new(
              descriptor=Some(base_descriptor_type),
            ),
          ),
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(base_type)),
          ),
          @lib.SubType::new(
            false,
            [base_type],
            @lib.CompType::struct_([
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i64()),
                @lib.Mut::const_(),
              ),
            ]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(subtype_descriptor)),
          ),
          @lib.SubType::new(
            false,
            [base_descriptor_type],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(subtype)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::i32()], [
              @lib.ValType::ref_type(sub_ref_type),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::i32()], [
              @lib.ValType::ref_type(base_descriptor_ref_type),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::i32(), @lib.ValType::i32()], [
              @lib.ValType::ref_type(base_ref_type),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        make_ref_func_type, make_desc_func_type, cast_func_type,
      ]),
    )
    .with_global_sec(
      @lib.GlobalSec::new([
        @lib.Global::new(
          @lib.GlobalType::new(@lib.ValType::i32(), true),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
        ),
        @lib.Global::new(
          @lib.GlobalType::new(@lib.ValType::i32(), true),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::global_set(@lib.GlobalIdx::new(0U)),
            @lib.Instruction::struct_new_default(subtype_descriptor),
            @lib.Instruction::struct_new_default_desc(subtype),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::global_set(@lib.GlobalIdx::new(1U)),
            @lib.Instruction::struct_new_default(base_descriptor_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
            @lib.Instruction::call(@lib.FuncIdx::new(1U)),
            @lib.Instruction::ref_cast_desc_eq_type(base_ref_type),
          ]),
        ),
      ]),
    )
  let optimized = optimize_instructions_test_run_module(module_)
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_false(pretty.contains("ref.cast_desc_eq"), msg=pretty)
  match optimized.code_sec {
    Some(
      @lib.CodeSec(
        [
          _,
          _,
          @lib.Func(
            _,
            @lib.Expr(
              [
                @lib.LocalGet(arg0),
                @lib.Call(ref_func),
                @lib.Drop,
                @lib.LocalGet(arg1),
                @lib.Call(desc_func),
                @lib.Drop,
                @lib.Unreachable,
              ]
            )
          ),
        ]
      )
    ) => {
      @debug.assert_eq(arg0, @lib.LocalIdx::new(0U))
      @debug.assert_eq(ref_func, @lib.FuncIdx::new(0U))
      @debug.assert_eq(arg1, @lib.LocalIdx::new(1U))
      @debug.assert_eq(desc_func, @lib.FuncIdx::new(1U))
    }
    _ =>
      fail(
        "expected local.get arg0; call ref; drop; local.get arg1; call desc; drop; unreachable",
      )
  }
}

///|
test "optimize-instructions folds descriptor casts with two-arg call exact descriptor misses" {
  // OI-J descriptor/effect order slice: Binaryen version_130 also folds the
  // exact descriptor miss when both direct calls take exactly two pure local
  // arguments. Keep this narrower than general argument localization: no
  // effectful/trapping arguments, indirect/call_ref, return_call*, multivalue,
  // escaping control/EH, or TNH/IIT widening is implied by this test.
  let base_type = @lib.TypeIdx::new(0U)
  let base_descriptor_type = @lib.TypeIdx::new(1U)
  let subtype = @lib.TypeIdx::new(2U)
  let subtype_descriptor = @lib.TypeIdx::new(3U)
  let make_ref_func_type = @lib.TypeIdx::new(4U)
  let make_desc_func_type = @lib.TypeIdx::new(5U)
  let cast_func_type = @lib.TypeIdx::new(6U)
  let base_heap = @lib.HeapType::new(base_type)
  let base_ref_type = @lib.RefType::new(false, base_heap)
  let base_descriptor_ref_type = @lib.RefType::new(
    false,
    @lib.HeapType::new(base_descriptor_type),
    exact=true,
  )
  let sub_ref_type = @lib.RefType::new(false, @lib.HeapType::new(subtype))
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
            ]),
            metadata=@lib.TypeMetadata::new(
              descriptor=Some(base_descriptor_type),
            ),
          ),
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(base_type)),
          ),
          @lib.SubType::new(
            false,
            [base_type],
            @lib.CompType::struct_([
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i64()),
                @lib.Mut::const_(),
              ),
            ]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(subtype_descriptor)),
          ),
          @lib.SubType::new(
            false,
            [base_descriptor_type],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(subtype)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::i32(), @lib.ValType::i32()], [
              @lib.ValType::ref_type(sub_ref_type),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::i32(), @lib.ValType::i32()], [
              @lib.ValType::ref_type(base_descriptor_ref_type),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func(
              [
                @lib.ValType::i32(),
                @lib.ValType::i32(),
                @lib.ValType::i32(),
                @lib.ValType::i32(),
              ],
              [@lib.ValType::ref_type(base_ref_type)],
            ),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        make_ref_func_type, make_desc_func_type, cast_func_type,
      ]),
    )
    .with_global_sec(
      @lib.GlobalSec::new([
        @lib.Global::new(
          @lib.GlobalType::new(@lib.ValType::i32(), true),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
        ),
        @lib.Global::new(
          @lib.GlobalType::new(@lib.ValType::i32(), true),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
            @lib.Instruction::i32_add(),
            @lib.Instruction::global_set(@lib.GlobalIdx::new(0U)),
            @lib.Instruction::struct_new_default(subtype_descriptor),
            @lib.Instruction::struct_new_default_desc(subtype),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
            @lib.Instruction::i32_add(),
            @lib.Instruction::global_set(@lib.GlobalIdx::new(1U)),
            @lib.Instruction::struct_new_default(base_descriptor_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(2U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(3U)),
            @lib.Instruction::call(@lib.FuncIdx::new(1U)),
            @lib.Instruction::ref_cast_desc_eq_type(base_ref_type),
          ]),
        ),
      ]),
    )
  let optimized = optimize_instructions_test_run_module(module_)
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_false(pretty.contains("ref.cast_desc_eq"), msg=pretty)
  match optimized.code_sec {
    Some(
      @lib.CodeSec(
        [
          _,
          _,
          @lib.Func(
            _,
            @lib.Expr(
              [
                @lib.LocalGet(arg0),
                @lib.LocalGet(arg1),
                @lib.Call(ref_func),
                @lib.Drop,
                @lib.LocalGet(arg2),
                @lib.LocalGet(arg3),
                @lib.Call(desc_func),
                @lib.Drop,
                @lib.Unreachable,
              ]
            )
          ),
        ]
      )
    ) => {
      @debug.assert_eq(arg0, @lib.LocalIdx::new(0U))
      @debug.assert_eq(arg1, @lib.LocalIdx::new(1U))
      @debug.assert_eq(ref_func, @lib.FuncIdx::new(0U))
      @debug.assert_eq(arg2, @lib.LocalIdx::new(2U))
      @debug.assert_eq(arg3, @lib.LocalIdx::new(3U))
      @debug.assert_eq(desc_func, @lib.FuncIdx::new(1U))
    }
    _ =>
      fail(
        "expected local.get arg0; local.get arg1; call ref; drop; local.get arg2; local.get arg3; call desc; drop; unreachable",
      )
  }
}

