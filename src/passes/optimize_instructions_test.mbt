          @lib.Func(
            _,
            @lib.Expr(
              [
                @lib.LocalGet(arg0),
                @lib.LocalGet(arg1),
                @lib.Call(ref_func),
                @lib.Drop,
                @lib.LocalGet(arg2),
                @lib.LocalGet(arg3),
                @lib.LocalGet(arg4),
                @lib.LocalGet(arg5),
                @lib.LocalGet(arg6),
