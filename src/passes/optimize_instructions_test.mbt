  )
}

///|
test "optimize-instructions rewrites eqz on sub into eq" {
  let func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32) (result i32) local.get 0 local.get 1 i32.sub i32.eqz))",
  )
  let root = @ir.hot_root_get(func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(func, root),
    Some(@lib.Instruction::i32_eq()),
  )
  let lhs = @ir.hot_child_get(func, root, 0)
  let rhs = @ir.hot_child_get(func, root, 1)
  match @ir.hot_node_get(func, lhs).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected lhs of eqz(sub) rewrite to remain the original lhs")
  }
  match @ir.hot_node_get(func, rhs).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected rhs of eqz(sub) rewrite to remain the original rhs")
  }
}

///|
test "optimize-instructions rewrites eqz on add const into eq negated const" {
  let func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) local.get 0 i32.const 5 i32.add i32.eqz))",
  )
  let root = @ir.hot_root_get(func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(func, root),
    Some(@lib.Instruction::i32_eq()),
  )
  let rhs = @ir.hot_child_get(func, root, 1)
  @debug.assert_eq(
    @ir.hot_const_get(func, @ir.hot_node_get(func, rhs).imm0),
    @ir.HotConstPayload::i32_const(@lib.I32(-5)),
  )
}

///|
test "optimize-instructions rewrites eqz on zero compare into inverted compare" {
  let i32_ne_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) local.get 0 i32.const 0 i32.ne i32.eqz))",
  )
  let i32_ne_root = @ir.hot_root_get(i32_ne_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(i32_ne_func, i32_ne_root),
    Some(@lib.Instruction::i32_eqz()),
  )
  let i32_ne_operand = @ir.hot_child_get(i32_ne_func, i32_ne_root, 0)
  match @ir.hot_node_get(i32_ne_func, i32_ne_operand).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected eqz(ne i32 zero) rewrite to keep the original operand")
  }

  let i64_ne_func = optimize_instructions_test_run_hot(
    "(module (func (param i64) (result i32) local.get 0 i64.const 0 i64.ne i32.eqz))",
  )
  let i64_ne_root = @ir.hot_root_get(i64_ne_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(i64_ne_func, i64_ne_root),
    Some(@lib.Instruction::i64_eqz()),
  )
  let i64_ne_operand = @ir.hot_child_get(i64_ne_func, i64_ne_root, 0)
  match @ir.hot_node_get(i64_ne_func, i64_ne_operand).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected eqz(ne i64 zero) rewrite to keep the original operand")
  }

  let i32_eq_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) local.get 0 i32.const 0 i32.eq i32.eqz))",
  )
  let i32_eq_root = @ir.hot_root_get(i32_eq_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(i32_eq_func, i32_eq_root),
    Some(@lib.Instruction::i32_ne()),
  )
  let i32_eq_lhs = @ir.hot_child_get(i32_eq_func, i32_eq_root, 0)
  let i32_eq_rhs = @ir.hot_child_get(i32_eq_func, i32_eq_root, 1)
  match @ir.hot_node_get(i32_eq_func, i32_eq_lhs).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected eqz(eq i32 zero) rewrite to keep the original operand")
  }
  @debug.assert_eq(
    @ir.hot_const_get(
      i32_eq_func,
      @ir.hot_node_get(i32_eq_func, i32_eq_rhs).imm0,
    ),
    @ir.HotConstPayload::i32_const(@lib.I32(0)),
  )
}

///|
test "optimize-instructions folds compare of eqz against boolean constants" {
  // Red-first OI-F boolean parity slice: Binaryen `version_130`
  // `--optimize-instructions` rewrites direct `i32.eq` / `i32.ne` compares
  // between an `i32.eqz` result and exact boolean constants. `eq(eqz(x), 0)`
  // and `ne(eqz(x), 1)` become `x != 0`; `ne(eqz(x), 0)` and
  // `eq(eqz(x), 1)` become `eqz(x)`. This deliberately does not claim
  // arbitrary boolean algebra, non-boolean constants, or branch rewrites.
  let eq_zero_rhs_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) local.get 0 i32.eqz i32.const 0 i32.eq))",
  )
  let eq_zero_rhs_root = @ir.hot_root_get(eq_zero_rhs_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(eq_zero_rhs_func, eq_zero_rhs_root),
    Some(@lib.Instruction::i32_ne()),
  )
  match
    @ir.hot_node_get(
      eq_zero_rhs_func,
      @ir.hot_child_get(eq_zero_rhs_func, eq_zero_rhs_root, 0),
    ).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected eq(eqz(x), 0) to keep the original operand")
  }
  @debug.assert_eq(
    @ir.hot_const_get(
      eq_zero_rhs_func,
      @ir.hot_node_get(
        eq_zero_rhs_func,
        @ir.hot_child_get(eq_zero_rhs_func, eq_zero_rhs_root, 1),
      ).imm0,
    ),
    @ir.HotConstPayload::i32_const(@lib.I32(0)),
  )

  let eq_zero_lhs_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) i32.const 0 local.get 0 i32.eqz i32.eq))",
  )
  let eq_zero_lhs_root = @ir.hot_root_get(eq_zero_lhs_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(eq_zero_lhs_func, eq_zero_lhs_root),
    Some(@lib.Instruction::i32_ne()),
  )

  let ne_zero_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) local.get 0 i32.eqz i32.const 0 i32.ne))",
  )
  let ne_zero_root = @ir.hot_root_get(ne_zero_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(ne_zero_func, ne_zero_root),
    Some(@lib.Instruction::i32_eqz()),
  )
  match
    @ir.hot_node_get(
      ne_zero_func,
      @ir.hot_child_get(ne_zero_func, ne_zero_root, 0),
    ).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected ne(eqz(x), 0) to keep the original operand")
  }

  let eq_one_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) local.get 0 i32.eqz i32.const 1 i32.eq))",
  )
  let eq_one_root = @ir.hot_root_get(eq_one_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(eq_one_func, eq_one_root),
    Some(@lib.Instruction::i32_eqz()),
  )

  let ne_one_func = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) local.get 0 i32.eqz i32.const 1 i32.ne))",
  )
  let ne_one_root = @ir.hot_root_get(ne_one_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(ne_one_func, ne_one_root),
    Some(@lib.Instruction::i32_ne()),
  )
}

///|
test "optimize-instructions folds compare of i64 eqz against boolean constants" {
  // Red-first OI-F boolean parity slice: Binaryen `version_130`
  // `--optimize-instructions` applies the same exact boolean-constant compare
  // cleanup to direct `i64.eqz` results as to direct `i32.eqz` results.
  // This deliberately covers only direct `i32.eq` / `i32.ne` shells around an
  // `i64.eqz` boolean result and exact i32 constants `0` / `1`.
  let eq_zero_func = optimize_instructions_test_run_hot(
    "(module (func (param i64) (result i32) local.get 0 i64.eqz i32.const 0 i32.eq))",
  )
  let eq_zero_root = @ir.hot_root_get(eq_zero_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(eq_zero_func, eq_zero_root),
    Some(@lib.Instruction::i64_ne()),
  )
  match
    @ir.hot_node_get(
      eq_zero_func,
      @ir.hot_child_get(eq_zero_func, eq_zero_root, 0),
    ).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected eq(i64.eqz(x), 0) to keep the original operand")
  }
  @debug.assert_eq(
    @ir.hot_const_get(
      eq_zero_func,
      @ir.hot_node_get(
        eq_zero_func,
        @ir.hot_child_get(eq_zero_func, eq_zero_root, 1),
      ).imm0,
    ),
    @ir.HotConstPayload::i64_const(@lib.I64(0L)),
  )

  let ne_zero_func = optimize_instructions_test_run_hot(
    "(module (func (param i64) (result i32) local.get 0 i64.eqz i32.const 0 i32.ne))",
  )
  @debug.assert_eq(
    @ir.hot_node_exact_instr(ne_zero_func, @ir.hot_root_get(ne_zero_func, 0)),
    Some(@lib.Instruction::i64_eqz()),
  )

  let eq_one_func = optimize_instructions_test_run_hot(
    "(module (func (param i64) (result i32) local.get 0 i64.eqz i32.const 1 i32.eq))",
  )
  @debug.assert_eq(
    @ir.hot_node_exact_instr(eq_one_func, @ir.hot_root_get(eq_one_func, 0)),
    Some(@lib.Instruction::i64_eqz()),
  )

  let ne_one_func = optimize_instructions_test_run_hot(
    "(module (func (param i64) (result i32) local.get 0 i64.eqz i32.const 1 i32.ne))",
  )
  @debug.assert_eq(
    @ir.hot_node_exact_instr(ne_one_func, @ir.hot_root_get(ne_one_func, 0)),
    Some(@lib.Instruction::i64_ne()),
  )
}

///|
test "optimize-instructions rewrites eqz on integer compares into inverted compares" {
  // Red-first OI-D parity slice: Binaryen `version_130`
  // `--optimize-instructions` rewrites `i32.eqz` around integer relational
  // compare results by inverting the compare opcode and preserving the original
  // operands. This deliberately does not cover compare-to-zero spellings or
  // NaN-sensitive float relational compares.
  let i32_rel_func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32) (result i32) local.get 0 local.get 1 i32.lt_s i32.eqz))",
  )
  let i32_rel_root = @ir.hot_root_get(i32_rel_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(i32_rel_func, i32_rel_root),
    Some(@lib.Instruction::i32_ge_s()),
  )
  let i32_lhs = @ir.hot_child_get(i32_rel_func, i32_rel_root, 0)
  let i32_rhs = @ir.hot_child_get(i32_rel_func, i32_rel_root, 1)
  match @ir.hot_node_get(i32_rel_func, i32_lhs).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected inverted i32 compare to keep the original lhs")
  }
  match @ir.hot_node_get(i32_rel_func, i32_rhs).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected inverted i32 compare to keep the original rhs")
  }

  let i64_rel_func = optimize_instructions_test_run_hot(
    "(module (func (param i64 i64) (result i32) local.get 0 local.get 1 i64.le_u i32.eqz))",
  )
  let i64_rel_root = @ir.hot_root_get(i64_rel_func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(i64_rel_func, i64_rel_root),
    Some(@lib.Instruction::i64_gt_u()),
  )
}

///|
test "optimize-instructions rewrites eqz on float eq-ne compares into inverted compares" {
  // Red-first OI-D parity slice: Binaryen `version_130`
  // `--optimize-instructions` rewrites `i32.eqz` around `f32.eq` / `f32.ne`
  // and `f64.eq` / `f64.ne` by inverting only the equality opcode. This is
  // deliberately not a NaN-sensitive float relational inversion: Binaryen kept
  // `i32.eqz(f32.lt(...))` in the prior companion probe.
  let f32_eq_func = optimize_instructions_test_run_hot(
    "(module (func (param f32 f32) (result i32) local.get 0 local.get 1 f32.eq i32.eqz))",
  )
  @debug.assert_eq(
    @ir.hot_node_exact_instr(f32_eq_func, @ir.hot_root_get(f32_eq_func, 0)),
    Some(@lib.Instruction::f32_ne()),
  )

  let f32_ne_func = optimize_instructions_test_run_hot(
    "(module (func (param f32 f32) (result i32) local.get 0 local.get 1 f32.ne i32.eqz))",
  )
  @debug.assert_eq(
    @ir.hot_node_exact_instr(f32_ne_func, @ir.hot_root_get(f32_ne_func, 0)),
    Some(@lib.Instruction::f32_eq()),
  )

  let f64_eq_func = optimize_instructions_test_run_hot(
    "(module (func (param f64 f64) (result i32) local.get 0 local.get 1 f64.eq i32.eqz))",
  )
  @debug.assert_eq(
    @ir.hot_node_exact_instr(f64_eq_func, @ir.hot_root_get(f64_eq_func, 0)),
    Some(@lib.Instruction::f64_ne()),
  )

  let f64_ne_func = optimize_instructions_test_run_hot(
    "(module (func (param f64 f64) (result i32) local.get 0 local.get 1 f64.ne i32.eqz))",
  )
  @debug.assert_eq(
    @ir.hot_node_exact_instr(f64_ne_func, @ir.hot_root_get(f64_ne_func, 0)),
    Some(@lib.Instruction::f64_eq()),
  )
}

///|
test "optimize-instructions recursively simplifies boolean block tails" {
  // Red-first OI-F behavior-parity slice: Binaryen v130 `optimizeBoolean`
  // recurses into the final value of an i32 block used as an `if` condition.
  // The focused oracle `.tmp/oi-probes/boolean-recursive-contexts.wat` removes
  // the tail-local `i32.ne(x, 0)` while preserving the preceding dropped value.
  let func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32) (result i32) (if (result i32) (block (result i32) (drop (local.get 1)) (i32.ne (local.get 0) (i32.const 0))) (then (i32.const 11)) (else (i32.const 22)))))",
  )
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_get(func, root).op {
    @ir.HotOp::If => ()
    other =>
      fail("expected outer boolean consumer to remain an if, got \{other}")
  }
  let condition = @ir.hot_child_get(func, root, 0)
  match @ir.hot_node_get(func, condition).op {
    @ir.HotOp::Block => ()
    other => fail("expected boolean condition to remain a block, got \{other}")
  }
  let body = @ir.hot_region_body_ref(func, condition)
  @debug.assert_eq(@ir.hot_region_root_count(func, body), 2)
  match @ir.hot_node_get(func, @ir.hot_region_get(func, body, 0)).op {
    @ir.HotOp::Drop => ()
    other => fail("expected boolean block prefix drop to remain, got \{other}")
  }
  let tail = @ir.hot_region_get(func, body, 1)
  match @ir.hot_node_get(func, tail).op {
    @ir.HotOp::LocalGet =>
      @debug.assert_eq(@ir.hot_node_get(func, tail).imm0, 0)
    other =>
      fail("expected boolean block tail to simplify to local.get, got \{other}")
  }
}

///|
test "optimize-instructions recursively simplifies boolean select arms" {
  // Red-first OI-F behavior-parity slice: Binaryen v130 `optimizeBoolean`
  // recursively treats both arms of a select as boolean values when that select
  // is itself an `if` condition. The focused oracle keeps the select and its
  // condition while removing exact `i32.ne(x, 0)` shells from both arms.
  let func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32 i32) (result i32) (if (result i32) (select (i32.ne (local.get 0) (i32.const 0)) (i32.ne (local.get 1) (i32.const 0)) (local.get 2)) (then (i32.const 11)) (else (i32.const 22)))))",
  )
  let root = @ir.hot_root_get(func, 0)
  let condition = @ir.hot_child_get(func, root, 0)
  match @ir.hot_node_get(func, condition).op {
    @ir.HotOp::Select => ()
    other => fail("expected boolean condition to remain a select, got \{other}")
  }
  for slot = 0; slot < 2; slot = slot + 1 {
    let arm = @ir.hot_child_get(func, condition, slot)
    match @ir.hot_node_get(func, arm).op {
      @ir.HotOp::LocalGet =>
        @debug.assert_eq(@ir.hot_node_get(func, arm).imm0, slot)
      other =>
        fail("expected boolean select arm \{slot} to simplify, got \{other}")
    }
  }
  let selector = @ir.hot_child_get(func, condition, 2)
  match @ir.hot_node_get(func, selector).op {
    @ir.HotOp::LocalGet =>
      @debug.assert_eq(@ir.hot_node_get(func, selector).imm0, 2)
    other => fail("expected boolean select condition to remain, got \{other}")
  }
}

///|
test "optimize-instructions recursively simplifies boolean if arms" {
  // Red-first OI-F behavior-parity slice: Binaryen v130 `optimizeBoolean`
  // recursively treats both result arms of an i32 if as boolean values when the
  // inner if is consumed as an outer condition. The focused oracle preserves
  // both if shells while removing exact `i32.ne(x, 0)` arm tails.
  let func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32 i32) (result i32) (if (result i32) (if (result i32) (local.get 2) (then (i32.ne (local.get 0) (i32.const 0))) (else (i32.ne (local.get 1) (i32.const 0)))) (then (i32.const 11)) (else (i32.const 22)))))",
  )
  let outer_if = @ir.hot_root_get(func, 0)
  let inner_if = @ir.hot_child_get(func, outer_if, 0)
  match @ir.hot_node_get(func, inner_if).op {
    @ir.HotOp::If => ()
    other => fail("expected boolean condition to remain an if, got \{other}")
  }
  let then_region = @ir.hot_region_then_ref(func, inner_if)
  let else_region = match @ir.hot_region_else_ref(func, inner_if) {
    Some(region) => region
    None => fail("expected boolean if condition to retain an else arm")
  }
  let assert_arm = fn(region : @ir.HotRegionRef, local_id : Int) raise {
    @debug.assert_eq(@ir.hot_region_root_count(func, region), 1)
    let arm = @ir.hot_region_get(func, region, 0)
    match @ir.hot_node_get(func, arm).op {
      @ir.HotOp::LocalGet =>
        @debug.assert_eq(@ir.hot_node_get(func, arm).imm0, local_id)
      other => fail("expected boolean if arm to simplify, got \{other}")
    }
  }
  assert_arm(then_region, 0)
  assert_arm(else_region, 1)
  let selector = @ir.hot_child_get(func, inner_if, 0)
  match @ir.hot_node_get(func, selector).op {
    @ir.HotOp::LocalGet =>
      @debug.assert_eq(@ir.hot_node_get(func, selector).imm0, 2)
    other => fail("expected inner if condition to remain, got \{other}")
  }

  let one_sided = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32 i32) (result i32) (if (result i32) (if (result i32) (local.get 2) (then (i32.ne (local.get 0) (i32.const 0))) (else (i32.add (local.get 1) (i32.const 7)))) (then (i32.const 11)) (else (i32.const 22)))))",
  )
  let one_sided_inner = @ir.hot_child_get(
    one_sided,
    @ir.hot_root_get(one_sided, 0),
    0,
  )
  let one_sided_then = @ir.hot_region_then_ref(one_sided, one_sided_inner)
  let one_sided_else = match
    @ir.hot_region_else_ref(one_sided, one_sided_inner) {
    Some(region) => region
    None => fail("expected one-sided boolean if to retain its else arm")
  }
  match
    @ir.hot_node_get(
      one_sided,
      @ir.hot_region_get(one_sided, one_sided_then, 0),
    ).op {
    @ir.HotOp::LocalGet => ()
    other =>
      fail("expected one-sided boolean then arm to simplify, got \{other}")
  }
  @debug.assert_eq(
    @ir.hot_node_exact_instr(
      one_sided,
      @ir.hot_region_get(one_sided, one_sided_else, 0),
    ),
    Some(@lib.Instruction::i32_add()),
  )
}

///|
test "optimize-instructions recursively simplifies boolean try body and catch" {
  // Red-first OI-F behavior-parity slice: Binaryen v130 `optimizeBoolean`
  // independently rewrites the body and every catch body of an i32 try used as
  // a condition. `.tmp/oi-probes/boolean-try-contexts.wat` preserves both
  // region prefixes while forwarding body ne-zero and catch zero-minus tails.
  let i32_type = @lib.ValType::i32()
  let func = @ir.HotFunc::new(
    locals=@ir.HotLocals::new(locals=[i32_type, i32_type]),
  )
  @ir.hot_body_result_type_set(func, @ir.hot_type_intern_value(func, i32_type))

  let body_tail = @ir.hot_build_binary(
    func,
    i32_type,
    @ir.hot_build_local_get(func, 0),
    @ir.hot_build_const_i32(func, @lib.I32(0)),
  )
  @ir.hot_node_exact_instr_set(func, body_tail, @lib.Instruction::i32_ne())
  let catch_tail = @ir.hot_build_binary(
    func,
    i32_type,
    @ir.hot_build_const_i32(func, @lib.I32(0)),
    @ir.hot_build_local_get(func, 1),
  )
  @ir.hot_node_exact_instr_set(func, catch_tail, @lib.Instruction::i32_sub())
  let condition = @ir.hot_build_try(
    func,
    @lib.BlockType::val_type(i32_type),
    [@ir.hot_build_drop(func, @ir.hot_build_local_get(func, 1)), body_tail],
    catch_body=Some([
      @ir.hot_build_drop(func, @ir.hot_build_local_get(func, 0)),
      catch_tail,
    ]),
  )
  @ir.hot_root_append(
    func,
    @ir.hot_build_if(
      func,
      @lib.BlockType::val_type(i32_type),
      condition,
      [@ir.hot_build_const_i32(func, @lib.I32(11))],
      else_body=Some([@ir.hot_build_const_i32(func, @lib.I32(22))]),
    ),
  )
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) => fail("expected boolean try optimization success, got \{err}")
  }

  let assert_region = fn(
    region : @ir.HotRegionRef,
    expected_local : Int,
    label : String,
  ) raise {
    @debug.assert_eq(@ir.hot_region_root_count(func, region), 2)
    match @ir.hot_node_get(func, @ir.hot_region_get(func, region, 0)).op {
      @ir.HotOp::Drop => ()
      other => fail("expected \{label} prefix drop to remain, got \{other}")
    }
    let tail = @ir.hot_region_get(func, region, 1)
    match @ir.hot_node_get(func, tail).op {
      @ir.HotOp::LocalGet =>
        @debug.assert_eq(@ir.hot_node_get(func, tail).imm0, expected_local)
      other => fail("expected \{label} boolean tail to simplify, got \{other}")
    }
  }
  assert_region(@ir.hot_region_body_ref(func, condition), 0, "try body")
  let catch_region = match @ir.hot_region_catch_ref(func, condition) {
    Some(region) => region
    None => fail("expected represented try catch region")
  }
  assert_region(catch_region, 1, "try catch")
}

///|
test "optimize-instructions simplifies boolean zero-minus leaves" {
  // Red-first OI-F behavior-parity slice: Binaryen v130 `optimizeBoolean`
  // rewrites `bool(0 - x)` to `bool(x)`. The focused oracle
  // `.tmp/oi-probes/boolean-leaf-binary-rules.wat` proves both the direct outer
  // condition and a recursively selected i32 block tail while preserving the
  // block prefix.
  let direct = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) (if (result i32) (i32.sub (i32.const 0) (local.get 0)) (then (i32.const 11)) (else (i32.const 22)))))",
  )
  let direct_condition = @ir.hot_child_get(
    direct,
    @ir.hot_root_get(direct, 0),
    0,
  )
  match @ir.hot_node_get(direct, direct_condition).op {
    @ir.HotOp::LocalGet =>
      @debug.assert_eq(@ir.hot_node_get(direct, direct_condition).imm0, 0)
    other =>
      fail("expected direct zero-minus boolean to forward x, got \{other}")
  }

  let nested = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32) (result i32) (if (result i32) (block (result i32) (drop (local.get 1)) (i32.sub (i32.const 0) (local.get 0))) (then (i32.const 11)) (else (i32.const 22)))))",
  )
  let nested_condition = @ir.hot_child_get(
    nested,
    @ir.hot_root_get(nested, 0),
    0,
  )
  let body = @ir.hot_region_body_ref(nested, nested_condition)
  @debug.assert_eq(@ir.hot_region_root_count(nested, body), 2)
  match @ir.hot_node_get(nested, @ir.hot_region_get(nested, body, 0)).op {
    @ir.HotOp::Drop => ()
    other => fail("expected zero-minus block prefix to remain, got \{other}")
  }
  let tail = @ir.hot_region_get(nested, body, 1)
  match @ir.hot_node_get(nested, tail).op {
    @ir.HotOp::LocalGet =>
      @debug.assert_eq(@ir.hot_node_get(nested, tail).imm0, 0)
    other => fail("expected zero-minus block tail to forward x, got \{other}")
  }
}

///|
test "optimize-instructions recursively simplifies boolean or operands" {
  // Red-first OI-F behavior-parity slice: Binaryen v130 `optimizeBoolean`
  // recursively optimizes both i32.or operands in boolean context. The focused
  // oracle `.tmp/oi-probes/boolean-leaf-binary-rules.wat` proves direct
  // ne-zero/zero-minus operands and the nested block -> or -> select shape.
  let direct = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32) (result i32) (if (result i32) (i32.or (i32.ne (local.get 0) (i32.const 0)) (i32.sub (i32.const 0) (local.get 1))) (then (i32.const 11)) (else (i32.const 22)))))",
  )
  let direct_or = @ir.hot_child_get(direct, @ir.hot_root_get(direct, 0), 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(direct, direct_or),
    Some(@lib.Instruction::i32_or()),
  )
  let direct_left = @ir.hot_child_get(direct, direct_or, 0)
  let direct_right = @ir.hot_child_get(direct, direct_or, 1)
  match
    (
      @ir.hot_node_get(direct, direct_left).op,
      @ir.hot_node_get(direct, direct_right).op,
    ) {
    (@ir.HotOp::LocalGet, @ir.HotOp::LocalGet) => {
      let left_local = @ir.hot_node_get(direct, direct_left).imm0
      let right_local = @ir.hot_node_get(direct, direct_right).imm0
      @debug.assert_eq(left_local + right_local, 1)
      assert_true(left_local != right_local)
    }
    other =>
      fail("expected both direct boolean or operands to simplify, got \{other}")
  }

  let nested = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32 i32) (result i32) (if (result i32) (block (result i32) (drop (local.get 2)) (i32.or (select (i32.ne (local.get 0) (i32.const 0)) (i32.sub (i32.const 0) (local.get 1)) (local.get 2)) (i32.ne (local.get 2) (i32.const 0)))) (then (i32.const 11)) (else (i32.const 22)))))",
  )
  let block = @ir.hot_child_get(nested, @ir.hot_root_get(nested, 0), 0)
  let body = @ir.hot_region_body_ref(nested, block)
  @debug.assert_eq(@ir.hot_region_root_count(nested, body), 2)
  match @ir.hot_node_get(nested, @ir.hot_region_get(nested, body, 0)).op {
    @ir.HotOp::Drop => ()
    other =>
      fail("expected nested boolean block prefix to remain, got \{other}")
  }
  let nested_or = @ir.hot_region_get(nested, body, 1)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(nested, nested_or),
    Some(@lib.Instruction::i32_or()),
  )
  let left = @ir.hot_child_get(nested, nested_or, 0)
  let right = @ir.hot_child_get(nested, nested_or, 1)
  let (select, sibling) = match
    (@ir.hot_node_get(nested, left).op, @ir.hot_node_get(nested, right).op) {
    (@ir.HotOp::Select, @ir.HotOp::LocalGet) => (left, right)
    (@ir.HotOp::LocalGet, @ir.HotOp::Select) => (right, left)
    other =>
      fail(
        "expected nested boolean or to retain select plus local, got \{other}",
      )
  }
  @debug.assert_eq(@ir.hot_node_get(nested, sibling).imm0, 2)
  for slot = 0; slot < 2; slot = slot + 1 {
    let arm = @ir.hot_child_get(nested, select, slot)
    match @ir.hot_node_get(nested, arm).op {
      @ir.HotOp::LocalGet =>
        @debug.assert_eq(@ir.hot_node_get(nested, arm).imm0, slot)
      other =>
        fail(
          "expected nested boolean select arm \{slot} to simplify, got \{other}",
        )
    }
  }
  let selector = @ir.hot_child_get(nested, select, 2)
  @debug.assert_eq(@ir.hot_node_get(nested, selector).imm0, 2)
}

///|
test "optimize-instructions masks signed remainders in boolean context" {
  // Red-first OI-F behavior-parity slice: Binaryen v130 `optimizeBoolean`
  // rewrites signed remainder by +/- powers of two, or signed-min, to an i32.and
  // mask when only truthiness is observed. The focused oracle
  // `.tmp/oi-probes/boolean-leaf-binary-rules.wat` proves masks 7 and INT_MAX
  // while retaining a non-power-of-two divisor.
  let assert_direct_mask = fn(divisor : Int, expected_mask : Int) raise {
    let func = optimize_instructions_test_run_hot(
      "(module (func (param i32) (result i32) (if (result i32) (i32.rem_s (local.get 0) (i32.const \{divisor})) (then (i32.const 11)) (else (i32.const 22)))))",
    )
    let condition = @ir.hot_child_get(func, @ir.hot_root_get(func, 0), 0)
    @debug.assert_eq(
      @ir.hot_node_exact_instr(func, condition),
      Some(@lib.Instruction::i32_and()),
    )
    let mask = @ir.hot_child_get(func, condition, 1)
    match @ir.hot_node_get(func, mask).op {
      @ir.HotOp::Const =>
        @debug.assert_eq(
          @ir.hot_const_get(func, @ir.hot_node_get(func, mask).imm0),
          @ir.HotConstPayload::i32_const(@lib.I32(expected_mask)),
        )
      other => fail("expected boolean remainder mask constant, got \{other}")
    }
  }
  assert_direct_mask(8, 7)
  assert_direct_mask(-8, 7)
  assert_direct_mask(-2147483648, 2147483647)

  let nonpower = optimize_instructions_test_run_hot(
    "(module (func (param i32) (result i32) (if (result i32) (i32.rem_s (local.get 0) (i32.const 6)) (then (i32.const 11)) (else (i32.const 22)))))",
  )
  let nonpower_condition = @ir.hot_child_get(
    nonpower,
    @ir.hot_root_get(nonpower, 0),
    0,
  )
  @debug.assert_eq(
    @ir.hot_node_exact_instr(nonpower, nonpower_condition),
    Some(@lib.Instruction::i32_rem_s()),
  )

  let nested = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32 i32) (result i32) (if (result i32) (select (i32.rem_s (local.get 0) (i32.const -8)) (i32.rem_s (local.get 1) (i32.const -2147483648)) (local.get 2)) (then (i32.const 11)) (else (i32.const 22)))))",
  )
  let select = @ir.hot_child_get(nested, @ir.hot_root_get(nested, 0), 0)
  for slot = 0; slot < 2; slot = slot + 1 {
    let arm = @ir.hot_child_get(nested, select, slot)
    @debug.assert_eq(
      @ir.hot_node_exact_instr(nested, arm),
      Some(@lib.Instruction::i32_and()),
    )
    let mask = @ir.hot_child_get(nested, arm, 1)
    let expected = if slot == 0 { 7 } else { 2147483647 }
    @debug.assert_eq(
      @ir.hot_const_get(nested, @ir.hot_node_get(nested, mask).imm0),
      @ir.HotConstPayload::i32_const(@lib.I32(expected)),
    )
  }
  @debug.assert_eq(
    @ir.hot_node_get(nested, @ir.hot_child_get(nested, select, 2)).imm0,
    2,
  )
}

///|
test "optimize-instructions folds i32 eqz block constants in boolean context" {
  // Red-first OI-F behavior-parity slice: Binaryen v130 `optimizeBoolean`
  // asks `getFallthrough` for an i32.eqz operand and replaces a constant block
  // tail with the truth value while preserving the original block evaluation as
  // a drop. Oracle: `.tmp/oi-probes/boolean-eqz-fallthrough-const.wat`.
  let assert_fold = fn(tail : Int, expected : Int) raise {
    let func = optimize_instructions_test_run_hot(
      "(module (global (mut i32) (i32.const 0)) (func (param i32) (result i32) (if (result i32) (i32.eqz (block (result i32) (global.set 0 (local.get 0)) (i32.const \{tail}))) (then (i32.const 11)) (else (i32.const 22)))))",
    )
    let condition = @ir.hot_child_get(func, @ir.hot_root_get(func, 0), 0)
    match @ir.hot_node_get(func, condition).op {
      @ir.HotOp::Block => ()
      other => fail("expected folded i32 eqz condition block, got \{other}")
    }
    let body = @ir.hot_region_body_ref(func, condition)
    @debug.assert_eq(@ir.hot_region_root_count(func, body), 2)
    match @ir.hot_node_get(func, @ir.hot_region_get(func, body, 0)).op {
      @ir.HotOp::Drop => ()
      other =>
        fail(
          "expected original i32 block evaluation to be dropped, got \{other}",
        )
    }
    let result = @ir.hot_region_get(func, body, 1)
    @debug.assert_eq(
