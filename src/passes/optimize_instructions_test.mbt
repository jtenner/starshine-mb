///|
test "optimize-instructions preserves local.tee while folding maxBits compares" {
  // Red-first OI-E behavior-parity slice: Binaryen v130 `Bits::getMaxBits`
  // sees through a local.tee value but preserves the local write before the
  // folded constant. HOT may materialize the preserved tee effect as local.set;
  // the parity requirement is that the impossible compare folds without erasing
  // the write.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (func (param $x i32) (result i32) (local $tmp i32)
        #|    (i32.eq
        #|      (local.tee $tmp (i32.and (local.get $x) (i32.const 255)))
        #|      (i32.const 256))))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) => fail("expected local.tee maxBits compare fold, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("i32.eq"), msg=pretty)
  assert_true(pretty.contains("local.set (Local 1)"), msg=pretty)
  assert_true(pretty.contains("I32(0)"), msg=pretty)
}

///|
test "optimize-instructions carries local maxBits through loop fallthrough assignments" {
  // Red-first OI-E behavior-parity slice: Binaryen v130 LocalScanner queries
  // `Properties::getFallthrough` on local.set values, so a loop body's tail can
  // seed the assigned local's maxBits fact even though direct loop compares are
  // an oracle-observed keep-spelling boundary.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (func (param $x i32) (result i32) (local $tmp i32)
        #|    (local.set $tmp
        #|      (loop (result i32)
        #|        (i32.and (local.get $x) (i32.const 255))))
        #|    (i32.eq (local.get $tmp) (i32.const 256))))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) => fail("expected loop-assigned local maxBits fold, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("i32.eq"), msg=pretty)
  assert_true(pretty.contains("loop"), msg=pretty)
  assert_true(pretty.contains("local.set (Local 1)"), msg=pretty)
  assert_true(pretty.contains("I32(0)"), msg=pretty)
}

///|
test "optimize-instructions carries local maxBits through one-sided if assignments" {
  // Red-first OI-E behavior-parity slice: Binaryen v130 LocalScanner's
  // assignment fallthrough sees through an if when exactly one arm is
  // unreachable, using the live arm's tail to seed maxBits for the assigned
  // local. This is assignment-only; direct one-sided-if compares stay bounded
  // by oracle evidence.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (func $else_unreachable (param $x i32) (result i32) (local $tmp i32)
        #|    (local.set $tmp
        #|      (if (result i32) (local.get $x)
        #|        (then (i32.and (local.get $x) (i32.const 255)))
        #|        (else unreachable)))
        #|    (i32.eq (local.get $tmp) (i32.const 256)))
        #|  (func $then_unreachable (param $x i32) (result i32) (local $tmp i32)
        #|    (local.set $tmp
        #|      (if (result i32) (local.get $x)
        #|        (then unreachable)
        #|        (else (i32.and (local.get $x) (i32.const 255)))))
        #|    (i32.eq (local.get $tmp) (i32.const 256))))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected one-sided-if assignment maxBits fold, got \{err}")
  }
  let first = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(first.contains("i32.eq"), msg=first)
  assert_true(first.contains("if"), msg=first)
  assert_true(first.contains("unreachable"), msg=first)
  assert_true(first.contains("local.set (Local 1)"), msg=first)
  assert_true(first.contains("I32(0)"), msg=first)
  let second = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_false(second.contains("i32.eq"), msg=second)
  assert_true(second.contains("if"), msg=second)
  assert_true(second.contains("unreachable"), msg=second)
  assert_true(second.contains("local.set (Local 1)"), msg=second)
  assert_true(second.contains("I32(0)"), msg=second)
}

///|
test "optimize-instructions removes redundant block-produced unsigned mask facts" {
  // OI-E finite closeout `.tmp/oi-e-v01-closeout-signoff-10000` exposed the
  // `oi-local-facts:block-produced-mask` bucket as the only sampled
  // size-losing residual. A simple value block preserves the same bounded
  // unsigned fact as the contained value, so the later all-ones masks are
  // redundant. Starshine removes both i32 and i64 masks as a smaller semantic
  // cleanup; Binaryen version_130 removes the sampled i32 mask and keeps the
  // i64 spelling.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (func (local $x i32) (local $y i64)
        #|    block (result i32)
        #|      i32.const 255
        #|    end
        #|    local.set $x
        #|    local.get $x
        #|    i32.const 255
        #|    i32.and
        #|    drop
        #|    block (result i64)
        #|      i64.const 65535
        #|    end
        #|    local.set $y
        #|    local.get $y
        #|    i64.const 65535
        #|    i64.and
        #|    drop))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) => fail("expected block-produced mask cleanup success, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("i32.and"), msg=pretty)
  assert_false(pretty.contains("i64.and"), msg=pretty)
  assert_true(pretty.contains("local.get (Local 0)"), msg=pretty)
  assert_true(pretty.contains("local.get (Local 1)"), msg=pretty)
}

///|
test "optimize-instructions public pipeline canonicalizes simple stack-carried call operands" {
  let trace : Array[String] = []
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (func (param i32) (result i32)
        #|    local.get 0
        #|    call $one
        #|    i32.add)
        #|  (func $one (result i32)
        #|    i32.const 1))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(trace=Some(fn(line) { trace.push(line) })),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected optimize-instructions call cleanup success, got \{err}")
  }
  assert_false(
    trace.any(fn(line) { line.contains("pass[optimize-instructions]:skip-raw") }),
    msg="unexpected raw skip in \{trace}",
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  optimize_instructions_assert_strings_in_order(pretty, [
    "call (Func 1)", "local.get (Local 0)", "i32.add",
  ])
}

///|
test "optimize-instructions skips functions mixing loads and calls" {
  let trace : Array[String] = []
  match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (import "m" "touch" (func $touch))
        #|  (memory 1)
        #|  (func (param $ptr i32)
        #|    local.get $ptr
        #|    i32.load
        #|    drop
        #|    call $touch
        #|    i32.const 0
        #|    i32.eqz
        #|    drop))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(trace=Some(fn(line) { trace.push(line) })),
    ) {
    Ok(_) => ()
    Err(err) =>
      fail("expected load-call optimize-instructions skip, got \{err}")
  }
  assert_true(
    trace.any(fn(line) {
      line.contains(
        "pass[optimize-instructions]:skip-raw reason=load-call-optimize-instructions-noop",
      )
    }),
  )
}

///|
test "optimize-instructions folds load-call constant memory offsets through narrow raw-gate escape" {
  let trace : Array[String] = []
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (import "m" "touch" (func $touch))
        #|  (memory 1)
        #|  (func
        #|    i32.const 8
        #|    i32.load offset=4
        #|    drop
        #|    call $touch))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(trace=Some(fn(line) { trace.push(line) })),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected load-call memory offset gate success, got \{err}")
  }
  assert_false(
    trace.any(fn(line) {
      line.contains(
        "pass[optimize-instructions]:skip-raw reason=load-call-optimize-instructions-noop",
      )
    }),
    msg="unexpected load-call raw skip",
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  // Binaryen version_130 folds the constant address and static offset even when
  // a call follows the dropped load. The escape remains exact: constant address,
  // nonzero static-offset load, drop, then direct call.
  assert_true(pretty.contains("i32.const I32(12)"), msg=pretty)
  assert_true(pretty.contains("i32.load"), msg=pretty)
  assert_false(pretty.contains("offset=U64(4)"), msg=pretty)
  assert_false(pretty.contains("i32.const I32(8)"), msg=pretty)
}

///|
test "optimize-instructions intentionally keeps nonconstant load-call offset boundary" {
  // Boundary-only OI-G classification: Binaryen `version_130`
  // `--optimize-instructions` keeps the probed nonconstant pointer load plus
  // following call spelling (`.tmp/oi-g-load-call-nonconst-offset-boundary-probe.wat`).
  // Starshine's raw-gate escape remains intentionally limited to the exact
  // constant-address load/drop/call shape, so this fixture prevents that narrow
  // implementation from being reported as broader mixed load/call parity.
  let trace : Array[String] = []
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (import "m" "touch" (func $touch))
        #|  (memory 1)
        #|  (func (param $ptr i32)
        #|    local.get $ptr
        #|    i32.load offset=4
        #|    drop
        #|    call $touch))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(trace=Some(fn(line) { trace.push(line) })),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected nonconstant load-call offset boundary success, got \{err}")
  }
  assert_true(
    trace.any(fn(line) {
      line.contains(
        "pass[optimize-instructions]:skip-raw reason=load-call-optimize-instructions-noop",
      )
    }),
    msg="expected load-call raw skip in \{trace}",
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_true(pretty.contains("local.get"), msg=pretty)
  assert_true(
    pretty.contains("i32.load align=U32(2) offset=U64(4)"),
    msg=pretty,
  )
  assert_true(pretty.contains("call (Func 0)"), msg=pretty)
  assert_false(pretty.contains("i32.const I32(4)"), msg=pretty)
}

///|
test "optimize-instructions skips call-local-write functions" {
  let trace : Array[String] = []
  match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (import "m" "touch" (func $touch))
        #|  (func
        #|    (local i32)
        #|    call $touch
        #|    i32.const 0
        #|    local.set 0
        #|    i32.const 0
        #|    i32.eqz
        #|    drop))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(trace=Some(fn(line) { trace.push(line) })),
    ) {
    Ok(_) => ()
    Err(err) =>
      fail("expected call-local-write optimize-instructions skip, got \{err}")
  }
  assert_true(
    trace.any(fn(line) {
      line.contains(
        "pass[optimize-instructions]:skip-raw reason=call-local-write-optimize-instructions-noop",
      )
    }),
  )
}

///|
test "optimize-instructions skips stack-carried values across effect barriers" {
  let trace : Array[String] = []
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (import "m" "decref" (func $decref (param i32)))
        #|  (memory 1)
        #|  (func (param $ptr i32) (result i32)
        #|    (local $out i32)
        #|    local.get $ptr
        #|    i32.load
        #|    local.get $ptr
        #|    call $decref
        #|    local.set $out
        #|    i32.const 0
        #|    i32.eqz
        #|    drop
        #|    local.get $out))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(trace=Some(fn(line) { trace.push(line) })),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail(
        "expected stack-carried optimize-instructions skip success, got \{err}",
      )
  }
  assert_true(
    trace.any(fn(line) {
      line.contains(
        "pass[optimize-instructions]:skip-raw reason=stack-carried-effect-optimize-instructions-noop",
      )
    }),
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  optimize_instructions_assert_strings_in_order(pretty, [
    "i32.load", "call (Func 0)", "local.set",
  ])
}

///|
test "optimize-instructions keeps i32.eqz on constant zero" {
  let func = optimize_instructions_test_run_hot(
    "(module (func (result i32) i32.const 0 i32.eqz))",
  )
  let root = @ir.hot_root_get(func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(func, root),
    Some(@lib.Instruction::i32_eqz()),
  )
  @debug.assert_eq(@ir.hot_child_count(func, root), 1)
  let operand = @ir.hot_child_get(func, root, 0)
  @debug.assert_eq(
    @ir.hot_const_get(func, @ir.hot_node_get(func, operand).imm0),
    @ir.HotConstPayload::i32_const(@lib.I32(0)),
  )
}

///|
fn optimize_instructions_test_run_hot(text : String) -> @ir.HotFunc {
  let func = pass_test_lift_first_func(text)
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => func
    Err(err) =>
      abort("expected optimize-instructions hot pass success, got \{err}")
  }
}

///|
fn optimize_instructions_test_count_substring(
  text : String,
  needle : String,
) -> Int {
  if needle.length() == 0 {
    return 0
  }
  let mut count = 0
  let limit = text.length() - needle.length()
  let mut i = 0
  while i <= limit {
    if text.sub(start=i, end=i + needle.length()).to_owned() == needle {
      count += 1
      i += needle.length()
    } else {
      i += 1
    }
  }
  count
}

///|
fn optimize_instructions_assert_strings_in_order(
  text : String,
  needles : Array[String],
) -> Unit raise {
  let mut start = 0
  for needle in needles {
    let mut found : Int? = None
    let limit = text.length() - needle.length()
    let mut i = start
    while i <= limit {
      if text.sub(start=i, end=i + needle.length()).to_owned() == needle {
        found = Some(i)
        break
      }
      i += 1
    }
    match found {
      Some(idx) => start = idx + needle.length()
      None => fail("expected `\{needle}` after offset \{start} in `\{text}`")
    }
  }
}

///|
fn optimize_instructions_shared_dag_fixture(depth : Int) -> @ir.HotFunc {
  let func = @ir.HotFunc::new()
  let mut value = @ir.hot_build_const_i32(func, @lib.I32(0))
  for i = 0; i < depth; i = i + 1 {
    let _ = i
    let lhs = @ir.hot_build_binary(
      func,
      @lib.ValType::i32(),
      value,
      @ir.hot_build_const_i32(func, @lib.I32(1)),
    )
    @ir.hot_node_exact_instr_set(func, lhs, @lib.Instruction::i32_add())
    let rhs = @ir.hot_build_binary(
      func,
      @lib.ValType::i32(),
      value,
      @ir.hot_build_const_i32(func, @lib.I32(2)),
    )
    @ir.hot_node_exact_instr_set(func, rhs, @lib.Instruction::i32_add())
    value = @ir.hot_build_binary(func, @lib.ValType::i32(), lhs, rhs)
    @ir.hot_node_exact_instr_set(func, value, @lib.Instruction::i32_add())
  }
  @ir.hot_root_append(func, @ir.hot_build_drop(func, value))
  func
}

///|
test "optimize-instructions keeps shared eqz constant children live" {
  let func = pass_test_lift_first_func(
    "(module (func (result i32) i32.const 0 i32.eqz))",
  )
  let eqz = @ir.hot_root_get(func, 0)
  let shared = @ir.hot_child_get(func, eqz, 0)
  let drop_ = @ir.hot_build_drop(func, shared)
  @ir.hot_root_append(func, drop_)
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
  )

  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) =>
      fail("expected optimize-instructions shared-child success, got \{err}")
  }

  let root = @ir.hot_root_get(func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(func, root),
    Some(@lib.Instruction::i32_eqz()),
  )
  @debug.assert_eq(@ir.hot_child_get(func, root, 0), shared)
  assert_true(@ir.hot_node_is_live(func, shared))
  @debug.assert_eq(@ir.hot_child_get(func, drop_, 0), shared)
}

///|
test "optimize-instructions folds literal double eqz to constant" {
  // OI-D grouped-sweep follow-up: Binaryen version_130 folds the generated
  // `i32.const 1; i32.eqz; i32.eqz` representative to `i32.const 1` instead
  // of stopping at the nonliteral double-eqz shape `i32.ne(1, 0)`. Keep the
  // existing single-literal `eqz` behavior above unchanged.
  let i32_func = optimize_instructions_test_run_hot(
    "(module (func (result i32) i32.const 1 i32.eqz i32.eqz))",
  )
  let i32_root = @ir.hot_root_get(i32_func, 0)
  @debug.assert_eq(
    @ir.hot_const_get(i32_func, @ir.hot_node_get(i32_func, i32_root).imm0),
    @ir.HotConstPayload::i32_const(@lib.I32(1)),
  )

  let i64_func = optimize_instructions_test_run_hot(
    "(module (func (result i32) i64.const 9 i64.eqz i32.eqz))",
  )
  let i64_root = @ir.hot_root_get(i64_func, 0)
  @debug.assert_eq(
    @ir.hot_const_get(i64_func, @ir.hot_node_get(i64_func, i64_root).imm0),
    @ir.HotConstPayload::i32_const(@lib.I32(1)),
  )
}

