                @lib.ValType::i32(),
              ],
              [@lib.ValType::ref_type(base_ref_type)],
            ),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        make_ref_func_type, make_desc_func_type, cast_func_type,
      ]),
    )
    .with_global_sec(
      @lib.GlobalSec::new([
        @lib.Global::new(
          @lib.GlobalType::new(@lib.ValType::i32(), true),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
        ),
        @lib.Global::new(
          @lib.GlobalType::new(@lib.ValType::i32(), true),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
            @lib.Instruction::i32_add(),
            @lib.Instruction::local_get(@lib.LocalIdx::new(2U)),
            @lib.Instruction::i32_add(),
            @lib.Instruction::local_get(@lib.LocalIdx::new(3U)),
            @lib.Instruction::i32_add(),
            @lib.Instruction::local_get(@lib.LocalIdx::new(4U)),
            @lib.Instruction::i32_add(),
            @lib.Instruction::global_set(@lib.GlobalIdx::new(0U)),
            @lib.Instruction::struct_new_default(subtype_descriptor),
            @lib.Instruction::struct_new_default_desc(subtype),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::global_set(@lib.GlobalIdx::new(1U)),
            @lib.Instruction::struct_new_default(base_descriptor_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(2U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(3U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(4U)),
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(5U)),
            @lib.Instruction::call(@lib.FuncIdx::new(1U)),
            @lib.Instruction::ref_cast_desc_eq_type(base_ref_type),
          ]),
        ),
      ]),
    )
  let optimized = optimize_instructions_test_run_module(module_)
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_false(pretty.contains("ref.cast_desc_eq"), msg=pretty)
  match optimized.code_sec {
    Some(
      @lib.CodeSec(
        [
          _,
          _,
          @lib.Func(
            _,
            @lib.Expr(
              [
                @lib.LocalGet(arg0),
                @lib.LocalGet(arg1),
                @lib.LocalGet(arg2),
                @lib.LocalGet(arg3),
                @lib.LocalGet(arg4),
                @lib.Call(ref_func),
                @lib.Drop,
                @lib.LocalGet(arg5),
                @lib.Call(desc_func),
                @lib.Drop,
                @lib.Unreachable,
              ]
            )
          ),
        ]
      )
    ) => {
      @debug.assert_eq(arg0, @lib.LocalIdx::new(0U))
      @debug.assert_eq(arg1, @lib.LocalIdx::new(1U))
      @debug.assert_eq(arg2, @lib.LocalIdx::new(2U))
      @debug.assert_eq(arg3, @lib.LocalIdx::new(3U))
      @debug.assert_eq(arg4, @lib.LocalIdx::new(4U))
      @debug.assert_eq(ref_func, @lib.FuncIdx::new(0U))
      @debug.assert_eq(arg5, @lib.LocalIdx::new(5U))
      @debug.assert_eq(desc_func, @lib.FuncIdx::new(1U))
    }
    _ =>
      fail(
        "expected five ref args; call ref; drop; one desc args; call desc; drop; unreachable",
      )
  }
}

///|
fn optimize_instructions_test_i32_params(count : Int) -> Array[@lib.ValType] {
  let params : Array[@lib.ValType] = []
  for arg = 0; arg < count; arg = arg + 1 {
    params.push(@lib.ValType::i32())
  }
  params
}

///|
fn optimize_instructions_test_i64_params(count : Int) -> Array[@lib.ValType] {
  let params : Array[@lib.ValType] = []
  for arg = 0; arg < count; arg = arg + 1 {
    params.push(@lib.ValType::i64())
  }
  params
}

///|
fn optimize_instructions_test_local_sum_then_global_set(
  arg_count : Int,
  global_idx : @lib.GlobalIdx,
) -> Array[@lib.Instruction] {
  let instrs : Array[@lib.Instruction] = []
  for arg = 0; arg < arg_count; arg = arg + 1 {
    instrs.push(@lib.Instruction::local_get(@lib.LocalIdx::new(arg.to_uint())))
    if arg > 0 {
      instrs.push(@lib.Instruction::i32_add())
    }
  }
  instrs.push(@lib.Instruction::global_set(global_idx))
  instrs
}

///|
fn optimize_instructions_test_mixed_direct_call_descriptor_miss_module(
  ref_arg_count : Int,
  desc_arg_count : Int,
  const_call_args? : Bool = false,
  i64_const_call_args? : Bool = false,
  global_call_args? : Bool = false,
) -> @lib.Module {
  let base_type = @lib.TypeIdx::new(0U)
  let base_descriptor_type = @lib.TypeIdx::new(1U)
  let subtype = @lib.TypeIdx::new(2U)
  let subtype_descriptor = @lib.TypeIdx::new(3U)
  let make_ref_func_type = @lib.TypeIdx::new(4U)
  let make_desc_func_type = @lib.TypeIdx::new(5U)
  let cast_func_type = @lib.TypeIdx::new(6U)
  let base_heap = @lib.HeapType::new(base_type)
  let base_ref_type = @lib.RefType::new(false, base_heap)
  let base_descriptor_ref_type = @lib.RefType::new(
    false,
    @lib.HeapType::new(base_descriptor_type),
    exact=true,
  )
  let sub_ref_type = @lib.RefType::new(false, @lib.HeapType::new(subtype))
  let ref_body = if i64_const_call_args {
    [
      @lib.Instruction::i32_const(@lib.I32(11)),
      @lib.Instruction::global_set(@lib.GlobalIdx::new(0U)),
    ]
  } else {
    optimize_instructions_test_local_sum_then_global_set(
      ref_arg_count,
      @lib.GlobalIdx::new(0U),
    )
  }
  ref_body.push(@lib.Instruction::struct_new_default(subtype_descriptor))
  ref_body.push(@lib.Instruction::struct_new_default_desc(subtype))
  let desc_body = if i64_const_call_args {
    [
      @lib.Instruction::i32_const(@lib.I32(17)),
      @lib.Instruction::global_set(@lib.GlobalIdx::new(1U)),
    ]
  } else {
    optimize_instructions_test_local_sum_then_global_set(
      desc_arg_count,
      @lib.GlobalIdx::new(1U),
    )
  }
  desc_body.push(@lib.Instruction::struct_new_default(base_descriptor_type))
  let cast_body : Array[@lib.Instruction] = []
  for arg = 0; arg < ref_arg_count; arg = arg + 1 {
    if const_call_args {
      cast_body.push(@lib.Instruction::i32_const(@lib.I32(100 + arg)))
    } else if i64_const_call_args {
      cast_body.push(
        @lib.Instruction::i64_const(@lib.I64((100 + arg).to_int64())),
      )
    } else if global_call_args {
      cast_body.push(
        @lib.Instruction::global_get(@lib.GlobalIdx::new((arg % 2).to_uint())),
      )
    } else {
      cast_body.push(
        @lib.Instruction::local_get(@lib.LocalIdx::new(arg.to_uint())),
      )
    }
  }
  cast_body.push(@lib.Instruction::call(@lib.FuncIdx::new(0U)))
  for arg = 0; arg < desc_arg_count; arg = arg + 1 {
    if const_call_args {
      cast_body.push(@lib.Instruction::i32_const(@lib.I32(200 + arg)))
    } else if i64_const_call_args {
      cast_body.push(
        @lib.Instruction::i64_const(@lib.I64((200 + arg).to_int64())),
      )
    } else if global_call_args {
      cast_body.push(
        @lib.Instruction::global_get(@lib.GlobalIdx::new((arg % 2).to_uint())),
      )
    } else {
      cast_body.push(
        @lib.Instruction::local_get(
          @lib.LocalIdx::new((ref_arg_count + arg).to_uint()),
        ),
      )
    }
  }
  cast_body.push(@lib.Instruction::call(@lib.FuncIdx::new(1U)))
  cast_body.push(@lib.Instruction::ref_cast_desc_eq_type(base_ref_type))
  let cast_params = if i64_const_call_args {
    optimize_instructions_test_i64_params(ref_arg_count + desc_arg_count)
  } else {
    optimize_instructions_test_i32_params(ref_arg_count + desc_arg_count)
  }
  let ref_call_params = if i64_const_call_args {
    optimize_instructions_test_i64_params(ref_arg_count)
  } else {
    optimize_instructions_test_i32_params(ref_arg_count)
  }
  let desc_call_params = if i64_const_call_args {
    optimize_instructions_test_i64_params(desc_arg_count)
  } else {
    optimize_instructions_test_i32_params(desc_arg_count)
  }
  @lib.Module::new()
  .with_type_sec(
    @lib.TypeSec::new([
      @lib.RecType::group([
        @lib.SubType::new(
          false,
          [],
          @lib.CompType::struct_([
            @lib.FieldType::new(
              @lib.StorageType::val_type(@lib.ValType::i32()),
              @lib.Mut::const_(),
            ),
          ]),
          metadata=@lib.TypeMetadata::new(descriptor=Some(base_descriptor_type)),
        ),
        @lib.SubType::new(
          false,
          [],
          @lib.CompType::struct_([]),
          metadata=@lib.TypeMetadata::new(describes=Some(base_type)),
        ),
        @lib.SubType::new(
          false,
          [base_type],
          @lib.CompType::struct_([
            @lib.FieldType::new(
              @lib.StorageType::val_type(@lib.ValType::i32()),
              @lib.Mut::const_(),
            ),
            @lib.FieldType::new(
              @lib.StorageType::val_type(@lib.ValType::i64()),
              @lib.Mut::const_(),
            ),
          ]),
          metadata=@lib.TypeMetadata::new(descriptor=Some(subtype_descriptor)),
        ),
        @lib.SubType::new(
          false,
          [base_descriptor_type],
          @lib.CompType::struct_([]),
          metadata=@lib.TypeMetadata::new(describes=Some(subtype)),
        ),
      ]),
      @lib.RecType::new(
        @lib.SubType::comp_type(
          @lib.CompType::func(ref_call_params, [
            @lib.ValType::ref_type(sub_ref_type),
          ]),
        ),
      ),
      @lib.RecType::new(
        @lib.SubType::comp_type(
          @lib.CompType::func(desc_call_params, [
            @lib.ValType::ref_type(base_descriptor_ref_type),
          ]),
        ),
      ),
      @lib.RecType::new(
        @lib.SubType::comp_type(
          @lib.CompType::func(cast_params, [
            @lib.ValType::ref_type(base_ref_type),
          ]),
        ),
      ),
    ]),
  )
  .with_func_sec(
    @lib.FuncSec::new([make_ref_func_type, make_desc_func_type, cast_func_type]),
  )
  .with_global_sec(
    @lib.GlobalSec::new([
      @lib.Global::new(
        @lib.GlobalType::new(@lib.ValType::i32(), true),
        @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
      ),
      @lib.Global::new(
        @lib.GlobalType::new(@lib.ValType::i32(), true),
        @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
      ),
    ]),
  )
  .with_code_sec(
    @lib.CodeSec::new([
      @lib.Func::new(@lib.Locals::empty(), @lib.Expr::new(ref_body)),
      @lib.Func::new(@lib.Locals::empty(), @lib.Expr::new(desc_body)),
      @lib.Func::new(@lib.Locals::empty(), @lib.Expr::new(cast_body)),
    ]),
  )
}

///|
fn optimize_instructions_test_assert_mixed_direct_call_descriptor_miss(
  ref_arg_count : Int,
  desc_arg_count : Int,
  const_call_args? : Bool = false,
  i64_const_call_args? : Bool = false,
  global_call_args? : Bool = false,
) -> Unit raise {
  let module_ = optimize_instructions_test_mixed_direct_call_descriptor_miss_module(
    ref_arg_count,
    desc_arg_count,
    const_call_args~,
    i64_const_call_args~,
    global_call_args~,
  )
  let optimized = if const_call_args || i64_const_call_args || global_call_args {
    match
      run_hot_pipeline(module_, HotPipelineOptions::new(), [
        "optimize-instructions",
      ]) {
      Ok(mod_) => mod_
      Err(err) =>
        fail(
          "expected descriptor miss nontrapping-argument pipeline success, got \{err}",
        )
    }
  } else {
    optimize_instructions_test_run_module(module_)
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_false(pretty.contains("ref.cast_desc_eq"), msg=pretty)
  let expected : Array[@lib.Instruction] = []
  for arg = 0; arg < ref_arg_count; arg = arg + 1 {
    if const_call_args {
      expected.push(@lib.Instruction::i32_const(@lib.I32(100 + arg)))
    } else if i64_const_call_args {
      expected.push(
        @lib.Instruction::i64_const(@lib.I64((100 + arg).to_int64())),
      )
    } else if global_call_args {
      expected.push(
        @lib.Instruction::global_get(@lib.GlobalIdx::new((arg % 2).to_uint())),
      )
    } else {
      expected.push(
        @lib.Instruction::local_get(@lib.LocalIdx::new(arg.to_uint())),
      )
    }
  }
  expected.push(@lib.Instruction::call(@lib.FuncIdx::new(0U)))
  expected.push(@lib.Instruction::drop())
  for arg = 0; arg < desc_arg_count; arg = arg + 1 {
    if const_call_args {
      expected.push(@lib.Instruction::i32_const(@lib.I32(200 + arg)))
    } else if i64_const_call_args {
      expected.push(
        @lib.Instruction::i64_const(@lib.I64((200 + arg).to_int64())),
      )
    } else if global_call_args {
      expected.push(
        @lib.Instruction::global_get(@lib.GlobalIdx::new((arg % 2).to_uint())),
      )
    } else {
      expected.push(
        @lib.Instruction::local_get(
          @lib.LocalIdx::new((ref_arg_count + arg).to_uint()),
        ),
      )
    }
  }
  expected.push(@lib.Instruction::call(@lib.FuncIdx::new(1U)))
  expected.push(@lib.Instruction::drop())
  expected.push(@lib.Instruction::unreachable_())
  match optimized.code_sec {
    Some(@lib.CodeSec([_, _, @lib.Func(_, @lib.Expr(body))])) =>
      @debug.assert_eq(body, expected)
    _ => fail("expected three-function descriptor-call test module")
  }
}

///|
fn optimize_instructions_test_mixed_direct_call_descriptor_success_module(
  ref_arg_count : Int,
  desc_arg_count : Int,
  exact_ref_result? : Bool = true,
  exact_cast_target? : Bool = true,
  nullable_cast_target? : Bool = false,
  const_call_args? : Bool = false,
  i64_const_call_args? : Bool = false,
  global_call_args? : Bool = false,
) -> @lib.Module {
  let base_type = @lib.TypeIdx::new(0U)
  let base_descriptor_type = @lib.TypeIdx::new(1U)
  let make_ref_func_type = @lib.TypeIdx::new(2U)
  let make_desc_func_type = @lib.TypeIdx::new(3U)
  let cast_func_type = @lib.TypeIdx::new(4U)
  let base_heap = @lib.HeapType::new(base_type)
  let base_ref_type = @lib.RefType::new(false, base_heap)
  let exact_base_ref_type = @lib.RefType::new(false, base_heap, exact=true)
  let base_descriptor_ref_type = @lib.RefType::new(
    false,
    @lib.HeapType::new(base_descriptor_type),
    exact=true,
  )
  let cast_target_ref_type = @lib.RefType::new(
    nullable_cast_target,
    base_heap,
    exact=exact_cast_target,
  )
  let ref_body = if i64_const_call_args {
    [
      @lib.Instruction::i32_const(@lib.I32(11)),
      @lib.Instruction::global_set(@lib.GlobalIdx::new(0U)),
    ]
  } else {
    optimize_instructions_test_local_sum_then_global_set(
      ref_arg_count,
      @lib.GlobalIdx::new(0U),
    )
  }
  ref_body.push(@lib.Instruction::struct_new_default(base_descriptor_type))
  ref_body.push(@lib.Instruction::struct_new_default_desc(base_type))
  let desc_body = if i64_const_call_args {
    [
      @lib.Instruction::i32_const(@lib.I32(17)),
      @lib.Instruction::global_set(@lib.GlobalIdx::new(1U)),
    ]
  } else {
    optimize_instructions_test_local_sum_then_global_set(
      desc_arg_count,
      @lib.GlobalIdx::new(1U),
    )
  }
  desc_body.push(@lib.Instruction::struct_new_default(base_descriptor_type))
  let cast_body : Array[@lib.Instruction] = []
  for arg = 0; arg < ref_arg_count; arg = arg + 1 {
    if const_call_args {
      cast_body.push(@lib.Instruction::i32_const(@lib.I32(100 + arg)))
    } else if i64_const_call_args {
      cast_body.push(
        @lib.Instruction::i64_const(@lib.I64((100 + arg).to_int64())),
      )
    } else if global_call_args {
      cast_body.push(
        @lib.Instruction::global_get(@lib.GlobalIdx::new((arg % 2).to_uint())),
      )
    } else {
      cast_body.push(
        @lib.Instruction::local_get(@lib.LocalIdx::new(arg.to_uint())),
      )
    }
  }
  cast_body.push(@lib.Instruction::call(@lib.FuncIdx::new(0U)))
  for arg = 0; arg < desc_arg_count; arg = arg + 1 {
    if const_call_args {
      cast_body.push(@lib.Instruction::i32_const(@lib.I32(200 + arg)))
    } else if i64_const_call_args {
      cast_body.push(
        @lib.Instruction::i64_const(@lib.I64((200 + arg).to_int64())),
      )
    } else if global_call_args {
      cast_body.push(
        @lib.Instruction::global_get(@lib.GlobalIdx::new((arg % 2).to_uint())),
      )
    } else {
      cast_body.push(
        @lib.Instruction::local_get(
          @lib.LocalIdx::new((ref_arg_count + arg).to_uint()),
        ),
      )
    }
  }
  cast_body.push(@lib.Instruction::call(@lib.FuncIdx::new(1U)))
  cast_body.push(@lib.Instruction::ref_cast_desc_eq_type(cast_target_ref_type))
  let ref_result_type = if exact_ref_result {
    exact_base_ref_type
  } else {
    base_ref_type
  }
  let cast_params = if const_call_args ||
    i64_const_call_args ||
    global_call_args {
    []
  } else {
    optimize_instructions_test_i32_params(ref_arg_count + desc_arg_count)
  }
  let ref_call_params = if i64_const_call_args {
    optimize_instructions_test_i64_params(ref_arg_count)
  } else {
    optimize_instructions_test_i32_params(ref_arg_count)
  }
  let desc_call_params = if i64_const_call_args {
    optimize_instructions_test_i64_params(desc_arg_count)
  } else {
    optimize_instructions_test_i32_params(desc_arg_count)
  }
  @lib.Module::new()
  .with_type_sec(
    @lib.TypeSec::new([
      @lib.RecType::group([
        @lib.SubType::new(
          false,
          [],
          @lib.CompType::struct_([
            @lib.FieldType::new(
              @lib.StorageType::val_type(@lib.ValType::i32()),
              @lib.Mut::const_(),
            ),
          ]),
          metadata=@lib.TypeMetadata::new(descriptor=Some(base_descriptor_type)),
        ),
        @lib.SubType::new(
          false,
          [],
          @lib.CompType::struct_([]),
          metadata=@lib.TypeMetadata::new(describes=Some(base_type)),
        ),
      ]),
      @lib.RecType::new(
        @lib.SubType::comp_type(
          @lib.CompType::func(ref_call_params, [
            @lib.ValType::ref_type(ref_result_type),
          ]),
        ),
      ),
      @lib.RecType::new(
        @lib.SubType::comp_type(
          @lib.CompType::func(desc_call_params, [
            @lib.ValType::ref_type(base_descriptor_ref_type),
          ]),
        ),
      ),
      @lib.RecType::new(
        @lib.SubType::comp_type(
          @lib.CompType::func(cast_params, [
            @lib.ValType::ref_type(cast_target_ref_type),
          ]),
        ),
      ),
    ]),
  )
  .with_func_sec(
    @lib.FuncSec::new([make_ref_func_type, make_desc_func_type, cast_func_type]),
  )
  .with_global_sec(
    @lib.GlobalSec::new([
      @lib.Global::new(
        @lib.GlobalType::new(@lib.ValType::i32(), true),
        @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
      ),
      @lib.Global::new(
        @lib.GlobalType::new(@lib.ValType::i32(), true),
        @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
      ),
    ]),
  )
  .with_code_sec(
    @lib.CodeSec::new([
      @lib.Func::new(@lib.Locals::empty(), @lib.Expr::new(ref_body)),
      @lib.Func::new(@lib.Locals::empty(), @lib.Expr::new(desc_body)),
      @lib.Func::new(@lib.Locals::empty(), @lib.Expr::new(cast_body)),
    ]),
  )
}

///|
fn optimize_instructions_test_assert_mixed_direct_call_descriptor_success(
  ref_arg_count : Int,
  desc_arg_count : Int,
) -> Unit raise {
  let module_ = optimize_instructions_test_mixed_direct_call_descriptor_success_module(
    ref_arg_count, desc_arg_count,
  )
  let optimized = optimize_instructions_test_run_module(module_)
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_false(pretty.contains("ref.cast_desc_eq"), msg=pretty)
  let expected : Array[@lib.Instruction] = []
  for arg = 0; arg < ref_arg_count; arg = arg + 1 {
    expected.push(
      @lib.Instruction::local_get(@lib.LocalIdx::new(arg.to_uint())),
    )
  }
  expected.push(@lib.Instruction::call(@lib.FuncIdx::new(0U)))
  for arg = 0; arg < desc_arg_count; arg = arg + 1 {
    expected.push(
      @lib.Instruction::local_get(
        @lib.LocalIdx::new((ref_arg_count + arg).to_uint()),
      ),
    )
  }
  expected.push(@lib.Instruction::call(@lib.FuncIdx::new(1U)))
  expected.push(@lib.Instruction::drop())
  match optimized.code_sec {
    Some(@lib.CodeSec([_, _, @lib.Func(_, @lib.Expr(body))])) =>
      @debug.assert_eq(body, expected)
    _ => fail("expected three-function descriptor-success test module")
  }
}

///|
fn optimize_instructions_test_assert_nonlocal_direct_call_exact_descriptor_success_boundary(
  ref_arg_count : Int,
  desc_arg_count : Int,
  const_call_args? : Bool = false,
  i64_const_call_args? : Bool = false,
  global_call_args? : Bool = false,
) -> Unit raise {
  let module_ = optimize_instructions_test_mixed_direct_call_descriptor_success_module(
    ref_arg_count,
    desc_arg_count,
    const_call_args~,
    i64_const_call_args~,
    global_call_args~,
  )
  let optimized = optimize_instructions_test_run_module(module_)
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_true(pretty.contains("ref.cast_desc_eq"), msg=pretty)
  let expected : Array[@lib.Instruction] = []
  for arg = 0; arg < ref_arg_count; arg = arg + 1 {
    if const_call_args {
      expected.push(@lib.Instruction::i32_const(@lib.I32(100 + arg)))
    } else if i64_const_call_args {
      expected.push(
        @lib.Instruction::i64_const(@lib.I64((100 + arg).to_int64())),
      )
    } else if global_call_args {
      expected.push(
        @lib.Instruction::global_get(@lib.GlobalIdx::new((arg % 2).to_uint())),
      )
    } else {
      expected.push(
        @lib.Instruction::local_get(@lib.LocalIdx::new(arg.to_uint())),
      )
    }
  }
  expected.push(@lib.Instruction::call(@lib.FuncIdx::new(0U)))
  for arg = 0; arg < desc_arg_count; arg = arg + 1 {
    if const_call_args {
      expected.push(@lib.Instruction::i32_const(@lib.I32(200 + arg)))
    } else if i64_const_call_args {
      expected.push(
        @lib.Instruction::i64_const(@lib.I64((200 + arg).to_int64())),
      )
    } else if global_call_args {
      expected.push(
        @lib.Instruction::global_get(@lib.GlobalIdx::new((arg % 2).to_uint())),
      )
    } else {
      expected.push(
        @lib.Instruction::local_get(
          @lib.LocalIdx::new((ref_arg_count + arg).to_uint()),
        ),
      )
    }
  }
  expected.push(@lib.Instruction::call(@lib.FuncIdx::new(1U)))
  expected.push(
    @lib.Instruction::ref_cast_desc_eq_type(
      @lib.RefType::new(
        false,
        @lib.HeapType::new(@lib.TypeIdx::new(0U)),
        exact=true,
      ),
    ),
  )
  match optimized.code_sec {
    Some(@lib.CodeSec([_, _, @lib.Func(_, @lib.Expr(body))])) =>
      @debug.assert_eq(body, expected)
    _ =>
      fail("expected three-function exact descriptor-success boundary module")
  }
}

///|
fn optimize_instructions_test_assert_mixed_direct_call_descriptor_exactifies_success(
  ref_arg_count : Int,
  desc_arg_count : Int,
  exact_ref_result? : Bool = true,
  exact_cast_target? : Bool = false,
  nullable_cast_target? : Bool = false,
  const_call_args? : Bool = false,
  i64_const_call_args? : Bool = false,
  global_call_args? : Bool = false,
) -> Unit raise {
  let module_ = optimize_instructions_test_mixed_direct_call_descriptor_success_module(
    ref_arg_count,
    desc_arg_count,
    exact_ref_result~,
    exact_cast_target~,
    nullable_cast_target~,
    const_call_args~,
    i64_const_call_args~,
    global_call_args~,
  )
  let optimized = optimize_instructions_test_run_module(module_)
  let expected : Array[@lib.Instruction] = []
  for arg = 0; arg < ref_arg_count; arg = arg + 1 {
    if const_call_args {
      expected.push(@lib.Instruction::i32_const(@lib.I32(100 + arg)))
    } else if i64_const_call_args {
      expected.push(
        @lib.Instruction::i64_const(@lib.I64((100 + arg).to_int64())),
      )
    } else if global_call_args {
      expected.push(
        @lib.Instruction::global_get(@lib.GlobalIdx::new((arg % 2).to_uint())),
      )
    } else {
      expected.push(
        @lib.Instruction::local_get(@lib.LocalIdx::new(arg.to_uint())),
      )
    }
  }
  expected.push(@lib.Instruction::call(@lib.FuncIdx::new(0U)))
  for arg = 0; arg < desc_arg_count; arg = arg + 1 {
    if const_call_args {
      expected.push(@lib.Instruction::i32_const(@lib.I32(200 + arg)))
    } else if i64_const_call_args {
      expected.push(
        @lib.Instruction::i64_const(@lib.I64((200 + arg).to_int64())),
      )
    } else if global_call_args {
      expected.push(
        @lib.Instruction::global_get(@lib.GlobalIdx::new((arg % 2).to_uint())),
      )
    } else {
      expected.push(
        @lib.Instruction::local_get(
          @lib.LocalIdx::new((ref_arg_count + arg).to_uint()),
        ),
      )
    }
  }
  expected.push(@lib.Instruction::call(@lib.FuncIdx::new(1U)))
  expected.push(
    @lib.Instruction::ref_cast_desc_eq_type(
      @lib.RefType::new(
        false,
        @lib.HeapType::new(@lib.TypeIdx::new(0U)),
        exact=true,
      ),
    ),
  )
  match optimized.code_sec {
    Some(@lib.CodeSec([_, _, @lib.Func(_, @lib.Expr(body))])) =>
      @debug.assert_eq(body, expected)
    _ => fail("expected three-function descriptor-exactification test module")
  }
}

///|
test "optimize-instructions keeps non-local exact descriptor successes" {
  // OI-J exact descriptor-success boundary: Binaryen removes the descriptor
  // equality cast only for the already-covered pure-local direct-call argument
  // family. If the same exact-success calls are fed by scalar constants or
  // global reads, Binaryen keeps the explicit descriptor check, so Starshine must
  // not reuse the broader exactification/miss nontrapping-argument predicate for
  // exact-success skipping.
  optimize_instructions_test_assert_nonlocal_direct_call_exact_descriptor_success_boundary(
    2,
    1,
    const_call_args=true,
  )
  optimize_instructions_test_assert_nonlocal_direct_call_exact_descriptor_success_boundary(
    2,
    1,
    i64_const_call_args=true,
  )
  optimize_instructions_test_assert_nonlocal_direct_call_exact_descriptor_success_boundary(
    2,
    1,
    global_call_args=true,
  )
}

///|
test "optimize-instructions exactifies direct-call descriptor success with constant arguments" {
  // OI-J pure-argument direct-call descriptor exactification: the reference and
  // descriptor operands are direct calls whose arguments are stack-local pure
  // i32 constants instead of `local.get*`. Binaryen keeps the descriptor check
  // and exactifies the cast target, so this extends the same semantic family to
  // pure constant argument localization without claiming effectful, trapping,
  // control/EH, indirect/call_ref, return_call*, TNH, or IIT behavior.
  optimize_instructions_test_assert_mixed_direct_call_descriptor_exactifies_success(
    2,
    1,
    const_call_args=true,
  )
}

///|
test "optimize-instructions narrows nullable direct-call descriptor success with constant arguments" {
  // Same-family nullable proof: constants may feed the direct calls, but a
  // nullable source cast still keeps `ref.cast_desc_eq` and narrows it to a
  // non-null exact target instead of entering the exact-success skip path.
  optimize_instructions_test_assert_mixed_direct_call_descriptor_exactifies_success(
    1,
    2,
    exact_ref_result=false,
    exact_cast_target=false,
    nullable_cast_target=true,
    const_call_args=true,
  )
}

///|
test "optimize-instructions exactifies direct-call descriptor success with i64 constant arguments" {
  // OI-J pure-argument direct-call descriptor exactification: `i64.const`
  // operands are the same nontrapping argument family as the earlier `i32.const`
  // probes. The direct calls still own the descriptor-success proof, so the pass
  // preserves both calls and exactifies the residual descriptor cast instead of
  // skipping it or depending on i32-only arity history.
  optimize_instructions_test_assert_mixed_direct_call_descriptor_exactifies_success(
    2,
    1,
    i64_const_call_args=true,
  )
}

///|
test "optimize-instructions narrows nullable direct-call descriptor success with i64 constant arguments" {
  // Same-family nullable proof for wider scalar constants: source order and the
  // descriptor equality check are preserved while the nullable/inexact cast is
  // rebuilt as non-null exact.
  optimize_instructions_test_assert_mixed_direct_call_descriptor_exactifies_success(
    1,
    2,
    exact_ref_result=false,
    exact_cast_target=false,
    nullable_cast_target=true,
    i64_const_call_args=true,
  )
}

///|
test "optimize-instructions exactifies direct-call descriptor success with global arguments" {
  // OI-J pure-argument direct-call descriptor exactification: `global.get`
  // operands read ordered i32 globals for direct-call arguments. Binaryen keeps
  // the descriptor equality check for this stack form and exactifies the cast,
  // so this extends the non-trapping argument family without merging into the
  // local-only exact-success skip path.
  optimize_instructions_test_assert_mixed_direct_call_descriptor_exactifies_success(
    2,
    1,
    global_call_args=true,
  )
}

///|
test "optimize-instructions narrows nullable direct-call descriptor success with global arguments" {
  // Same-family nullable proof for global.get arguments: preserve source order
  // and the descriptor check while narrowing the residual cast to non-null
  // exact, not skipping it as an exact descriptor success.
  optimize_instructions_test_assert_mixed_direct_call_descriptor_exactifies_success(
    1,
    2,
    exact_ref_result=false,
    exact_cast_target=false,
    nullable_cast_target=true,
    global_call_args=true,
  )
}

///|
test "optimize-instructions exactifies direct-call descriptor success with value-call arguments" {
  // OI-J direct-call descriptor exactification family: Binaryen exactifies an
  // inexact or nullable descriptor-success cast even when the direct reference
  // and descriptor calls are fed by ordered no-parameter direct scalar calls.
  // The value-producing calls are effectful call chunks that must stay in source
  // order before the owning reference/descriptor calls and the residual
  // descriptor equality check. This does not widen exact-success skipping,
  // descriptor misses, indirect/call_ref, return_call*, multivalue, control/EH,
  // TNH, or IIT behavior.
  let base_type = @lib.TypeIdx::new(0U)
  let base_descriptor_type = @lib.TypeIdx::new(1U)
  let make_i32_func_type = @lib.TypeIdx::new(2U)
  let make_ref_func_type = @lib.TypeIdx::new(3U)
  let make_desc_func_type = @lib.TypeIdx::new(4U)
  let exactify_func_type = @lib.TypeIdx::new(5U)
  let narrow_func_type = @lib.TypeIdx::new(6U)
  let base_heap = @lib.HeapType::new(base_type)
  let base_ref_type = @lib.RefType::new(false, base_heap)
  let nullable_base_ref_type = @lib.RefType::new(true, base_heap)
  let exact_base_ref_type = @lib.RefType::new(false, base_heap, exact=true)
  let exact_base_descriptor_ref_type = @lib.RefType::new(
    false,
    @lib.HeapType::new(base_descriptor_type),
    exact=true,
  )
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
            ]),
            metadata=@lib.TypeMetadata::new(
              descriptor=Some(base_descriptor_type),
            ),
          ),
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(base_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::i32()]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::i32()], [
              @lib.ValType::ref_type(base_ref_type),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::i32()], [
              @lib.ValType::ref_type(exact_base_descriptor_ref_type),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::ref_type(base_ref_type)]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [
              @lib.ValType::ref_type(nullable_base_ref_type),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        make_i32_func_type, make_ref_func_type, make_desc_func_type, exactify_func_type,
        narrow_func_type,
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(7))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::struct_new_default(base_descriptor_type),
            @lib.Instruction::struct_new_default_desc(base_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::struct_new_default(base_descriptor_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::call(@lib.FuncIdx::new(1U)),
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::call(@lib.FuncIdx::new(2U)),
            @lib.Instruction::ref_cast_desc_eq_type(base_ref_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::call(@lib.FuncIdx::new(1U)),
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::call(@lib.FuncIdx::new(2U)),
            @lib.Instruction::ref_cast_desc_eq_type(nullable_base_ref_type),
          ]),
        ),
      ]),
    ),
  )
  let expected = [
    @lib.Instruction::call(@lib.FuncIdx::new(0U)),
    @lib.Instruction::call(@lib.FuncIdx::new(1U)),
    @lib.Instruction::call(@lib.FuncIdx::new(0U)),
    @lib.Instruction::call(@lib.FuncIdx::new(2U)),
    @lib.Instruction::ref_cast_desc_eq_type(exact_base_ref_type),
  ]
  match optimized.code_sec {
    Some(
      @lib.CodeSec(
        [
          _,
          _,
          _,
          @lib.Func(_, @lib.Expr(exactify_body)),
          @lib.Func(_, @lib.Expr(narrow_body)),
        ]
      )
    ) => {
      @debug.assert_eq(exactify_body, expected)
      @debug.assert_eq(narrow_body, expected)
    }
    _ =>
      fail("expected five-function descriptor value-call exactification module")
  }
}

///|
test "optimize-instructions narrows nullable direct-call descriptor success with exact same-heap result" {
  // OI-J nullable direct-call descriptor-success family: Binaryen keeps the
  // explicit descriptor equality cast for a nullable target even when the
  // direct reference call already returns exact non-null `$base`, but it narrows
  // the cast result to non-null exact `$base`. This is not the exact non-null
  // skip family because the nullable source spelling still preserves the
  // descriptor check.
  optimize_instructions_test_assert_mixed_direct_call_descriptor_exactifies_success(
    10,
    1,
    exact_cast_target=true,
    nullable_cast_target=true,
  )
}

///|
test "optimize-instructions exactifies nullable direct-call descriptor success with inexact same-heap result" {
  // Sibling same-family proof: an inexact non-null same-heap direct-call result
  // with an exact descriptor call narrows from nullable inexact `$base` to
  // non-null exact `$base` while keeping `ref.cast_desc_eq` in source order.
  optimize_instructions_test_assert_mixed_direct_call_descriptor_exactifies_success(
    1,
    10,
    exact_ref_result=false,
    exact_cast_target=false,
    nullable_cast_target=true,
  )
}

///|
test "optimize-instructions exactifies direct-call descriptor success with exact same-heap result" {
  // OI-J direct-call descriptor exactification family: an ordered pure
  // local.get* reference call returns a non-null value from the target heap and
  // an ordered pure descriptor call returns the exact target descriptor, but the
  // source cast target is inexact. Binaryen keeps the descriptor cast while
  // exactifying its result type, so Starshine must not treat this as the
  // exact-target skip family.
  optimize_instructions_test_assert_mixed_direct_call_descriptor_exactifies_success(
    10, 1,
  )
}

///|
test "optimize-instructions exactifies direct-call descriptor success with inexact same-heap result" {
  // Sibling same-family proof: the reference result need only be a non-null
  // same-heap value, not already exact, because the exact descriptor operand is
  // the source of the exactness proof. This remains narrower than nullable,
  // strict-subtype miss, effectful/non-local argument, indirect/call_ref,
  // return_call*, multivalue, control/EH, TNH, or IIT behavior.
  optimize_instructions_test_assert_mixed_direct_call_descriptor_exactifies_success(
    1,
    10,
    exact_ref_result=false,
  )
}

///|
test "optimize-instructions skips descriptor casts with semantic family mixed 10-ref 1-desc exact descriptor success" {
  // OI-J direct-call descriptor-success family: ordered pure `local.get*`
  // reference arguments feed a direct call that returns an exact non-null
  // instance of the cast target, and ordered pure descriptor arguments feed a
  // direct call returning the exact descriptor for that target. The descriptor
  // equality check cannot fail and does not add exactness, so the pass may
  // preserve ref args; call ref; desc args; call desc; drop, leaving the
  // original reference result on the stack.
  optimize_instructions_test_assert_mixed_direct_call_descriptor_success(10, 1)
}

///|
test "optimize-instructions skips descriptor casts with semantic family mixed 1-ref 10-desc exact descriptor success" {
  // Inverse same-family proof for direct-call descriptor success. Coverage is
  // by semantic precondition, not by one-off arity whitelisting.
  optimize_instructions_test_assert_mixed_direct_call_descriptor_success(1, 10)
}

///|
test "optimize-instructions folds descriptor casts with semantic family mixed 10-ref 1-desc exact descriptor miss" {
  // OI-J direct-call descriptor-miss family: this previously-unlisted arity
  // pair has the same semantic shape as the covered grid: ordered pure
  // `local.get*` reference arguments, a direct reference call returning a
  // non-null strict subtype of the cast target, ordered pure `local.get*`
  // descriptor arguments, and a direct descriptor call that exactly describes
  // the target. The fold must preserve ref-args; call-ref; drop; desc-args;
  // call-desc; drop; unreachable evaluation order.
  optimize_instructions_test_assert_mixed_direct_call_descriptor_miss(10, 1)
}

///|
test "optimize-instructions folds descriptor casts with semantic family mixed 1-ref 10-desc exact descriptor miss" {
  // Inverse same-family proof for the direct-call descriptor miss. Coverage is
  // by semantic precondition, not by one-off arity whitelisting.
  optimize_instructions_test_assert_mixed_direct_call_descriptor_miss(1, 10)
}

///|
test "optimize-instructions folds descriptor casts with semantic family 11-arg exact descriptor miss" {
  // Same-family equal-arity case beyond the old evidence-history ceiling.
  // This guards the family predicate while keeping non-local/effectful args,
  // indirect calls, return_call*, multivalue, escaping control/EH, and TNH/IIT
  // behavior out of scope for this narrow direct-call descriptor-miss fold.
  optimize_instructions_test_assert_mixed_direct_call_descriptor_miss(11, 11)
}

///|
test "optimize-instructions folds direct-call descriptor misses with i32 constant arguments" {
  // OI-J direct-call descriptor-miss argument family: scalar i32 constants are
  // nontrapping ordered operands for the reference and descriptor calls. A
  // strict-subtype reference result plus an exact target descriptor still means
  // the descriptor cast cannot succeed, so the fold preserves constants, calls,
  // drops, and the final unreachable rather than relying on local-only arity
  // history.
  optimize_instructions_test_assert_mixed_direct_call_descriptor_miss(
    2,
    1,
    const_call_args=true,
  )
}

///|
test "optimize-instructions folds direct-call descriptor misses with i64 constant arguments" {
  // Same semantic miss family for wider nontrapping scalar constants. This is
  // deliberately separate from exact-success skipping: the reference call
  // returns a strict subtype, so the explicit descriptor equality check is known
  // to fail after both direct calls and their i64 arguments are evaluated.
  optimize_instructions_test_assert_mixed_direct_call_descriptor_miss(
    1,
    2,
    i64_const_call_args=true,
  )
}

///|
test "optimize-instructions folds direct-call descriptor misses with global arguments" {
  // Same semantic miss family for ordered global.get operands. The globals are
  // read before their direct calls, then both call results are dropped before
  // unreachable; this does not widen to effectful/trapping argument expressions,
  // indirect/call_ref producers, return_call*, control/EH, TNH, or IIT behavior.
  optimize_instructions_test_assert_mixed_direct_call_descriptor_miss(
    2,
    1,
    global_call_args=true,
  )
}

///|
test "optimize-instructions folds descriptor casts with mixed 3-ref 4-desc call exact descriptor misses" {
  // OI-J descriptor/effect order slice: Binaryen version_130 also folds the
  // exact descriptor miss when the reference call takes three pure local
  // arguments and the descriptor call takes four pure local arguments. Keep
  // this narrower than general argument localization: no other mixed arity,
  // effectful/trapping arguments, indirect/call_ref, return_call*, multivalue,
  // escaping control/EH, or TNH/IIT widening is implied.
  optimize_instructions_test_assert_mixed_direct_call_descriptor_miss(3, 4)
}

///|
test "optimize-instructions folds descriptor casts with mixed 4-ref 3-desc call exact descriptor misses" {
  // OI-J descriptor/effect order slice: Binaryen version_130 also folds the
  // exact descriptor miss when the reference call takes four pure local
  // arguments and the descriptor call takes three pure local arguments. Keep
  // this narrower than general argument localization: no other mixed arity,
  // effectful/trapping arguments, indirect/call_ref, return_call*, multivalue,
  // escaping control/EH, or TNH/IIT widening is implied.
  optimize_instructions_test_assert_mixed_direct_call_descriptor_miss(4, 3)
}

///|
test "optimize-instructions folds descriptor casts with mixed 5-ref 2-desc call exact descriptor misses" {
  // OI-J descriptor/effect order slice: Binaryen version_130 also folds the
  // exact descriptor miss when the reference call takes five pure local
  // arguments and the descriptor call takes two pure local arguments. Keep
  // this narrower than general argument localization: no other mixed arity,
  // effectful/trapping arguments, indirect/call_ref, return_call*, multivalue,
  // escaping control/EH, or TNH/IIT widening is implied.
  optimize_instructions_test_assert_mixed_direct_call_descriptor_miss(5, 2)
}

///|
test "optimize-instructions folds descriptor casts with mixed 3-ref 5-desc call exact descriptor misses" {
  // OI-J descriptor/effect order slice: Binaryen version_130 also folds the
  // exact descriptor miss when the reference call takes three pure local
  // arguments and the descriptor call takes five pure local arguments. Keep
  // this narrower than general argument localization: no other mixed arity,
  // effectful/trapping arguments, indirect/call_ref, return_call*, multivalue,
  // escaping control/EH, or TNH/IIT widening is implied.
  optimize_instructions_test_assert_mixed_direct_call_descriptor_miss(3, 5)
}

///|
test "optimize-instructions folds descriptor casts with mixed 5-ref 3-desc call exact descriptor misses" {
  // OI-J descriptor/effect order slice: Binaryen version_130 also folds the
  // exact descriptor miss when the reference call takes five pure local
  // arguments and the descriptor call takes three pure local arguments. Keep
  // this narrower than general argument localization: no other mixed arity,
  // effectful/trapping arguments, indirect/call_ref, return_call*, multivalue,
  // escaping control/EH, or TNH/IIT widening is implied.
  optimize_instructions_test_assert_mixed_direct_call_descriptor_miss(5, 3)
}

///|
test "optimize-instructions folds descriptor casts with mixed 4-ref 5-desc call exact descriptor misses" {
  // OI-J descriptor/effect order slice: Binaryen version_130 also folds the
  // exact descriptor miss when the reference call takes four pure local
  // arguments and the descriptor call takes five pure local arguments. Keep
  // this narrower than general argument localization: no other mixed arity,
  // effectful/trapping arguments, indirect/call_ref, return_call*, multivalue,
  // escaping control/EH, or TNH/IIT widening is implied.
  optimize_instructions_test_assert_mixed_direct_call_descriptor_miss(4, 5)
}

///|
test "optimize-instructions folds descriptor casts with mixed 5-ref 4-desc call exact descriptor misses" {
  // OI-J descriptor/effect order slice: Binaryen version_130 also folds the
  // exact descriptor miss when the reference call takes five pure local
  // arguments and the descriptor call takes four pure local arguments. This
  // completes the current <=5-per-call mixed direct-call arity grid without
  // implying effectful/trapping arguments, indirect/call_ref, return_call*,
  // multivalue, escaping control/EH, wider calls, or TNH/IIT widening.
  optimize_instructions_test_assert_mixed_direct_call_descriptor_miss(5, 4)
}

///|
test "optimize-instructions folds descriptor casts with four-arg call exact descriptor misses" {
  // OI-J descriptor/effect order slice: Binaryen version_130 folds the exact
  // descriptor miss when both direct calls take exactly four pure local
  // arguments. Keep this as the current equal-arity ceiling: no mixed arity,
  // effectful/trapping arguments, indirect/call_ref, return_call*, multivalue,
  // escaping control/EH, or TNH/IIT widening is implied.
  let base_type = @lib.TypeIdx::new(0U)
  let base_descriptor_type = @lib.TypeIdx::new(1U)
  let subtype = @lib.TypeIdx::new(2U)
  let subtype_descriptor = @lib.TypeIdx::new(3U)
  let make_ref_func_type = @lib.TypeIdx::new(4U)
  let make_desc_func_type = @lib.TypeIdx::new(5U)
  let cast_func_type = @lib.TypeIdx::new(6U)
  let base_heap = @lib.HeapType::new(base_type)
  let base_ref_type = @lib.RefType::new(false, base_heap)
  let base_descriptor_ref_type = @lib.RefType::new(
    false,
    @lib.HeapType::new(base_descriptor_type),
    exact=true,
  )
  let sub_ref_type = @lib.RefType::new(false, @lib.HeapType::new(subtype))
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
            ]),
            metadata=@lib.TypeMetadata::new(
              descriptor=Some(base_descriptor_type),
            ),
          ),
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(base_type)),
          ),
          @lib.SubType::new(
            false,
            [base_type],
            @lib.CompType::struct_([
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i64()),
                @lib.Mut::const_(),
              ),
            ]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(subtype_descriptor)),
          ),
          @lib.SubType::new(
            false,
            [base_descriptor_type],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(subtype)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func(
              [
                @lib.ValType::i32(),
                @lib.ValType::i32(),
                @lib.ValType::i32(),
                @lib.ValType::i32(),
              ],
              [@lib.ValType::ref_type(sub_ref_type)],
            ),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func(
              [
                @lib.ValType::i32(),
                @lib.ValType::i32(),
                @lib.ValType::i32(),
                @lib.ValType::i32(),
              ],
              [@lib.ValType::ref_type(base_descriptor_ref_type)],
            ),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func(
              [
                @lib.ValType::i32(),
                @lib.ValType::i32(),
                @lib.ValType::i32(),
                @lib.ValType::i32(),
                @lib.ValType::i32(),
                @lib.ValType::i32(),
                @lib.ValType::i32(),
                @lib.ValType::i32(),
              ],
              [@lib.ValType::ref_type(base_ref_type)],
            ),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        make_ref_func_type, make_desc_func_type, cast_func_type,
      ]),
    )
    .with_global_sec(
      @lib.GlobalSec::new([
        @lib.Global::new(
          @lib.GlobalType::new(@lib.ValType::i32(), true),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
        ),
        @lib.Global::new(
          @lib.GlobalType::new(@lib.ValType::i32(), true),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
            @lib.Instruction::i32_add(),
            @lib.Instruction::local_get(@lib.LocalIdx::new(2U)),
            @lib.Instruction::i32_add(),
            @lib.Instruction::local_get(@lib.LocalIdx::new(3U)),
            @lib.Instruction::i32_add(),
            @lib.Instruction::global_set(@lib.GlobalIdx::new(0U)),
            @lib.Instruction::struct_new_default(subtype_descriptor),
            @lib.Instruction::struct_new_default_desc(subtype),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
            @lib.Instruction::i32_add(),
            @lib.Instruction::local_get(@lib.LocalIdx::new(2U)),
            @lib.Instruction::i32_add(),
            @lib.Instruction::local_get(@lib.LocalIdx::new(3U)),
            @lib.Instruction::i32_add(),
            @lib.Instruction::global_set(@lib.GlobalIdx::new(1U)),
            @lib.Instruction::struct_new_default(base_descriptor_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(2U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(3U)),
            @lib.Instruction::call(@lib.FuncIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(4U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(5U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(6U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(7U)),
            @lib.Instruction::call(@lib.FuncIdx::new(1U)),
            @lib.Instruction::ref_cast_desc_eq_type(base_ref_type),
          ]),
        ),
      ]),
    )
  let optimized = optimize_instructions_test_run_module(module_)
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_false(pretty.contains("ref.cast_desc_eq"), msg=pretty)
  match optimized.code_sec {
    Some(
      @lib.CodeSec(
        [
          _,
          _,
          @lib.Func(
            _,
            @lib.Expr(
              [
                @lib.LocalGet(arg0),
                @lib.LocalGet(arg1),
                @lib.LocalGet(arg2),
                @lib.LocalGet(arg3),
                @lib.Call(ref_func),
                @lib.Drop,
                @lib.LocalGet(arg4),
                @lib.LocalGet(arg5),
                @lib.LocalGet(arg6),
                @lib.LocalGet(arg7),
                @lib.Call(desc_func),
                @lib.Drop,
                @lib.Unreachable,
              ]
            )
          ),
        ]
      )
    ) => {
      @debug.assert_eq(arg0, @lib.LocalIdx::new(0U))
      @debug.assert_eq(arg1, @lib.LocalIdx::new(1U))
      @debug.assert_eq(arg2, @lib.LocalIdx::new(2U))
      @debug.assert_eq(arg3, @lib.LocalIdx::new(3U))
      @debug.assert_eq(ref_func, @lib.FuncIdx::new(0U))
      @debug.assert_eq(arg4, @lib.LocalIdx::new(4U))
      @debug.assert_eq(arg5, @lib.LocalIdx::new(5U))
      @debug.assert_eq(arg6, @lib.LocalIdx::new(6U))
      @debug.assert_eq(arg7, @lib.LocalIdx::new(7U))
      @debug.assert_eq(desc_func, @lib.FuncIdx::new(1U))
    }
    _ =>
      fail(
        "expected four ref args; call ref; drop; four desc args; call desc; drop; unreachable",
      )
  }
}

