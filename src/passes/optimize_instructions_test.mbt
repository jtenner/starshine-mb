///|
test "optimize-instructions folds i32 eqz nonthrowing try constants in boolean context" {
  // Red-first OI-F behavior-parity slice: Binaryen v130
  // `Properties::getImmediateFallthrough` descends through a legacy try when
  // `EffectAnalyzer(...).throws()` proves its body nonthrowing, then
  // `optimizeBoolean` folds the selected i32 constant. Oracle:
  // `.tmp/oi-probes/boolean-eqz-fallthrough-try.wat`.
  let assert_fold = fn(tail : Int, expected : Int) raise {
    let i32_type = @lib.ValType::i32()
    let func = @ir.HotFunc::new()
    @ir.hot_body_result_type_set(
      func,
      @ir.hot_type_intern_value(func, i32_type),
    )
    let try_value = @ir.hot_build_try(
      func,
      @lib.BlockType::val_type(i32_type),
      [@ir.hot_build_const_i32(func, @lib.I32(tail))],
      catch_body=Some([@ir.hot_build_const_i32(func, @lib.I32(7))]),
    )
    let condition = @ir.hot_build_unary(func, i32_type, try_value)
    @ir.hot_node_exact_instr_set(func, condition, @lib.Instruction::i32_eqz())
    @ir.hot_root_append(
      func,
      @ir.hot_build_if(
        func,
        @lib.BlockType::val_type(i32_type),
        condition,
        [@ir.hot_build_const_i32(func, @lib.I32(11))],
        else_body=Some([@ir.hot_build_const_i32(func, @lib.I32(22))]),
      ),
    )
    let ctx = HotPassContext::new(
      optimize_instructions_descriptor(),
      @ir.HotAnalysisCache::new(),
      HotPipelineVerifyPolicy::after_each_pass(),
      false,
      fn(_) { () },
    )
    match hot_pass_run(ctx, func) {
      Ok(_) => ()
      Err(err) => fail("expected i32 try fallthrough optimization, got \{err}")
    }
    let result = @ir.hot_child_get(func, @ir.hot_root_get(func, 0), 0)
    match @ir.hot_node_get(func, result).op {
      @ir.HotOp::Const => ()
      other => fail("expected folded i32 try truth constant, got \{other}")
    }
    @debug.assert_eq(
      @ir.hot_const_get(func, @ir.hot_node_get(func, result).imm0),
      @ir.HotConstPayload::i32_const(@lib.I32(expected)),
    )
  }
  assert_fold(0, 1)
  assert_fold(9, 0)
}

