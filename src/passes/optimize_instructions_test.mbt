///|
test "optimize-instructions lowers one-bit false-zero selects to and" {
  // Red-first OI-F parity slice: Binaryen version_130 `optimizeSelect` uses
  // `Bits::getMaxBits` facts for the condition and both i32 arms before
  // rewriting `select(y, 0, x)` to `i32.and(y, x)`. The focused oracle is
  // `.tmp/oi-probes/select-boolean-algebra.wat`.
  let func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32 i32 i32) (result i32) local.get 2 local.get 3 i32.eq i32.const 0 local.get 0 local.get 1 i32.lt_u select))",
  )
  let root = @ir.hot_root_get(func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(func, root),
    Some(@lib.Instruction::i32_and()),
  )
  @debug.assert_eq(
    @ir.hot_node_exact_instr(func, @ir.hot_child_get(func, root, 0)),
    Some(@lib.Instruction::i32_eq()),
  )
  @debug.assert_eq(
    @ir.hot_node_exact_instr(func, @ir.hot_child_get(func, root, 1)),
    Some(@lib.Instruction::i32_lt_u()),
  )
}

///|
test "optimize-instructions lowers one-bit true-one selects to or" {
  // Red-first OI-F parity slice: Binaryen version_130's sibling one-bit rule
  // rewrites `select(1, y, x)` to `i32.or(y, x)` after proving the condition
  // and both arms have `Bits::getMaxBits <= 1`. Oracle:
  // `.tmp/oi-probes/select-boolean-algebra.wat`.
  let func = optimize_instructions_test_run_hot(
    "(module (func (param i32 i32 i32 i32) (result i32) i32.const 1 local.get 2 local.get 3 i32.ne local.get 0 local.get 1 i32.lt_s select))",
  )
  let root = @ir.hot_root_get(func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(func, root),
    Some(@lib.Instruction::i32_or()),
  )
  @debug.assert_eq(
    @ir.hot_node_exact_instr(func, @ir.hot_child_get(func, root, 0)),
    Some(@lib.Instruction::i32_ne()),
  )
  @debug.assert_eq(
    @ir.hot_node_exact_instr(func, @ir.hot_child_get(func, root, 1)),
    Some(@lib.Instruction::i32_lt_s()),
  )
}

///|
test "optimize-instructions hoists eqz from select arms paired with booleans" {
  // Red-first OI-F ternary parity slice: Binaryen version_130
  // `optimizeTernary` moves a direct i32/i64 eqz out of a select when the
  // sibling arm is an i32 boolean constant, flips that constant into the eqz
  // input type, and leaves the original condition on the inner select. Oracle:
  // `.tmp/oi-probes/select-eqz-const-hoist.wat`.
  let assert_hoisted = fn(
    wat : String,
    expected_unary : @lib.Instruction,
    expected_const : @ir.HotConstPayload,
    const_slot : Int,
  ) raise {
    let func = optimize_instructions_test_run_hot(wat)
    let root = @ir.hot_root_get(func, 0)
    @debug.assert_eq(@ir.hot_node_exact_instr(func, root), Some(expected_unary))
    let inner = @ir.hot_child_get(func, root, 0)
    match @ir.hot_node_get(func, inner).op {
      @ir.HotOp::Select => ()
      other => fail("expected hoisted eqz child select, got \{other}")
    }
    let flipped_const = @ir.hot_child_get(func, inner, const_slot)
    @debug.assert_eq(
      @ir.hot_const_get(func, @ir.hot_node_get(func, flipped_const).imm0),
      expected_const,
    )
  }
  assert_hoisted(
    "(module (func (param i32 i32) (result i32) local.get 0 i32.eqz i32.const 0 local.get 1 select))",
    @lib.Instruction::i32_eqz(),
    @ir.HotConstPayload::i32_const(@lib.I32(1)),
    1,
  )
  assert_hoisted(
    "(module (func (param i32 i32) (result i32) i32.const 1 local.get 0 i32.eqz local.get 1 select))",
    @lib.Instruction::i32_eqz(),
    @ir.HotConstPayload::i32_const(@lib.I32(0)),
    0,
  )
  assert_hoisted(
    "(module (func (param i64 i32) (result i32) local.get 0 i64.eqz i32.const 1 local.get 1 select))",
    @lib.Instruction::i64_eqz(),
    @ir.HotConstPayload::i64_const(@lib.I64(0L)),
    1,
  )
  assert_hoisted(
    "(module (func (param i64 i32) (result i32) i32.const 0 local.get 0 i64.eqz local.get 1 select))",
    @lib.Instruction::i64_eqz(),
    @ir.HotConstPayload::i64_const(@lib.I64(1L)),
    0,
  )
}

///|
test "optimize-instructions hoists matching eqz select arm shells" {
  // Red-first OI-F ternary parity slice: Binaryen version_130's shallow-equal
  // one-child loop moves matching direct i32/i64 eqz shells outside a select
  // after proving equal child types, no shallow shell effects, and selectable
  // child arms. Oracle: `.tmp/oi-probes/select-matching-unary-hoist.wat`.
  let assert_hoisted = fn(
    wat : String,
    expected_unary : @lib.Instruction,
    expected_child_type : @lib.ValType,
  ) raise {
    let func = optimize_instructions_test_run_hot(wat)
    let root = @ir.hot_root_get(func, 0)
    @debug.assert_eq(@ir.hot_node_exact_instr(func, root), Some(expected_unary))
    let inner = @ir.hot_child_get(func, root, 0)
    match @ir.hot_node_get(func, inner).op {
      @ir.HotOp::Select => ()
      other =>
        fail("expected matching eqz shells to hoist over select, got \{other}")
    }
    @debug.assert_eq(
      @ir.hot_type_results(func, @ir.hot_node_type(func, inner)),
      [expected_child_type],
    )
  }
  assert_hoisted(
    "(module (func (param i32 i32 i32) (result i32) local.get 0 i32.eqz local.get 1 i32.eqz local.get 2 select))",
    @lib.Instruction::i32_eqz(),
    @lib.ValType::i32(),
  )
  assert_hoisted(
    "(module (func (param i64 i64 i32) (result i32) local.get 0 i64.eqz local.get 1 i64.eqz local.get 2 select))",
    @lib.Instruction::i64_eqz(),
    @lib.ValType::i64(),
  )
}

