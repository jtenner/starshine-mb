///|
test "optimize-instructions rewrites equal array.new_fixed values through facts" {
  // OI-K/OI-L aggregate constructor fact: Binaryen version_130
  // `visitArrayNewFixed` compares adjacent fixed elements with
  // `areConsecutiveInputsEqual`. Equal default values become
  // `array.new_default`; equal non-default values become repeated-value
  // `array.new`; unequal values remain `array.new_fixed`.
  let array_type = @lib.TypeIdx::new(0U)
  let result_type = @lib.TypeIdx::new(1U)
  let param_result_type = @lib.TypeIdx::new(2U)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::array(
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
            ),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [
              @lib.ValType::ref_null(@lib.HeapType::new(array_type)),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::i32()], [
              @lib.ValType::ref_null(@lib.HeapType::new(array_type)),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        result_type, result_type, param_result_type, result_type,
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::array_new_fixed(array_type, @lib.U32(2U)),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::array_new_fixed(array_type, @lib.U32(2U)),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::array_new_fixed(array_type, @lib.U32(2U)),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::i32_const(@lib.I32(8)),
            @lib.Instruction::array_new_fixed(array_type, @lib.U32(2U)),
          ]),
        ),
      ]),
    ),
  )
  let non_default = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(non_default.contains("array.new_fixed"), msg=non_default)
  assert_false(non_default.contains("array.new_default"), msg=non_default)
  assert_true(non_default.contains("array.new"), msg=non_default)
  assert_true(non_default.contains("I32(2)"), msg=non_default)
  let default_value = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_false(default_value.contains("array.new_fixed"), msg=default_value)
  assert_true(default_value.contains("array.new_default"), msg=default_value)
  assert_true(default_value.contains("I32(2)"), msg=default_value)
  let repeated_local = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_false(repeated_local.contains("array.new_fixed"), msg=repeated_local)
  assert_false(repeated_local.contains("array.new_default"), msg=repeated_local)
  assert_true(repeated_local.contains("array.new"), msg=repeated_local)
  assert_true(
    repeated_local.contains("local.get (Local 0)"),
    msg=repeated_local,
  )
  assert_true(repeated_local.contains("I32(2)"), msg=repeated_local)
  let unequal = optimized.pretty_print_func(@lib.FuncIdx::new(3U))
  assert_true(unequal.contains("array.new_fixed"), msg=unequal)
}

///|
test "optimize-instructions preserves local tee default array.new_fixed effects through facts" {
  // OI-K/OI-L aggregate constructor fact: Binaryen version_130
  // `visitArrayNewFixed` checks the default value through `getFallthrough`,
  // then uses `getDroppedChildrenAndAppend` so a default-producing
  // `local.tee` is still evaluated before the new `array.new_default`.
  let array_type = @lib.TypeIdx::new(0U)
  let result_type = @lib.TypeIdx::new(1U)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::array(
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
            ),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::i32()]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([result_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::single(1U, @lib.ValType::i32()),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(9)),
            @lib.Instruction::local_set(@lib.LocalIdx::new(0U)),
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::local_tee(@lib.LocalIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::array_new_fixed(array_type, @lib.U32(2U)),
            @lib.Instruction::drop(),
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
          ]),
        ),
      ]),
    ),
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("array.new_fixed"), msg=pretty)
  assert_true(pretty.contains("array.new_default"), msg=pretty)
  assert_true(pretty.contains("drop"), msg=pretty)
  assert_true(pretty.contains("local.set (Local 0)"), msg=pretty)
  assert_true(pretty.contains("I32(0)"), msg=pretty)
  assert_true(pretty.contains("I32(2)"), msg=pretty)
}

///|
test "optimize-instructions localizes non-default repeated array.new_fixed effects through facts" {
  // OI-K/OI-L aggregate constructor fact: Binaryen version_130
  // `visitArrayNewFixed` uses `getDroppedChildrenAndAppend` when equal
  // non-default operands collapse to `array.new`. Effectful or state-reading
  // fixed operands are materialized into scratch locals before the repeated
  // value allocation, rather than being silently dropped by a scanner-style
  // fixed-array rewrite.
  let array_type = @lib.TypeIdx::new(0U)
  let result_type = @lib.TypeIdx::new(1U)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::array(
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
            ),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [
              @lib.ValType::ref_null(@lib.HeapType::new(array_type)),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([result_type, result_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::single(1U, @lib.ValType::i32()),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::local_tee(@lib.LocalIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::array_new_fixed(array_type, @lib.U32(2U)),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::single(1U, @lib.ValType::i32()),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(@lib.ValType::i32()),
              @lib.Expr::new([
                @lib.Instruction::i32_const(@lib.I32(9)),
                @lib.Instruction::local_set(@lib.LocalIdx::new(0U)),
                @lib.Instruction::i32_const(@lib.I32(7)),
              ]),
            ),
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::array_new_fixed(array_type, @lib.U32(2U)),
          ]),
        ),
      ]),
    ),
  )
  let tee_get = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(tee_get.contains("array.new_fixed"), msg=tee_get)
  assert_true(tee_get.contains("array.new"), msg=tee_get)
  assert_true(tee_get.contains("local.set (Local 1)"), msg=tee_get)
  assert_true(tee_get.contains("local.set (Local 2)"), msg=tee_get)
  optimize_instructions_assert_strings_in_order(tee_get, [
    "local.tee", "local.set (Local 1)", "local.get (Local 0)", "local.set (Local 2)",
    "local.get (Local 1)", "array.new",
  ])
  let block_const = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_false(block_const.contains("array.new_fixed"), msg=block_const)
  assert_true(block_const.contains("array.new"), msg=block_const)
  assert_true(block_const.contains("local.set (Local 0)"), msg=block_const)
  assert_true(block_const.contains("local.set (Local 1)"), msg=block_const)
  optimize_instructions_assert_strings_in_order(block_const, [
    "block", "local.set (Local 0)", "local.set (Local 1)", "local.get (Local 1)",
    "array.new",
  ])
}

///|
test "optimize-instructions preserves block default array.new_fixed effects through facts" {
  // OI-K/OI-L aggregate constructor fact: Binaryen version_130
  // `visitArrayNewFixed` checks the default value through `getFallthrough`,
  // which peers into a branch-free block's final value. The block may still
  // contain earlier effects, so the replacement must drop that block before the
  // `array.new_default` allocation just as Binaryen's `getDroppedChildrenAndAppend`
  // does.
  let array_type = @lib.TypeIdx::new(0U)
  let effect_type = @lib.TypeIdx::new(1U)
  let result_type = @lib.TypeIdx::new(2U)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::array(
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
            ),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::i32()]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [
              @lib.ValType::ref_null(@lib.HeapType::new(array_type)),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([effect_type, result_type, result_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(@lib.ValType::i32()),
              @lib.Expr::new([
                @lib.Instruction::call(@lib.FuncIdx::new(0U)),
                @lib.Instruction::drop(),
                @lib.Instruction::i32_const(@lib.I32(0)),
              ]),
            ),
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::array_new_fixed(array_type, @lib.U32(2U)),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(@lib.ValType::i32()),
              @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
            ),
            @lib.Instruction::i32_const(@lib.I32(0)),
            @lib.Instruction::array_new_fixed(array_type, @lib.U32(2U)),
          ]),
        ),
      ]),
    ),
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_false(pretty.contains("array.new_fixed"), msg=pretty)
  assert_true(pretty.contains("array.new_default"), msg=pretty)
  assert_true(pretty.contains("call (Func 0)"), msg=pretty)
  assert_true(pretty.contains("drop"), msg=pretty)
  assert_true(pretty.contains("I32(2)"), msg=pretty)
  let pure = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_false(pure.contains("array.new_fixed"), msg=pure)
  assert_true(pure.contains("array.new_default"), msg=pure)
  assert_false(pure.contains("call"), msg=pure)
  assert_false(pure.contains("drop"), msg=pure)
  assert_true(pure.contains("I32(2)"), msg=pure)
}

