///|
test "optimize-instructions intentionally keeps exact ref.cast on inexact locals" {
  // OI-J exactness boundary: Binaryen version_130 keeps exact casts from
  // inexact locals because an inexact `(ref $foo)` value may carry a subtype
  // descriptor at runtime. Removing the cast would both lose the exactness trap
  // and may produce an inexact value for an exact result type.
  let foo_type = @lib.TypeIdx::new(0U)
  let nonnull_type = @lib.TypeIdx::new(1U)
  let nullable_type = @lib.TypeIdx::new(2U)
  let foo_heap = @lib.HeapType::new(foo_type)
  let inexact_foo_ref = @lib.ValType::ref_type(
    @lib.RefType::new(false, foo_heap),
  )
  let nullable_inexact_foo_ref = @lib.ValType::ref_type(
    @lib.RefType::new(true, foo_heap),
  )
  let exact_foo_ref_type = @lib.RefType::new(false, foo_heap, exact=true)
  let exact_foo_ref = @lib.ValType::ref_type(exact_foo_ref_type)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::new(false, [], @lib.CompType::struct_([])),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([inexact_foo_ref], [exact_foo_ref]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([nullable_inexact_foo_ref], [exact_foo_ref]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([nonnull_type, nullable_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_cast_type(exact_foo_ref_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_cast_type(exact_foo_ref_type),
          ]),
        ),
      ]),
    ),
  )
  let nonnull_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  let nullable_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_true(nonnull_pretty.contains("ref.cast"), msg=nonnull_pretty)
  assert_true(nullable_pretty.contains("ref.cast"), msg=nullable_pretty)
  assert_true(nonnull_pretty.contains("Exact"), msg=nonnull_pretty)
  assert_true(nullable_pretty.contains("Exact"), msg=nullable_pretty)
}

///|
test "optimize-instructions removes redundant nested ref.cast through fact" {
  // Binaryen v130 `visitRefCast` removes a child `ref.cast` when the parent
  // cast is at least as strong as the child cast, after using the child type for
  // known-result folds. This locks that ordinary one-child cast-chain rewrite as
  // a fact-driven ref.cast plan instead of a visitor-local scanner.
  let foo_type = @lib.TypeIdx::new(0U)
  let func_type = @lib.TypeIdx::new(1U)
  let foo_heap = @lib.HeapType::new(foo_type)
  let eq_heap = @lib.HeapType::abs(@lib.AbsHeapType::eq())
  let eq_ref = @lib.ValType::ref_type(@lib.RefType::new(true, eq_heap))
  let nullable_foo_ref_type = @lib.RefType::new(true, foo_heap)
  let nullable_foo_ref = @lib.ValType::ref_type(nullable_foo_ref_type)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::new(false, [], @lib.CompType::struct_([])),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([eq_ref], [nullable_foo_ref]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([func_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_cast_type(nullable_foo_ref_type),
            @lib.Instruction::ref_cast_type(nullable_foo_ref_type),
          ]),
        ),
      ]),
    ),
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  @debug.assert_eq(
    optimize_instructions_test_count_substring(pretty, "ref.cast"),
    1,
    msg=pretty,
  )
  assert_true(pretty.contains("local.get"), msg=pretty)
}

///|
test "optimize-instructions tightens ref.cast with fallthrough type fact" {
  // Binaryen v130 `visitRefCast` first intersects the cast target with
  // `getFallthroughType(ref)`. A non-null eqref operand cast to nullable `$foo`
  // becomes a non-null `$foo` cast before the known-result and child-wrapper
  // folds. This locks that GLB/nullability step as a fact-driven ref.cast plan.
  let foo_type = @lib.TypeIdx::new(0U)
  let func_type = @lib.TypeIdx::new(1U)
  let foo_heap = @lib.HeapType::new(foo_type)
  let eq_heap = @lib.HeapType::abs(@lib.AbsHeapType::eq())
  let nonnull_eq_ref = @lib.ValType::ref_type(@lib.RefType::new(false, eq_heap))
  let nullable_foo_ref_type = @lib.RefType::new(true, foo_heap)
  let nonnull_foo_ref_type = @lib.RefType::new(false, foo_heap)
  let nullable_foo_ref = @lib.ValType::ref_type(nullable_foo_ref_type)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::new(false, [], @lib.CompType::struct_([])),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([nonnull_eq_ref], [nullable_foo_ref]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([func_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_cast_type(nullable_foo_ref_type),
          ]),
        ),
      ]),
    ),
  )
  let @lib.Func(_, @lib.Expr(body)) = match optimized.code_sec {
    Some(@lib.CodeSec([func])) => func
    _ => fail("expected optimized ref.cast GLB function")
  }
  @debug.assert_eq(body, [
    @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
    @lib.Instruction::ref_cast_type(nonnull_foo_ref_type),
  ])
}

///|
test "optimize-instructions removes child ref.as_non_null from ref.cast through fact" {
  // Binaryen v130 `visitRefCast` removes a child `ref.as_non_null` after the
  // known-result and child-cast folds by tightening the parent cast to a
  // non-null target. This locks that ordinary child-wrapper rewrite as a
  // fact-driven ref.cast plan instead of a visitor-local scanner.
  let foo_type = @lib.TypeIdx::new(0U)
  let func_type = @lib.TypeIdx::new(1U)
  let foo_heap = @lib.HeapType::new(foo_type)
  let eq_heap = @lib.HeapType::abs(@lib.AbsHeapType::eq())
  let eq_ref = @lib.ValType::ref_type(@lib.RefType::new(true, eq_heap))
  let nullable_foo_ref_type = @lib.RefType::new(true, foo_heap)
  let nullable_foo_ref = @lib.ValType::ref_type(nullable_foo_ref_type)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::new(false, [], @lib.CompType::struct_([])),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([eq_ref], [nullable_foo_ref]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([func_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_cast_type(nullable_foo_ref_type),
          ]),
        ),
      ]),
    ),
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  @debug.assert_eq(
    optimize_instructions_test_count_substring(pretty, "ref.cast"),
    1,
    msg=pretty,
  )
  assert_false(pretty.contains("ref.as_non_null"), msg=pretty)
  assert_true(pretty.contains("local.get"), msg=pretty)
}

///|
test "optimize-instructions folds exact ref.cast on already exact locals" {
  // OI-J exactness positive: Binaryen version_130 removes exact casts when the
  // operand is already exactly the target heap. Nullable-to-non-null exact casts
  // still preserve the null trap by becoming ref.as_non_null.
  let foo_type = @lib.TypeIdx::new(0U)
  let nonnull_type = @lib.TypeIdx::new(1U)
  let nullable_to_nonnull_type = @lib.TypeIdx::new(2U)
  let nullable_to_nullable_type = @lib.TypeIdx::new(3U)
  let foo_heap = @lib.HeapType::new(foo_type)
  let exact_foo_ref_type = @lib.RefType::new(false, foo_heap, exact=true)
  let nullable_exact_foo_ref_type = @lib.RefType::new(
    true,
    foo_heap,
    exact=true,
  )
  let exact_foo_ref = @lib.ValType::ref_type(exact_foo_ref_type)
  let nullable_exact_foo_ref = @lib.ValType::ref_type(
    nullable_exact_foo_ref_type,
  )
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::new(false, [], @lib.CompType::struct_([])),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([exact_foo_ref], [exact_foo_ref]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([nullable_exact_foo_ref], [exact_foo_ref]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([nullable_exact_foo_ref], [
              nullable_exact_foo_ref,
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        nonnull_type, nullable_to_nonnull_type, nullable_to_nullable_type,
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_cast_type(exact_foo_ref_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_cast_type(exact_foo_ref_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_cast_type(nullable_exact_foo_ref_type),
          ]),
        ),
      ]),
    ),
  )
  let nonnull_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  let nullable_to_nonnull_pretty = optimized.pretty_print_func(
    @lib.FuncIdx::new(1U),
  )
  let nullable_to_nullable_pretty = optimized.pretty_print_func(
    @lib.FuncIdx::new(2U),
  )
  assert_false(nonnull_pretty.contains("ref.cast"), msg=nonnull_pretty)
  assert_true(nonnull_pretty.contains("local.get"), msg=nonnull_pretty)
  assert_false(
    nullable_to_nonnull_pretty.contains("ref.cast"),
    msg=nullable_to_nonnull_pretty,
  )
  assert_true(
    nullable_to_nonnull_pretty.contains("ref.as_non_null"),
    msg=nullable_to_nonnull_pretty,
  )
  assert_false(
    nullable_to_nullable_pretty.contains("ref.cast"),
    msg=nullable_to_nullable_pretty,
  )
  assert_true(
    nullable_to_nullable_pretty.contains("local.get"),
    msg=nullable_to_nullable_pretty,
  )
}

///|
test "optimize-instructions folds ref.test from precise fallthrough block facts" {
  // OI-J fallthrough-type fact slice: Binaryen version_130 `visitRefTest`
  // calls `getFallthroughType(curr->ref)` before evaluating the cast check, so
  // a block whose declared result is a supertype still folds when the actual
  // fallthrough producer is a precise subtype. This locks a reusable
  // Binaryen-style fallthrough ref fact instead of adding a block-name scanner.
  let eq_heap = @lib.HeapType::abs(@lib.AbsHeapType::eq())
  let i31_heap = @lib.HeapType::abs(@lib.AbsHeapType::i31())
  let eq_ref = @lib.ValType::ref_type(@lib.RefType::new(false, eq_heap))
  let i31_ref_type = @lib.RefType::new(false, i31_heap)
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::i32()]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([@lib.TypeIdx::new(0U)]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(eq_ref),
              @lib.Expr::new([
                @lib.Instruction::i32_const(@lib.I32(7)),
                @lib.Instruction::ref_i31(),
              ]),
            ),
            @lib.Instruction::ref_test_type(i31_ref_type),
          ]),
        ),
      ]),
    )
  // Starshine's current validator rejects this Binaryen-valid block-result
  // subtype fixture before OI can run, so this test exercises the HOT pass
  // directly and skips final module validation. Reopen the public-pipeline
  // shape when validator subtype support accepts the equivalent WAT.
  let func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(0U))
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::final_module_only(),
    false,
    ignore,
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) => fail("expected fallthrough ref.test HOT success, got \{err}")
  }
  let @lib.Func(_, @lib.Expr(body)) = @ir.hot_lower_func_unverified(func)
  let rendered = "\{body}"
  assert_false(
    body.any(fn(instr) {
      instr == @lib.Instruction::ref_test_type(i31_ref_type)
    }),
    msg="expected fallthrough ref.test to fold, got \{body}",
  )
  assert_true(
    rendered.contains("I32(1)"),
    msg="expected folded true constant, got \{body}",
  )
}

///|
test "optimize-instructions folds ref.test misses from fallthrough producer facts" {
  // Binaryen version_130 `visitRefTest` evaluates the cast check against
  // `getFallthroughType(curr->ref)`, so a broad block result whose live value is
  // an `i31ref` still proves a non-null `structref` test false. This locks the
  // miss as a producer/fallthrough fact instead of an opcode-local block scan.
  let eq_heap = @lib.HeapType::abs(@lib.AbsHeapType::eq())
  let struct_heap = @lib.HeapType::abs(@lib.AbsHeapType::struct_())
  let eq_ref = @lib.ValType::ref_type(@lib.RefType::new(false, eq_heap))
  let struct_ref_type = @lib.RefType::new(false, struct_heap)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::i32()]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([@lib.TypeIdx::new(0U)]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(eq_ref),
              @lib.Expr::new([
                @lib.Instruction::i32_const(@lib.I32(7)),
                @lib.Instruction::ref_i31(),
              ]),
            ),
            @lib.Instruction::ref_test_type(struct_ref_type),
          ]),
        ),
      ]),
    ),
  )
  let @lib.Func(_, @lib.Expr(body)) = match optimized.code_sec {
    Some(@lib.CodeSec([func])) => func
    _ => fail("expected optimized fallthrough-miss ref.test function")
  }
  assert_false(
    body.any(fn(instr) {
      instr == @lib.Instruction::ref_test_type(struct_ref_type)
    }),
    msg="expected fallthrough producer miss to fold ref.test, got \{body}",
  )
  assert_true(
    "\{body}".contains("I32(0)"),
    msg="expected folded false ref.test result, got \{body}",
  )
}

///|
test "optimize-instructions tightens ref.test nullability from fallthrough GLB facts" {
  // Binaryen version_130 `visitRefTest` first intersects the test cast type
  // with `getFallthroughType(curr->ref)` before evaluating the cast. A non-null
  // `eqref` operand tested against nullable `structref` is still an unknown
  // runtime predicate, but its cast type can be narrowed to non-null `structref`.
  // This locks the narrowing as a reusable fact rather than leaving the visitor
  // as a ref.test-specific immediate scanner.
  let eq_heap = @lib.HeapType::abs(@lib.AbsHeapType::eq())
  let struct_heap = @lib.HeapType::abs(@lib.AbsHeapType::struct_())
  let non_null_eq_ref = @lib.ValType::ref_type(
    @lib.RefType::new(false, eq_heap),
  )
  let nullable_struct_ref_type = @lib.RefType::new(true, struct_heap)
  let non_null_struct_ref_type = @lib.RefType::new(false, struct_heap)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([non_null_eq_ref], [@lib.ValType::i32()]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([@lib.TypeIdx::new(0U)]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_test_type(nullable_struct_ref_type),
          ]),
        ),
      ]),
    ),
  )
  let @lib.Func(_, @lib.Expr(body)) = match optimized.code_sec {
    Some(@lib.CodeSec([func])) => func
    _ => fail("expected optimized ref.test function")
  }
  assert_false(
    body.any(fn(instr) {
      instr == @lib.Instruction::ref_test_type(nullable_struct_ref_type)
    }),
    msg="expected nullable ref.test immediate to tighten, got \{body}",
  )
  assert_true(
    body.any(fn(instr) {
      instr == @lib.Instruction::ref_test_type(non_null_struct_ref_type)
    }),
    msg="expected non-null ref.test immediate after GLB tightening, got \{body}",
  )
}

///|
test "optimize-instructions folds ref.test from local.tee fallthrough facts" {
  // OI-J fallthrough-type fact slice: Binaryen version_130
  // `Properties::getImmediateFallthrough` looks through `local.tee` for cast
  // checks, so a tee into a broad local preserves the precise producer type for
  // the following `ref.test`. This locks local.tee fallthrough as a reusable
  // fact, not a ref.test-specific scanner.
  let eq_heap = @lib.HeapType::abs(@lib.AbsHeapType::eq())
  let i31_heap = @lib.HeapType::abs(@lib.AbsHeapType::i31())
  let eq_ref = @lib.ValType::ref_type(@lib.RefType::new(true, eq_heap))
  let i31_ref_type = @lib.RefType::new(false, i31_heap)
