        #|    i32.const 4
        #|    i32.add
        #|    memory.size
        #|    i32.const 4
        #|    i32.add
        #|    local.get $size
        #|    memory.copy)
        #|  (func (export "table-size-add") (param $size i32)
        #|    table.size 0
        #|    i32.const 4
        #|    i32.add
        #|    table.size 0
        #|    i32.const 4
        #|    i32.add
        #|    local.get $size
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(traps_never_happen=true),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail(
        "expected state-read scalar-tree memory.copy TNH success, got \{err}",
      )
  }
  let memory_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(memory_pretty.contains("memory.copy"), msg=memory_pretty)
  optimize_instructions_assert_strings_in_order(memory_pretty, [
    "memory.size", "i32.add", "drop", "memory.size", "i32.add", "drop", "local.get (Local 0)",
    "drop",
  ])
  let table_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_false(table_pretty.contains("memory.copy"), msg=table_pretty)
  optimize_instructions_assert_strings_in_order(table_pretty, [
    "table.size", "i32.add", "drop", "table.size", "i32.add", "drop", "local.get (Local 0)",
    "drop",
  ])
}

///|
test "optimize-instructions keeps growth-interfered state-read scalar-tree memory.copy" {
  // Boundary guard for the scalar-tree state-read equality fact: Binaryen v130
  // keeps the trap-relaxed copy when a right-block prefix can grow the memory or
  // table before the right `memory.size` / `table.size` leaf, because the two
  // scalar address trees may no longer evaluate to the same value.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1 2)
        #|  (table 1 2 funcref)
        #|  (func (export "memory-grow-add") (param $size i32)
        #|    memory.size
        #|    i32.const 4
        #|    i32.add
        #|    (block (result i32)
        #|      i32.const 0
        #|      memory.grow
        #|      drop
        #|      memory.size
        #|      i32.const 4
        #|      i32.add)
        #|    local.get $size
        #|    memory.copy)
        #|  (func (export "table-grow-add") (param $size i32)
        #|    table.size 0
        #|    i32.const 4
        #|    i32.add
        #|    (block (result i32)
        #|      ref.null func
        #|      i32.const 0
        #|      table.grow 0
        #|      drop
        #|      table.size 0
        #|      i32.const 4
        #|      i32.add)
        #|    local.get $size
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(traps_never_happen=true),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail(
        "expected growth-interfered state-read scalar-tree memory.copy success, got \{err}",
      )
  }
  for func_idx = 0; func_idx < 2; func_idx = func_idx + 1 {
    let pretty = optimized.pretty_print_func(
      @lib.FuncIdx::new(func_idx.reinterpret_as_uint()),
    )
    assert_true(pretty.contains("memory.copy"), msg=pretty)
    assert_true(pretty.contains(".grow"), msg=pretty)
    assert_true(pretty.contains("i32.add"), msg=pretty)
  }
}

///|
test "optimize-instructions keeps growth-interfered state-read memory.copy" {
  // Boundary guard for the state-read equality fact: Binaryen v130 rejects
  // `memory.size` / `table.size` equality when the right operand prefix can grow
  // the same memory/table before the fallthrough read. The trap-relaxed copy
  // must stay live because the two state reads may produce different addresses.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1 2)
        #|  (table 1 2 funcref)
        #|  (func (export "memory-grow") (param $size i32)
        #|    memory.size
        #|    (block (result i32)
        #|      i32.const 0
        #|      memory.grow
        #|      drop
        #|      memory.size)
        #|    local.get $size
        #|    memory.copy)
        #|  (func (export "table-grow") (param $size i32)
        #|    table.size 0
        #|    (block (result i32)
        #|      ref.null func
        #|      i32.const 0
        #|      table.grow 0
        #|      drop
        #|      table.size 0)
        #|    local.get $size
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(traps_never_happen=true),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail(
        "expected growth-interfered state-read memory.copy success, got \{err}",
      )
  }
  for func_idx = 0; func_idx < 2; func_idx = func_idx + 1 {
    let pretty = optimized.pretty_print_func(
      @lib.FuncIdx::new(func_idx.reinterpret_as_uint()),
    )
    assert_true(pretty.contains("memory.copy"), msg=pretty)
    assert_true(pretty.contains(".grow"), msg=pretty)
  }
}

///|
test "optimize-instructions drops const same-address memory.copy under trap-relaxed facts" {
  // OI-G same-input equality fact breadth: Binaryen version_130
  // `areConsecutiveInputsEqual` uses `ExpressionAnalyzer::equal` after peeling
  // fallthroughs, so identical constant address operands are equal even without
  // local/global state facts. A dynamic size avoids the separate tiny-copy
  // lowering and proves the trap-relaxed same-address bulk drop directly.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func (export "f") (param $size i32)
        #|    i32.const 16
        #|    i32.const 16
        #|    local.get $size
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(traps_never_happen=true),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected const same-address memory.copy TNH success, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("memory.copy"), msg=pretty)
  assert_false(pretty.contains("i32.load"), msg=pretty)
  assert_false(pretty.contains("i32.store"), msg=pretty)
  optimize_instructions_assert_strings_in_order(pretty, [
    "i32.const I32(16)", "drop", "i32.const I32(16)", "drop", "local.get (Local 0)",
    "drop",
  ])
}

///|
test "optimize-instructions drops right block const same-address memory.copy" {
  // OI-G same-input constant equality plus right fallthrough facts: Binaryen
  // v130 accepts a right block whose fallthrough constant equals the left
  // constant when prefix effects are not ordered before the constant value.
  // Starshine should preserve the prefix call in the dropped source operand and
  // remove the trap-relaxed same-address bulk copy.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func $side)
        #|  (func (export "f") (param $size i32)
        #|    i32.const 16
        #|    (block (result i32)
        #|      call $side
        #|      i32.const 16)
        #|    local.get $size
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(traps_never_happen=true),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected right block const memory.copy TNH success, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_false(pretty.contains("memory.copy"), msg=pretty)
  assert_true(pretty.contains("call (Func 0)"), msg=pretty)
  optimize_instructions_assert_strings_in_order(pretty, [
    "i32.const I32(16)", "drop", "call (Func 0)", "i32.const I32(16)", "drop", "local.get (Local 0)",
    "drop",
  ])
}

///|
test "optimize-instructions drops pure binary same-address memory.copy under trap-relaxed facts" {
  // OI-G same-input equality fact breadth: Binaryen version_130
  // `areConsecutiveInputsEqual` delegates to `ExpressionAnalyzer::equal` after
  // peeling adjacent operand fallthroughs. Identical pure scalar expression
  // trees, such as repeated `i32.add(local.get, const)` address operands, are
  // equal and let the trap-relaxed same-address `memory.copy` collapse to drops.
  // Starshine currently sees this public WAT shape as flat stack code, so the
  // route is a narrow raw fact bridge backed by the same equality contract.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func (export "f") (param $addr i32) (param $size i32)
        #|    local.get $addr
        #|    i32.const 4
        #|    i32.add
        #|    local.get $addr
        #|    i32.const 4
        #|    i32.add
        #|    local.get $size
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(traps_never_happen=true),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail(
        "expected pure binary same-address memory.copy TNH success, got \{err}",
      )
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("memory.copy"), msg=pretty)
  @debug.assert_eq(
    optimize_instructions_test_count_substring(pretty, "i32.add"),
    2,
  )
  optimize_instructions_assert_strings_in_order(pretty, [
    "local.get (Local 0)", "i32.const I32(4)", "i32.add", "drop", "local.get (Local 0)",
    "i32.const I32(4)", "i32.add", "drop", "local.get (Local 1)", "drop",
  ])
}

///|
test "optimize-instructions drops flat pure scalar same-address memory.copy" {
  // OI-G raw stack-expression fact breadth: Binaryen version_130
  // `areConsecutiveInputsEqual` delegates to `ExpressionAnalyzer::equal`, so
  // repeated flat pure scalar address operands beyond the first i32.add/local
  // const bridge are equal too. Keep this source-backed bridge fact-shaped while
  // public WAT lowering represents these operands as flat stack instructions.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func (export "sub") (param $addr i32) (param $size i32)
        #|    local.get $addr
        #|    i32.const 4
        #|    i32.sub
        #|    local.get $addr
        #|    i32.const 4
        #|    i32.sub
        #|    local.get $size
        #|    memory.copy)
        #|  (func (export "eqz") (param $addr i32) (param $size i32)
        #|    local.get $addr
        #|    i32.eqz
        #|    local.get $addr
        #|    i32.eqz
        #|    local.get $size
        #|    memory.copy)
        #|  (func (export "local-local-add") (param $a i32) (param $b i32) (param $size i32)
        #|    local.get $a
        #|    local.get $b
        #|    i32.add
        #|    local.get $a
        #|    local.get $b
        #|    i32.add
        #|    local.get $size
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(traps_never_happen=true),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected flat pure scalar memory.copy TNH success, got \{err}")
  }
  for func_idx = 0; func_idx < 3; func_idx = func_idx + 1 {
    let pretty = optimized.pretty_print_func(
      @lib.FuncIdx::new(func_idx.reinterpret_as_uint()),
    )
    assert_false(pretty.contains("memory.copy"), msg=pretty)
    assert_true(pretty.contains("drop"), msg=pretty)
  }
}

///|
test "optimize-instructions drops commuted flat add same-address memory.copy" {
  // OI-G raw stack-expression equality breadth: Binaryen v130 delegates the
  // trap-relaxed same-address `memory.copy` check to `ExpressionAnalyzer::equal`,
  // and the local probe showed reordered one-level `i32.add` address operands
  // are equal while noncommutative `i32.sub` is not. Keep this fact-shaped until
  // the public WAT path can carry the operands as HOT expression children.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func (export "add-swap") (param $a i32) (param $b i32) (param $size i32)
        #|    local.get $a
        #|    local.get $b
        #|    i32.add
        #|    local.get $b
        #|    local.get $a
        #|    i32.add
        #|    local.get $size
        #|    memory.copy)
        #|  (func (export "const-add-swap") (param $addr i32) (param $size i32)
        #|    local.get $addr
        #|    i32.const 4
        #|    i32.add
        #|    i32.const 4
        #|    local.get $addr
        #|    i32.add
        #|    local.get $size
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(traps_never_happen=true),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected commuted flat add memory.copy TNH success, got \{err}")
  }
  for func_idx = 0; func_idx < 2; func_idx = func_idx + 1 {
    let pretty = optimized.pretty_print_func(
      @lib.FuncIdx::new(func_idx.reinterpret_as_uint()),
    )
    assert_false(pretty.contains("memory.copy"), msg=pretty)
    assert_true(pretty.contains("i32.add"), msg=pretty)
    assert_true(pretty.contains("drop"), msg=pretty)
  }
}

///|
test "optimize-instructions drops commuted flat integer op same-address memory.copy" {
  // OI-G raw stack-expression equality breadth: Binaryen v130 treats commuted
  // pure-scalar integer operators (`i32.mul`, `i32.and`, `i32.or`, `i32.xor`)
  // like commuted `i32.add` under `ExpressionAnalyzer::equal`, so same-address
  // `memory.copy` collapses under `--traps-never-happen`. Keep the set explicit
  // and source-backed; noncommutative shifts remain outside this fact below.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func (export "mul-swap") (param $a i32) (param $b i32) (param $size i32)
        #|    local.get $a
        #|    local.get $b
        #|    i32.mul
        #|    local.get $b
        #|    local.get $a
        #|    i32.mul
        #|    local.get $size
        #|    memory.copy)
        #|  (func (export "and-swap") (param $a i32) (param $b i32) (param $size i32)
        #|    local.get $a
        #|    local.get $b
        #|    i32.and
        #|    local.get $b
        #|    local.get $a
        #|    i32.and
        #|    local.get $size
        #|    memory.copy)
        #|  (func (export "or-swap") (param $a i32) (param $b i32) (param $size i32)
        #|    local.get $a
        #|    local.get $b
        #|    i32.or
        #|    local.get $b
        #|    local.get $a
        #|    i32.or
        #|    local.get $size
        #|    memory.copy)
        #|  (func (export "xor-swap") (param $a i32) (param $b i32) (param $size i32)
        #|    local.get $a
        #|    local.get $b
        #|    i32.xor
        #|    local.get $b
        #|    local.get $a
        #|    i32.xor
        #|    local.get $size
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(traps_never_happen=true),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected commuted integer op memory.copy TNH success, got \{err}")
  }
  for func_idx = 0; func_idx < 4; func_idx = func_idx + 1 {
    let pretty = optimized.pretty_print_func(
      @lib.FuncIdx::new(func_idx.reinterpret_as_uint()),
    )
    assert_false(pretty.contains("memory.copy"), msg=pretty)
    assert_true(pretty.contains("drop"), msg=pretty)
  }
}

///|
test "optimize-instructions drops commuted flat equality same-address memory.copy" {
  // OI-G raw stack-expression equality breadth: Binaryen v130 treats swapped
  // integer equality/inequality operands as equal under `ExpressionAnalyzer::equal`,
  // so trap-relaxed same-address `memory.copy` collapses. This is intentionally
  // an explicit compare fact extension, not a broad compare/operator scanner:
  // ordered relational predicates remain outside the commutative fact below.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
