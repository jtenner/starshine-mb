///|
fn optimize_instructions_large_local_fixture() -> String {
  let out = StringBuilder::new()
  out.write_string("(module (func (local i32")
  for i = 0; i < 1024; i = i + 1 {
    let _ = i
    out.write_string(" i32")
  }
  out.write_string(") i32.const 0 i32.eqz drop))")
  out.to_string()
}

///|
fn optimize_instructions_large_lowered_fixture() -> String {
  let out = StringBuilder::new()
  out.write_string("(module (func (local")
  for i = 0; i < 65; i = i + 1 {
    let _ = i
    out.write_string(" i32")
  }
  out.write_string(")")
  for i = 0; i < 260; i = i + 1 {
    let _ = i
    out.write_string(" i32.const 0 drop")
  }
  out.write_string("))")
  out.to_string()
}

///|
fn optimize_instructions_structured_gate_fixture(
  repeats : Int,
  extra_calls : Int,
  extra_writes : Int,
) -> String {
  let out = StringBuilder::new()
  out.write_string(
    "(module (import \"m\" \"touch\" (func $touch)) (func (local i32)",
  )
  for i = 0; i < repeats; i = i + 1 {
    out.write_string(" (block $b")
    out.write_string(i.to_string())
    out.write_string(
      " i32.const 0 if call $touch i32.const 0 local.set 0 br $b",
    )
    out.write_string(i.to_string())
    out.write_string(" else i32.const 1 local.set 0 return end)")
  }
  for i = 0; i < extra_calls; i = i + 1 {
    let _ = i
    out.write_string(" call $touch")
  }
  for i = 0; i < extra_writes; i = i + 1 {
    let _ = i
    out.write_string(" i32.const 0 local.set 0")
  }
  out.write_string("))")
  out.to_string()
}

///|
fn optimize_instructions_loop_gate_fixture() -> String {
  (
    #|(module
    #|  (import "m" "touch" (func $touch))
    #|  (func (local i32)
    #|    (loop $l
    #|      i32.const 0
    #|      if
    #|        call $touch
    #|        i32.const 0
    #|        local.set 0
    #|        i32.const 1
    #|        local.set 0
    #|        i32.const 2
    #|        local.set 0
    #|        i32.const 3
    #|        local.set 0
    #|        br $l
    #|      end)))
    #|,
  )
}

///|
fn optimize_instructions_test_run_module(mod_ : @lib.Module) -> @lib.Module {
  match @validate.validate_module(mod_) {
    Ok(_) => ()
    Err(err) =>
      abort("unexpected invalid optimize-instructions fixture: \{err}")
  }
  match
    run_hot_pipeline(mod_, HotPipelineOptions::new(), ["optimize-instructions"]) {
    Ok(mod_) => mod_
    Err(err) =>
      abort("expected optimize-instructions pipeline success, got \{err}")
  }
}

///|
fn optimize_instructions_assert_skip_reason(
  text : String,
  reason : String,
) -> Unit raise {
  let trace : Array[String] = []
  match
    pass_test_run_pipeline(
      text,
      ["optimize-instructions"],
      options=HotPipelineOptions::new(trace=Some(fn(line) { trace.push(line) })),
    ) {
    Ok(_) => ()
    Err(err) => fail("expected optimize-instructions skip success, got \{err}")
  }
  assert_true(
    trace.any(fn(line) {
      line.contains("pass[optimize-instructions]:skip-raw reason=\{reason}")
    }),
    msg="expected skip reason \{reason} in \{trace}",
  )
}

///|
test "optimize-instructions skips very large local-heavy functions" {
  optimize_instructions_assert_skip_reason(
    optimize_instructions_large_local_fixture(),
    "large-local-optimize-instructions",
  )
}

///|
test "optimize-instructions skips large lowered functions" {
  optimize_instructions_assert_skip_reason(
    optimize_instructions_large_lowered_fixture(),
    "large-lowered-optimize-instructions-noop",
  )
}

///|
test "optimize-instructions skips structured call and branch meshes with precise reason" {
  optimize_instructions_assert_skip_reason(
    optimize_instructions_structured_gate_fixture(10, 6, 0),
    "structured-call-branch-optimize-instructions-noop",
  )
}

///|
test "optimize-instructions skips block return call branch meshes below structured threshold" {
  optimize_instructions_assert_skip_reason(
    optimize_instructions_structured_gate_fixture(5, 7, 10),
    "block-return-call-branch-optimize-instructions-noop",
  )
}

///|
test "optimize-instructions skips loop branch local writes below block threshold" {
  optimize_instructions_assert_skip_reason(
    optimize_instructions_loop_gate_fixture(),
    "loop-branch-local-write-optimize-instructions-noop",
  )
}

///|
test "optimize-instructions public pipeline still cleans neutral add outside raw gates" {
  let trace : Array[String] = []
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (func (param i32) (result i32)
        #|    local.get 0
        #|    i32.const 0
        #|    i32.add))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(trace=Some(fn(line) { trace.push(line) })),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected optimize-instructions cleanup success, got \{err}")
  }
  assert_false(
    trace.any(fn(line) { line.contains("pass[optimize-instructions]:skip-raw") }),
    msg="unexpected raw skip in \{trace}",
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("i32.add"), msg=pretty)
  assert_true(pretty.contains("local.get"), msg=pretty)
}

///|
test "optimize-instructions raw skip removes local-carried add-zero before sign extensions" {
  // OI-E grouped pass-oi-local-facts residual: the call/local-write raw skip
  // path must still remove neutral add wrappers before sign-extension facts.
  // This reduces Binaryen-vs-Starshine drift without claiming broad LocalScanner
  // closure or any descriptor/exactness/TNH/IIT evidence.
  let trace : Array[String] = []
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (global $g (mut i32) (i32.const 0))
        #|  (func $make_i32 (result i32)
        #|    i32.const 3
        #|    global.set $g
        #|    i32.const 127)
        #|  (func $make_i64 (result i64)
        #|    i32.const 4
        #|    global.set $g
        #|    i64.const 2147483647)
        #|  (func (local $x i32) (local $y i64)
        #|    call $make_i32
        #|    local.set $x
        #|    local.get $x
        #|    i32.const 0
        #|    i32.add
        #|    i32.extend8_s
        #|    drop
        #|    call $make_i64
        #|    local.set $y
        #|    local.get $y
        #|    i64.const 0
        #|    i64.add
        #|    i64.extend32_s
        #|    drop))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(trace=Some(fn(line) { trace.push(line) })),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected optimize-instructions raw skip success, got \{err}")
  }
  assert_true(
    trace.any(fn(line) {
      line.contains(
        "pass[optimize-instructions]:skip-raw reason=call-local-write-optimize-instructions-noop",
      )
    }),
    msg="expected call/local-write raw skip in \{trace}",
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_false(pretty.contains("i32.add"), msg=pretty)
  assert_false(pretty.contains("i64.add"), msg=pretty)
  assert_true(pretty.contains("i32.extend8s"), msg=pretty)
  assert_true(pretty.contains("i64.extend32s"), msg=pretty)
  assert_true(pretty.contains("local.get (Local 0)"), msg=pretty)
  assert_true(pretty.contains("local.get (Local 1)"), msg=pretty)
}

///|
test "optimize-instructions keeps sign extends after conflicting local facts" {
  // Binaryen's LocalScanner records one conservative fact per local for the
  // whole function. If the same local is written with incompatible sign-width
  // evidence, later local.gets cannot use a more precise straight-line fact.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (func (local $x i32)
        #|    i32.const 127
        #|    local.set $x
        #|    local.get $x
        #|    i32.extend8_s
        #|    drop
        #|    i32.const 32767
        #|    local.set $x))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected optimize-instructions sign-ext fact success, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_true(pretty.contains("i32.extend8s"), msg=pretty)
}

///|
test "optimize-instructions removes redundant local-carried unsigned mask facts" {
  // OI-E wide local-carried mask residual: if LocalScanner facts prove an i32
  // local is already within an all-ones mask, the mask is redundant. Keep the
  // i64 mask whose local fact is wider than the mask.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (func (local $x i32) (local $y i64)
        #|    i32.const 127
        #|    local.set $x
        #|    local.get $x
        #|    i32.const 255
        #|    i32.and
        #|    drop
        #|    i64.const 2147483647
        #|    local.set $y
        #|    local.get $y
        #|    i64.const 65535
        #|    i64.and
        #|    drop))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected optimize-instructions mask cleanup success, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("i32.and"), msg=pretty)
  assert_true(pretty.contains("i64.and"), msg=pretty)
  assert_true(pretty.contains("local.get (Local 0)"), msg=pretty)
}

///|
test "optimize-instructions erases pure block operands after maxBits compare folds" {
  // Red-first OI-E behavior-parity slice: Binaryen v130 `Bits::getMaxBits`
  // sees through a single-value block and, because the block body is pure,
  // replaces an impossible compare with a bare constant instead of preserving
  // the block as `drop(block); const`. This bounds pure block erasure to the
  // same single-value fallthrough shape already used by Starshine maxBits facts.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (func (param $x i32) (result i32)
        #|    (i32.eq
        #|      (block (result i32)
        #|        (i32.and (local.get $x) (i32.const 255)))
        #|      (i32.const 256))))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) => fail("expected pure block maxBits compare fold, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("i32.eq"), msg=pretty)
  assert_false(pretty.contains("i32.and"), msg=pretty)
  assert_false(pretty.contains("block"), msg=pretty)
  assert_false(pretty.contains("drop"), msg=pretty)
  assert_true(pretty.contains("I32(0)"), msg=pretty)
}

///|
test "optimize-instructions erases pure block prefixes after maxBits compare folds" {
  // Red-first OI-E behavior-parity slice: Binaryen v130 can use the tail value
  // of a block with pure dropped prefixes for maxBits, then erase the whole
  // pure block when the compare folds. This keeps effectful/branching block
  // localization out of scope while removing pure prefix residue.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (func (param $x i32) (result i32)
        #|    (i32.eq
        #|      (block (result i32)
        #|        (drop (i32.const 99))
        #|        (i32.and (local.get $x) (i32.const 255)))
        #|      (i32.const 256))))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) => fail("expected pure-prefix block maxBits fold, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("i32.eq"), msg=pretty)
  assert_false(pretty.contains("i32.and"), msg=pretty)
  assert_false(pretty.contains("block"), msg=pretty)
  assert_false(pretty.contains("drop"), msg=pretty)
  assert_true(pretty.contains("I32(0)"), msg=pretty)
}

///|
test "optimize-instructions preserves effectful block prefixes after maxBits compare folds" {
  // Red-first OI-E behavior-parity slice: Binaryen v130 uses a block tail's
  // maxBits even when earlier block roots have effects, but preserves the full
  // block before the folded constant. This keeps branch/control localization out
  // of scope while covering straight-line effectful prefixes.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (func (param $x i32) (result i32) (local $tmp i32)
        #|    (i32.eq
        #|      (block (result i32)
        #|        (local.set $tmp (i32.const 7))
        #|        (i32.and (local.get $x) (i32.const 255)))
        #|      (i32.const 256))))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) => fail("expected effectful-prefix block maxBits fold, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("i32.eq"), msg=pretty)
  assert_true(pretty.contains("i32.and"), msg=pretty)
  assert_true(pretty.contains("local.set (Local 1)"), msg=pretty)
  assert_true(pretty.contains("I32(7)"), msg=pretty)
  assert_true(pretty.contains("I32(0)"), msg=pretty)
}

///|
test "optimize-instructions preserves memory-store block prefixes after maxBits compare folds" {
  // Red-first OI-E behavior-parity slice: Binaryen v130 `Bits::getMaxBits`
  // uses the tail of a block even when an earlier straight-line root writes
  // memory. The rewrite preserves the store by dropping the original block and
  // replacing only the impossible compare with a constant.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func (param $x i32) (result i32)
        #|    (i32.eq
        #|      (block (result i32)
        #|        (i32.store (i32.const 0) (i32.const 7))
        #|        (i32.and (local.get $x) (i32.const 255)))
        #|      (i32.const 256))))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) => fail("expected memory-store prefix maxBits fold, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("i32.eq"), msg=pretty)
  assert_true(pretty.contains("i32.store"), msg=pretty)
  assert_true(pretty.contains("i32.and"), msg=pretty)
  assert_true(pretty.contains("I32(7)"), msg=pretty)
  assert_true(pretty.contains("I32(0)"), msg=pretty)
}

///|
test "optimize-instructions preserves call block prefixes after maxBits compare folds" {
  // Red-first OI-E behavior-parity slice: Binaryen v130 also uses a block tail
  // for maxBits when a preceding straight-line prefix is a direct call. The
  // call may have arbitrary effects, so the fold must preserve the original
  // block as a dropped value before the constant.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (func $side)
        #|  (func (param $x i32) (result i32)
        #|    (i32.eq
        #|      (block (result i32)
        #|        (call $side)
        #|        (i32.and (local.get $x) (i32.const 255)))
        #|      (i32.const 256))))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) => fail("expected call prefix maxBits fold, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_false(pretty.contains("i32.eq"), msg=pretty)
  assert_true(pretty.contains("call"), msg=pretty)
  assert_true(pretty.contains("i32.and"), msg=pretty)
  assert_true(pretty.contains("I32(0)"), msg=pretty)
}

///|
test "optimize-instructions preserves drop-call block prefixes after maxBits compare folds" {
  // Red-first OI-E behavior-parity slice: Binaryen v130 also folds the
  // impossible maxBits compare through a drop-wrapped value-returning direct
  // call prefix, while preserving the call, its traps/effects, and the dropped
  // result before the folded constant. This is narrower than arbitrary call_ref,
  // indirect-call return values, or branch/control localization.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (func $side (result i32) (i32.const 7))
        #|  (func (param $x i32) (result i32)
        #|    (i32.eq
        #|      (block (result i32)
        #|        (drop (call $side))
        #|        (i32.and (local.get $x) (i32.const 255)))
        #|      (i32.const 256))))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) => fail("expected drop-call prefix maxBits fold, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_false(pretty.contains("i32.eq"), msg=pretty)
  assert_true(pretty.contains("call"), msg=pretty)
  assert_true(pretty.contains("drop"), msg=pretty)
  assert_true(pretty.contains("i32.and"), msg=pretty)
  assert_true(pretty.contains("I32(0)"), msg=pretty)
}

///|
test "optimize-instructions preserves call_indirect block prefixes after maxBits compare folds" {
  // Red-first OI-E behavior-parity slice: Binaryen v130 folds an impossible
  // maxBits compare through a straight-line call_indirect block prefix, while
  // preserving the indirect call before the folded constant.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (type $t (func))
        #|  (table 1 funcref)
        #|  (elem (i32.const 0) $side)
        #|  (func $side)
        #|  (func (param $x i32) (result i32)
        #|    (i32.eq
        #|      (block (result i32)
        #|        (call_indirect (type $t) (i32.const 0))
        #|        (i32.and (local.get $x) (i32.const 255)))
        #|      (i32.const 256))))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) => fail("expected call_indirect prefix maxBits fold, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_false(pretty.contains("i32.eq"), msg=pretty)
  assert_true(pretty.contains("call_indirect"), msg=pretty)
  assert_true(pretty.contains("i32.and"), msg=pretty)
  assert_true(pretty.contains("I32(0)"), msg=pretty)
}

///|
test "optimize-instructions preserves drop-call_indirect block prefixes after maxBits compare folds" {
  // Red-first OI-E behavior-parity slice: Binaryen v130 folds the impossible
  // maxBits compare through a drop-wrapped value-returning indirect call prefix,
  // preserving the table/type trap, callee effects, and dropped result before
  // the folded constant. This does not claim call_ref or branch/control breadth.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (type $t (func (result i32)))
        #|  (table 1 funcref)
        #|  (elem (i32.const 0) $side)
        #|  (func $side (result i32) (i32.const 7))
        #|  (func (param $x i32) (result i32)
        #|    (i32.eq
        #|      (block (result i32)
        #|        (drop (call_indirect (type $t) (i32.const 0)))
        #|        (i32.and (local.get $x) (i32.const 255)))
        #|      (i32.const 256))))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected drop-call_indirect prefix maxBits fold, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_false(pretty.contains("i32.eq"), msg=pretty)
  assert_true(pretty.contains("call_indirect"), msg=pretty)
  assert_true(pretty.contains("drop"), msg=pretty)
  assert_true(pretty.contains("i32.and"), msg=pretty)
  assert_true(pretty.contains("I32(0)"), msg=pretty)
}

///|
test "optimize-instructions preserves call_ref block prefixes after maxBits compare folds" {
  // Red-first OI-E behavior-parity slice: Binaryen v130 folds the impossible
  // maxBits compare through a void call_ref block prefix, preserving the
  // call_ref null trap and callee effects before the folded constant. Use a
  // parameter target so this proves the call_ref prefix fact rather than
  // same-pass ref.func directization; value-returning call_ref remains covered
  // by the drop-wrapped prefix fixture below.
  let callee_type = @lib.TypeIdx::new(0U)
  let callee_ref = @lib.ValType::ref_type(
    @lib.RefType::new(true, @lib.HeapType::new(callee_type)),
  )
  let test_type = @lib.TypeIdx::new(1U)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(@lib.SubType::comp_type(@lib.CompType::func([], []))),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([callee_ref, @lib.ValType::i32()], [
              @lib.ValType::i32(),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([callee_type, test_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(@lib.Locals::empty(), @lib.Expr::new([])),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(@lib.ValType::i32()),
              @lib.Expr::new([
                @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
                @lib.Instruction::call_ref(callee_type),
                @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
                @lib.Instruction::i32_const(@lib.I32(255)),
                @lib.Instruction::i32_and(),
              ]),
            ),
            @lib.Instruction::i32_const(@lib.I32(256)),
            @lib.Instruction::i32_eq(),
          ]),
        ),
      ]),
    ),
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_false(pretty.contains("i32.eq"), msg=pretty)
  assert_true(pretty.contains("call_ref"), msg=pretty)
  assert_true(pretty.contains("i32.and"), msg=pretty)
  assert_true(pretty.contains("I32(0)"), msg=pretty)
}

///|
test "optimize-instructions preserves drop-call_ref block prefixes after maxBits compare folds" {
  // Red-first OI-E behavior-parity slice: Binaryen v130 folds the impossible
  // maxBits compare through a drop-wrapped value-returning call_ref prefix,
  // preserving the null trap/callee effects and dropped result before the folded
  // constant. Use a parameter target so this does not rely on same-pass ref.func
  // directization; branch/control, aggregate atomics, and generalized
  // localization stay separate. Build the fixture programmatically because the
  // WAT parser does not currently accept the typed function-reference spelling.
  let callee_type = @lib.TypeIdx::new(0U)
  let callee_ref = @lib.ValType::ref_type(
    @lib.RefType::new(true, @lib.HeapType::new(callee_type)),
  )
  let test_type = @lib.TypeIdx::new(1U)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::i32()]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([callee_ref, @lib.ValType::i32()], [
              @lib.ValType::i32(),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([callee_type, test_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(7))]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(@lib.ValType::i32()),
              @lib.Expr::new([
                @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
                @lib.Instruction::call_ref(callee_type),
                @lib.Instruction::drop(),
                @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
                @lib.Instruction::i32_const(@lib.I32(255)),
                @lib.Instruction::i32_and(),
              ]),
            ),
            @lib.Instruction::i32_const(@lib.I32(256)),
            @lib.Instruction::i32_eq(),
          ]),
        ),
      ]),
    ),
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_false(pretty.contains("i32.eq"), msg=pretty)
  assert_true(pretty.contains("call_ref"), msg=pretty)
  assert_true(pretty.contains("drop"), msg=pretty)
  assert_true(pretty.contains("i32.and"), msg=pretty)
  assert_true(pretty.contains("I32(0)"), msg=pretty)
}

///|
test "optimize-instructions preserves global-set block prefixes after maxBits compare folds" {
  // Red-first OI-E behavior-parity slice: Binaryen v130's block-tail maxBits
  // fold also preserves a straight-line mutable-global write prefix. The folded
  // compare must not erase or reorder that global.set.
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (global $g (mut i32) (i32.const 0))
        #|  (func (param $x i32) (result i32)
        #|    (i32.eq
        #|      (block (result i32)
        #|        (global.set $g (i32.const 7))
        #|        (i32.and (local.get $x) (i32.const 255)))
        #|      (i32.const 256))))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) => fail("expected global-set prefix maxBits fold, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("i32.eq"), msg=pretty)
  assert_true(pretty.contains("global.set"), msg=pretty)
  assert_true(pretty.contains("i32.and"), msg=pretty)
  assert_true(pretty.contains("I32(7)"), msg=pretty)
  assert_true(pretty.contains("I32(0)"), msg=pretty)
}

