  assert_false(pretty.contains("v128.store"), msg=pretty)
}

///|
test "optimize-instructions expands tiny bulk-memory inside dead if shells" {
  let trace : Array[String] = []
  let source = StringBuilder::new()
  source.write_string(
    (
      #|(module
      #|  (memory 1)
      #|  (func (param $dst i32) (param $src i32) (local
      #|,
    ),
  )
  for i = 0; i < 65; i = i + 1 {
    let _ = i
    source.write_string(" i32")
  }
  source.write_string(
    (
      #|)
      #|    i32.const 0
      #|    if
      #|      local.get $dst
      #|      local.get $src
      #|      i32.const 0
      #|      memory.copy
      #|      local.get $dst
      #|      i32.const 255
      #|      i32.const 0
      #|      memory.fill
      #|      local.get $dst
      #|      local.get $src
      #|      i32.const 1
      #|      memory.copy
      #|      local.get $dst
      #|      i32.const 255
      #|      i32.const 1
      #|      memory.fill
      #|      local.get $dst
      #|      local.get $src
      #|      i32.const 2
      #|      memory.copy
      #|      local.get $dst
      #|      i32.const 255
      #|      i32.const 2
      #|      memory.fill
      #|      local.get $dst
      #|      local.get $src
      #|      i32.const 3
      #|      memory.copy
      #|      local.get $dst
      #|      i32.const 255
      #|      i32.const 3
      #|      memory.fill
      #|      local.get $dst
      #|      local.get $src
      #|      i32.const 4
      #|      memory.copy
      #|      local.get $dst
      #|      i32.const 255
      #|      i32.const 4
      #|      memory.fill
      #|      local.get $dst
      #|      local.get $src
      #|      i32.const 5
      #|      memory.copy
      #|      local.get $dst
      #|      i32.const 255
      #|      i32.const 5
      #|      memory.fill
      #|      local.get $dst
      #|      local.get $src
      #|      i32.const 8
      #|      memory.copy
      #|      local.get $dst
      #|      i32.const 255
      #|      i32.const 8
      #|      memory.fill
      #|      local.get $dst
      #|      local.get $src
      #|      i32.const 16
      #|      memory.copy
      #|      local.get $dst
      #|      i32.const 255
      #|      i32.const 16
      #|      memory.fill
      #|    end
      #|,
    ),
  )
  for i = 0; i < 260; i = i + 1 {
    let _ = i
    source.write_string(" i32.const 0 drop")
  }
  source.write_string("))")
  let optimized = match
    pass_test_run_pipeline(
      source.to_string(),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(trace=Some(fn(line) { trace.push(line) })),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected dead bulk-memory shell optimize success, got \{err}")
  }
  assert_true(
    trace.any(fn(line) {
      line.contains(
        "pass[optimize-instructions]:skip-raw reason=large-lowered-optimize-instructions-noop",
      )
    }),
    msg="expected dead tiny bulk-memory shell to exercise raw-skip path, trace=\{trace}",
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  // OI-G grouped evidence `.tmp/oi-g-memory-family-classify-20260628` shows
  // Binaryen lowers sizes 1/2/4/8/16 inside this synthetic dead shell while
  // preserving zero-size and size-3/5 bulk spellings. This red-first guard is
  // deliberately scoped to the smoke transform contract, not OI-G family closeout.
  @debug.assert_eq(
    optimize_instructions_test_count_substring(pretty, "memory.copy"),
    3,
    msg=pretty,
  )
  @debug.assert_eq(
    optimize_instructions_test_count_substring(pretty, "memory.fill"),
    3,
    msg=pretty,
  )
  assert_true(pretty.contains("i32.load8u"), msg=pretty)
  assert_true(pretty.contains("i32.load16u"), msg=pretty)
  assert_true(pretty.contains("i32.load"), msg=pretty)
  assert_true(pretty.contains("i64.load"), msg=pretty)
  assert_true(pretty.contains("v128.load"), msg=pretty)
  assert_true(pretty.contains("i32.store8"), msg=pretty)
  assert_true(pretty.contains("i32.store16"), msg=pretty)
  assert_true(pretty.contains("i32.store"), msg=pretty)
  assert_true(pretty.contains("i64.store"), msg=pretty)
  assert_true(pretty.contains("v128.store"), msg=pretty)
}

///|
test "optimize-instructions expands dynamic self tiny memory.copy" {
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func
        #|    memory.size
        #|    i32.const 0
        #|    i32.ne
        #|    if
        #|      memory.size
        #|      i32.const 32768
        #|      i32.mul
        #|      memory.size
        #|      i32.const 32768
        #|      i32.mul
        #|      i32.const 1
        #|      memory.copy
        #|      memory.size
        #|      i32.const 32768
        #|      i32.mul
        #|      i32.load8_u
        #|      drop
        #|    end))
        #|,
      ),
      ["optimize-instructions"],
    ) {
    Ok(mod_) => mod_
    Err(err) => fail("expected dynamic self-copy optimize success, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  // OI-G dynamic-copy grouped evidence uses a reachable length-1 self-copy at
  // `memory.size * 32768`. Binaryen lowers the copy to load/store while keeping
  // the dynamic address, so this guards the same behavior without claiming
  // randomized-address or live trap-order closure.
  assert_false(pretty.contains("memory.copy"), msg=pretty)
  assert_false(pretty.contains("I32(32768)"), msg=pretty)
  assert_true(pretty.contains("I32(15)"), msg=pretty)
  assert_true(pretty.contains("i32.load8u"), msg=pretty)
  assert_true(pretty.contains("i32.store8"), msg=pretty)
}

///|
test "optimize-instructions drops narrow-store masks after dead bulk-memory raw shell" {
  let trace : Array[String] = []
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func
        #|    i32.const 0
        #|    if
        #|      i32.const 0
        #|      i32.const 0
        #|      i32.const 1
        #|      memory.copy
        #|      i32.const 0
        #|      i32.const 255
        #|      i32.const 1
        #|      memory.fill
        #|    end
        #|    i32.const 0
        #|    i32.const 4660
        #|    i32.const 255
        #|    i32.and
        #|    i32.store8
        #|    i32.const 2
        #|    i32.const 305419896
        #|    i32.const 65535
        #|    i32.and
        #|    i32.store16
        #|    i32.const 4
        #|    i64.const 4660
        #|    i64.const 255
        #|    i64.and
        #|    i64.store8))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(trace=Some(fn(line) { trace.push(line) })),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected raw-shell narrow-store optimize success, got \{err}")
  }
  assert_true(
    trace.any(fn(line) {
      line.contains(
        "pass[optimize-instructions]:skip-raw reason=raw-partial-optimize-instructions",
      )
    }),
    msg="expected dead memory-size-boundary-like shell to exercise raw partial path, trace=\{trace}",
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  // OI-G grouped evidence `.tmp/oi-g-memory-family-expanded-profile-20260628`
  // exposed this exact store-mask profile case after `oi-memory-size-boundary`.
  // Binaryen version_130 removes the exact i32 masks in the raw shell but keeps
  // i64 masks before i64 narrow stores.
  assert_false(pretty.contains("i32.and"), msg=pretty)
  assert_true(pretty.contains("i64.and"), msg=pretty)
  optimize_instructions_assert_strings_in_order(pretty, [
    "i32.load8u", "i32.store8", "I32(4660)", "i32.store8", "I32(305419896)", "i32.store16",
    "I64(4660)", "I64(255)", "i64.and", "i64.store8",
  ])
  let wasm = match @binary.encode_module(optimized) {
    Ok(bytes) => bytes
    Err(err) =>
      fail("expected optimized raw-shell module to encode, got \{err}")
  }
  // Follow-up from `.tmp/oi-g-second-atomic-count350-20260629` case 000058:
  // Starshine's raw output was larger only because the raw partial tiny-copy
  // lowering emitted explicit memory-index-zero memargs (`0x40 0x00 0x00`) for
  // default-memory load/store operations. Keep the raw-size fix grounded in the
  // exact lowered byte spelling without claiming OI-G family closeout.
  for i = 0; i + 3 < wasm.length(); i = i + 1 {
    let opcode = wasm[i]
    if (opcode == 0x2d || opcode == 0x3a) &&
      wasm[i + 1] == 0x40 &&
      wasm[i + 2] == 0x00 &&
      wasm[i + 3] == 0x00 {
      fail(
        "expected default-memory load/store memargs to omit explicit memidx 0",
      )
    }
  }
}

///|
test "optimize-instructions raw partial lowers commuted constant memory addresses" {
  let trace : Array[String] = []
  let optimized = match
    pass_test_run_pipeline(
      (
        #|(module
        #|  (memory 1)
        #|  (func
        #|    i32.const 0
        #|    if
        #|      i32.const 0
        #|      i32.const 0
        #|      i32.const 1
        #|      memory.copy
        #|    end
        #|    i32.const 5
        #|    i32.const 7
        #|    i32.add
        #|    i32.const 63
        #|    i32.const 255
        #|    i32.and
        #|    i32.store8
        #|    i32.const 5
        #|    i32.const 7
        #|    i32.add
        #|    i32.const 7
        #|    i32.const 5
        #|    i32.add
        #|    i32.const 1
        #|    memory.copy))
        #|,
      ),
      ["optimize-instructions"],
      options=HotPipelineOptions::new(trace=Some(fn(line) { trace.push(line) })),
    ) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected raw commuted-address optimize success, got \{err}")
  }
  assert_true(
    trace.any(fn(line) {
      line.contains(
        "pass[optimize-instructions]:skip-raw reason=raw-partial-optimize-instructions",
      )
    }),
    msg="expected dead bulk-memory shell to exercise raw partial path, trace=\{trace}",
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  // Follow-up from `.tmp/oi-g-memory-commuted-operands-count400-20260629`:
  // the OI-G memory-commuted transform exposed raw-partial residuals where
  // Binaryen lowered the folded same-address size-1 `memory.copy` and removed
  // the reversed redundant `i32.and 255` store mask. Keep this scoped to pure
  // constant address arithmetic and size-1 copies.
  assert_false(pretty.contains("memory.copy"), msg=pretty)
  assert_false(pretty.contains("i32.and"), msg=pretty)
  optimize_instructions_assert_strings_in_order(pretty, [
    "I32(12)", "I32(63)", "i32.store8", "I32(12)", "I32(12)", "i32.load8u", "i32.store8",
  ])
}

