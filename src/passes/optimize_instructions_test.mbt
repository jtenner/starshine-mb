  let optimize_caller = fn(right_const : Int) raise {
    let wat = "(module (@binaryen.idempotent) (func $id (param i32) (result i32) local.get 0) (func (param i32) (result i32) local.get 0 i32.const 3 i32.mul call $id i32.const 0 local.get 0 i32.const " +
      right_const.to_string() +
      " i32.mul call $id select))"
    let optimized = match
      pass_test_run_pipeline(wat, ["optimize-instructions"]) {
      Ok(mod_) => mod_
      Err(err) =>
        fail("expected i32.mul-tree idempotent-call OI success, got \{err}")
    }
    optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  }
  let equal = optimize_caller(3)
  assert_false(equal.contains("select"), msg=equal)
  @debug.assert_eq(
    optimize_instructions_test_count_substring(equal, "call (Func 0)"),
    1,
  )
  let different_const = optimize_caller(5)
  assert_true(different_const.contains("select"), msg=different_const)
  @debug.assert_eq(
    optimize_instructions_test_count_substring(different_const, "call (Func 0)"),
    2,
  )
}

///|
test "optimize-instructions folds composed-tree idempotent-call self-selects" {
  // Red-first OI-F parity slice: Binaryen version_130 recursively walks
  // represented nontrapping operand shells, so i32.eqz(i32.add(local, const))
  // is foldable when both repeated trees are equal. Source:
  // `OptimizeInstructions.cpp:2891-2947`; oracle:
  // `.tmp/oi-probes/select-idempotent-call-next-foldability.wat`
  // (`composed_equal` and `composed_mismatch`).
  let optimize_caller = fn(right_const : Int) raise {
    let wat = "(module (@binaryen.idempotent) (func $id (param i32) (result i32) local.get 0) (func (param i32) (result i32) local.get 0 i32.const 1 i32.add i32.eqz call $id i32.const 0 local.get 0 i32.const " +
      right_const.to_string() +
      " i32.add i32.eqz call $id select))"
    let optimized = match
      pass_test_run_pipeline(wat, ["optimize-instructions"]) {
      Ok(mod_) => mod_
      Err(err) =>
        fail("expected composed-tree idempotent-call OI success, got \{err}")
    }
    optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  }
  let equal = optimize_caller(1)
  assert_false(equal.contains("select"), msg=equal)
  @debug.assert_eq(
    optimize_instructions_test_count_substring(equal, "call (Func 0)"),
    1,
  )
  let different_inner_const = optimize_caller(2)
  assert_true(
    different_inner_const.contains("select"),
    msg=different_inner_const,
  )
  @debug.assert_eq(
    optimize_instructions_test_count_substring(
      different_inner_const, "call (Func 0)",
    ),
    2,
  )
}

///|
test "optimize-instructions folds immutable-global i64 add-tree idempotent calls" {
  // Red-first OI-F parity slice: Binaryen version_130 accepts an immutable i64
  // global read below the represented nontrapping add shell, while a mutable
  // global read can be invalidated by the first annotated call. Source:
  // `OptimizeInstructions.cpp:2891-2947`; oracle:
  // `.tmp/oi-probes/select-idempotent-call-next-foldability.wat`
  // (`immutable64_tree` and `mutable64_tree`).
  let optimize_global = fn(mutable : Bool) raise {
    let global_type = if mutable { "(mut i64)" } else { "i64" }
    let wat = "(module (global $g " +
      global_type +
      " (i64.const 7)) (@binaryen.idempotent) (func $id (param i64) (result i64) local.get 0) (func (result i64) i64.const 0 global.get $g i64.const 1 i64.add call $id global.get $g i64.const 1 i64.add call $id i64.eqz select))"
    let optimized = match
      pass_test_run_pipeline(wat, ["optimize-instructions"]) {
      Ok(mod_) => mod_
      Err(err) =>
        fail(
          "expected i64 global add-tree idempotent-call OI success, got \{err}",
        )
    }
    optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  }
  let immutable = optimize_global(false)
  assert_false(immutable.contains("select"), msg=immutable)
  @debug.assert_eq(
    optimize_instructions_test_count_substring(immutable, "call (Func 0)"),
    1,
  )
  let mutable = optimize_global(true)
  assert_true(mutable.contains("select"), msg=mutable)
  @debug.assert_eq(
    optimize_instructions_test_count_substring(mutable, "call (Func 0)"),
    2,
  )
}

///|
test "optimize-instructions folds local and const idempotent-call self-selects" {
  // Red-first OI-F parity slice: Binaryen version_130 checks idempotent-call
  // operand effects before folding the later equal call. Direct local.get and
  // scalar-constant operands have no unremovable effects and cannot be
  // invalidated by the call shell. Source: `OptimizeInstructions.cpp:2891-2947`;
  // oracle: `.tmp/oi-probes/select-idempotent-call-foldability.wat`.
  let optimize_caller = fn(body : String, params : String) raise {
    let wat = "(module (@binaryen.idempotent) (func $id (param i32) (result i32) local.get 0) (func " +
      params +
      " (result i32) " +
      body +
      "))"
    let optimized = match
      pass_test_run_pipeline(wat, ["optimize-instructions"]) {
      Ok(mod_) => mod_
      Err(err) =>
        fail("expected operand idempotent-call OI success, got \{err}")
    }
    optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  }
  let local_arg = optimize_caller(
    "local.get 0 call $id i32.const 0 local.get 0 call $id select", "(param i32)",
  )
  assert_false(local_arg.contains("select"), msg=local_arg)
  @debug.assert_eq(
    optimize_instructions_test_count_substring(local_arg, "call (Func 0)"),
    1,
  )
  let const_ = optimize_caller(
    "i32.const 0 i32.const 9 call $id i32.const 9 call $id select", "",
  )
  assert_false(const_.contains("select"), msg=const_)
  @debug.assert_eq(
    optimize_instructions_test_count_substring(const_, "call (Func 0)"),
    1,
  )
  assert_true(const_.contains("drop"), msg=const_)
  let different_locals = optimize_caller(
    "local.get 0 call $id i32.const 0 local.get 1 call $id select", "(param i32 i32)",
  )
  assert_true(different_locals.contains("select"), msg=different_locals)
  @debug.assert_eq(
    optimize_instructions_test_count_substring(
      different_locals, "call (Func 0)",
    ),
    2,
  )
}

