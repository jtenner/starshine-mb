///|
test "optimize-instructions sinks br_on_non_null trapping fallthrough ref.get_desc like Binaryen" {
  // OI-J descriptor-operand escaping-label trap-order boundary: Binaryen
  // version_130 default/IIT do not flatten this trapping fallthrough, but they
  // sink `ref.get_desc` into the descriptor block after the preserved trap and
  // remove the explicit outer `ref.as_non_null`. This is intentionally narrow
  // and does not claim broad trapping/effectful br_on_* localization.
