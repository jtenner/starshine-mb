///|
test "optimize-instructions folds ref.test from br_on_null fallthrough facts" {
  // OI-J fallthrough-type fact slice: Binaryen version_130
  // `Properties::getImmediateFallthrough` returns `BrOn::ref`, so a direct HOT
  // `br_on_null` fallthrough value can expose the precise producer type to
  // `visitRefTest`. Public stack-prefix coverage remains blocked by HOT's
  // multi-result branch representation: a valid WAT prefix payload makes the
  // br_on node produce `(payload, ref)`, and ref.test folding needs a separate
  // lane-localization repair before it may drop/replace that shared producer.
  let eq_heap = @lib.HeapType::abs(@lib.AbsHeapType::eq())
  let i31_heap = @lib.HeapType::abs(@lib.AbsHeapType::i31())
  let eq_ref_val = @lib.ValType::ref_type(@lib.RefType::new(false, eq_heap))
  let i31_ref_type = @lib.RefType::new(false, i31_heap)
  let i31_ref_val = @lib.ValType::ref_type(i31_ref_type)
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::i32()]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([@lib.TypeIdx::new(0U)]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::i32_const(@lib.I32(7)),
            @lib.Instruction::ref_i31(),
            @lib.Instruction::ref_test_type(i31_ref_type),
          ]),
        ),
      ]),
    )
  let func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(0U))
  let ref_test = @ir.hot_root_get(func, 0)
  let ref_i31 = @ir.hot_child_get(func, ref_test, 0)
  let target = @ir.hot_control_node_label(
    func,
    @ir.hot_build_block(func, @lib.BlockType::void_(), []),
  )
  let br_on_null = @ir.hot_build_node(
    func,
    @ir.HotOp::br_on_null(),
    @ir.hot_type_intern_value(func, i31_ref_val),
    imm0=target,
    children=[ref_i31],
  )
  let fallthrough_block = @ir.hot_build_block(
    func,
    @lib.BlockType::val_type(eq_ref_val),
    [br_on_null],
  )
  @ir.hot_child_set(func, ref_test, 0, fallthrough_block)
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::final_module_only(),
    false,
    ignore,
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) =>
      fail("expected br_on_null fallthrough ref.test HOT success, got \{err}")
  }
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_get(func, root).op {
    @ir.HotOp::Block => ()
    other => fail("expected folded br_on_null ref.test block, got \{other}")
  }
  let body = @ir.hot_region_body_ref(func, root)
  @debug.assert_eq(@ir.hot_region_root_count(func, body), 2)
  match @ir.hot_node_get(func, @ir.hot_region_get(func, body, 1)).op {
    @ir.HotOp::Const => ()
    other =>
      fail("expected folded true constant after br_on_null drop, got \{other}")
  }
}

///|
test "optimize-instructions folds ref.test through ref cast fallthrough facts" {
  // OI-J fallthrough-type fact slice: Binaryen version_130
  // `Properties::getImmediateFallthrough` looks through `ref.cast` and
  // non-conversion `ref.as_non_null`, then `getFallthroughType` intersects the
  // wrapper type with the wrapped producer. A broad cast/null-check wrapper must
  // therefore still expose the precise fallthrough producer to `visitRefTest`.
  // This HOT-only fixture follows the existing block/if fallthrough tests until
  // public validation accepts subtype block-result shapes.
  let eq_heap = @lib.HeapType::abs(@lib.AbsHeapType::eq())
  let i31_heap = @lib.HeapType::abs(@lib.AbsHeapType::i31())
  let non_null_eq_ref = @lib.ValType::ref_type(
    @lib.RefType::new(false, eq_heap),
  )
  let nullable_eq_ref = @lib.ValType::ref_type(@lib.RefType::new(true, eq_heap))
  let i31_ref_type = @lib.RefType::new(false, i31_heap)
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::i32()]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::i32()]),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([@lib.TypeIdx::new(0U), @lib.TypeIdx::new(1U)]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(non_null_eq_ref),
              @lib.Expr::new([
                @lib.Instruction::i32_const(@lib.I32(7)),
                @lib.Instruction::ref_i31(),
              ]),
            ),
            @lib.Instruction::ref_cast(false, eq_heap),
            @lib.Instruction::ref_test_type(i31_ref_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(nullable_eq_ref),
              @lib.Expr::new([
                @lib.Instruction::i32_const(@lib.I32(8)),
                @lib.Instruction::ref_i31(),
              ]),
            ),
            @lib.Instruction::ref_as_non_null(),
            @lib.Instruction::ref_test_type(i31_ref_type),
          ]),
        ),
      ]),
    )
  for func_idx = 0; func_idx < 2; func_idx = func_idx + 1 {
    let func = @ir.hot_lift_func(
      module_,
      @lib.FuncIdx::new(func_idx.reinterpret_as_uint()),
    )
    let ctx = HotPassContext::new(
      optimize_instructions_descriptor(),
      @ir.HotAnalysisCache::new(),
      HotPipelineVerifyPolicy::final_module_only(),
      false,
      ignore,
    )
    match hot_pass_run(ctx, func) {
      Ok(_) => ()
      Err(err) =>
        fail("expected cast fallthrough ref.test HOT success, got \{err}")
    }
    let @lib.Func(_, @lib.Expr(body)) = @ir.hot_lower_func_unverified(func)
    let rendered = "\{body}"
    assert_false(
      body.any(fn(instr) {
        instr == @lib.Instruction::ref_test_type(i31_ref_type)
      }),
      msg="expected cast fallthrough ref.test to fold, got \{body}",
    )
    assert_true(
      rendered.contains("I32(1)"),
      msg="expected folded true constant, got \{body}",
    )
  }
}

///|
test "optimize-instructions folds exact ref.test on already exact operands" {
  // OI-J exactness positive: Binaryen version_130 folds
  // `ref.test (ref (exact $a))` to true when the tested value is already an
  // exact `$a`, preserving effectful producers as dropped operands. Binaryen
  // also folds the non-null same-heap inexact local predicate to true here when
  // the heap is final, unlike exact ref.cast where Binaryen keeps the runtime
  // cast/proof.
  let foo_type = @lib.TypeIdx::new(0U)
  let pure_func_type = @lib.TypeIdx::new(1U)
  let effectful_func_type = @lib.TypeIdx::new(1U)
  let inexact_func_type = @lib.TypeIdx::new(2U)
  let foo_heap = @lib.HeapType::new(foo_type)
  let exact_foo_ref_type = @lib.RefType::new(false, foo_heap, exact=true)
  let exact_foo_ref = @lib.ValType::ref_type(exact_foo_ref_type)
  let inexact_foo_ref = @lib.ValType::ref_type(
    @lib.RefType::new(false, foo_heap),
  )
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::new(true, [], @lib.CompType::struct_([])),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([exact_foo_ref], [@lib.ValType::i32()]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([inexact_foo_ref], [@lib.ValType::i32()]),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([pure_func_type, effectful_func_type, inexact_func_type]),
    )
    .with_global_sec(
      @lib.GlobalSec::new([
        @lib.Global::new(
          @lib.GlobalType::new(@lib.ValType::i32(), true),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_test_type(exact_foo_ref_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(exact_foo_ref),
              @lib.Expr::new([
                @lib.Instruction::i32_const(@lib.I32(1)),
                @lib.Instruction::global_set(@lib.GlobalIdx::new(0U)),
                @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
              ]),
            ),
            @lib.Instruction::ref_test_type(exact_foo_ref_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_test_type(exact_foo_ref_type),
          ]),
        ),
      ]),
    ),
  )
  let exact_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  let effectful_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  let inexact_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_false(exact_pretty.contains("ref.test"), msg=exact_pretty)
  assert_true(exact_pretty.contains("I32(1)"), msg=exact_pretty)
  assert_false(effectful_pretty.contains("ref.test"), msg=effectful_pretty)
  assert_true(effectful_pretty.contains("global.set"), msg=effectful_pretty)
  assert_true(effectful_pretty.contains("I32(1)"), msg=effectful_pretty)
  assert_false(inexact_pretty.contains("ref.test"), msg=inexact_pretty)
  assert_true(inexact_pretty.contains("I32(1)"), msg=inexact_pretty)
}

///|
test "optimize-instructions folds exact ref.test and ref.cast misses on exact subtype operands" {
  // OI-J exactness miss slice: Binaryen version_130 folds an exact test/cast
  // against `$base` to false/unreachable when the operand is statically known to
  // be exact `$sub <: $base`. The ordinary subtype matcher cannot prove this
  // because inexact `$sub` values match `$base`; exact-target matching must also
  // rule out the exact supertype result. Effectful producers are kept as dropped
  // prefixes before the false/unreachable replacement.
  let base_type = @lib.TypeIdx::new(0U)
  let sub_type = @lib.TypeIdx::new(1U)
  let test_func_type = @lib.TypeIdx::new(2U)
  let cast_func_type = @lib.TypeIdx::new(3U)
  let base_heap = @lib.HeapType::new(base_type)
  let sub_heap = @lib.HeapType::new(sub_type)
  let exact_base_ref_type = @lib.RefType::new(false, base_heap, exact=true)
  let exact_sub_ref_type = @lib.RefType::new(false, sub_heap, exact=true)
  let exact_base_ref = @lib.ValType::ref_type(exact_base_ref_type)
  let exact_sub_ref = @lib.ValType::ref_type(exact_sub_ref_type)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::new(
            false,
            [base_type],
            @lib.CompType::struct_([
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i64()),
                @lib.Mut::const_(),
              ),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([exact_sub_ref], [@lib.ValType::i32()]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([exact_sub_ref], [exact_base_ref]),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        test_func_type, test_func_type, cast_func_type, cast_func_type,
      ]),
    )
    .with_global_sec(
      @lib.GlobalSec::new([
        @lib.Global::new(
          @lib.GlobalType::new(@lib.ValType::i32(), true),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_test_type(exact_base_ref_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(exact_sub_ref),
              @lib.Expr::new([
                @lib.Instruction::i32_const(@lib.I32(1)),
                @lib.Instruction::global_set(@lib.GlobalIdx::new(0U)),
                @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
              ]),
            ),
            @lib.Instruction::ref_test_type(exact_base_ref_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_cast_type(exact_base_ref_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(exact_sub_ref),
              @lib.Expr::new([
                @lib.Instruction::i32_const(@lib.I32(2)),
                @lib.Instruction::global_set(@lib.GlobalIdx::new(0U)),
                @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
              ]),
            ),
            @lib.Instruction::ref_cast_type(exact_base_ref_type),
          ]),
        ),
      ]),
    ),
  )
  let test_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  let effect_test_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  let cast_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  let effect_cast_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(3U))
  assert_false(test_pretty.contains("ref.test"), msg=test_pretty)
  assert_true(test_pretty.contains("I32(0)"), msg=test_pretty)
  assert_false(effect_test_pretty.contains("ref.test"), msg=effect_test_pretty)
  assert_true(effect_test_pretty.contains("global.set"), msg=effect_test_pretty)
  assert_true(effect_test_pretty.contains("I32(0)"), msg=effect_test_pretty)
  assert_false(cast_pretty.contains("ref.cast"), msg=cast_pretty)
  assert_true(cast_pretty.contains("unreachable"), msg=cast_pretty)
  assert_false(effect_cast_pretty.contains("ref.cast"), msg=effect_cast_pretty)
  assert_true(effect_cast_pretty.contains("global.set"), msg=effect_cast_pretty)
  assert_true(
    effect_cast_pretty.contains("unreachable"),
    msg=effect_cast_pretty,
  )
}

///|
test "optimize-instructions folds exact ref.test and ref.cast misses on inexact strict subtype operands" {
  // OI-J exactness/useful-type-info slice: Binaryen version_130 folds an
  // exact test/cast against `$base` to false/unreachable when the operand is a
  // non-null inexact `$sub <: $base` local. Even though `$sub` values match the
  // inexact `$base` heap, they can never have exact runtime type `$base`.
  // Effectful producers are preserved as dropped prefixes before the
  // false/unreachable replacement. This deliberately does not fold arbitrary
  // same-heap inexact exact-target casts or descriptor forms.
  let base_type = @lib.TypeIdx::new(0U)
  let sub_type = @lib.TypeIdx::new(1U)
  let test_func_type = @lib.TypeIdx::new(2U)
  let cast_func_type = @lib.TypeIdx::new(3U)
  let base_heap = @lib.HeapType::new(base_type)
  let sub_heap = @lib.HeapType::new(sub_type)
  let exact_base_ref_type = @lib.RefType::new(false, base_heap, exact=true)
  let exact_base_ref = @lib.ValType::ref_type(exact_base_ref_type)
  let inexact_sub_ref = @lib.ValType::ref_type(
    @lib.RefType::new(false, sub_heap),
  )
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::new(
            false,
            [base_type],
            @lib.CompType::struct_([
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i64()),
                @lib.Mut::const_(),
              ),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([inexact_sub_ref], [@lib.ValType::i32()]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([inexact_sub_ref], [exact_base_ref]),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        test_func_type, test_func_type, cast_func_type, cast_func_type,
      ]),
    )
    .with_global_sec(
      @lib.GlobalSec::new([
        @lib.Global::new(
          @lib.GlobalType::new(@lib.ValType::i32(), true),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_test_type(exact_base_ref_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(inexact_sub_ref),
              @lib.Expr::new([
                @lib.Instruction::i32_const(@lib.I32(1)),
                @lib.Instruction::global_set(@lib.GlobalIdx::new(0U)),
                @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
              ]),
            ),
            @lib.Instruction::ref_test_type(exact_base_ref_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_cast_type(exact_base_ref_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(inexact_sub_ref),
              @lib.Expr::new([
                @lib.Instruction::i32_const(@lib.I32(2)),
                @lib.Instruction::global_set(@lib.GlobalIdx::new(0U)),
                @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
              ]),
            ),
            @lib.Instruction::ref_cast_type(exact_base_ref_type),
          ]),
        ),
      ]),
    ),
  )
  let test_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  let effect_test_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  let cast_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  let effect_cast_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(3U))
  assert_false(test_pretty.contains("ref.test"), msg=test_pretty)
  assert_true(test_pretty.contains("I32(0)"), msg=test_pretty)
  assert_false(effect_test_pretty.contains("ref.test"), msg=effect_test_pretty)
  assert_true(effect_test_pretty.contains("global.set"), msg=effect_test_pretty)
  assert_true(effect_test_pretty.contains("I32(0)"), msg=effect_test_pretty)
  assert_false(cast_pretty.contains("ref.cast"), msg=cast_pretty)
  assert_true(cast_pretty.contains("unreachable"), msg=cast_pretty)
  assert_false(effect_cast_pretty.contains("ref.cast"), msg=effect_cast_pretty)
  assert_true(effect_cast_pretty.contains("global.set"), msg=effect_cast_pretty)
  assert_true(
    effect_cast_pretty.contains("unreachable"),
    msg=effect_cast_pretty,
  )
}

///|
test "optimize-instructions keeps non-final inexact exact ref.test checks" {
  // OI-J exactness/useful-type-info boundary: an inexact reference to a
  // non-final heap can hold a future strict-subtype value, so `ref.test` against
  // the exact same heap is not definitely true. Binaryen version_130 keeps the
  // predicate for explicit non-final `(sub ...)` heaps; the successful exact
  // same-heap fold is valid only when the source is already exact or the heap is
  // final.
  let open_type = @lib.TypeIdx::new(0U)
  let test_func_type = @lib.TypeIdx::new(1U)
  let open_heap = @lib.HeapType::new(open_type)
  let exact_open_ref_type = @lib.RefType::new(false, open_heap, exact=true)
  let inexact_open_ref = @lib.ValType::ref_type(
    @lib.RefType::new(false, open_heap),
  )
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([inexact_open_ref], [@lib.ValType::i32()]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([test_func_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_test_type(exact_open_ref_type),
          ]),
        ),
      ]),
    ),
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_true(pretty.contains("ref.test"), msg=pretty)
  assert_false(pretty.contains("I32(1)"), msg=pretty)
}

///|
test "optimize-instructions folds final heap exact ref.test matches" {
  // OI-J exactness/useful-type-info slice: Binaryen version_130 treats an
  // inexact reference to a final heap as exact for `ref.test` because no
  // concrete strict subtype can exist. Non-null final operands tested against a
  // non-null exact target and nullable final operands tested against a nullable
  // exact target fold to true; effectful operands are still evaluated before the
  // constant. Nullable final operands tested against a non-null exact target
  // keep only the null check. Exact `ref.cast` is deliberately not widened here
  // because Binaryen keeps final-heap exact casts.
  let final_type = @lib.TypeIdx::new(0U)
  let nonnull_test_func_type = @lib.TypeIdx::new(1U)
  let nullable_test_func_type = @lib.TypeIdx::new(2U)
  let final_heap = @lib.HeapType::new(final_type)
  let nonnull_final_ref_type = @lib.RefType::new(false, final_heap, exact=true)
  let nullable_final_ref_type = @lib.RefType::new(true, final_heap, exact=true)
  let nonnull_final_ref = @lib.ValType::ref_type(
    @lib.RefType::new(false, final_heap),
  )
  let nullable_final_ref = @lib.ValType::ref_type(
    @lib.RefType::new(true, final_heap),
  )
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::new(
            true,
            [],
            @lib.CompType::struct_([
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([nonnull_final_ref], [@lib.ValType::i32()]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([nullable_final_ref], [@lib.ValType::i32()]),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        nonnull_test_func_type, nullable_test_func_type, nullable_test_func_type,
        nullable_test_func_type,
      ]),
    )
    .with_global_sec(
      @lib.GlobalSec::new([
        @lib.Global::new(
          @lib.GlobalType::new(@lib.ValType::i32(), true),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_test_type(nonnull_final_ref_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_test_type(nullable_final_ref_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(nullable_final_ref),
              @lib.Expr::new([
                @lib.Instruction::i32_const(@lib.I32(1)),
                @lib.Instruction::global_set(@lib.GlobalIdx::new(0U)),
                @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
              ]),
            ),
            @lib.Instruction::ref_test_type(nullable_final_ref_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_test_type(nonnull_final_ref_type),
          ]),
        ),
      ]),
    ),
  )
  let nonnull_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  let nullable_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  let effect_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  let nullable_to_nonnull_pretty = optimized.pretty_print_func(
    @lib.FuncIdx::new(3U),
  )
  assert_false(nonnull_pretty.contains("ref.test"), msg=nonnull_pretty)
  assert_true(nonnull_pretty.contains("I32(1)"), msg=nonnull_pretty)
  assert_false(nullable_pretty.contains("ref.test"), msg=nullable_pretty)
  assert_true(nullable_pretty.contains("I32(1)"), msg=nullable_pretty)
  assert_false(effect_pretty.contains("ref.test"), msg=effect_pretty)
  assert_true(effect_pretty.contains("global.set"), msg=effect_pretty)
  assert_true(effect_pretty.contains("I32(1)"), msg=effect_pretty)
  assert_false(
    nullable_to_nonnull_pretty.contains("ref.test"),
    msg=nullable_to_nonnull_pretty,
  )
  assert_true(
    nullable_to_nonnull_pretty.contains("ref.null"),
    msg=nullable_to_nonnull_pretty,
  )
}

///|
test "optimize-instructions folds nullable exact ref.test subtype misses to ref.is_null" {
  // OI-J exactness/useful-type-info slice: Binaryen version_130 rewrites a
  // nullable exact-target test to `ref.is_null` when a nullable `$sub` operand
  // cannot have exact runtime type `$base`; null is the only matching value.
  // This covers exact and inexact strict-subtype operands plus an effectful
  // inexact producer, and deliberately does not widen nullable exact casts.
  let base_type = @lib.TypeIdx::new(0U)
  let sub_type = @lib.TypeIdx::new(1U)
  let exact_test_func_type = @lib.TypeIdx::new(2U)
  let inexact_test_func_type = @lib.TypeIdx::new(3U)
  let base_heap = @lib.HeapType::new(base_type)
  let sub_heap = @lib.HeapType::new(sub_type)
  let nullable_exact_base_ref_type = @lib.RefType::new(
    true,
    base_heap,
    exact=true,
  )
  let nullable_exact_sub_ref = @lib.ValType::ref_type(
    @lib.RefType::new(true, sub_heap, exact=true),
  )
  let nullable_inexact_sub_ref = @lib.ValType::ref_type(
    @lib.RefType::new(true, sub_heap),
  )
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::new(
            false,
            [base_type],
            @lib.CompType::struct_([
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i64()),
                @lib.Mut::const_(),
              ),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([nullable_exact_sub_ref], [@lib.ValType::i32()]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([nullable_inexact_sub_ref], [
              @lib.ValType::i32(),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        exact_test_func_type, inexact_test_func_type, inexact_test_func_type,
      ]),
    )
    .with_global_sec(
      @lib.GlobalSec::new([
        @lib.Global::new(
          @lib.GlobalType::new(@lib.ValType::i32(), true),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_test_type(nullable_exact_base_ref_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_test_type(nullable_exact_base_ref_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(nullable_inexact_sub_ref),
              @lib.Expr::new([
                @lib.Instruction::i32_const(@lib.I32(1)),
                @lib.Instruction::global_set(@lib.GlobalIdx::new(0U)),
                @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
              ]),
            ),
            @lib.Instruction::ref_test_type(nullable_exact_base_ref_type),
          ]),
        ),
      ]),
    ),
  )
  let exact_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  let inexact_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  let effect_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  // pretty_print currently spells the lowered RefIsNull instruction as
  // `ref.null`; this test locks the OI rewrite by proving `ref.test` is gone
  // and the null predicate remains instead of a constant false/true fold.
  assert_false(exact_pretty.contains("ref.test"), msg=exact_pretty)
  assert_true(exact_pretty.contains("ref.null"), msg=exact_pretty)
  assert_false(inexact_pretty.contains("ref.test"), msg=inexact_pretty)
  assert_true(inexact_pretty.contains("ref.null"), msg=inexact_pretty)
  assert_false(effect_pretty.contains("ref.test"), msg=effect_pretty)
  assert_true(effect_pretty.contains("ref.null"), msg=effect_pretty)
  assert_true(effect_pretty.contains("global.set"), msg=effect_pretty)
  match optimized.code_sec {
    Some(
      @lib.CodeSec(
        [
          @lib.Func(_, @lib.Expr(exact_body)),
          @lib.Func(_, @lib.Expr(inexact_body)),
          @lib.Func(_, @lib.Expr(effect_body)),
        ]
      )
    ) => {
      assert_true(
        exact_body.any(fn(instr) { instr == @lib.Instruction::ref_is_null() }),
      )
      assert_true(
        inexact_body.any(fn(instr) { instr == @lib.Instruction::ref_is_null() }),
      )
      assert_true(
        effect_body.any(fn(instr) { instr == @lib.Instruction::ref_is_null() }),
      )
    }
    _ => fail("expected exactly three optimized functions")
  }
}

///|
test "optimize-instructions narrows nullable exact ref.cast subtype misses to nullref" {
  // OI-J exactness/useful-type-info slice: Binaryen version_130 rewrites a
  // nullable exact-target cast to `ref.cast nullref` when a nullable `$sub`
  // operand cannot have exact runtime type `$base`; null is the only value that
  // can successfully pass the original cast. This mirrors the adjacent
  // nullable exact-target `ref.test` -> `ref.is_null` slice, preserves effectful
  // operands as the cast child, and deliberately does not widen descriptor casts
  // or arbitrary same-heap exact-target casts.
  let base_type = @lib.TypeIdx::new(0U)
  let sub_type = @lib.TypeIdx::new(1U)
  let exact_cast_func_type = @lib.TypeIdx::new(2U)
  let inexact_cast_func_type = @lib.TypeIdx::new(3U)
  let base_heap = @lib.HeapType::new(base_type)
  let sub_heap = @lib.HeapType::new(sub_type)
  let none_heap = @lib.HeapType::abs(@lib.AbsHeapType::none())
  let nullable_exact_base_ref_type = @lib.RefType::new(
    true,
    base_heap,
    exact=true,
  )
  let nullable_exact_base_ref = @lib.ValType::ref_type(
    nullable_exact_base_ref_type,
  )
  let nullable_exact_sub_ref = @lib.ValType::ref_type(
    @lib.RefType::new(true, sub_heap, exact=true),
  )
  let nullable_inexact_sub_ref = @lib.ValType::ref_type(
    @lib.RefType::new(true, sub_heap),
  )
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::new(
            false,
            [base_type],
            @lib.CompType::struct_([
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i64()),
                @lib.Mut::const_(),
              ),
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([nullable_exact_sub_ref], [
              nullable_exact_base_ref,
            ]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([nullable_inexact_sub_ref], [
              nullable_exact_base_ref,
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(
      @lib.FuncSec::new([
        exact_cast_func_type, inexact_cast_func_type, inexact_cast_func_type,
      ]),
    )
    .with_global_sec(
      @lib.GlobalSec::new([
        @lib.Global::new(
          @lib.GlobalType::new(@lib.ValType::i32(), true),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_cast_type(nullable_exact_base_ref_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_cast_type(nullable_exact_base_ref_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(nullable_inexact_sub_ref),
              @lib.Expr::new([
                @lib.Instruction::i32_const(@lib.I32(1)),
                @lib.Instruction::global_set(@lib.GlobalIdx::new(0U)),
                @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
              ]),
            ),
            @lib.Instruction::ref_cast_type(nullable_exact_base_ref_type),
          ]),
        ),
      ]),
    ),
  )
  let exact_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  let inexact_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  let effect_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(2U))
  assert_false(exact_pretty.contains("(exact"), msg=exact_pretty)
  assert_false(inexact_pretty.contains("(exact"), msg=inexact_pretty)
  assert_false(effect_pretty.contains("(exact"), msg=effect_pretty)
  assert_true(effect_pretty.contains("global.set"), msg=effect_pretty)
  match optimized.code_sec {
    Some(
      @lib.CodeSec(
        [
          @lib.Func(_, @lib.Expr(exact_body)),
          @lib.Func(_, @lib.Expr(inexact_body)),
          @lib.Func(_, @lib.Expr(effect_body)),
        ]
      )
    ) => {
      let is_nullref_cast = fn(instr : @lib.Instruction) -> Bool {
        match instr {
          @lib.RefCast(true, false, target) => target == none_heap
          _ => false
        }
      }
      assert_true(exact_body.any(is_nullref_cast))
      assert_true(inexact_body.any(is_nullref_cast))
      assert_true(effect_body.any(is_nullref_cast))
    }
    _ => fail("expected exactly three optimized functions")
  }
}

///|
test "optimize-instructions removes local ref.as_non_null sets under trap-ignoring modes" {
  // OI-J trap-mode slice: Binaryen version_130 default mode preserves the
  // implicit null trap in `local.set $x (ref.as_non_null (local.get $x))`, but
  // both `--ignore-implicit-traps` and `--traps-never-happen` erase the null
  // check because the target local is nullable and accepts the original value.
  // This is deliberately limited to local.set/local.tee-compatible children and
  // does not claim broader ref.as_non_null result-context rewriting.
  let source =
    #|(module
    #|  (func (param $x anyref)
    #|    (local.set $x (ref.as_non_null (local.get $x)))))
    #|
  let default_optimized = match
    pass_test_run_pipeline(source, ["optimize-instructions"]) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected default ref.as_non_null probe success, got \{err}")
  }
  let default_pretty = default_optimized.pretty_print_func(
    @lib.FuncIdx::new(0U),
  )
  assert_true(default_pretty.contains("ref.as_non_null"), msg=default_pretty)

  let iit_optimized = match
    pass_test_run_pipeline(
      source,
      ["optimize-instructions"],
      options=HotPipelineOptions::new(ignore_implicit_traps=true),
    ) {
    Ok(mod_) => mod_
    Err(err) => fail("expected IIT ref.as_non_null probe success, got \{err}")
  }
  let iit_pretty = iit_optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(iit_pretty.contains("ref.as_non_null"), msg=iit_pretty)
  optimize_instructions_assert_strings_in_order(iit_pretty, [
    "local.get", "local.set",
  ])

  let tnh_optimized = match
    pass_test_run_pipeline(
      source,
      ["optimize-instructions"],
      options=HotPipelineOptions::new(traps_never_happen=true),
    ) {
    Ok(mod_) => mod_
    Err(err) => fail("expected TNH ref.as_non_null probe success, got \{err}")
  }
  let tnh_pretty = tnh_optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(tnh_pretty.contains("ref.as_non_null"), msg=tnh_pretty)
  optimize_instructions_assert_strings_in_order(tnh_pretty, [
    "local.get", "local.set",
  ])
}

///|
test "optimize-instructions folds same-local nullable ref.cast equality under trap-ignoring modes" {
  // OI-J trap-mode slice from roadmap probe 12: default mode must preserve the
  // nullable ref.cast trap in `ref.eq(x, ref.cast T x)`, but IIT/TNH can skip the
  // trap and fold same-local equality to true. This covers only the local-ref.eq
  // observation point, not general ordinary cast erasure.
  let type_idx = @lib.TypeIdx::new(0U)
  let func_type = @lib.TypeIdx::new(1U)
  let heap = @lib.HeapType::new(type_idx)
  let eqref_type = @lib.ValType::ref_type(
    @lib.RefType::new(true, @lib.HeapType::abs(@lib.AbsHeapType::eq())),
  )
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::new(@lib.SubType::comp_type(@lib.CompType::struct_([]))),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([eqref_type], [@lib.ValType::i32()]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([func_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_cast_type(@lib.RefType::new(true, heap)),
            @lib.Instruction::ref_eq(),
          ]),
        ),
      ]),
    )

  let default_func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(0U))
  let default_ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    module_ctx=Some(@ir.hot_module_context_from_module(module_)),
  )
  match hot_pass_run(default_ctx, default_func) {
    Ok(_) => ()
    Err(err) =>
      fail("expected default same-local cast equality success, got \{err}")
  }
  let @lib.Func(_, @lib.Expr(default_body)) = @ir.hot_lower_func(default_func)
  assert_true(
    default_body.any(fn(instr) { instr == @lib.Instruction::ref_eq() }),
  )
  assert_true(
    default_body.any(fn(instr) {
      match instr {
        @lib.RefCast(true, false, target) => target == heap
        _ => false
      }
    }),
  )

  let iit_func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(0U))
  let iit_ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    ignore_implicit_traps=true,
    module_ctx=Some(@ir.hot_module_context_from_module(module_)),
  )
  match hot_pass_run(iit_ctx, iit_func) {
    Ok(_) => ()
    Err(err) =>
      fail("expected IIT same-local cast equality success, got \{err}")
  }
  let @lib.Func(_, @lib.Expr(iit_body)) = @ir.hot_lower_func(iit_func)
  @debug.assert_eq(iit_body, [@lib.Instruction::i32_const(@lib.I32(1))])

  let tnh_func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(0U))
  let tnh_ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    traps_never_happen=true,
    module_ctx=Some(@ir.hot_module_context_from_module(module_)),
  )
  match hot_pass_run(tnh_ctx, tnh_func) {
    Ok(_) => ()
    Err(err) =>
      fail("expected TNH same-local cast equality success, got \{err}")
  }
  let @lib.Func(_, @lib.Expr(tnh_body)) = @ir.hot_lower_func(tnh_func)
  @debug.assert_eq(tnh_body, [@lib.Instruction::i32_const(@lib.I32(1))])
}

///|
test "optimize-instructions traps standalone ref.get_desc on known-null child" {
  // OI-J null-trap fact slice: Binaryen version_130 routes ref.get_desc
  // through trapOnNull, so a known-null reference operand becomes unreachable
  // without preserving the descriptor read. This locks a reusable ref fact before
  // widening descriptor-cast rewrites that depend on the same null evidence.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let func_type = @lib.TypeIdx::new(2U)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(@lib.SubType::comp_type(@lib.CompType::func([], []))),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([func_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::ref_null(@lib.HeapType::new(described_type)),
            @lib.Instruction::ref_get_desc(described_type),
            @lib.Instruction::drop(),
          ]),
        ),
      ]),
    ),
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_true(pretty.contains("unreachable"), msg=pretty)
  assert_false(pretty.contains("ref.get_desc"), msg=pretty)
}

///|
test "optimize-instructions folds ref.test_desc null operands from descriptor test facts" {
  // OI-J descriptor-test fact slice: Binaryen version_130 routes ref.test_desc
  // through the same RefTest cast-check family. Null operands fold entirely from
  // the nullable target fact before any broader descriptor producer or
  // fallthrough-type lattice is needed.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let nullable_func_type = @lib.TypeIdx::new(2U)
  let nonnull_func_type = @lib.TypeIdx::new(3U)
  let described_heap = @lib.HeapType::new(described_type)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::i32()]),
          ),
        ),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::i32()]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([nullable_func_type, nonnull_func_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::ref_null(described_heap),
            @lib.Instruction::ref_test_desc(true, described_heap),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::ref_null(described_heap),
            @lib.Instruction::ref_test_desc(false, described_heap),
          ]),
        ),
      ]),
    ),
  )
  let @lib.Func(_, @lib.Expr(nullable_body)) = match optimized.code_sec {
    Some(@lib.CodeSec([func, _])) => func
    _ => fail("expected optimized nullable ref.test_desc function")
  }
  let @lib.Func(_, @lib.Expr(nonnull_body)) = match optimized.code_sec {
    Some(@lib.CodeSec([_, func])) => func
    _ => fail("expected optimized non-null ref.test_desc function")
  }
  @debug.assert_eq(nullable_body, [@lib.Instruction::i32_const(@lib.I32(1))])
  @debug.assert_eq(nonnull_body, [@lib.Instruction::i32_const(@lib.I32(0))])
}

///|
test "optimize-instructions documents descriptor ref.test_desc miss validation boundary" {
  // OI-J descriptor-test miss boundary: Binaryen version_130 routes
  // `ref.test_desc` through the same `GCTypeUtils::evaluateCastCheck` family as
  // ordinary `ref.test`, but Starshine's current validation rejects a disjoint
  // descriptor-test target before OI can observe or fold the miss. Keep this as
  // an explicit invalid-shape boundary; reopen only with a validated public/HOT
  // fixture whose descriptor target can miss the operand type.
  let described_a_type = @lib.TypeIdx::new(0U)
  let descriptor_a_type = @lib.TypeIdx::new(1U)
  let described_b_type = @lib.TypeIdx::new(2U)
  let descriptor_b_type = @lib.TypeIdx::new(3U)
  let func_type = @lib.TypeIdx::new(4U)
  let described_b_heap = @lib.HeapType::new(described_b_type)
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_a_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_a_type)),
          ),
        ]),
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_b_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_b_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::i32()]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([func_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::struct_new_default(descriptor_a_type),
            @lib.Instruction::struct_new_default_desc(described_a_type),
            @lib.Instruction::ref_test_desc(false, described_b_heap),
          ]),
        ),
      ]),
    )
  match @validate.validate_module(module_) {
    Ok(_) =>
      fail("expected disjoint ref.test_desc target to stay validation-blocked")
    Err(err) =>
      assert_true(
        "\{err}".contains("ref.test_desc target does not match operand type"),
        msg="expected descriptor miss validation boundary, got \{err}",
      )
  }
}

///|
test "optimize-instructions folds same-heap ref.test_desc successes from descriptor test facts" {
  // OI-J descriptor-test fact slice: Binaryen version_130 evaluates
  // `ref.test_desc` through the RefTest cast-check path. A non-null operand
  // whose fallthrough type already matches the descriptor-test target succeeds
  // without a runtime descriptor-test check; the operand's construction/effects
  // are still preserved as the dropped payload when needed.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let func_type = @lib.TypeIdx::new(2U)
  let described_heap = @lib.HeapType::new(described_type)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::i32()]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([func_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::struct_new_default(descriptor_type),
            @lib.Instruction::struct_new_default_desc(described_type),
            @lib.Instruction::ref_test_desc(false, described_heap),
          ]),
        ),
      ]),
    ),
  )
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_false(pretty.contains("ref.test_desc"), msg=pretty)
  assert_true(pretty.contains("I32(1)"), msg=pretty)
}

///|
test "optimize-instructions intentionally keeps legacy descriptor equality casts" {
  // Boundary-only OI-J descriptor slice: Binaryen version_130 keeps official
  // two-operand descriptor equality casts under `--enable-custom-descriptors`
  // because the explicit descriptor operand participates in the runtime equality
  // check. Starshine's current HOT lift still models descriptor casts as a
  // legacy unary surface, so this test locks the local fail-closed behavior:
  // do not route descriptor casts through ordinary same-heap ref.cast cleanup.
  let described_type = @lib.TypeIdx::new(0U)
  let nullable_func_type = @lib.TypeIdx::new(2U)
  let nonnull_func_type = @lib.TypeIdx::new(3U)
  let described_heap = @lib.HeapType::new(described_type)
  let nullable_described_ref_type = @lib.RefType::new(true, described_heap)
  let nonnull_described_ref_type = @lib.RefType::new(false, described_heap)
  let nullable_described_ref = @lib.ValType::ref_type(
    nullable_described_ref_type,
  )
  let nonnull_described_ref = @lib.ValType::ref_type(nonnull_described_ref_type)
  let optimized = optimize_instructions_test_run_module(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(
              descriptor=Some(@lib.TypeIdx::rec(1)),
            ),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(
              describes=Some(@lib.TypeIdx::rec(0)),
            ),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::func([nullable_described_ref], [
              nullable_described_ref,
            ]),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::func([nonnull_described_ref], [nonnull_described_ref]),
          ),
        ]),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([nullable_func_type, nonnull_func_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_cast_desc_eq_type(nullable_described_ref_type),
          ]),
        ),
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::ref_cast_desc_eq_type(nonnull_described_ref_type),
          ]),
        ),
      ]),
    ),
  )
  let nullable_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  let nonnull_pretty = optimized.pretty_print_func(@lib.FuncIdx::new(1U))
  assert_true(nullable_pretty.contains("ref.cast_desc_eq"), msg=nullable_pretty)
  assert_true(nonnull_pretty.contains("ref.cast_desc_eq"), msg=nonnull_pretty)
  assert_true(nullable_pretty.contains("local.get"), msg=nullable_pretty)
  assert_true(nonnull_pretty.contains("local.get"), msg=nonnull_pretty)
}

///|
test "optimize-instructions narrows nullable descriptor casts on exact non-null operands without inventing exact descriptor target" {
  // OI-J useful-type-info descriptor slice: the nullable result can narrow to
  // non-null when the reference operand is already non-null, but this fixture's
  // descriptor operand is not proven exact. Keep the immediate inexact so the
  // output stays valid under current custom-descriptor validation; ref.test_desc,
  // TNH, IIT, and broader descriptor-cast success logic remain open.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let described_heap = @lib.HeapType::new(described_type)
  let nullable_described_ref_type = @lib.RefType::new(true, described_heap)
  let func = @ir.hot_lift_func(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [
              @lib.ValType::ref_type(nullable_described_ref_type),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([@lib.TypeIdx::new(2U)]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::struct_new_default(descriptor_type),
            @lib.Instruction::struct_new_default_desc(described_type),
            @lib.Instruction::struct_new_default(descriptor_type),
            @lib.Instruction::ref_cast_desc_eq_type(nullable_described_ref_type),
          ]),
        ),
      ]),
    ),
    @lib.FuncIdx::new(0U),
  )
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) => fail("expected descriptor useful-type-info success, got \{err}")
  }
  let root = @ir.hot_root_get(func, 0)
  @debug.assert_eq(@ir.hot_child_count(func, root), 2)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(func, root),
    Some(
      @lib.Instruction::ref_cast_desc_eq_type(
        @lib.RefType::new(false, described_heap),
      ),
    ),
  )
  match @ir.hot_type_results(func, @ir.hot_node_type(func, root)) {
    [@lib.ValType::RefTypeValType(ref_type)] => {
      @debug.assert_eq(ref_type.is_non_nullable(), true)
      @debug.assert_eq(ref_type.is_exact(), false)
      @debug.assert_eq(ref_type.get_heap_type(), described_heap)
    }
    other => fail("expected narrowed ref.cast_desc_eq type, got \{other}")
  }
}

///|
test "optimize-instructions tightens nullable descriptor casts from non-null fallthrough facts" {
  // Binaryen v130 `visitRefCast` tightens descriptor-cast nullability from
  // `getFallthroughType(ref)` before known-result cleanup. Unlike ordinary
  // descriptor result narrowing, this does not require proving the reference
  // heap matches/subtypes the descriptor target: a successful descriptor cast of
  // any non-null reference still returns a non-null target or traps. Lock that
  // source-backed step as a descriptor-cast fact rather than widening the old
  // operand/target scanner.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let func_type = @lib.TypeIdx::new(2U)
  let described_heap = @lib.HeapType::new(described_type)
  let descriptor_heap = @lib.HeapType::new(descriptor_type)
  let eq_heap = @lib.HeapType::abs(@lib.AbsHeapType::eq())
  let nullable_described_ref_type = @lib.RefType::new(true, described_heap)
  let func = @ir.hot_lift_func(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func(
              [
                @lib.ValType::ref_type(@lib.RefType::new(false, eq_heap)),
                @lib.ValType::ref_type(
                  @lib.RefType::new(false, descriptor_heap),
                ),
              ],
              [@lib.ValType::ref_type(nullable_described_ref_type)],
            ),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([func_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
            @lib.Instruction::ref_cast_desc_eq_type(nullable_described_ref_type),
          ]),
        ),
      ]),
    ),
    @lib.FuncIdx::new(0U),
  )
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) =>
      fail("expected descriptor fallthrough tightening success, got \{err}")
  }
  let root = @ir.hot_root_get(func, 0)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(func, root),
    Some(
      @lib.Instruction::ref_cast_desc_eq_type(
        @lib.RefType::new(false, described_heap),
      ),
    ),
  )
  match @ir.hot_type_results(func, @ir.hot_node_type(func, root)) {
    [@lib.ValType::RefTypeValType(ref_type)] => {
      @debug.assert_eq(ref_type.is_non_nullable(), true)
      @debug.assert_eq(ref_type.is_exact(), false)
      @debug.assert_eq(ref_type.get_heap_type(), described_heap)
    }
    other => fail("expected tightened descriptor cast type, got \{other}")
  }
}

///|
test "optimize-instructions preserves inexact descriptor casts on exact operands without exact descriptors" {
  // OI-J exactness/useful-type-info breadth: an exact reference operand alone is
  // not enough to spell an exact descriptor-cast immediate when the descriptor
  // operand is not itself proven exact. Preserve the explicit descriptor
  // equality check and keep the immediate inexact; this does not claim
  // ref.test_desc or broad descriptor success parity.
  let described_type = @lib.TypeIdx::new(0U)
  let descriptor_type = @lib.TypeIdx::new(1U)
  let described_heap = @lib.HeapType::new(described_type)
  let described_ref_type = @lib.RefType::new(false, described_heap)
  let func = @ir.hot_lift_func(
    @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(descriptor_type)),
          ),
          @lib.SubType::comp_type(
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(described_type)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([], [@lib.ValType::ref_type(described_ref_type)]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([@lib.TypeIdx::new(2U)]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::struct_new_default(descriptor_type),
            @lib.Instruction::struct_new_default_desc(described_type),
            @lib.Instruction::struct_new_default(descriptor_type),
            @lib.Instruction::ref_cast_desc_eq_type(described_ref_type),
          ]),
        ),
      ]),
    ),
    @lib.FuncIdx::new(0U),
  )
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) => fail("expected non-null descriptor narrowing, got \{err}")
  }
  let root = @ir.hot_root_get(func, 0)
  @debug.assert_eq(@ir.hot_child_count(func, root), 2)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(func, root),
    Some(
      @lib.Instruction::ref_cast_desc_eq_type(
        @lib.RefType::new(false, described_heap),
      ),
    ),
  )
  match @ir.hot_type_results(func, @ir.hot_node_type(func, root)) {
    [@lib.ValType::RefTypeValType(ref_type)] => {
      @debug.assert_eq(ref_type.is_non_nullable(), true)
      @debug.assert_eq(ref_type.is_exact(), false)
      @debug.assert_eq(ref_type.get_heap_type(), described_heap)
    }
    other => fail("expected non-null ref.cast_desc_eq type, got \{other}")
  }
}

///|
test "optimize-instructions narrows descriptor casts on non-null subtype operands" {
  // OI-J useful-type-info breadth: Binaryen version_130 default and IIT modes
  // rewrite a nullable descriptor equality cast whose reference operand is a
  // non-null strict subtype of the target heap to a non-null descriptor cast,
  // while preserving the explicit descriptor equality check. This widens the
  // previous exact same-target operand coverage without claiming exact-subtype,
  // ref.test_desc, or broad descriptor success parity.
  let base_type = @lib.TypeIdx::new(0U)
  let base_descriptor_type = @lib.TypeIdx::new(1U)
  let subtype = @lib.TypeIdx::new(2U)
  let subtype_descriptor = @lib.TypeIdx::new(3U)
  let func_type = @lib.TypeIdx::new(4U)
  let base_heap = @lib.HeapType::new(base_type)
  let subtype_heap = @lib.HeapType::new(subtype)
  let nullable_base_ref_type = @lib.RefType::new(true, base_heap)
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(
              descriptor=Some(base_descriptor_type),
            ),
          ),
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(base_type)),
          ),
          @lib.SubType::new(
            false,
            [base_type],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(subtype_descriptor)),
          ),
          @lib.SubType::new(
            false,
            [base_descriptor_type],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(subtype)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func(
              [
                @lib.ValType::ref_type(@lib.RefType::new(false, subtype_heap)),
                @lib.ValType::ref_type(
                  @lib.RefType::new(
                    false,
                    @lib.HeapType::new(base_descriptor_type),
                  ),
                ),
              ],
              [@lib.ValType::ref_type(nullable_base_ref_type)],
            ),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([func_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
            @lib.Instruction::ref_cast_desc_eq_type(nullable_base_ref_type),
          ]),
        ),
      ]),
    )
  let func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(0U))
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    module_ctx=Some(@ir.hot_module_context_from_module(module_)),
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) => fail("expected subtype descriptor narrowing, got \{err}")
  }
  let root = @ir.hot_root_get(func, 0)
  @debug.assert_eq(@ir.hot_child_count(func, root), 2)
  @debug.assert_eq(
    @ir.hot_node_exact_instr(func, root),
    Some(
      @lib.Instruction::ref_cast_desc_eq_type(
        @lib.RefType::new(false, base_heap),
      ),
    ),
  )
}

///|
test "optimize-instructions skips descriptor casts on non-null subtype operands under traps-never-happen" {
  // OI-J TNH descriptor-cast breadth: the same strict-subtype operand probe is
  // removed entirely by Binaryen version_130 under `--traps-never-happen`, while
  // default and IIT keep the descriptor check. This covers only the non-null
  // subtype operand shape; exact-subtype, effectful subtype operands, and
  // ref.test_desc remain open.
  let base_type = @lib.TypeIdx::new(0U)
  let base_descriptor_type = @lib.TypeIdx::new(1U)
  let subtype = @lib.TypeIdx::new(2U)
  let subtype_descriptor = @lib.TypeIdx::new(3U)
  let func_type = @lib.TypeIdx::new(4U)
  let base_heap = @lib.HeapType::new(base_type)
  let subtype_heap = @lib.HeapType::new(subtype)
  let nullable_base_ref_type = @lib.RefType::new(true, base_heap)
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(
              descriptor=Some(base_descriptor_type),
            ),
          ),
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(base_type)),
          ),
          @lib.SubType::new(
            false,
            [base_type],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(subtype_descriptor)),
          ),
          @lib.SubType::new(
            false,
            [base_descriptor_type],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(subtype)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func(
              [
                @lib.ValType::ref_type(@lib.RefType::new(false, subtype_heap)),
                @lib.ValType::ref_type(
                  @lib.RefType::new(
                    false,
                    @lib.HeapType::new(base_descriptor_type),
                  ),
                ),
              ],
              [@lib.ValType::ref_type(nullable_base_ref_type)],
            ),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([func_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::local_get(@lib.LocalIdx::new(1U)),
            @lib.Instruction::ref_cast_desc_eq_type(nullable_base_ref_type),
          ]),
        ),
      ]),
    )
  let func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(0U))
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    traps_never_happen=true,
    module_ctx=Some(@ir.hot_module_context_from_module(module_)),
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) => fail("expected subtype descriptor TNH skip, got \{err}")
  }
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_get(func, root).op {
    @ir.HotOp::LocalGet => ()
    _ => fail("expected local.get after subtype descriptor TNH skip")
  }
  @debug.assert_eq(@ir.hot_node_get(func, root).imm0, 0)
}

///|
test "optimize-instructions folds descriptor casts with exact mismatching descriptors" {
  // OI-J descriptor exactness breadth: Binaryen version_130 rewrites a
  // descriptor equality cast to `unreachable` when a non-null strict-subtype
  // reference operand is paired with an exact descriptor for the supertype.
  // The descriptor equality check can only pass for exact `$base` values, so a
  // `(ref $sub)` operand cannot produce a successful result. This finite slice
  // covers only pure/erasable operands; effectful descriptor/ref operands,
  // nullable null-only descriptor casts, TNH/IIT, and ref.test_desc remain open.
  let base_type = @lib.TypeIdx::new(0U)
  let base_descriptor_type = @lib.TypeIdx::new(1U)
  let subtype = @lib.TypeIdx::new(2U)
  let subtype_descriptor = @lib.TypeIdx::new(3U)
  let func_type = @lib.TypeIdx::new(4U)
  let base_heap = @lib.HeapType::new(base_type)
  let base_ref_type = @lib.RefType::new(false, base_heap)
  let sub_ref_type = @lib.RefType::new(false, @lib.HeapType::new(subtype))
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
            ]),
            metadata=@lib.TypeMetadata::new(
              descriptor=Some(base_descriptor_type),
            ),
          ),
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(base_type)),
          ),
          @lib.SubType::new(
            false,
            [base_type],
            @lib.CompType::struct_([
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i64()),
                @lib.Mut::const_(),
              ),
            ]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(subtype_descriptor)),
          ),
          @lib.SubType::new(
            false,
            [base_descriptor_type],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(subtype)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([@lib.ValType::ref_type(sub_ref_type)], [
              @lib.ValType::ref_type(base_ref_type),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([func_type]))
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
            @lib.Instruction::struct_new_default(base_descriptor_type),
            @lib.Instruction::ref_cast_desc_eq_type(base_ref_type),
          ]),
        ),
      ]),
    )
  let func = @ir.hot_lift_func(module_, @lib.FuncIdx::new(0U))
  let ctx = HotPassContext::new(
    optimize_instructions_descriptor(),
    @ir.HotAnalysisCache::new(),
    HotPipelineVerifyPolicy::after_each_pass(),
    false,
    fn(_) { () },
    module_ctx=Some(@ir.hot_module_context_from_module(module_)),
  )
  match hot_pass_run(ctx, func) {
    Ok(_) => ()
    Err(err) => fail("expected exact descriptor miss fold, got \{err}")
  }
  let root = @ir.hot_root_get(func, 0)
  match @ir.hot_node_get(func, root).op {
    @ir.HotOp::Unreachable => ()
    _ => fail("expected unreachable for exact descriptor mismatch")
  }
}

///|
test "optimize-instructions folds descriptor casts with effectful reference exact descriptor misses" {
  // OI-J descriptor/effect slice: Binaryen version_130 rewrites the same
  // strict-subtype/exact-descriptor miss to `drop(effectful-ref); unreachable`
  // when the reference operand has ordered side effects and the descriptor
  // operand is a fresh erasable exact descriptor. This slice preserves the
  // reference operand before the unreachable replacement; effectful descriptor
  // operands, control/EH, TNH/IIT, and nullable null-only descriptor casts remain
  // fail-closed.
  let base_type = @lib.TypeIdx::new(0U)
  let base_descriptor_type = @lib.TypeIdx::new(1U)
  let subtype = @lib.TypeIdx::new(2U)
  let subtype_descriptor = @lib.TypeIdx::new(3U)
  let func_type = @lib.TypeIdx::new(4U)
  let base_heap = @lib.HeapType::new(base_type)
  let base_ref_type = @lib.RefType::new(false, base_heap)
  let sub_ref_type = @lib.RefType::new(false, @lib.HeapType::new(subtype))
  let sub_val_type = @lib.ValType::ref_type(sub_ref_type)
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
            ]),
            metadata=@lib.TypeMetadata::new(
              descriptor=Some(base_descriptor_type),
            ),
          ),
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(base_type)),
          ),
          @lib.SubType::new(
            false,
            [base_type],
            @lib.CompType::struct_([
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i64()),
                @lib.Mut::const_(),
              ),
            ]),
            metadata=@lib.TypeMetadata::new(descriptor=Some(subtype_descriptor)),
          ),
          @lib.SubType::new(
            false,
            [base_descriptor_type],
            @lib.CompType::struct_([]),
            metadata=@lib.TypeMetadata::new(describes=Some(subtype)),
          ),
        ]),
        @lib.RecType::new(
          @lib.SubType::comp_type(
            @lib.CompType::func([sub_val_type], [
              @lib.ValType::ref_type(base_ref_type),
            ]),
          ),
        ),
      ]),
    )
    .with_func_sec(@lib.FuncSec::new([func_type]))
    .with_global_sec(
      @lib.GlobalSec::new([
        @lib.Global::new(
          @lib.GlobalType::new(@lib.ValType::i32(), true),
          @lib.Expr::new([@lib.Instruction::i32_const(@lib.I32(0))]),
        ),
      ]),
    )
    .with_code_sec(
      @lib.CodeSec::new([
        @lib.Func::new(
          @lib.Locals::empty(),
          @lib.Expr::new([
            @lib.Instruction::block(
              @lib.BlockType::val_type(sub_val_type),
              @lib.Expr::new([
                @lib.Instruction::i32_const(@lib.I32(1)),
                @lib.Instruction::global_set(@lib.GlobalIdx::new(0U)),
                @lib.Instruction::local_get(@lib.LocalIdx::new(0U)),
              ]),
            ),
            @lib.Instruction::struct_new_default(base_descriptor_type),
            @lib.Instruction::ref_cast_desc_eq_type(base_ref_type),
          ]),
        ),
      ]),
    )
  let optimized = match
    run_hot_pipeline(module_, HotPipelineOptions::new(), [
      "optimize-instructions",
    ]) {
    Ok(mod_) => mod_
    Err(err) =>
      fail("expected effectful exact descriptor miss fold, got \{err}")
  }
  let pretty = optimized.pretty_print_func(@lib.FuncIdx::new(0U))
  assert_true(pretty.contains("global.set"), msg=pretty)
  assert_true(pretty.contains("unreachable"), msg=pretty)
  assert_false(pretty.contains("ref.cast_desc_eq"), msg=pretty)
}

///|
test "optimize-instructions folds descriptor casts with effectful descriptor exact descriptor misses" {
  // OI-J descriptor/effect slice: Binaryen version_130 rewrites the
  // strict-subtype/exact-descriptor miss to `drop(effectful-descriptor);
  // unreachable` when the reference operand is pure and the descriptor operand
  // has straight-line ordered effects before producing the exact supertype
  // descriptor. This preserves descriptor operand effects after the pure
  // reference operand has been evaluated, while still keeping both-effectful
  // operand-order, control/EH, TNH/IIT, and nullable descriptor cases open.
  let base_type = @lib.TypeIdx::new(0U)
  let base_descriptor_type = @lib.TypeIdx::new(1U)
  let subtype = @lib.TypeIdx::new(2U)
  let subtype_descriptor = @lib.TypeIdx::new(3U)
  let func_type = @lib.TypeIdx::new(4U)
  let base_heap = @lib.HeapType::new(base_type)
  let base_ref_type = @lib.RefType::new(false, base_heap)
  let base_descriptor_ref_type = @lib.RefType::new(
    false,
    @lib.HeapType::new(base_descriptor_type),
    exact=true,
  )
  let sub_ref_type = @lib.RefType::new(false, @lib.HeapType::new(subtype))
  let sub_val_type = @lib.ValType::ref_type(sub_ref_type)
  let descriptor_val_type = @lib.ValType::ref_type(base_descriptor_ref_type)
  let module_ = @lib.Module::new()
    .with_type_sec(
      @lib.TypeSec::new([
        @lib.RecType::group([
          @lib.SubType::new(
            false,
            [],
            @lib.CompType::struct_([
              @lib.FieldType::new(
                @lib.StorageType::val_type(@lib.ValType::i32()),
                @lib.Mut::const_(),
              ),
            ]),
